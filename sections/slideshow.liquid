{%- if section.blocks.size > 0 -%}
  <style>
    {%- if section.settings.transition_type != 'fade' -%}
      #shopify-section-{{ section.id }} {
        --slideshow-background: {{ section.settings.background.rgb }};
      }
    {%- endif -%}

    {%- if section.settings.enable_frame -%}
      #shopify-section-{{ section.id }} {
        padding: {{ section.settings.frame_padding }}px;
        background:
          radial-gradient(ellipse at top left, {{ section.settings.frame_color }} 0%, transparent 60%),
          radial-gradient(ellipse at bottom right, {{ section.settings.frame_color }} 0%, transparent 60%),
          #ffffff;
      }
      #shopify-section-{{ section.id }} .slideshow {
        border-radius: {{ section.settings.frame_border_radius }}px;
      }
      #shopify-section-{{ section.id }} .slideshow__controls {
        place-self: end center;
        margin-inline-end: 0;
      }
      #shopify-section-{{ section.id }} .slideshow__autoplay-button {
        display: none;
      }
      #shopify-section-{{ section.id }} .scroll-marker-group--lines .scroll-marker {
        --scroll-marker-width: 2rem;
        --scroll-marker-height: 2px;
        background-color: rgba(255, 255, 255, 0.7);
      }
      #shopify-section-{{ section.id }} .scroll-marker-group--lines .scroll-marker[aria-current="true"] {
        --scroll-marker-width: 2rem;
        background-color: {{ section.settings.frame_color }};
      }
      #shopify-section-{{ section.id }} .scroll-marker-group--autoplay .scroll-marker[aria-current="true"] {
        background-color: rgba(255, 255, 255, 0.7);
      }
      #shopify-section-{{ section.id }} .scroll-marker-group--autoplay .scroll-marker[aria-current="true"] .scroll-marker-group__line-progress {
        background-color: {{ section.settings.frame_color }};
      }
    {%- endif -%}
  </style>

  <slideshow-carousel id="slideshow-{{ section.id }}" allow-swipe cell-selector=".slideshow__slide" {% if section.settings.allow_transparent_header %}allow-transparent-header{% endif %} class="slideshow" transition="{{ section.settings.transition_type }}" {% if section.settings.autoplay %}autoplay="{{ section.settings.cycle_speed }}" {% if section.settings.pause_auto_rotate_on_hover %}pause-on-hover{% endif %}{% endif %} role="region">
    {%- content_for 'blocks' -%}

    {%- if section.blocks.size > 1 -%}
      {%- content_for 'block', type: '_slideshow-controls', id: 'slideshow-controls' -%}
    {%- endif -%}
  </slideshow-carousel>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.slideshow.name",
  "class": "shopify-section--slideshow",
  "tag": "section",
  "max_blocks": 5,
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "allow_transparent_header",
      "label": "t:global.section.allow_transparent_header",
      "info": "t:global.section.allow_transparent_header_info",
      "default": true
    },
    {
      "type": "select",
      "id": "image_size",
      "label": "t:global.image.size",
      "options": [
        {
          "value": "auto",
          "label": "t:global.sizes.original_image_ratio"
        },
        {
          "value": "sm",
          "label": "t:global.sizes.small"
        },
        {
          "value": "md",
          "label": "t:global.sizes.medium"
        },
        {
          "value": "lg",
          "label": "t:global.sizes.large"
        },
        {
          "value": "fill",
          "label": "t:global.sizes.fit_screen"
        }
      ],
      "info": "t:global.image.ratio_avoid_cropping_info",
      "default": "auto"
    },
    {
      "type": "select",
      "id": "transition_type",
      "label": "t:sections.slideshow.transition_type",
      "options": [
        {
          "value": "fade",
          "label": "t:sections.slideshow.transition_type_options.fade"
        },
        {
          "value": "vertical_reveal",
          "label": "t:sections.slideshow.transition_type_options.vertical_reveal"
        },
        {
          "value": "curtain",
          "label": "t:sections.slideshow.transition_type_options.curtain"
        },
        {
          "value": "distortion",
          "label": "t:sections.slideshow.transition_type_options.distortion"
        },
        {
          "value": "perspective",
          "label": "t:sections.slideshow.transition_type_options.perspective"
        },
        {
          "value": "scale_down",
          "label": "t:sections.slideshow.transition_type_options.scale_down"
        }
      ],
      "default": "curtain"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:sections.slideshow.auto_rotate_between_slides",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "pause_auto_rotate_on_hover",
      "label": "t:sections.slideshow.pause_auto_rotate_on_hover",
      "default": false,
      "visible_if": "{{ section.settings.autoplay }}"
    },
    {
      "type": "range",
      "id": "cycle_speed",
      "min": 4,
      "max": 20,
      "step": 1,
      "unit": "sec",
      "label": "t:sections.slideshow.cycle_speed",
      "default": 6,
      "visible_if": "{{ section.settings.autoplay }}"
    },
    {
      "type": "color",
      "id": "background",
      "label": "t:global.colors.background",
      "info": "t:sections.slideshow.background_info",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Outer frame"
    },
    {
      "type": "checkbox",
      "id": "enable_frame",
      "label": "Show outer frame",
      "default": false
    },
    {
      "type": "color",
      "id": "frame_color",
      "label": "Frame background color",
      "default": "#d9ff36",
      "visible_if": "{{ section.settings.enable_frame }}"
    },
    {
      "type": "range",
      "id": "frame_padding",
      "label": "Frame padding",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 20,
      "visible_if": "{{ section.settings.enable_frame }}"
    },
    {
      "type": "range",
      "id": "frame_border_radius",
      "label": "Frame border radius",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 24,
      "visible_if": "{{ section.settings.enable_frame }}"
    }
  ],
  "blocks": [
    { "type": "_slideshow-image-slide" },
    { "type": "_slideshow-video-slide" }
  ],
  "presets": [
    {
      "name": "t:sections.slideshow.name",
      "category": "t:global.categories.banners",
      "blocks": [
        {
          "type": "_slideshow-controls",
          "id": "slideshow-controls",
          "static": true
        },
        {
          "type": "_slideshow-image-slide",
          "blocks": [
            {
              "type": "heading",
              "settings": {
                "text": "Slide 1",
                "heading_size": "h1"
              }
            }
          ]
        },
        {
          "type": "_slideshow-image-slide",
          "blocks": [
            {
              "type": "heading",
              "settings": {
                "text": "Slide 2",
                "heading_size": "h1"
              }
            }
          ]
        }
      ]
    }
  ]
}
{% endschema %}
