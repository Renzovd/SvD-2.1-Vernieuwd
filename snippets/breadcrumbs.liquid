{%- comment -%}
  Basic breadcrumbs for product pages (visible + accessible).
{%- endcomment -%}
{%- if request.page_type == 'product' and product != blank -%}
  {%- assign breadcrumb_collection = collection | default: product.collections.first -%}
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol class="breadcrumbs__list">
      <li class="breadcrumbs__item">
        <a href="{{ routes.root_url }}">{{ 'general.home' | t }}</a>
      </li>
      {%- if breadcrumb_collection -%}
        <li class="breadcrumbs__item">
          <span class="breadcrumbs__separator" aria-hidden="true">/</span>
          <a href="{{ breadcrumb_collection.url }}">{{ breadcrumb_collection.title }}</a>
        </li>
      {%- endif -%}
      <li class="breadcrumbs__item" aria-current="page">
        <span class="breadcrumbs__separator" aria-hidden="true">/</span>
        <span class="breadcrumbs__current">{{ product.title }}</span>
      </li>
    </ol>
  </nav>
{%- endif -%}

