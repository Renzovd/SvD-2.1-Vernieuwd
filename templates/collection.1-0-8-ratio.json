p-card p{font-size:14px;margin:0;line-height:1.6}\n.svd-faq-list{margin:24px 0 0 0}\n.svd-faq-item{border:1px solid var(--svd-border);border-radius:var(--svd-radius);margin-bottom:12px;overflow:hidden}\n.svd-faq-item details{width:100%}\n.svd-faq-item summary{padding:16px 20px;font-weight:700;font-size:15px;color:var(--svd-dark);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;background:#ffffff;transition:background 0.15s ease}\n.svd-faq-item summary:hover{background:var(--svd-bg)}\n.svd-faq-item summary::-webkit-details-marker{display:none}\n.svd-faq-item summary::after{content:'+';font-size:20px;font-weight:300;color:var(--svd-text-muted);flex-shrink:0;margin-left:12px}\n.svd-faq-item details[open] summary::after{content:'−'}\n.svd-faq-item .svd-faq-answer{padding:0 20px 18px 20px;font-size:14px;line-height:1.7;color:var(--svd-text)}\n.svd-faq-item .svd-faq-answer p{margin:0 0 10px 0}\n.svd-faq-item .svd-faq-answer p:last-child{margin:0}\n.svd-faq-item .svd-faq-answer a{color:var(--svd-dark);text-decoration:underline;font-weight:600}\n.svd-ratio-explainer{background:#ffffff;border:2px solid var(--svd-lime);border-radius:var(--svd-radius);padding:28px 32px;margin:24px 0}\n.svd-ratio-explainer h3{font-size:1.1rem;margin:0 0 12px 0}\n.svd-ratio-explainer p{font-size:14px;margin:0 0 12px 0;line-height:1.7}\n.svd-ratio-explainer p:last-child{margin:0}\n.svd-vs-block{display:grid;grid-template-columns:1fr auto 1fr;gap:16px;align-items:center;margin:24px 0}\n.svd-vs-card{background:var(--svd-bg);border:1px solid var(--svd-border);border-radius:var(--svd-radius);padding:20px;text-align:center}\n.svd-vs-card.vs-old{opacity:0.7}\n.svd-vs-card h4{font-size:1rem;font-weight:800;margin:0 0 6px 0;color:var(--svd-dark)}\n.svd-vs-card p{font-size:13px;margin:0;color:var(--svd-text-light)}\n.svd-vs-divider{font-size:1.4rem;font-weight:900;color:var(--svd-text-muted);text-align:center}\n@media(min-width:600px){.svd-jump-nav ul{grid-template-columns:1fr 1fr}.svd-usp-grid{grid-template-columns:1fr 1fr}.svd-products-grid{grid-template-columns:1fr 1fr}.svd-scenario-grid{grid-template-columns:1fr 1fr 1fr}.svd-tips-grid{grid-template-columns:1fr 1fr}.svd-brand-grid{grid-template-columns:1fr 1fr 1fr}}\n@media(min-width:900px){.svd-hero{padding:56px 40px}.svd-hero h1{font-size:2.6rem}.svd-products-grid{grid-template-columns:repeat(3,1fr)}.svd-brand-grid{grid-template-columns:repeat(3,1fr)}}\n@media(max-width:599px){.svd-compare-table{font-size:12px}.svd-compare-table th,.svd-compare-table td{padding:10px 8px}.svd-vs-block{grid-template-columns:1fr;gap:8px}.svd-vs-divider{font-size:1rem}}\n</style>\n\n<div class=\"svd-ratio-page\">\n\n<!-- ═══ HERO ═══ -->\n<section class=\"svd-hero\" id=\"intro\">\n<span class=\"svd-hero-tag\">Maximale opname</span>\n<h1>Sportvoeding met 1:0.8 ratio: tot 120g koolhydraten per uur</h1>\n<p>De geavanceerde 1:0.8 glucose:fructose verhouding doorbreekt de opnamegrens van de klassieke 2:1 ratio. Ontdek gels, sportdranken en chews die je lichaam in staat stellen tot 120 gram koolhydraten per uur op te nemen.</p>\n</section>\n\n<!-- ═══ BADGES ═══ -->\n<div class=\"svd-badges\">\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-orange\"></span>1:0.8 glucose:fructose ratio</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>Opname tot 120g koolhydraten per uur</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lavender\"></span>Gels, sportdranken & chews</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-dark\"></span>NZVT · Informed Sport gecertificeerd</span>\n</div>\n\n<!-- ═══ JUMP NAV ═══ -->\n<nav class=\"svd-jump-nav\" aria-label=\"Pagina navigatie\">\n<h3>Op deze pagina</h3>\n<ul>\n<li><a href=\"#waarom-108\">Waarom 1:0.8? <span>De wetenschap</span></a></li>\n<li><a href=\"#alle-producten\">Alle 1:0.8 producten <span>Gels, dranken & chews</span></a></li>\n<li><a href=\"#vergelijking\">Vergelijkingstabel <span>Alle producten op een rij</span></a></li>\n<li><a href=\"#strategieen\">Voedingsstrategieen <span>3 scenario's</span></a></li>\n<li><a href=\"#tips\">Praktische tips <span>Darmtraining & timing</span></a></li>\n<li><a href=\"#faq\">Veelgestelde vragen <span>Over de 1:0.8 ratio</span></a></li>\n</ul>\n</nav>\n\n<!-- ═══ WAAROM 1:0.8 ═══ -->\n<section id=\"waarom-108\">\n<h2><span class=\"svd-heading-line\">Waarom de 1:0.8 ratio?</span></h2>\n<p>Je darmen gebruiken verschillende transportroutes om koolhydraten op te nemen. Glucose en fructose hebben elk hun eigen 'poortje'. Door de verhouding te optimaliseren, benut je beide routes maximaal en neem je meer energie op dan ooit tevoren.</p>\n\n<div class=\"svd-vs-block\">\n<div class=\"svd-vs-card vs-old\">\n<h4>2:1 ratio</h4>\n<p>Klassieke standaard<br>Opname tot <strong>90g/uur</strong><br>Fructose-route onderbenut</p>\n</div>\n<div class=\"svd-vs-divider\">→</div>\n<div class=\"svd-vs-card\">\n<h4 style=\"color:var(--svd-lime-dark)\">1:0.8 ratio</h4>\n<p>Geavanceerde verhouding<br>Opname tot <strong>120g/uur</strong><br>Beide routes optimaal benut</p>\n</div>\n</div>\n\n<div class=\"svd-usp-grid\">\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">🚀</div>\n<div>\n<strong>Tot 120g koolhydraten per uur</strong>\n<span>Door een relatief grotere hoeveelheid fructose (de 0.8) aan te bieden, wordt de fructose-transportroute efficienter benut. De totale opname stijgt van 90g naar 120g per uur.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">🫁</div>\n<div>\n<strong>Minder maagklachten</strong>\n<span>Omdat de opname efficienter verloopt, blijven er minder koolhydraten achter in de darmen. Dit resulteert in minder maag- en darmklachten, zelfs bij hoge innames.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">🔬</div>\n<div>\n<strong>Wetenschappelijk onderbouwd</strong>\n<span>Recente studies tonen aan dat de 1:0.8 verhouding superieur is aan de 2:1 ratio voor opnames boven de 90 gram per uur. Gebruikt door profteams en olympische atleten.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">🏆</div>\n<div>\n<strong>Keuze van de profs</strong>\n<span>Team Visma | Lease a Bike (Amacx Turbo Line) en marathon-wereldtoppers (Maurten) vertrouwen op de 1:0.8 ratio voor hun zwaarste wedstrijden.</span>\n</div>\n</div>\n</div>\n</section>\n\n<!-- ═══ ALLE PRODUCTEN ═══ -->\n<section id=\"alle-producten\">\n<h2><span class=\"svd-heading-line\">Alle 1:0.8 producten bij SportvoedingDirect</span></h2>\n<p>Van energiegels en sportdranken tot kauwbare fruitchews: alle producten met de geavanceerde 1:0.8 glucose:fructose ratio op een rij.</p>\n\n<h3>Amacx Turbo Line – Team Visma | Lease a Bike</h3>\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Drinkbare gel · 40g carbs</span>\n<h4>Amacx Turbo Drink Gel</h4>\n<p>40g koolhydraten · 200 mg natrium · 1:0.8 glucose:fructose. Drinkbare gel, makkelijk in te nemen zonder extra water. Cassis-variant met 100 mg cafeïne beschikbaar. Vegan, glutenvrij, lactosevrij. NZVT-gecertificeerd.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-gel\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Kauwbaar fruit · 40g carbs</span>\n<h4>Amacx Turbo Fruit Chew</h4>\n<p>40g koolhydraten · 1:0.8 glucose:fructose · 51% echt fruit. Zachte bite met gesuikerde buitenlaag die niet plakt. Ideale afwisseling naast gels en dranken. Smaken: Cassis en Citrus. Vegan, NZVT-gecertificeerd.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-fruit-chew-turbo\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Sportdrank · 40-80g carbs</span>\n<h4>Amacx Turbo Drink</h4>\n<p>40 of 80g koolhydraten per bidon (500 ml) · 1:0.8 glucose:fructose · natrium, kalium, calcium en magnesium. Flexibel te doseren. Vloeibare basis van je koolhydraatstrategie. Vegan, NZVT-gecertificeerd.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-lemon\">Bekijk en bestel →</a>\n</div>\n</div>\n\n<h3>Maurten – hydrogel-technologie</h3>\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Hydrogel · 25g carbs</span>\n<h4>Maurten Gel 100</h4>\n<p>25g koolhydraten · 85 mg natrium · 0.8:1 fructose:glucose ratio. Hydrogel-technologie kapselt koolhydraten in een gel-matrix van alginaat en pectine. Minimale maaglast, 6 natuurlijke ingrediënten. Vegan.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/maurten-gel-100\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Hydrogel sportdrank · 80g carbs</span>\n<h4>Maurten Drink Mix 320</h4>\n<p>80g koolhydraten per 500 ml · 0.8:1 fructose:glucose · hydrogel-technologie. Dé hoeksteen voor maximale energie. Koolhydraten ingekapseld in hydrogel voor soepele maagpassage. Vegan, 5 ingrediënten.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/maurten-drink-mix-320\">Bekijk en bestel →</a>\n</div>\n</div>\n\n<h3>226ERS – cyclodextrine & high fructose</h3>\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Compact · 30g carbs</span>\n<h4>226ERS High Fructose Gel XS</h4>\n<p>30g koolhydraten · 140 mg natrium · 1:0.8 glucose:fructose. Compact formaat voor opname tot 120g/uur. Licht verteerbaar dankzij lage osmolariteit. Cologne List® gecertificeerd.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/226ers-high-fructose-gel-xs\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Krachtpatser · 55g carbs</span>\n<h4>226ERS High Fructose Gel</h4>\n<p>55g koolhydraten · 250 mg natrium · 10:8 maltodextrine:fructose · 220 kcal. De krachtigste gel per portie. Cherry-variant met 160 mg cafeïne beschikbaar. Cologne List® gecertificeerd.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/226ers-high-fructose-gel\">Bekijk en bestel →</a>\n</div>\n</div>\n</section>\n\n<!-- ═══ VERGELIJKING ═══ -->\n<section id=\"vergelijking\">\n<h2><span class=\"svd-heading-line\">Alle 1:0.8 producten vergeleken</span></h2>\n<p>Vergelijk alle producten met de 1:0.8 ratio op koolhydraten, natrium, type en ideaal gebruik.</p>\n\n<div style=\"overflow-x:auto;border-radius:var(--svd-radius);border:1px solid var(--svd-border);box-shadow:var(--svd-shadow)\">\n<table class=\"svd-compare-table\">\n<thead>\n<tr><th>Product</th><th>Carbs</th><th>Natrium</th><th>Type</th><th>Certificering</th><th>Ideaal voor</th></tr>\n</thead>\n<tbody>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-gel\">Amacx Turbo Drink Gel</a></td><td>40g</td><td>200 mg</td><td><span class=\"svd-table-badge badge-gel\">gel</span></td><td><span class=\"svd-table-badge badge-nzvt\">NZVT</span></td><td>Snelle boost, wedstrijd</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-gel\">Amacx Turbo Gel Cassis CAF</a></td><td>40g</td><td>200 mg</td><td><span class=\"svd-table-badge badge-gel\">gel</span><span class=\"svd-table-badge badge-cafeine\">100mg caf</span></td><td><span class=\"svd-table-badge badge-nzvt\">NZVT</span></td><td>Finale, mentale boost</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-fruit-chew-turbo\">Amacx Turbo Fruit Chew</a></td><td>40g</td><td>–</td><td><span class=\"svd-table-badge badge-chew\">chew</span></td><td><span class=\"svd-table-badge badge-nzvt\">NZVT</span></td><td>Afwisseling, lange ritten</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-lemon\">Amacx Turbo Drink (40g)</a></td><td>40g</td><td>200 mg</td><td><span class=\"svd-table-badge badge-drink\">drank</span></td><td><span class=\"svd-table-badge badge-nzvt\">NZVT</span></td><td>Basis, hydratatie + energie</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-lemon\">Amacx Turbo Drink (80g)</a></td><td>80g</td><td>400 mg</td><td><span class=\"svd-table-badge badge-drink\">drank</span></td><td><span class=\"svd-table-badge badge-nzvt\">NZVT</span></td><td>Maximale inname per bidon</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/maurten-gel-100\">Maurten Gel 100</a></td><td>25g</td><td>85 mg</td><td><span class=\"svd-table-badge badge-hydrogel\">hydrogel</span></td><td>–</td><td>Gevoelige maag, marathon</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/maurten-drink-mix-320\">Maurten Drink Mix 320</a></td><td>80g</td><td>–</td><td><span class=\"svd-table-badge badge-hydrogel\">hydrogel</span><span class=\"svd-table-badge badge-drink\">drank</span></td><td>–</td><td>Hoeksteen voedingsplan</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/226ers-high-fructose-gel-xs\">226ERS HF Gel XS</a></td><td>30g</td><td>140 mg</td><td><span class=\"svd-table-badge badge-gel\">gel</span></td><td>Cologne List®</td><td>Compact, hoge opname</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/226ers-high-fructose-gel\">226ERS HF Gel</a></td><td>55g</td><td>250 mg</td><td><span class=\"svd-table-badge badge-gel\">gel</span></td><td>Cologne List®</td><td>Max carbs + natrium</td></tr>\n</tbody>\n</table>\n</div>\n</section>\n\n<!-- ═══ STRATEGIEEN ═══ -->\n<section id=\"strategieen\">\n<h2><span class=\"svd-heading-line\">Voedingsstrategieen met de 1:0.8 ratio</span></h2>\n<p>De 1:0.8 ratio komt het best tot zijn recht bij inspanningen langer dan 2-3 uur, waar je maximale opname nodig hebt. Hier zijn drie bewezen strategieën.</p>\n\n<div class=\"svd-scenario-grid\">\n<div class=\"svd-scenario-card\">\n<span class=\"svd-scenario-tag tag-basis\">Instap 1:0.8</span>\n<h3>80g koolhydraten per uur</h3>\n<p>De ideale start met de 1:0.8 ratio. Combineer een sportdrank met een gel voor een beheersbare maar krachtige strategie.</p>\n<div class=\"svd-scenario-products\">\n<strong>Voorbeeld:</strong> 1x <a href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-lemon\">Amacx Turbo Drink</a> (40g bidon) + 1x <a href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-gel\">Amacx Turbo Gel</a> (40g)\n</div>\n</div>\n<div class=\"svd-scenario-card scenario-allround\">\n<span class=\"svd-scenario-tag tag-wedstrijd\">Wedstrijd niveau</span>\n<h3>100g koolhydraten per uur</h3>\n<p>Voor serieuze wedstrijden. Combineer drank, gel en chew voor variatie en maximale opname zonder smaakmoeheid.</p>\n<div class=\"svd-scenario-products\">\n<strong>Voorbeeld:</strong> 1x <a href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-lemon\">Turbo Drink</a> (40g) + 1x <a href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-gel\">Turbo Gel</a> (40g) + ½ <a href=\"https://sportvoedingdirect.nl/products/amacx-fruit-chew-turbo\">Turbo Chew</a> (20g)\n</div>\n</div>\n<div class=\"svd-scenario-card scenario-extreme\">\n<span class=\"svd-scenario-tag tag-elite\">Maximale opname</span>\n<h3>120g koolhydraten per uur</h3>\n<p>Alleen voor ervaren atleten met getrainde darmen. Vereist een consequent gevolgd plan met meerdere bronnen per uur.</p>\n<div class=\"svd-scenario-products\">\n<strong>Voorbeeld:</strong> 1x <a href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-lemon\">Turbo Drink</a> (80g bidon) + 1x <a href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-gel\">Turbo Gel</a> (40g) · Of: 1x <a href=\"https://sportvoedingdirect.nl/products/maurten-drink-mix-320\">Maurten 320</a> (80g) + 1x <a href=\"https://sportvoedingdirect.nl/products/226ers-high-fructose-gel\">226ERS HF Gel</a> (55g)\n</div>\n</div>\n</div>\n</section>\n\n<!-- ═══ TIPS ═══ -->\n<section id=\"tips\">\n<h2><span class=\"svd-heading-line\">6 tips voor de 1:0.8 ratio</span></h2>\n\n<div class=\"svd-tips-grid\">\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">1</div>\n<div><p><strong>Train je darmen:</strong> je maag-darmstelsel is trainbaar. Begin in training met 60g/uur en bouw over 4-6 weken op naar 90-120g/uur. Nooit zonder darmtraining op wedstrijddag maximaal doseren.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">2</div>\n<div><p><strong>Mix en match producten:</strong> wissel gels, dranken en chews af voor variatie in textuur en smaak. Alle Amacx Turbo producten delen dezelfde 1:0.8 ratio en zijn perfect combineerbaar.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">3</div>\n<div><p><strong>Start vroeg, doseer regelmatig:</strong> neem je eerste portie na 30-45 minuten en herhaal elke 20-30 minuten. Een constante stroom wordt beter verdragen dan grote hoeveelheden ineens.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">4</div>\n<div><p><strong>Sportdrank als basis:</strong> gebruik de Amacx Turbo Drink of Maurten Drink Mix 320 als vloeibare basis in je bidon. Vul aan met gels en chews voor je gewenste totaal per uur.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">5</div>\n<div><p><strong>Cafeïne strategisch:</strong> bewaar de Amacx Turbo Gel Cassis CAF (100 mg) of 226ERS HF Gel met cafeïne (160 mg) voor de laatste 1-2 uur van je wedstrijd. Effect na 30-60 minuten.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">6</div>\n<div><p><strong>Test exact je wedstrijdplan:</strong> oefen tijdens lange duurlopen en ritten met precies de producten en hoeveelheden die je in de wedstrijd wilt gebruiken. Geen verrassingen op raceday.</p></div>\n</div>\n</div>\n</section>\n\n<!-- ═══ FAQ ═══ -->\n<section id=\"faq\">\n<h2><span class=\"svd-heading-line\">Veelgestelde vragen over de 1:0.8 ratio</span></h2>\n\n<div class=\"svd-faq-list\">\n<div class=\"svd-faq-item\"><details>\n<summary>Wat is het verschil tussen de 2:1 en 1:0.8 glucose:fructose ratio?</summary>\n<div class=\"svd-faq-answer\">\n<p>De 2:1 ratio is de klassieke standaard die opname tot 90g koolhydraten per uur mogelijk maakt. De 1:0.8 ratio biedt relatief meer fructose, waardoor de fructose-transportroute in je darmen efficiënter wordt benut. Dit verhoogt de totale opnamecapaciteit naar 120g per uur en resulteert vaak in minder maagklachten.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Voor wie is de 1:0.8 ratio geschikt?</summary>\n<div class=\"svd-faq-answer\">\n<p>De 1:0.8 ratio is ideaal voor serieuze duursporters bij inspanningen langer dan 2-3 uur: marathonlopers, triatleten, wielrenners en ultralopers. Bij inspanningen korter dan 90 minuten heb je meestal genoeg aan je lichaamseigen glycogeenvoorraden. Voor inspanningen van 1,5-3 uur volstaat vaak de 2:1 ratio. Het voordeel van 1:0.8 wordt het grootst bij 3+ uur.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Moet ik mijn darmen echt trainen voor hoge koolhydraatinnames?</summary>\n<div class=\"svd-faq-answer\">\n<p>Ja, absoluut. Je darmen zijn trainbaar, net als je spieren. Begin met lagere doseringen (60g/uur) en bouw over 4-6 weken geleidelijk op. Gebruik in training exact dezelfde producten als in je wedstrijd. Zonder darmtraining loop je risico op maagklachten bij hoge innames van 90+ gram per uur.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Kan ik Amacx Turbo producten combineren met Maurten?</summary>\n<div class=\"svd-faq-answer\">\n<p>Ja, beide merken gebruiken de 1:0.8 verhouding. Je kunt bijvoorbeeld de <a href=\"https://sportvoedingdirect.nl/products/maurten-drink-mix-320\">Maurten Drink Mix 320</a> als basis in je bidon gebruiken en aanvullen met een <a href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-gel\">Amacx Turbo Gel</a> voor extra koolhydraten. Test deze combinatie altijd in training.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Wat is het verschil tussen Amacx Turbo Gel en Maurten Gel 100?</summary>\n<div class=\"svd-faq-answer\">\n<p>De <a href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-gel\">Amacx Turbo Gel</a> levert 40g koolhydraten met 200 mg natrium en is een isotone drinkgel. De <a href=\"https://sportvoedingdirect.nl/products/maurten-gel-100\">Maurten Gel 100</a> levert 25g koolhydraten met 85 mg natrium en gebruikt hydrogel-technologie. Amacx biedt meer koolhydraten en elektrolyten per portie; Maurten biedt de unieke hydrogel voor minimale maaglast.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Hoeveel koolhydraten per uur kan ik maximaal opnemen?</summary>\n<div class=\"svd-faq-answer\">\n<p>Met de 1:0.8 ratio is een opname van 120 gram per uur mogelijk, mits je darmen hierop getraind zijn. Sommige topatleten experimenteren zelfs met hogere innames tot 150g/uur. Begin met 60-80g/uur en verhoog stapsgewijs. Luister altijd naar je lichaam en forceer niets.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Heb ik water nodig bij de Amacx Turbo Gel?</summary>\n<div class=\"svd-faq-answer\">\n<p>Nee, de <a href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-gel\">Amacx Turbo Drink Gel</a> is een drinkbare gel die je zonder extra water inneemt. De vloeibare textuur maakt het makkelijk om in te nemen, zelfs tijdens hoge inspanning. Hetzelfde geldt voor de <a href=\"https://sportvoedingdirect.nl/products/maurten-gel-100\">Maurten Gel 100</a> dankzij de hydrogel-technologie.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Welke 1:0.8 producten bevatten cafeïne?</summary>\n<div class=\"svd-faq-answer\">\n<p>De <a href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-gel\">Amacx Turbo Gel Cassis Caffeine</a> bevat 100 mg cafeïne en de <a href=\"https://sportvoedingdirect.nl/products/226ers-high-fructose-gel\">226ERS High Fructose Gel Cherry Caffeine</a> bevat 160 mg cafeïne. Gebruik cafeïnegels strategisch: bewaar ze voor de tweede helft of de finale van je wedstrijd. Houd rekening met maximaal 3-4 mg cafeïne per kg lichaamsgewicht.</p>\n</div>\n</details></div>\n</div>\n</section>\n\n</div>\n\n<script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"CollectionPage\",\"name\":\"Sportvoeding met 1:0.8 ratio\",\"description\":\"Sportvoeding met 1:0.8 glucose:fructose ratio kopen bij SportvoedingDirect. Gels, sportdranken en chews van Amacx, Maurten en 226ERS voor maximale koolhydraatopname tot 120g per uur.\",\"url\":\"https://sportvoedingdirect.nl/collections/sportvoeding-met-1-0-8-ratio\",\"numberOfItems\":7,\"provider\":{\"@type\":\"Organization\",\"name\":\"SportvoedingDirect\",\"url\":\"https://sportvoedingdirect.nl\"}}</script>\n<script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Wat is het verschil tussen de 2:1 en 1:0.8 glucose:fructose ratio?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"De 2:1 ratio maakt opname tot 90g koolhydraten per uur mogelijk. De 1:0.8 ratio benut de fructose-transportroute efficiënter en verhoogt de opnamecapaciteit naar 120g per uur, vaak met minder maagklachten.\"}},{\"@type\":\"Question\",\"name\":\"Voor wie is de 1:0.8 ratio geschikt?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"De 1:0.8 ratio is ideaal voor duursporters bij inspanningen langer dan 2-3 uur: marathonlopers, triatleten, wielrenners en ultralopers. Het voordeel wordt het grootst bij 3+ uur.\"}},{\"@type\":\"Question\",\"name\":\"Moet ik mijn darmen echt trainen voor hoge koolhydraatinnames?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Ja. Begin met lagere doseringen (60g/uur) en bouw over 4-6 weken geleidelijk op. Gebruik in training exact dezelfde producten als in je wedstrijd.\"}},{\"@type\":\"Question\",\"name\":\"Kan ik Amacx Turbo producten combineren met Maurten?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Ja, beide merken gebruiken de 1:0.8 verhouding. Je kunt ze vrij combineren. Test combinaties altijd in training.\"}},{\"@type\":\"Question\",\"name\":\"Wat is het verschil tussen Amacx Turbo Gel en Maurten Gel 100?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"De Amacx Turbo Gel levert 40g koolhydraten met 200 mg natrium. De Maurten Gel 100 levert 25g koolhydraten met hydrogel-technologie voor minimale maaglast.\"}},{\"@type\":\"Question\",\"name\":\"Hoeveel koolhydraten per uur kan ik maximaal opnemen?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Met de 1:0.8 ratio is 120 gram per uur mogelijk met getrainde darmen. Begin met 60-80g/uur en verhoog stapsgewijs.\"}},{\"@type\":\"Question\",\"name\":\"Heb ik water nodig bij de Amacx Turbo Gel?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Nee, de Amacx Turbo Drink Gel is een drinkbare gel die je zonder extra water inneemt. Hetzelfde geldt voor de Maurten Gel 100.\"}},{\"@type\":\"Question\",\"name\":\"Welke 1:0.8 producten bevatten cafeïne?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"De Amacx Turbo Gel Cassis Caffeine (100 mg) en de 226ERS High Fructose Gel Cherry Caffeine (160 mg). Gebruik strategisch in de tweede helft van je wedstrijd.\"}}]}</script>",
