x 0 0 0}\n.svd-faq-item{border:1px solid var(--svd-border);border-radius:var(--svd-radius);margin-bottom:12px;overflow:hidden}\n.svd-faq-item details{width:100%}\n.svd-faq-item summary{padding:16px 20px;font-weight:700;font-size:15px;color:var(--svd-dark);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;background:#ffffff;transition:background 0.15s ease}\n.svd-faq-item summary:hover{background:var(--svd-bg)}\n.svd-faq-item summary::-webkit-details-marker{display:none}\n.svd-faq-item summary::after{content:'+';font-size:20px;font-weight:300;color:var(--svd-text-muted);flex-shrink:0;margin-left:12px}\n.svd-faq-item details[open] summary::after{content:'−'}\n.svd-faq-item .svd-faq-answer{padding:0 20px 18px 20px;font-size:14px;line-height:1.7;color:var(--svd-text)}\n.svd-faq-item .svd-faq-answer p{margin:0 0 10px 0}\n.svd-faq-item .svd-faq-answer p:last-child{margin:0}\n.svd-faq-item .svd-faq-answer a{color:var(--svd-dark);text-decoration:underline;font-weight:600}\n@media(min-width:600px){.svd-jump-nav ul{grid-template-columns:1fr 1fr}.svd-usp-grid{grid-template-columns:1fr 1fr}.svd-products-grid{grid-template-columns:1fr 1fr}.svd-scenario-grid{grid-template-columns:1fr 1fr 1fr}.svd-tips-grid{grid-template-columns:1fr 1fr}.svd-brand-grid{grid-template-columns:1fr 1fr 1fr}}\n@media(min-width:900px){.svd-hero{padding:56px 40px}.svd-hero h1{font-size:2.6rem}.svd-products-grid{grid-template-columns:repeat(3,1fr)}}\n@media(max-width:599px){.svd-compare-table{font-size:12px}.svd-compare-table th,.svd-compare-table td{padding:10px 8px}}\n</style>\n\n<div class=\"svd-ratio21-page\">\n\n<!-- ═══ HERO ═══ -->\n<section class=\"svd-hero\" id=\"intro\">\n<span class=\"svd-hero-tag\">Bewezen formule</span>\n<h1>Sportvoeding met 2:1 ratio: tot 90 gram koolhydraten per uur</h1>\n<p>De 2:1 glucose-fructoseratio is de gouden standaard in sportvoeding. Door twee koolhydraatbronnen slim te combineren neem je tot 90 gram per uur op – maagvriendelijk en wetenschappelijk bewezen. Van energiegels tot sportdranken en repen: ontdek alle 2:1 producten.</p>\n</section>\n\n<!-- ═══ BADGES ═══ -->\n<div class=\"svd-badges\">\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>13 producten met 2:1 ratio</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lavender\"></span>Gels, repen, sportdranken & herstel</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-dark\"></span>Amacx · Precision · BYE!</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>Tot 90g koolhydraten per uur</span>\n</div>\n\n<!-- ═══ JUMP NAV ═══ -->\n<nav class=\"svd-jump-nav\" aria-label=\"Pagina navigatie\">\n<h3>Op deze pagina</h3>\n<ul>\n<li><a href=\"#wetenschap\">Hoe werkt de 2:1 ratio? <span>De wetenschap</span></a></li>\n<li><a href=\"#energiegels\">Energiegels met 2:1 ratio <span>4 gels</span></a></li>\n<li><a href=\"#energierepen\">Energierepen met 2:1 ratio <span>4 repen</span></a></li>\n<li><a href=\"#sportdranken\">Sportdranken met 2:1 ratio <span>3 dranken</span></a></li>\n<li><a href=\"#herstelproducten\">Herstelproducten met 2:1 ratio <span>2 producten</span></a></li>\n<li><a href=\"#strategie\">Jouw 90g/uur strategie <span>3 scenario's</span></a></li>\n<li><a href=\"#vergelijking\">Vergelijkingstabel <span>13 producten</span></a></li>\n<li><a href=\"#faq\">Veelgestelde vragen <span>Over de 2:1 ratio</span></a></li>\n</ul>\n</nav>\n\n<!-- ═══ WETENSCHAP ═══ -->\n<section id=\"wetenschap\">\n<h2><span class=\"svd-heading-line\">Hoe werkt de 2:1 glucose-fructoseratio?</span></h2>\n<p>Je darmen gebruiken aparte transportkanalen voor glucose (SGLT1) en fructose (GLUT5). Het glucosekanaal raakt verzadigd bij circa 60 gram per uur. Door fructose toe te voegen in een 2:1 verhouding open je een tweede snelweg voor energie, waardoor je tot 90 gram koolhydraten per uur kunt opnemen.</p>\n\n<div class=\"svd-usp-grid\">\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">🔬</div>\n<div>\n<strong>Twee transportkanalen tegelijk</strong>\n<span>Glucose en fructose worden via verschillende poortjes in je darmen opgenomen. De 2:1 ratio benut beide kanalen maximaal voor een hogere totale opname.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">⚡</div>\n<div>\n<strong>Tot 90 gram koolhydraten per uur</strong>\n<span>Met alleen glucose is 60g/uur het maximum. Door fructose toe te voegen stijgt je opnamecapaciteit naar 90g/uur – bewezen in tientallen wetenschappelijke studies.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">😊</div>\n<div>\n<strong>Betere maagverdraagbaarheid</strong>\n<span>De mix wordt sneller uit de maag doorgestuurd naar de darmen. Minder voedsel in je maag betekent minder kans op misselijkheid, krampen en opgeblazen gevoel.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">🧮</div>\n<div>\n<strong>Eenvoudig te plannen</strong>\n<span>De meeste 2:1 producten bevatten 30g koolhydraten. Drie producten per uur = 90 gram. Twee per uur = 60 gram. Simpel en effectief.</span>\n</div>\n</div>\n</div>\n</section>\n\n<!-- ═══ ENERGIEGELS ═══ -->\n<section id=\"energiegels\">\n<h2><span class=\"svd-heading-line\">Energiegels met 2:1 ratio</span></h2>\n<p>Snelle, vloeibare energie voor de kritieke momenten in je training of wedstrijd. Alle gels hieronder gebruiken de bewezen 2:1 glucose-fructoseverhouding.</p>\n\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Meest populair</span>\n<h4>Amacx Drink Gel</h4>\n<p>30g koolhydraten · 2:1 ratio · drinkbare, isotone formule. Geen water nodig. Met elektrolyten (natrium). Smaken: Citrus, Strawberry, Orange, Cola + Caffeine (75mg). NZVT.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Precisie dosering</span>\n<h4>Precision PF 30 Gel</h4>\n<p>30g koolhydraten · 2:1 ratio · bewust milde smaak tegen smaakmoeheid. Geen elektrolyten (combineer met PH-tabletten). Informed Sport gecertificeerd.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/precision-pf-30-gel\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Cafeïne boost</span>\n<h4>Precision PF 30 Gel + Caffeine</h4>\n<p>30g koolhydraten · 2:1 ratio · 100 mg cafeïne. Strategisch wapen voor de finale. Neem 45-60 minuten voor het moment dat je de boost nodig hebt. Informed Sport.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/precision-pf-30-gel-caffeine\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">100% natuurlijk</span>\n<h4>BYE! Pro Fruit Gel</h4>\n<p>22g koolhydraten · 20% echt fruit · magnesiumcitraat. Zachte, vloeibare textuur als een frisse fruit smoothie. Zonder kunstmatige toevoegingen. Vegan.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/bye-pro-fruit-gel\">Bekijk en bestel →</a>\n</div>\n</div>\n</section>\n\n<!-- ═══ ENERGIEREPEN ═══ -->\n<section id=\"energierepen\">\n<h2><span class=\"svd-heading-line\">Energierepen met 2:1 ratio</span></h2>\n<p>Vaste brandstof met snelle koolhydraten. Ideaal voor de eerste fase van een lange inspanning, wanneer kauwen nog comfortabel is.</p>\n\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Zachte bite</span>\n<h4>Amacx Fast Bar</h4>\n<p>31g koolhydraten · 2:1 ratio · 45 mg natrium · 40% amandelen. Zacht als amandelspijs, makkelijk te eten bij hoge hartslag. Smaken: Lemon, Vanilla, Chocolate. NZVT.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-fast-bar\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Klassieke nougat</span>\n<h4>Amacx Energy Nougat</h4>\n<p>32g koolhydraten · 2:1 ratio · 45 mg natrium. Zachte nougatreep, hapt makkelijk weg. Gluten- en lactosevrij. Smaken: Cranberry, Papaya, Speculoos. NZVT.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-energy-nougat\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Fruitgom 2:1</span>\n<h4>Amacx Fruit Chew</h4>\n<p>30g koolhydraten · 2:1 ratio · 51% echt fruitpulp. Kauwbaar als een snoepje, plakt niet. Perfecte afwisseling op gels. Vegan, NZVT. Smaken: Cassis, Cranberry.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-fruit-chew\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Flexibel doseren</span>\n<h4>Precision PF 30 Chew</h4>\n<p>30g koolhydraten · 2:1 ratio · 2x 15g blokjes. Eet 15g of 30g per keer. Milde smaak, geen elektrolyten. Vegan, Informed Sport.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/precision-pf-30-chew\">Bekijk en bestel →</a>\n</div>\n</div>\n</section>\n\n<!-- ═══ SPORTDRANKEN ═══ -->\n<section id=\"sportdranken\">\n<h2><span class=\"svd-heading-line\">Sportdranken met 2:1 ratio</span></h2>\n<p>Koolhydraten, elektrolyten én vocht in één slok. Een isotone sportdrank met de 2:1 ratio is de perfecte basis van elk voedingsplan.</p>\n\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Team Visma</span>\n<h4>Amacx Energy Drink</h4>\n<p>30g koolhydraten · 2:1 ratio · isotoon. Combineert snelle energie met elektrolyten en vocht. De ideale basisbidon. NZVT. Smaken: Lemon, Orange.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-energy-drink-sachets\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Precisie systeem</span>\n<h4>Precision Carb &amp; Electrolyte Drink Mix</h4>\n<p>30g koolhydraten · 2:1 ratio · gecombineerd met elektrolyten. Milde smaak. Het PF-getal vertelt precies hoeveel gram koolhydraten je binnenkrijgt. Informed Sport.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/precision-carb-electrolyte-drink-mix\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">100% natuurlijk</span>\n<h4>BYE! Isotonic Sportdrink</h4>\n<p>2:1 ratio · unieke 2-in-1 formule: isotoon (35g/500ml) of hypotoon (20g/500ml). Hoog natrium (375mg), magnesium (100mg). 100% natuurlijk. Smaken: Citroen, Rood Fruit, Watermeloen.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/bye-isotonic-sportdrink\">Bekijk en bestel →</a>\n</div>\n</div>\n</section>\n\n<!-- ═══ HERSTELPRODUCTEN ═══ -->\n<section id=\"herstelproducten\">\n<h2><span class=\"svd-heading-line\">Herstelproducten met 2:1 ratio</span></h2>\n<p>De 2:1 ratio is niet alleen voor tijdens, maar ook voor na de inspanning. Snelle koolhydraatopname helpt je glycogeenvoorraden razendsnel aan te vullen.</p>\n\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Compleet herstel</span>\n<h4>Amacx Recovery Shake</h4>\n<p>30g koolhydraten (2:1 ratio) + 20g whey-eiwit. De complete alles-in-één shake: aanvullen, herstellen én hydrateren. Neem binnen 30-45 min na training. NZVT. Smaken: Vanilla, Chocolade.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-recovery-shake\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Natuurlijk herstel</span>\n<h4>Amacx Cherry Juice</h4>\n<p>30g koolhydraten (2:1 ratio) + 100 mg anthocyanine. Zure kersenextract met ontstekingsremmende werking. Gebruik 4-7 dagen voor wedstrijd of direct na inspanning. NZVT.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-cherry-juice\">Bekijk en bestel →</a>\n</div>\n</div>\n</section>\n\n<!-- ═══ STRATEGIE ═══ -->\n<section id=\"strategie\">\n<h2><span class=\"svd-heading-line\">Jouw 90 gram per uur strategie</span></h2>\n<p>De 2:1 ratio maakt het simpel: elk product bevat circa 30g koolhydraten. Kies je doel en stel je plan samen.</p>\n\n<div class=\"svd-scenario-grid\">\n<div class=\"svd-scenario-card\">\n<span class=\"svd-scenario-tag tag-basis\">60 gram per uur</span>\n<h3>Training &amp; wedstrijden tot 3 uur</h3>\n<p>Twee 2:1 producten per uur is voldoende voor de meeste trainingen en korte wedstrijden. Wissel af voor variatie.</p>\n<div class=\"svd-scenario-products\">\n<strong>Voorbeeld:</strong> 1x <a href=\"https://sportvoedingdirect.nl/products/amacx-energy-drink-sachets\">Energy Drink</a> (bidon) + 1x <a href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Drink Gel</a> per uur\n</div>\n</div>\n<div class=\"svd-scenario-card scenario-allround\">\n<span class=\"svd-scenario-tag tag-wedstrijd\">90 gram per uur</span>\n<h3>Marathon, Ironman, cyclo's</h3>\n<p>Drie 2:1 producten per uur voor maximale prestatie. Mix en match gels, repen en sportdrank om smaakmoeheid te voorkomen.</p>\n<div class=\"svd-scenario-products\">\n<strong>Voorbeeld:</strong> 1x <a href=\"https://sportvoedingdirect.nl/products/amacx-energy-drink-sachets\">Energy Drink</a> + 1x <a href=\"https://sportvoedingdirect.nl/products/precision-pf-30-gel\">PF 30 Gel</a> + 1x <a href=\"https://sportvoedingdirect.nl/products/amacx-fruit-chew\">Fruit Chew</a> per uur\n</div>\n</div>\n<div class=\"svd-scenario-card scenario-extreme\">\n<span class=\"svd-scenario-tag tag-elite\">Mix met 1:0.8</span>\n<h3>Combineer 2:1 en Turbo</h3>\n<p>Gebruik de 2:1 producten als basis en voeg <a href=\"https://sportvoedingdirect.nl/collections/sportvoeding-met-1-0-8-ratio\">1:0.8 Turbo producten</a> toe voor de zwaarste momenten. Zo haal je 90-120g/uur.</p>\n<div class=\"svd-scenario-products\">\n<strong>Voorbeeld:</strong> 1x <a href=\"https://sportvoedingdirect.nl/products/amacx-energy-drink-sachets\">Energy Drink</a> (2:1) + 1x <a href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Drink Gel</a> (2:1) + 1x Turbo Gel (1:0.8, 40g)\n</div>\n</div>\n</div>\n</section>\n\n<!-- ═══ VERGELIJKING ═══ -->\n<section id=\"vergelijking\">\n<h2><span class=\"svd-heading-line\">Alle 2:1 producten vergeleken</span></h2>\n<p>Alle sportvoeding met de 2:1 glucose-fructoseratio op een rij. Vergelijk op koolhydraten, type, merk en ideaal moment.</p>\n\n<div style=\"overflow-x:auto;border-radius:var(--svd-radius);border:1px solid var(--svd-border);box-shadow:var(--svd-shadow)\">\n<table class=\"svd-compare-table\">\n<thead>\n<tr><th>Product</th><th>Carbs</th><th>Type</th><th>Merk</th><th>Ideaal voor</th></tr>\n</thead>\n<tbody>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Amacx Drink Gel</a></td><td>30g</td><td><span class=\"svd-table-badge badge-gel\">gel</span></td><td>Amacx</td><td>Snelle energie, maagvriendelijk</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/precision-pf-30-gel\">Precision PF 30 Gel</a></td><td>30g</td><td><span class=\"svd-table-badge badge-gel\">gel</span></td><td>Precision</td><td>Milde smaak, combineer met PH</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/precision-pf-30-gel-caffeine\">Precision PF 30 + Caffeine</a></td><td>30g</td><td><span class=\"svd-table-badge badge-gel\">gel</span><span class=\"svd-table-badge badge-caf\">100mg caf</span></td><td>Precision</td><td>Finale boost, mentale scherpte</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/bye-pro-fruit-gel\">BYE! Pro Fruit Gel</a></td><td>22g</td><td><span class=\"svd-table-badge badge-gel\">gel</span></td><td>BYE!</td><td>Natuurlijk, zacht verteerbaar</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-fast-bar\">Amacx Fast Bar</a></td><td>31g</td><td><span class=\"svd-table-badge badge-reep\">reep</span></td><td>Amacx</td><td>Zachte bite, hoge hartslag</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-energy-nougat\">Amacx Energy Nougat</a></td><td>32g</td><td><span class=\"svd-table-badge badge-reep\">reep</span></td><td>Amacx</td><td>Klassieke reep, wielrennen</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-fruit-chew\">Amacx Fruit Chew</a></td><td>30g</td><td><span class=\"svd-table-badge badge-chew\">chew</span></td><td>Amacx</td><td>Snoepje als afwisseling</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/precision-pf-30-chew\">Precision PF 30 Chew</a></td><td>30g</td><td><span class=\"svd-table-badge badge-chew\">chew</span></td><td>Precision</td><td>Flexibel doseren, 2x 15g</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-energy-drink-sachets\">Amacx Energy Drink</a></td><td>30g</td><td><span class=\"svd-table-badge badge-drank\">drank</span></td><td>Amacx</td><td>Basisbidon, hydratatie + energie</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/precision-carb-electrolyte-drink-mix\">Precision Carb &amp; Electrolyte</a></td><td>30g</td><td><span class=\"svd-table-badge badge-drank\">drank</span></td><td>Precision</td><td>Precisie systeem, milde smaak</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/bye-isotonic-sportdrink\">BYE! Isotonic Sportdrink</a></td><td>35g</td><td><span class=\"svd-table-badge badge-drank\">drank</span></td><td>BYE!</td><td>Natuurlijk, 2-in-1 formule</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-recovery-shake\">Amacx Recovery Shake</a></td><td>30g</td><td><span class=\"svd-table-badge badge-herstel\">herstel</span></td><td>Amacx</td><td>Na training, compleet herstel</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-cherry-juice\">Amacx Cherry Juice</a></td><td>30g</td><td><span class=\"svd-table-badge badge-herstel\">herstel</span></td><td>Amacx</td><td>Wedstrijdvoorbereiding, antioxidant</td></tr>\n</tbody>\n</table>\n</div>\n</section>\n\n<!-- ═══ MERKEN ═══ -->\n<section id=\"merken\">\n<h2><span class=\"svd-heading-line\">3 merken, 1 bewezen ratio</span></h2>\n<p>Elk merk heeft een eigen benadering van de 2:1 formule. Ontdek welke filosofie past bij jouw aanpak.</p>\n\n<div class=\"svd-brand-grid\">\n<div class=\"svd-brand-card\">\n<h4><a href=\"https://sportvoedingdirect.nl/collections/amacx\">Amacx</a></h4>\n<p>Het breedste 2:1 assortiment: gels, repen, chews, sportdranken én herstel. Elk product levert ~30g koolhydraten voor eenvoudig mix &amp; match. Gebruikt door Team Visma | Lease a Bike. NZVT-gecertificeerd.</p>\n</div>\n<div class=\"svd-brand-card\">\n<h4><a href=\"https://sportvoedingdirect.nl/collections/precision\">Precision Fuel &amp; Hydration</a></h4>\n<p>Eenvoud en precisie. Het getal op de verpakking (PF 30) is het aantal gram koolhydraten. Bewust scheiding van brandstof (PF) en hydratatie (PH) voor ultieme controle. Informed Sport.</p>\n</div>\n<div class=\"svd-brand-card\">\n<h4><a href=\"https://sportvoedingdirect.nl/collections/boost-your-energy\">BYE! Nutrition</a></h4>\n<p>100% natuurlijk, zonder kunstmatige toevoegingen. Met echt fruit in gels en een flexibele 2-in-1 sportdrank. Nederlands merk, vegan, biologisch afbreekbare verpakkingen.</p>\n</div>\n</div>\n</section>\n\n<!-- ═══ TIPS ═══ -->\n<section id=\"tips\">\n<h2><span class=\"svd-heading-line\">6 tips voor je 2:1 voedingsplan</span></h2>\n\n<div class=\"svd-tips-grid\">\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">1</div>\n<div><p><strong>Train your gut:</strong> bouw je koolhydraatinname geleidelijk op tijdens trainingen. Start met 30-40g/uur en verhoog stapsgewijs naar 60-90g/uur over meerdere weken.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">2</div>\n<div><p><strong>Mix en match:</strong> wissel gels, repen en sportdrank af. Variatie voorkomt smaakmoeheid en zorgt voor betere verdraagzaamheid bij inspanningen langer dan 2 uur.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">3</div>\n<div><p><strong>Begin vroeg:</strong> start met je eerste product in de eerste 15-20 minuten. Als je wacht tot je honger of energiedip voelt, ben je al te laat.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">4</div>\n<div><p><strong>Test in training, nooit in wedstrijd:</strong> probeer nooit een nieuw product of een hogere inname voor het eerst op wedstrijddag. Oefen altijd tijdens lange duurtrainingen.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">5</div>\n<div><p><strong>Combineer met hydratatie:</strong> koolhydraten zonder voldoende vocht werken niet optimaal. Drink elke 15-20 minuten een paar slokken sportdrank of water.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">6</div>\n<div><p><strong>2:1 als basis, Turbo als boost:</strong> de 2:1 ratio is de perfecte allrounder. Wil je hoger? Combineer met <a href=\"https://sportvoedingdirect.nl/collections/sportvoeding-met-1-0-8-ratio\">1:0.8 Turbo producten</a> voor 90-120g/uur.</p></div>\n</div>\n</div>\n</section>\n\n<!-- ═══ FAQ ═══ -->\n<section id=\"faq\">\n<h2><span class=\"svd-heading-line\">Veelgestelde vragen over de 2:1 ratio</span></h2>\n\n<div class=\"svd-faq-list\">\n<div class=\"svd-faq-item\"><details>\n<summary>Wat betekent de 2:1 glucose-fructoseratio precies?</summary>\n<div class=\"svd-faq-answer\">\n<p>De 2:1 ratio betekent dat er twee delen glucose (of maltodextrine, dat wordt omgezet in glucose) worden gecombineerd met één deel fructose. Deze verhouding is wetenschappelijk bewezen als optimaal voor het benutten van beide koolhydraat-transportkanalen in je darmen, waardoor je tot 90 gram koolhydraten per uur kunt opnemen.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Wanneer kies ik 2:1 in plaats van de 1:0.8 ratio?</summary>\n<div class=\"svd-faq-answer\">\n<p>De 2:1 ratio is de perfecte keuze voor de overgrote meerderheid van de sporters, gericht op een inname tot 90g/uur. De <a href=\"https://sportvoedingdirect.nl/collections/sportvoeding-met-1-0-8-ratio\">1:0.8 ratio</a> (Turbo-lijn) is een specialistische formule voor atleten die getraind zijn om meer dan 90g/uur op te nemen. Je kunt ze ook combineren.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Is 90 gram koolhydraten per uur niet heel veel?</summary>\n<div class=\"svd-faq-answer\">\n<p>Voor lange en intensieve duurinspanningen (marathon, Ironman, cyclo's) is 60-90g/uur de wetenschappelijke aanbeveling. Voor kortere of minder intensieve trainingen is 30-60g/uur vaak al voldoende. Bouw je inname altijd geleidelijk op en oefen tijdens trainingen.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Kan ik producten van verschillende merken combineren?</summary>\n<div class=\"svd-faq-answer\">\n<p>Absoluut. Zolang producten de 2:1 ratio gebruiken, kun je ze vrij combineren. Mix bijvoorbeeld een <a href=\"https://sportvoedingdirect.nl/products/amacx-energy-drink-sachets\">Amacx Energy Drink</a> in je bidon met een <a href=\"https://sportvoedingdirect.nl/products/precision-pf-30-gel\">Precision PF 30 Gel</a> en een <a href=\"https://sportvoedingdirect.nl/products/amacx-fruit-chew\">Amacx Fruit Chew</a> voor 90g/uur.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Heb ik extra water nodig bij 2:1 producten?</summary>\n<div class=\"svd-faq-answer\">\n<p>Isotone sportdranken en drinkbare gels (zoals de <a href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Amacx Drink Gel</a>) bevatten al voldoende vocht. Bij vaste repen of dikke gels is het verstandig om er een paar slokken water bij te drinken. Een richtlijn is 500-750ml vocht per uur, inclusief je sportdrank.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Wat is het verschil tussen maltodextrine en glucose in 2:1 producten?</summary>\n<div class=\"svd-faq-answer\">\n<p>Maltodextrine wordt in je lichaam snel omgezet in glucose en gebruikt hetzelfde transportkanaal (SGLT1). Het voordeel van maltodextrine is dat het minder zoet smaakt en een lagere osmolaliteit heeft, waardoor sportdranken isotoon kunnen blijven ondanks een hoge koolhydraatconcentratie.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Waarom scheidt Precision brandstof (PF) en hydratatie (PH)?</summary>\n<div class=\"svd-faq-answer\">\n<p>Dit geeft je ultieme controle. Op een hete dag drink je meer elektrolyten maar eet je dezelfde hoeveelheid koolhydraten. Combineer de <a href=\"https://sportvoedingdirect.nl/products/precision-pf-30-gel\">PF 30 producten</a> met <a href=\"https://sportvoedingdirect.nl/products/precision-ph-1000-electrolyte-tablets\">PH tabletten</a> voor een op maat gemaakt plan.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Zijn 2:1 producten geschikt voor beginners?</summary>\n<div class=\"svd-faq-answer\">\n<p>Ja, de 2:1 ratio is juist ideaal voor beginners. Het is de meest bewezen, breed inzetbare formule met minimale kans op maagklachten. Start met 30g/uur (één product) en bouw op naar 60-90g/uur naarmate je ervaring groeit.</p>\n</div>\n</details></div>\n</div>\n</section>\n\n</div>\n\n<script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"CollectionPage\",\"name\":\"Sportvoeding met 2:1 ratio\",\"description\":\"Sportvoeding met de bewezen 2:1 glucose-fructoseratio. 13 producten van Amacx, Precision en BYE!: energiegels, repen, sportdranken en herstelvoeding voor tot 90g koolhydraten per uur.\",\"url\":\"https://sportvoedingdirect.nl/collections/sportvoeding-met-2-1-ratio\",\"numberOfItems\":13,\"provider\":{\"@type\":\"Organization\",\"name\":\"SportvoedingDirect\",\"url\":\"https://sportvoedingdirect.nl\"}}</script>\n<script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Wat betekent de 2:1 glucose-fructoseratio precies?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"De 2:1 ratio betekent dat er twee delen glucose worden gecombineerd met één deel fructose. Deze verhouding benut beide koolhydraat-transportkanalen in je darmen, waardoor je tot 90 gram koolhydraten per uur kunt opnemen.\"}},{\"@type\":\"Question\",\"name\":\"Wanneer kies ik 2:1 in plaats van de 1:0.8 ratio?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"De 2:1 ratio is de perfecte keuze voor de overgrote meerderheid van de sporters, gericht op een inname tot 90g/uur. De 1:0.8 ratio is voor atleten die getraind zijn om meer dan 90g/uur op te nemen.\"}},{\"@type\":\"Question\",\"name\":\"Is 90 gram koolhydraten per uur niet heel veel?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Voor lange duurinspanningen is 60-90g/uur de wetenschappelijke aanbeveling. Voor kortere trainingen is 30-60g/uur vaak al voldoende.\"}},{\"@type\":\"Question\",\"name\":\"Kan ik producten van verschillende merken combineren?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Absoluut. Zolang producten de 2:1 ratio gebruiken, kun je ze vrij combineren voor je gewenste inname per uur.\"}},{\"@type\":\"Question\",\"name\":\"Heb ik extra water nodig bij 2:1 producten?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Isotone sportdranken en drinkbare gels bevatten al voldoende vocht. Bij vaste repen is het verstandig om er water bij te drinken. Richtlijn: 500-750ml vocht per uur.\"}},{\"@type\":\"Question\",\"name\":\"Wat is het verschil tussen maltodextrine en glucose in 2:1 producten?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Maltodextrine wordt snel omgezet in glucose en gebruikt hetzelfde transportkanaal. Het voordeel is dat het minder zoet smaakt en een lagere osmolaliteit heeft.\"}},{\"@type\":\"Question\",\"name\":\"Waarom scheidt Precision brandstof (PF) en hydratatie (PH)?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Dit geeft ultieme controle. Op een hete dag drink je meer elektrolyten maar eet je dezelfde hoeveelheid koolhydraten.\"}},{\"@type\":\"Question\",\"name\":\"Zijn 2:1 producten geschikt voor beginners?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Ja, de 2:1 ratio is ideaal voor beginners. Start met 30g/uur en bouw op naar 60-90g/uur naarmate je ervaring groeit.\"}}]}</script>",
