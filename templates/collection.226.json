    "custom_liquid_e6pAYg": {
      "type": "custom-liquid",
      "settings": {
        "color_scheme": "scheme-2",
        "liquid": "<style>\n    /* ==================================================\n       226ERS Collectiepagina – SportvoedingDirect\n       Stijl: consistent met e-mail & pakbon designsysteem\n       Kleuren: lime #d9ff36, lavendel #dbb8ff, dark #1a1a1a\n       Typografie: -apple-system stack\n       Radius: 12px (cards), 8px (tags), 4px (small)\n    ================================================== */\n\n    :root {\n        --svd-lime: #d9ff36;\n        --svd-lime-dark: #c8f00a;\n        --svd-lavender: #dbb8ff;\n        --svd-lavender-bg: #faf5ff;\n        --svd-lavender-border: #e8ddf5;\n        --svd-dark: #1a1a1a;\n        --svd-text: #333333;\n        --svd-text-light: #666666;\n        --svd-text-muted: #888888;\n        --svd-bg: #fafafa;\n        --svd-border: #eeeeee;\n        --svd-yellow: #f0c000;\n        --svd-yellow-bg: #fffaeb;\n        --svd-radius: 12px;\n        --svd-radius-sm: 8px;\n        --svd-shadow: 0 2px 12px rgba(0,0,0,0.06);\n    }\n\n    .svd-226ers-page {\n        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;\n        line-height: 1.7;\n        color: var(--svd-text);\n        padding: 0;\n        -webkit-font-smoothing: antialiased;\n    }\n\n    .svd-226ers-page * {\n        box-sizing: border-box;\n    }\n\n    /* ── HERO ── */\n    .svd-hero {\n        background: linear-gradient(135deg, var(--svd-lime) 0%, var(--svd-lime-dark) 100%);\n        padding: 48px 32px;\n        border-radius: var(--svd-radius);\n        margin-bottom: 40px;\n        position: relative;\n        overflow: hidden;\n    }\n    .svd-hero::after {\n        content: '226';\n        position: absolute;\n        right: -20px;\n        bottom: -30px;\n        font-size: 180px;\n        font-weight: 900;\n        color: rgba(0,0,0,0.04);\n        line-height: 1;\n        pointer-events: none;\n    }\n    .svd-hero-tag {\n        display: inline-block;\n        background-color: var(--svd-dark);\n        color: #ffffff;\n        font-size: 11px;\n        font-weight: 700;\n        text-transform: uppercase;\n        letter-spacing: 0.08em;\n        padding: 5px 12px;\n        border-radius: 6px;\n        margin-bottom: 16px;\n    }\n    .svd-hero h1 {\n        font-size: 2.2rem;\n        font-weight: 800;\n        color: var(--svd-dark);\n        margin: 0 0 14px 0;\n        line-height: 1.2;\n        max-width: 600px;\n    }\n    .svd-hero p {\n        font-size: 16px;\n        color: var(--svd-dark);\n        margin: 0;\n        max-width: 560px;\n        line-height: 1.65;\n        opacity: 0.85;\n    }\n\n    /* ── SECTION SPACING ── */\n    .svd-226ers-page section {\n        margin-bottom: 48px;\n    }\n\n    /* ── HEADINGS ── */\n    .svd-226ers-page h2 {\n        font-size: 1.6rem;\n        font-weight: 800;\n        color: var(--svd-dark);\n        margin: 0 0 20px 0;\n        line-height: 1.25;\n    }\n    .svd-heading-line {\n        display: inline-block;\n        padding-bottom: 10px;\n        border-bottom: 3px solid var(--svd-lime);\n    }\n    .svd-226ers-page h3 {\n        font-size: 1.15rem;\n        font-weight: 700;\n        color: var(--svd-dark);\n        margin: 0 0 10px 0;\n        line-height: 1.3;\n    }\n    .svd-226ers-page p {\n        margin: 0 0 16px 0;\n    }\n\n    /* ── JUMP NAV ── */\n    .svd-jump-nav {\n        background: var(--svd-bg);\n        border: 1px solid var(--svd-border);\n        border-left: 4px solid var(--svd-lime);\n        border-radius: var(--svd-radius);\n        padding: 20px 24px;\n        margin-bottom: 40px;\n    }\n    .svd-jump-nav h3 {\n        margin: 0 0 12px 0;\n        font-size: 14px;\n        text-transform: uppercase;\n        letter-spacing: 0.04em;\n        color: var(--svd-text-muted);\n    }\n    .svd-jump-nav ul {\n        list-style: none;\n        padding: 0;\n        margin: 0;\n        display: grid;\n        grid-template-columns: 1fr;\n        gap: 8px;\n    }\n    .svd-jump-nav a {\n        display: block;\n        padding: 10px 14px;\n        background: #ffffff;\n        border: 1px solid var(--svd-border);\n        border-radius: var(--svd-radius-sm);\n        color: var(--svd-dark);\n        text-decoration: none;\n        font-weight: 600;\n        font-size: 14px;\n        transition: all 0.15s ease;\n    }\n    .svd-jump-nav a:hover {\n        background: var(--svd-lime);\n        border-color: var(--svd-lime-dark);\n    }\n    .svd-jump-nav a span {\n        color: var(--svd-text-muted);\n        font-weight: 400;\n        margin-left: 4px;\n    }\n\n    /* ── USP GRID ── */\n    .svd-usp-grid {\n        display: grid;\n        grid-template-columns: 1fr;\n        gap: 12px;\n        margin: 24px 0;\n    }\n    .svd-usp-card {\n        background: var(--svd-bg);\n        border: 1px solid var(--svd-border);\n        border-radius: var(--svd-radius);\n        padding: 18px 20px;\n        display: flex;\n        align-items: flex-start;\n        gap: 14px;\n    }\n    .svd-usp-icon {\n        flex-shrink: 0;\n        width: 40px;\n        height: 40px;\n        background: var(--svd-lime);\n        border-radius: 10px;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        font-size: 18px;\n        font-weight: 700;\n    }\n    .svd-usp-card strong {\n        display: block;\n        font-size: 14px;\n        font-weight: 700;\n        color: var(--svd-dark);\n        margin-bottom: 2px;\n    }\n    .svd-usp-card span {\n        font-size: 13px;\n        color: var(--svd-text-light);\n        line-height: 1.5;\n    }\n\n    /* ── PRODUCT CARDS GRID ── */\n    .svd-products-grid {\n        display: grid;\n        grid-template-columns: 1fr;\n        gap: 16px;\n        margin: 24px 0;\n    }\n    .svd-product-card {\n        background: #ffffff;\n        border: 1px solid var(--svd-border);\n        border-radius: var(--svd-radius);\n        padding: 22px 24px;\n        box-shadow: var(--svd-shadow);\n        transition: box-shadow 0.15s ease;\n    }\n    .svd-product-card:hover {\n        box-shadow: 0 4px 20px rgba(0,0,0,0.1);\n    }\n    .svd-product-card-rank {\n        display: inline-block;\n        background: var(--svd-lavender);\n        color: #3b0764;\n        font-size: 11px;\n        font-weight: 800;\n        padding: 3px 10px;\n        border-radius: 4px;\n        margin-bottom: 10px;\n        text-transform: uppercase;\n        letter-spacing: 0.06em;\n    }\n    .svd-product-card h4 {\n        font-size: 1.05rem;\n        font-weight: 700;\n        color: var(--svd-dark);\n        margin: 0 0 8px 0;\n        line-height: 1.3;\n    }\n    .svd-product-card p {\n        font-size: 14px;\n        color: var(--svd-text);\n        margin: 0 0 12px 0;\n        line-height: 1.6;\n    }\n    .svd-product-card a.svd-card-link {\n        display: inline-block;\n        font-size: 13px;\n        font-weight: 700;\n        color: #3b0764;\n        text-decoration: none;\n        padding: 8px 16px;\n        background: var(--svd-lavender);\n        border-radius: var(--svd-radius-sm);\n        transition: background 0.15s ease;\n    }\n    .svd-product-card a.svd-card-link:hover {\n        background: #cda0ff;\n    }\n\n    /* ── PRODUCTLIJN CARDS ── */\n    .svd-lines-grid {\n        display: grid;\n        grid-template-columns: 1fr;\n        gap: 16px;\n        margin: 24px 0;\n    }\n    .svd-line-card {\n        background: #ffffff;\n        border: 1px solid var(--svd-border);\n        border-radius: var(--svd-radius);\n        padding: 22px 24px;\n        border-top: 4px solid var(--svd-lime);\n    }\n    .svd-line-card.lavender {\n        border-top-color: var(--svd-lavender);\n    }\n    .svd-line-card h4 {\n        font-size: 1rem;\n        font-weight: 700;\n        color: var(--svd-dark);\n        margin: 0 0 8px 0;\n    }\n    .svd-line-card .svd-line-tag {\n        display: inline-block;\n        font-size: 10px;\n        font-weight: 700;\n        text-transform: uppercase;\n        letter-spacing: 0.06em;\n        padding: 3px 8px;\n        border-radius: 4px;\n        margin-bottom: 10px;\n    }\n    .svd-line-card .tag-energie {\n        background: var(--svd-lime);\n        color: var(--svd-dark);\n    }\n    .svd-line-card .tag-hydratatie {\n        background: #e0f0ff;\n        color: #0a5299;\n    }\n    .svd-line-card .tag-ultra {\n        background: var(--svd-dark);\n        color: #ffffff;\n    }\n    .svd-line-card .tag-herstel {\n        background: #f0e6ff;\n        color: #5b21a8;\n    }\n    .svd-line-card p {\n        font-size: 14px;\n        color: var(--svd-text);\n        margin: 0;\n        line-height: 1.6;\n    }\n\n    /* ── WETENSCHAP SECTIE ── */\n    .svd-science-block {\n        background: var(--svd-bg);\n        border: 1px solid var(--svd-border);\n        border-radius: var(--svd-radius);\n        padding: 24px 28px;\n        margin-bottom: 16px;\n    }\n    .svd-science-block h3 {\n        margin: 0 0 8px 0;\n    }\n    .svd-science-block p {\n        font-size: 14px;\n        line-height: 1.7;\n        margin: 0;\n    }\n    .svd-science-highlight {\n        background: var(--svd-lime);\n        display: inline;\n        padding: 2px 6px;\n        border-radius: 4px;\n        font-weight: 700;\n    }\n\n    /* ── FAQ ── */\n    .svd-faq-list {\n        margin: 24px 0 0 0;\n    }\n    .svd-faq-item {\n        border: 1px solid var(--svd-border);\n        border-radius: var(--svd-radius);\n        margin-bottom: 12px;\n        overflow: hidden;\n    }\n    .svd-faq-item details {\n        width: 100%;\n    }\n    .svd-faq-item summary {\n        padding: 16px 20px;\n        font-weight: 700;\n        font-size: 15px;\n        color: var(--svd-dark);\n        cursor: pointer;\n        list-style: none;\n        display: flex;\n        justify-content: space-between;\n        align-items: center;\n        background: #ffffff;\n        transition: background 0.15s ease;\n    }\n    .svd-faq-item summary:hover {\n        background: var(--svd-bg);\n    }\n    .svd-faq-item summary::-webkit-details-marker {\n        display: none;\n    }\n    .svd-faq-item summary::after {\n        content: '+';\n        font-size: 20px;\n        font-weight: 300;\n        color: var(--svd-text-muted);\n        flex-shrink: 0;\n        margin-left: 12px;\n    }\n    .svd-faq-item details[open] summary::after {\n        content: '−';\n    }\n    .svd-faq-item .svd-faq-answer {\n        padding: 0 20px 18px 20px;\n        font-size: 14px;\n        line-height: 1.7;\n        color: var(--svd-text);\n    }\n    .svd-faq-item .svd-faq-answer p {\n        margin: 0;\n    }\n\n    /* ── BADGES ROW ── */\n    .svd-badges {\n        display: flex;\n        flex-wrap: wrap;\n        gap: 8px;\n        margin: 24px 0;\n    }\n    .svd-badge {\n        display: inline-flex;\n        align-items: center;\n        gap: 6px;\n        padding: 6px 14px;\n        border-radius: 20px;\n        font-size: 12px;\n        font-weight: 600;\n        border: 1px solid var(--svd-border);\n        background: #ffffff;\n        color: var(--svd-text);\n    }\n    .svd-badge-dot {\n        width: 8px;\n        height: 8px;\n        border-radius: 50%;\n        flex-shrink: 0;\n    }\n    .dot-lime { background: var(--svd-lime); }\n    .dot-lavender { background: var(--svd-lavender); }\n    .dot-dark { background: var(--svd-dark); }\n\n    /* ── RESPONSIVE ── */\n    @media (min-width: 600px) {\n        .svd-jump-nav ul { grid-template-columns: 1fr 1fr; }\n        .svd-usp-grid { grid-template-columns: 1fr 1fr; }\n        .svd-products-grid { grid-template-columns: 1fr 1fr; }\n        .svd-lines-grid { grid-template-columns: 1fr 1fr; }\n    }\n    @media (min-width: 900px) {\n        .svd-hero { padding: 56px 40px; }\n        .svd-hero h1 { font-size: 2.6rem; }\n        .svd-products-grid { grid-template-columns: repeat(3, 1fr); }\n        .svd-lines-grid { grid-template-columns: repeat(4, 1fr); }\n    }\n</style>\n\n<div class=\"svd-226ers-page\">\n\n    <!-- ═══ HERO ═══ -->\n    <section class=\"svd-hero\" id=\"intro\">\n        <span class=\"svd-hero-tag\">Feed your dreams</span>\n        <h1>226ERS sportvoeding: maximale energie, nul maagklachten</h1>\n        <p>226ERS ontwikkelt sportvoeding specifiek voor duursporters. Glutenvrij, veganistisch en gebaseerd op de wetenschappelijk bewezen 1:0.8 koolhydraatverhouding. Zo neem je tot 120 gram koolhydraten per uur op, zonder je maag te belasten.</p>\n    </section>\n\n    <!-- ═══ BADGES ═══ -->\n    <div class=\"svd-badges\">\n        <span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>Glutenvrij</span>\n        <span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>Veganistisch</span>\n        <span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lavender\"></span>Cologne List® gecertificeerd</span>\n        <span class=\"svd-badge\"><span class=\"svd-badge-dot dot-dark\"></span>Geen toegevoegde suikers</span>\n        <span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>Opgericht in Valencia, Spanje (2010)</span>\n    </div>\n\n    <!-- ═══ JUMP NAV ═══ -->\n    <nav class=\"svd-jump-nav\" aria-label=\"Pagina navigatie\">\n        <h3>Op deze pagina</h3>\n        <ul>\n            <li><a href=\"#waarom-226ers\">Waarom 226ERS? <span>De voordelen</span></a></li>\n            <li><a href=\"#top-producten\">Top 5 bestverkocht <span>Direct bestellen</span></a></li>\n            <li><a href=\"#productlijnen\">Productlijnen <span>Kies op doel</span></a></li>\n            <li><a href=\"#wetenschap\">De wetenschap <span>1:0.8 uitgelegd</span></a></li>\n            <li><a href=\"#faq\">Veelgestelde vragen <span>Over 226ERS</span></a></li>\n        </ul>\n    </nav>\n\n    <!-- ═══ WAAROM 226ERS ═══ -->\n    <section id=\"waarom-226ers\">\n        <h2><span class=\"svd-heading-line\">Waarom kiezen duursporters voor 226ERS?</span></h2>\n        <p>De naam 226ERS verwijst naar de 226 kilometer van een volledige Ironman triatlon. Oprichter Jesús Sánchez startte het merk in 2010 in Valencia nadat hij zelf uitviel door maagproblemen tijdens wedstrijden. Het resultaat: sportvoeding die specifiek is ontwikkeld om de maag te ontzien en tegelijk maximale energie te leveren.</p>\n\n        <div class=\"svd-usp-grid\">\n            <div class=\"svd-usp-card\">\n                <div class=\"svd-usp-icon\">⚡</div>\n                <div>\n                    <strong>Tot 120 g koolhydraten per uur</strong>\n                    <span>De 1:0.8 verhouding van maltodextrine en fructose benut twee opnameroutes in de darmen (SGLT1 en GLUT5) tegelijk.</span>\n                </div>\n            </div>\n            <div class=\"svd-usp-card\">\n                <div class=\"svd-usp-icon\">🫁</div>\n                <div>\n                    <strong>Geen maagklachten</strong>\n                    <span>Cyclodextrine en lage osmolariteit zorgen voor snelle maagpassage. Geen opgeblazen gevoel, geen krampen.</span>\n                </div>\n            </div>\n            <div class=\"svd-usp-card\">\n                <div class=\"svd-usp-icon\">🧪</div>\n                <div>\n                    <strong>Cologne List® gecertificeerd</strong>\n                    <span>Onafhankelijk getest op verboden stoffen conform de WADA-lijst. Veilig voor wedstrijdsporters.</span>\n                </div>\n            </div>\n            <div class=\"svd-usp-card\">\n                <div class=\"svd-usp-icon\">🌿</div>\n                <div>\n                    <strong>Glutenvrij en veganistisch</strong>\n                    <span>Alle producten zijn glutenvrij. Het overgrote deel is volledig veganistisch en vrij van toegevoegde suikers.</span>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- ═══ TOP 5 PRODUCTEN ═══ -->\n    <section id=\"top-producten\">\n        <h2><span class=\"svd-heading-line\">Top 5 bestverkochte 226ERS sportvoeding</span></h2>\n        <p>De producten waarmee de meeste duursporters in Nederland hun prestaties verbeteren:</p>\n\n        <div class=\"svd-products-grid\">\n            <div class=\"svd-product-card\">\n                <span class=\"svd-product-card-rank\">#1 Bestseller</span>\n                <h4>High Fructose Gel</h4>\n                <p>55 g koolhydraten en 250 mg natrium per gel. Geformuleerd met de 1:0.8 maltodextrine/fructose verhouding. Ideaal voor intensieve duurinspanningen waarbij je maximale energie nodig hebt.</p>\n                <a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/226ers-high-fructose-gel\">Bekijk en bestel →</a>\n            </div>\n            <div class=\"svd-product-card\">\n                <span class=\"svd-product-card-rank\">#2 Populair</span>\n                <h4>Hydrazero Elektrolyten</h4>\n                <p>Calorievrije elektrolyten met 500 mg natrium per tablet. Zonder suiker, zonder koolhydraten. Gebruik het los voor hydratatie of combineer het met een energiegel voor volledige voeding.</p>\n                <a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/226ers-elektrolyten-bruistabletten\">Bekijk en bestel →</a>\n            </div>\n            <div class=\"svd-product-card\">\n                <span class=\"svd-product-card-rank\">#3 Favoriet</span>\n                <h4>Isotonic Gel</h4>\n                <p>Energiegel die je zonder water kunt innemen. 22 g koolhydraten per gel in een isotone formule op basis van cyclodextrine. Snel opneembaar en licht verteerbaar.</p>\n                <a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/226ers-isotonic-gel\">Bekijk en bestel →</a>\n            </div>\n            <div class=\"svd-product-card\">\n                <span class=\"svd-product-card-rank\">#4 Race-favoriet</span>\n                <h4>High Fructose Energy Drink</h4>\n                <p>87 g koolhydraten en 500 mg natrium per portie in je bidon. Dezelfde 1:0.8 verhouding als de gels. Gemaakt voor lange duurinspanningen waarbij je energie en hydratatie wilt combineren.</p>\n                <a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/226ers-high-fructose-energy-drink\">Bekijk en bestel →</a>\n            </div>\n            <div class=\"svd-product-card\">\n                <span class=\"svd-product-card-rank\">#5 Veelzijdig</span>\n                <h4>High Energy Gel</h4>\n                <p>50 g koolhydraten uit cyclodextrine voor geleidelijke energieafgifte. Verkrijgbaar met BCAA's of cafeïne. Geschikt voor trainingen en wedstrijden van elke afstand.</p>\n                <a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/226ers-high-energy-gel\">Bekijk en bestel →</a>\n            </div>\n        </div>\n    </section>\n\n    <!-- ═══ PRODUCTLIJNEN ═══ -->\n    <section id=\"productlijnen\">\n        <h2><span class=\"svd-heading-line\">226ERS productlijnen: kies op basis van jouw doel</span></h2>\n        <p>226ERS deelt het assortiment in op basis van inspanningsduur en sportdoel. Zo vind je snel de juiste sportvoeding.</p>\n\n        <div class=\"svd-lines-grid\">\n            <div class=\"svd-line-card\">\n                <span class=\"svd-line-tag tag-energie\">Maximale energie</span>\n                <h4>High Fructose</h4>\n                <p>De lijn voor maximale koolhydraatopname. De 1:0.8 verhouding van maltodextrine en fructose maakt opname van 90 tot 120 g koolhydraten per uur mogelijk. Gels, drinks en poeder.</p>\n            </div>\n            <div class=\"svd-line-card lavender\">\n                <span class=\"svd-line-tag tag-hydratatie\">Hydratatie</span>\n                <h4>Hydrazero</h4>\n                <p>Calorievrije hydratatie met hoog natriumgehalte (500 mg). Bruistabletten en kauwtabletten. Combineer met een energiegel als je koolhydraten en hydratatie apart wilt sturen.</p>\n            </div>\n            <div class=\"svd-line-card\">\n                <span class=\"svd-line-tag tag-ultra\">Ultra-endurance</span>\n                <h4>SUB9</h4>\n                <p>Specifiek voor inspanningen langer dan 4 uur. Combineert koolhydraten met eiwitten en BCAA's om spierafbraak tegen te gaan. Voor ultralopen, Ironman en bikepacking.</p>\n            </div>\n            <div class=\"svd-line-card lavender\">\n                <span class=\"svd-line-tag tag-herstel\">Herstel</span>\n                <h4>Recovery &amp; Essentials</h4>\n                <p>Hersteldranken, aminozuren (6.4 AMINO) en supplementen zoals Creatine Creapure®. Ondersteunt spierherstel na zware trainingen en wedstrijden.</p>\n            </div>\n        </div>\n    </section>\n\n    <!-- ═══ WETENSCHAP ═══ -->\n    <section id=\"wetenschap\">\n        <h2><span class=\"svd-heading-line\">De wetenschap achter 226ERS: waarom de 1:0.8 verhouding werkt</span></h2>\n        <p>De effectiviteit van 226ERS sportvoeding zit in twee wetenschappelijk onderbouwde principes:</p>\n\n        <div class=\"svd-science-block\">\n            <h3>Multi-transporter technologie (maltodextrine + fructose)</h3>\n            <p>Je lichaam neemt koolhydraten op via twee verschillende transporters in de dunne darm. Maltodextrine wordt opgenomen via het SGLT1 transport en omgezet in glucose voor snelle energie. Fructose gaat via de GLUT5 transporters naar de lever en vult de glycogeenvoorraden aan voor geleidelijke energie. Door beide bronnen tegelijk te benutten in een <span class=\"svd-science-highlight\">verhouding van 1:0.8</span> kun je tot 120 gram koolhydraten per uur opnemen. Met één enkele koolhydraatbron zit je vast op maximaal 60 gram per uur.</p>\n        </div>\n\n        <div class=\"svd-science-block\">\n            <h3>Cyclodextrine en lage osmolariteit</h3>\n            <p>De Isotonic Gel en High Energy Gel lijn gebruiken cyclodextrine (Cluster Dextrin™) als koolhydraatbron. Dit koolhydraat heeft een hoog molecuulgewicht maar een lage osmolariteit, waardoor het extreem snel door de maag gaat. Het resultaat: geen opgeblazen gevoel, geen maagkrampen en geen insulinepieken. Constante energie zonder de bekende crash.</p>\n        </div>\n    </section>\n\n    <!-- ═══ FAQ ═══ -->\n    <section id=\"faq\">\n        <h2><span class=\"svd-heading-line\">Veelgestelde vragen over 226ERS</span></h2>\n\n        <div class=\"svd-faq-list\">\n            <div class=\"svd-faq-item\">\n                <details>\n                    <summary>Wat is het verschil tussen de High Fructose Gel en de Isotonic Gel?</summary>\n                    <div class=\"svd-faq-answer\">\n                        <p>De High Fructose Gel levert 55 g koolhydraten per gel en moet je combineren met water. Gebruik deze wanneer je maximale energie nodig hebt. De Isotonic Gel bevat 22 g koolhydraten en kun je innemen zonder water, omdat de isotone formule zelfstandig opneembaar is. Ideaal als snelle tussendoortje of wanneer je geen bidon bij de hand hebt.</p>\n                    </div>\n                </details>\n            </div>\n            <div class=\"svd-faq-item\">\n                <details>\n                    <summary>Waarom bevat de Hydrazero 500 mg natrium?</summary>\n                    <div class=\"svd-faq-answer\">\n                        <p>Natrium is het elektrolyt dat je het meest verliest via zweet. Een tekort leidt tot krampen, vermoeidheid en verminderde prestaties. De 500 mg natrium per tablet vult dit verlies effectief aan en stabiliseert je vochtbalans. Omdat Hydrazero calorievrij is, kun je de hydratatie volledig los sturen van je koolhydraatinname.</p>\n                    </div>\n                </details>\n            </div>\n            <div class=\"svd-faq-item\">\n                <details>\n                    <summary>Is 226ERS geschikt voor een marathon of triathlon?</summary>\n                    <div class=\"svd-faq-answer\">\n                        <p>Ja. 226ERS is ontstaan vanuit de triatlonwereld. De naam verwijst naar de 226 kilometer van een Ironman. De High Fructose lijn en SUB9 lijn zijn specifiek ontwikkeld voor duurinspanningen van meerdere uren, terwijl de Hydrazero lijn zorgt voor stabiele hydratatie onder alle omstandigheden.</p>\n                    </div>\n                </details>\n            </div>\n            <div class=\"svd-faq-item\">\n                <details>\n                    <summary>Zijn alle 226ERS producten veganistisch en glutenvrij?</summary>\n                    <div class=\"svd-faq-answer\">\n                        <p>Alle producten van 226ERS zijn glutenvrij. Het overgrote deel van het assortiment is ook volledig veganistisch en vrij van toegevoegde suikers. Controleer altijd de productpagina voor de specifieke samenstelling van je gekozen variant.</p>\n                    </div>\n                </details>\n            </div>\n            <div class=\"svd-faq-item\">\n                <details>\n                    <summary>Wat betekent de Cologne List® certificering?</summary>\n                    <div class=\"svd-faq-answer\">\n                        <p>De Cologne List® is het grootste platform voor dopingpreventie bij voedingssupplementen ter wereld. Producten op deze lijst zijn onafhankelijk getest op verboden stoffen uit de WADA-lijst. Veel 226ERS producten staan op deze lijst, wat extra zekerheid biedt voor wedstrijdsporters die regelmatig getest worden.</p>\n                    </div>\n                </details>\n            </div>\n            <div class=\"svd-faq-item\">\n                <details>\n                    <summary>Hoeveel koolhydraten per uur moet ik innemen?</summary>\n                    <div class=\"svd-faq-answer\">\n                        <p>Dit hangt af van de intensiteit en duur van je inspanning. Als richtlijn: bij inspanningen tot 2 uur is 60 g per uur een goed startpunt. Bij langere inspanningen (marathon, triatlon, lange fietstochten) kun je met de High Fructose lijn opbouwen naar 90 tot 120 g per uur. Train altijd eerst je darmopname voordat je deze hoeveelheden in wedstrijden gebruikt.</p>\n                    </div>\n                </details>\n            </div>\n        </div>\n    </section>\n\n</div>\n\n<!-- ═══ STRUCTURED DATA ═══ -->\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"CollectionPage\",\n  \"name\": \"226ERS Sportvoeding kopen | Energie Gels, Elektrolyten en Hydratatie\",\n  \"description\": \"Ontdek 226ERS sportvoeding bij SportvoedingDirect. Glutenvrij, veganistisch en gebaseerd op de wetenschappelijk bewezen 1:0.8 koolhydraatverhouding. High Fructose Gels, Hydrazero elektrolyten en meer.\",\n  \"url\": \"https://sportvoedingdirect.nl/collections/226ers\",\n  \"mainEntity\": {\n    \"@type\": \"ItemList\",\n    \"name\": \"Top 5 bestverkochte 226ERS producten\",\n    \"itemListElement\": [\n      {\n        \"@type\": \"ListItem\",\n        \"position\": 1,\n        \"item\": {\n          \"@type\": \"Product\",\n          \"name\": \"226ERS High Fructose Gel\",\n          \"url\": \"https://sportvoedingdirect.nl/products/226ers-high-fructose-gel\"\n        }\n      },\n      {\n        \"@type\": \"ListItem\",\n        \"position\": 2,\n        \"item\": {\n          \"@type\": \"Product\",\n          \"name\": \"226ERS Hydrazero Elektrolyten\",\n          \"url\": \"https://sportvoedingdirect.nl/products/226ers-elektrolyten-bruistabletten\"\n        }\n      },\n      {\n        \"@type\": \"ListItem\",\n        \"position\": 3,\n        \"item\": {\n          \"@type\": \"Product\",\n          \"name\": \"226ERS Isotonic Gel\",\n          \"url\": \"https://sportvoedingdirect.nl/products/226ers-isotonic-gel\"\n        }\n      },\n      {\n        \"@type\": \"ListItem\",\n        \"position\": 4,\n        \"item\": {\n          \"@type\": \"Product\",\n          \"name\": \"226ERS High Fructose Energy Drink\",\n          \"url\": \"https://sportvoeding