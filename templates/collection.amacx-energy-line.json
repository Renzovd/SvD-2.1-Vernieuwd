d-scenario-card .svd-scenario-products strong{color:var(--svd-dark)}\n.svd-compare-table{width:100%;border-collapse:collapse;margin:24px 0;font-size:13px}\n.svd-compare-table th{background:var(--svd-dark);color:#ffffff;font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:0.04em;padding:12px 14px;text-align:left}\n.svd-compare-table td{padding:12px 14px;border-bottom:1px solid var(--svd-border);vertical-align:top}\n.svd-compare-table tr:nth-child(even) td{background:var(--svd-bg)}\n.svd-compare-table a{color:var(--svd-dark);text-decoration:underline;font-weight:600}\n.svd-table-badge{display:inline-block;font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;margin-right:4px}\n.badge-gel{background:var(--svd-lavender);color:#3b0764}\n.badge-drink{background:#00b894;color:#fff}\n.badge-chew{background:#ff9f43;color:#fff}\n.badge-reep{background:#e17055;color:#fff}\n.badge-nzvt{background:var(--svd-lime);color:var(--svd-dark)}\n.svd-tips-grid{display:grid;grid-template-columns:1fr;gap:12px;margin:24px 0}\n.svd-tip-card{background:var(--svd-bg);border:1px solid var(--svd-border);border-radius:var(--svd-radius);padding:18px 20px;display:flex;align-items:flex-start;gap:12px}\n.svd-tip-number{flex-shrink:0;width:32px;height:32px;background:var(--svd-lime);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:800;color:var(--svd-dark)}\n.svd-tip-card p{font-size:14px;margin:0;line-height:1.6}\n.svd-faq-list{margin:24px 0 0 0}\n.svd-faq-item{border:1px solid var(--svd-border);border-radius:var(--svd-radius);margin-bottom:12px;overflow:hidden}\n.svd-faq-item details{width:100%}\n.svd-faq-item summary{padding:16px 20px;font-weight:700;font-size:15px;color:var(--svd-dark);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;background:#ffffff;transition:background 0.15s ease}\n.svd-faq-item summary:hover{background:var(--svd-bg)}\n.svd-faq-item summary::-webkit-details-marker{display:none}\n.svd-faq-item summary::after{content:'+';font-size:20px;font-weight:300;color:var(--svd-text-muted);flex-shrink:0;margin-left:12px}\n.svd-faq-item details[open] summary::after{content:'−'}\n.svd-faq-item .svd-faq-answer{padding:0 20px 18px 20px;font-size:14px;line-height:1.7;color:var(--svd-text)}\n.svd-faq-item .svd-faq-answer p{margin:0 0 10px 0}\n.svd-faq-item .svd-faq-answer p:last-child{margin:0}\n.svd-faq-item .svd-faq-answer a{color:var(--svd-dark);text-decoration:underline;font-weight:600}\n.svd-ratio-explainer{background:#ffffff;border:2px solid var(--svd-lime);border-radius:var(--svd-radius);padding:28px 32px;margin:24px 0}\n.svd-ratio-explainer h3{font-size:1.1rem;margin:0 0 12px 0}\n.svd-ratio-explainer p{font-size:14px;margin:0 0 12px 0;line-height:1.7}\n.svd-ratio-explainer p:last-child{margin:0}\n@media(min-width:600px){.svd-jump-nav ul{grid-template-columns:1fr 1fr}.svd-usp-grid{grid-template-columns:1fr 1fr}.svd-products-grid{grid-template-columns:1fr 1fr}.svd-scenario-grid{grid-template-columns:1fr 1fr 1fr}.svd-tips-grid{grid-template-columns:1fr 1fr}}\n@media(min-width:900px){.svd-hero{padding:56px 40px}.svd-hero h1{font-size:2.6rem}.svd-products-grid{grid-template-columns:repeat(2,1fr)}}\n@media(max-width:599px){.svd-compare-table{font-size:12px}.svd-compare-table th,.svd-compare-table td{padding:10px 8px}}\n</style>\n\n<div class=\"svd-ratio-page\">\n\n<!-- ═══ HERO ═══ -->\n<section class=\"svd-hero\" id=\"intro\">\n<span class=\"svd-hero-tag\">Mix & match systeem</span>\n<h1>Amacx Energy Line: de brandstof voor jouw marathon en meer</h1>\n<p>De Amacx Energy Line is jouw motor tijdens elke training en wedstrijd. Elk product levert circa 30 gram koolhydraten in een bewezen 2:1 glucose:fructose ratio. Mix en match voor een efficiënte opname tot 90 gram koolhydraten per uur.</p>\n</section>\n\n<!-- ═══ BADGES ═══ -->\n<div class=\"svd-badges\">\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-orange\"></span>2:1 glucose:fructose ratio</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>~30g koolhydraten per product</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lavender\"></span>Gels, dranken, chews & repen</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-dark\"></span>NZVT-gecertificeerd</span>\n</div>\n\n<!-- ═══ JUMP NAV ═══ -->\n<nav class=\"svd-jump-nav\" aria-label=\"Pagina navigatie\">\n<h3>Op deze pagina</h3>\n<ul>\n<li><a href=\"#waarom-energy-line\">Waarom de Energy Line? <span>De voordelen</span></a></li>\n<li><a href=\"#alle-producten\">Alle Energy Line producten <span>Gels, dranken, chews & repen</span></a></li>\n<li><a href=\"#vergelijking\">Vergelijkingstabel <span>Alle producten op een rij</span></a></li>\n<li><a href=\"#strategieen\">Voedingsstrategieën <span>3 scenario's</span></a></li>\n<li><a href=\"#tips\">Praktische tips <span>Timing & variatie</span></a></li>\n<li><a href=\"#faq\">Veelgestelde vragen <span>Over de Energy Line</span></a></li>\n</ul>\n</nav>\n\n<!-- ═══ WAAROM ENERGY LINE ═══ -->\n<section id=\"waarom-energy-line\">\n<h2><span class=\"svd-heading-line\">Waarom de Amacx Energy Line?</span></h2>\n<p>De Energy Line is ontworpen als een compleet, uitwisselbaar systeem. Elk product bevat circa 30 gram koolhydraten, waardoor je eenvoudig je inname per uur kunt berekenen en afstemmen op je inspanning.</p>\n\n<div class=\"svd-usp-grid\">\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">🔢</div>\n<div>\n<strong>Eenvoudig mix & match systeem</strong>\n<span>Elk product bevat ~30g koolhydraten. Twee producten per uur is 60g, drie is 90g. Zo simpel is het. Combineer gels, dranken, chews en repen naar wens.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">⚡</div>\n<div>\n<strong>Efficiënte 2:1 ratio</strong>\n<span>De glucose:fructose samenstelling zorgt voor een maximale opname tot 90g per uur met een minimale kans op maagklachten. Bewezen wetenschap, betrouwbare resultaten.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">💧</div>\n<div>\n<strong>Ondersteunt de vochtbalans</strong>\n<span>De producten bevatten een verhoogd natriumgehalte om de hydratatie tijdens langdurige inspanningen te ondersteunen. Energie en vocht in één systeem.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">🎯</div>\n<div>\n<strong>Ruime keuze voor afwisseling</strong>\n<span>Van drinkbare gelletjes tot zachte nougatrepen; genoeg variatie in textuur en smaak om smaakmoeheid te voorkomen, zelfs tijdens de langste wedstrijden.</span>\n</div>\n</div>\n</div>\n</section>\n\n<!-- ═══ ALLE PRODUCTEN ═══ -->\n<section id=\"alle-producten\">\n<h2><span class=\"svd-heading-line\">Alle Energy Line producten bij SportvoedingDirect</span></h2>\n<p>Van drinkbare gels en isotone sportdranken tot kauwbare fruitchews en zachte energierepen: alle producten uit de Amacx Energy Line op een rij.</p>\n\n<h3>Drink Gels – snelle, vloeibare energie</h3>\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Drinkbare gel · ~30g carbs</span>\n<h4>Amacx Drink Gel</h4>\n<p>~30g koolhydraten · 2:1 glucose:fructose · isotoon. De snelste en makkelijkste energie. Innemen zonder extra water dankzij de isotone samenstelling. Ideaal voor de cruciale momenten in een wedstrijd. Meerdere smaken beschikbaar. Vegan, NZVT-gecertificeerd.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Bekijk en bestel →</a>\n</div>\n</div>\n\n<h3>Energy Drink – basis van je bidon</h3>\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Sportdrank · ~30g carbs</span>\n<h4>Amacx Energy Drink</h4>\n<p>~30g koolhydraten per portie · 2:1 glucose:fructose · elektrolyten (natrium, kalium). De basis van je hydratatie- en energieplan. Vult niet alleen koolhydraten aan, maar ook de elektrolyten die je verliest door te zweten. Onmisbaar in je bidon. Vegan, NZVT-gecertificeerd.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-energy-drink\">Bekijk en bestel →</a>\n</div>\n</div>\n\n<h3>Fruit Chews – lekker sportsnoepje</h3>\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Kauwbaar fruit · ~30g carbs</span>\n<h4>Amacx Energy Fruit Chew</h4>\n<p>~30g koolhydraten · 2:1 glucose:fructose · op basis van echt fruit. Zachte kauwbare blokjes die niet alleen effectief zijn, maar ook een genot om te eten. De ideale mentale oppepper en afwisseling naast gels en dranken. Vegan, NZVT-gecertificeerd.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-fruit-chew\">Bekijk en bestel →</a>\n</div>\n</div>\n\n<h3>Energierepen – geleidelijke energie met een bite</h3>\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Zachte reep · ~30g carbs</span>\n<h4>Amacx Energy Nougat</h4>\n<p>~30g koolhydraten · zachte nougattextuur · makkelijk verteerbaar. Voor een meer geleidelijke energieafgifte en een lekkere bite. Perfect voor de eerste uren van een lange rit of duurloop. Vegan, NZVT-gecertificeerd.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-energy-nougat\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Snelle reep · ~30g carbs</span>\n<h4>Amacx Fast Bar</h4>\n<p>~30g koolhydraten · snel verteerbaar · compact formaat. Een snel verteerbare reep voor de perfecte afwisseling naast gels en dranken. Licht en makkelijk mee te nemen. NZVT-gecertificeerd.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/collections/energierepen?filter.p.vendor=Amacx\">Bekijk en bestel →</a>\n</div>\n</div>\n</section>\n\n<!-- ═══ VERGELIJKING ═══ -->\n<section id=\"vergelijking\">\n<h2><span class=\"svd-heading-line\">Alle Energy Line producten vergeleken</span></h2>\n<p>Vergelijk alle producten uit de Amacx Energy Line op koolhydraten, type, certificering en ideaal gebruik.</p>\n\n<div style=\"overflow-x:auto;border-radius:var(--svd-radius);border:1px solid var(--svd-border);box-shadow:var(--svd-shadow)\">\n<table class=\"svd-compare-table\">\n<thead>\n<tr><th>Product</th><th>Carbs</th><th>Type</th><th>Certificering</th><th>Ideaal voor</th></tr>\n</thead>\n<tbody>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Amacx Drink Gel</a></td><td>~30g</td><td><span class=\"svd-table-badge badge-gel\">gel</span></td><td><span class=\"svd-table-badge badge-nzvt\">NZVT</span></td><td>Snelle boost, wedstrijd</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-energy-drink\">Amacx Energy Drink</a></td><td>~30g</td><td><span class=\"svd-table-badge badge-drink\">drank</span></td><td><span class=\"svd-table-badge badge-nzvt\">NZVT</span></td><td>Basis, hydratatie + energie</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-fruit-chew\">Amacx Energy Fruit Chew</a></td><td>~30g</td><td><span class=\"svd-table-badge badge-chew\">chew</span></td><td><span class=\"svd-table-badge badge-nzvt\">NZVT</span></td><td>Afwisseling, mentale oppepper</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-energy-nougat\">Amacx Energy Nougat</a></td><td>~30g</td><td><span class=\"svd-table-badge badge-reep\">reep</span></td><td><span class=\"svd-table-badge badge-nzvt\">NZVT</span></td><td>Geleidelijke energie, lange ritten</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/collections/energierepen?filter.p.vendor=Amacx\">Amacx Fast Bar</a></td><td>~30g</td><td><span class=\"svd-table-badge badge-reep\">reep</span></td><td><span class=\"svd-table-badge badge-nzvt\">NZVT</span></td><td>Compact, snel verteerbaar</td></tr>\n</tbody>\n</table>\n</div>\n</section>\n\n<!-- ═══ STRATEGIEËN ═══ -->\n<section id=\"strategieen\">\n<h2><span class=\"svd-heading-line\">Voedingsstrategieën met de Energy Line</span></h2>\n<p>De Energy Line komt het best tot zijn recht bij inspanningen langer dan 60-90 minuten. Het eenvoudige ~30g-per-product systeem maakt je strategie overzichtelijk. Hier zijn drie bewezen aanpakken.</p>\n\n<div class=\"svd-scenario-grid\">\n<div class=\"svd-scenario-card\">\n<span class=\"svd-scenario-tag tag-basis\">Instap</span>\n<h3>60g koolhydraten per uur</h3>\n<p>Het ideale startpunt voor inspanningen van 1,5–3 uur. Twee producten per uur, eenvoudig en effectief.</p>\n<div class=\"svd-scenario-products\">\n<strong>Voorbeeld:</strong> 1x <a href=\"https://sportvoedingdirect.nl/products/amacx-energy-drink\">Energy Drink</a> (bidon) + 1x <a href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Drink Gel</a>\n</div>\n</div>\n<div class=\"svd-scenario-card scenario-allround\">\n<span class=\"svd-scenario-tag tag-wedstrijd\">Wedstrijd niveau</span>\n<h3>90g koolhydraten per uur</h3>\n<p>Voor marathons en zware wedstrijden. Drie producten per uur met variatie in textuur om smaakmoeheid te voorkomen.</p>\n<div class=\"svd-scenario-products\">\n<strong>Voorbeeld:</strong> 1x <a href=\"https://sportvoedingdirect.nl/products/amacx-energy-drink\">Energy Drink</a> (bidon) + 1x <a href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Drink Gel</a> + 1x <a href=\"https://sportvoedingdirect.nl/products/amacx-fruit-chew\">Fruit Chew</a>\n</div>\n</div>\n<div class=\"svd-scenario-card scenario-extreme\">\n<span class=\"svd-scenario-tag tag-elite\">Marathon plan</span>\n<h3>Complete marathonstrategie</h3>\n<p>Een slim plan over 4+ uur. Sportdrank als basis, gels als motor, en chews of repen als afwisseling halverwege.</p>\n<div class=\"svd-scenario-products\">\n<strong>Per uur:</strong> 1x <a href=\"https://sportvoedingdirect.nl/products/amacx-energy-drink\">Energy Drink</a> + 1x <a href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Drink Gel</a> elke 30 min + halverwege 1x <a href=\"https://sportvoedingdirect.nl/products/amacx-fruit-chew\">Fruit Chew</a> of <a href=\"https://sportvoedingdirect.nl/products/amacx-energy-nougat\">Energy Nougat</a>\n</div>\n</div>\n</div>\n</section>\n\n<!-- ═══ TIPS ═══ -->\n<section id=\"tips\">\n<h2><span class=\"svd-heading-line\">6 tips voor de Amacx Energy Line</span></h2>\n\n<div class=\"svd-tips-grid\">\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">1</div>\n<div><p><strong>Reken in producten:</strong> elk Amacx Energy product levert ~30g koolhydraten. Tel simpelweg het aantal producten per uur: 2 stuks = 60g, 3 stuks = 90g. Geen ingewikkelde berekeningen nodig.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">2</div>\n<div><p><strong>Sportdrank als basis:</strong> vul je bidons met de <a href=\"https://sportvoedingdirect.nl/products/amacx-energy-drink\">Amacx Energy Drink</a> voor een constante toevoer van vocht, elektrolyten en koolhydraten. Dit is de fundering van je energieplan.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">3</div>\n<div><p><strong>Start vroeg, doseer regelmatig:</strong> neem je eerste portie na 30-45 minuten en herhaal elke 20-30 minuten. Een constante stroom wordt beter verdragen dan grote hoeveelheden ineens.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">4</div>\n<div><p><strong>Wissel texturen af:</strong> voorkom smaakmoeheid door gels, dranken, chews en repen te combineren. De variatie in structuur en smaak houdt je fris, ook na uren inspanning.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">5</div>\n<div><p><strong>Drink Gel zonder water:</strong> de Amacx Drink Gel is isotoon en hoeft niet met water ingenomen te worden. Ideaal op momenten dat je geen bidon bij de hand hebt of snel energie nodig hebt.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">6</div>\n<div><p><strong>Test je wedstrijdplan:</strong> oefen tijdens lange duurlopen en ritten met precies de producten en hoeveelheden die je in de wedstrijd wilt gebruiken. Geen verrassingen op raceday.</p></div>\n</div>\n</div>\n</section>\n\n<!-- ═══ FAQ ═══ -->\n<section id=\"faq\">\n<h2><span class=\"svd-heading-line\">Veelgestelde vragen over de Energy Line</span></h2>\n\n<div class=\"svd-faq-list\">\n<div class=\"svd-faq-item\"><details>\n<summary>Wat betekent de 2:1 koolhydraatratio precies?</summary>\n<div class=\"svd-faq-answer\">\n<p>De 2:1 verhouding tussen glucose en fructose maakt gebruik van twee verschillende opnamesystemen in je lichaam. Glucose wordt opgenomen via het SGLT1-transporteiwit, fructose via GLUT5. Door beide routes te benutten kun je efficiënt tot 90 gram koolhydraten per uur opnemen, terwijl de kans op maag- en darmklachten aanzienlijk kleiner is dan bij enkel glucose.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Hoeveel producten heb ik nodig voor een marathon?</summary>\n<div class=\"svd-faq-answer\">\n<p>Dit hangt af van je doel, maar een goed streven is 60-90 gram koolhydraten per uur. Omdat elk Amacx Energy product ~30g koolhydraten bevat, komt dit neer op 2 tot 3 producten per uur. Voor een marathon van 4 uur heb je dus ongeveer 8-12 producten nodig, zoals <a href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Drink Gels</a> aangevuld met <a href=\"https://sportvoedingdirect.nl/products/amacx-energy-drink\">Energy Drink</a> in je bidon.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Moet ik extra water drinken bij de Amacx Drink Gel?</summary>\n<div class=\"svd-faq-answer\">\n<p>Nee, dat is het grote voordeel. De <a href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Drink Gel</a> is isotoon, wat betekent dat de concentratie deeltjes gelijk is aan die in je bloed. Hierdoor wordt de gel snel opgenomen zonder dat je extra water hoeft te drinken. Ideaal tijdens wedstrijden waar je geen bidon bij de hand hebt.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Wat is het verschil tussen de Energy Line en de Turbo Line?</summary>\n<div class=\"svd-faq-answer\">\n<p>De Energy Line gebruikt een 2:1 glucose:fructose ratio en levert ~30g koolhydraten per product, voor een opname tot 90g per uur. De <a href=\"https://sportvoedingdirect.nl/collections/sportvoeding-met-1-0-8-ratio\">Turbo Line</a> gebruikt de geavanceerde 1:0.8 ratio en levert 40g koolhydraten per product, voor een opname tot 120g per uur. De Energy Line is ideaal als instap of bij inspanningen tot 3 uur; de Turbo Line is de keuze voor maximale opname bij 3+ uur wedstrijden.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Kan ik de Energy Line producten combineren met andere merken?</summary>\n<div class=\"svd-faq-answer\">\n<p>Ja, dat kan. Zolang je de totale koolhydraatinname per uur in de gaten houdt, kun je de Amacx Energy Line combineren met producten van andere merken. Let wel op dat je bij de 2:1 ratio de maximale opname van 90g per uur niet overschrijdt. Test nieuwe combinaties altijd eerst in training.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Voor wie is de Energy Line geschikt?</summary>\n<div class=\"svd-faq-answer\">\n<p>De Energy Line is geschikt voor iedere sporter bij inspanningen langer dan 60-90 minuten: marathonlopers, wielrenners, triatleten, mountainbikers en andere duursporters. Het eenvoudige systeem maakt het toegankelijk voor zowel beginners als gevorderde atleten. Bij inspanningen korter dan 60 minuten heb je meestal genoeg aan je lichaamseigen glycogeenvoorraden.</p>\n</div>\n</details></div>\n</div>\n</section>\n\n</div>\n\n<script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"CollectionPage\",\"name\":\"Amacx Energy Line\",\"description\":\"Amacx Energy Line sportvoeding kopen bij SportvoedingDirect. Drink gels, sportdranken, fruit chews en energierepen met 2:1 glucose:fructose ratio voor maximale koolhydraatopname tot 90g per uur.\",\"url\":\"https://sportvoedingdirect.nl/collections/amacx-energy-line\",\"numberOfItems\":5,\"provider\":{\"@type\":\"Organization\",\"name\":\"SportvoedingDirect\",\"url\":\"https://sportvoedingdirect.nl\"}}</script>\n<script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Wat betekent de 2:1 koolhydraatratio precies?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"De 2:1 verhouding tussen glucose en fructose maakt gebruik van twee verschillende opnamesystemen in je lichaam. Hierdoor kun je efficiënt tot 90 gram koolhydraten per uur opnemen met een minimale kans op maagklachten.\"}},{\"@type\":\"Question\",\"name\":\"Hoeveel producten heb ik nodig voor een marathon?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Streef naar 60-90 gram koolhydraten per uur. Elk Amacx Energy product bevat ~30g, dus 2 tot 3 producten per uur. Voor een marathon van 4 uur heb je ongeveer 8-12 producten nodig.\"}},{\"@type\":\"Question\",\"name\":\"Moet ik extra water drinken bij de Amacx Drink Gel?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Nee, de Drink Gel is isotoon en wordt snel opgenomen zonder extra water.\"}},{\"@type\":\"Question\",\"name\":\"Wat is het verschil tussen de Energy Line en de Turbo Line?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"De Energy Line gebruikt een 2:1 ratio (~30g per product, tot 90g/uur). De Turbo Line gebruikt de 1:0.8 ratio (40g per product, tot 120g/uur) voor maximale opname bij zware wedstrijden.\"}},{\"@type\":\"Question\",\"name\":\"Kan ik de Energy Line producten combineren met andere merken?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Ja, zolang je de totale koolhydraatinname per uur bewaakt en niet boven de 90g per uur gaat bij de 2:1 ratio. Test nieuwe combinaties altijd eerst in training.\"}},{\"@type\":\"Question\",\"name\":\"Voor wie is de Energy Line geschikt?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Voor iedere sporter bij inspanningen langer dan 60-90 minuten: marathonlopers, wielrenners, triatleten en andere duursporters. Het eenvoudige systeem is toegankelijk voor beginners en gevorderden.\"}}]}</script>",
