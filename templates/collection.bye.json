    "custom_liquid_e6pAYg": {
      "type": "custom-liquid",
      "settings": {
        "color_scheme": "scheme-2",
        "liquid": "<style>\n    /* ==================================================\n       BYE! Nutrition Collectiepagina – SportvoedingDirect\n       Stijl: consistent met e-mail & pakbon designsysteem\n       Status: Merk niet meer verkrijgbaar, redirect naar alternatieven\n       Kleuren: lime #d9ff36, lavendel #dbb8ff, dark #1a1a1a\n    ================================================== */\n\n    :root {\n        --svd-lime: #d9ff36;\n        --svd-lime-dark: #c8f00a;\n        --svd-lavender: #dbb8ff;\n        --svd-lavender-bg: #faf5ff;\n        --svd-lavender-border: #e8ddf5;\n        --svd-dark: #1a1a1a;\n        --svd-text: #333333;\n        --svd-text-light: #666666;\n        --svd-text-muted: #888888;\n        --svd-bg: #fafafa;\n        --svd-border: #eeeeee;\n        --svd-yellow: #f0c000;\n        --svd-yellow-bg: #fffaeb;\n        --svd-radius: 12px;\n        --svd-radius-sm: 8px;\n        --svd-shadow: 0 2px 12px rgba(0,0,0,0.06);\n    }\n\n    .svd-bye-page {\n        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;\n        line-height: 1.7;\n        color: var(--svd-text);\n        padding: 0;\n        -webkit-font-smoothing: antialiased;\n    }\n\n    .svd-bye-page * {\n        box-sizing: border-box;\n    }\n\n    /* ── HERO (dark – niet meer verkrijgbaar) ── */\n    .svd-hero-dark {\n        background: var(--svd-dark);\n        padding: 48px 32px;\n        border-radius: var(--svd-radius);\n        margin-bottom: 40px;\n        position: relative;\n        overflow: hidden;\n    }\n    .svd-hero-dark::after {\n        content: 'BYE';\n        position: absolute;\n        right: -10px;\n        bottom: -25px;\n        font-size: 180px;\n        font-weight: 900;\n        color: rgba(255,255,255,0.03);\n        line-height: 1;\n        pointer-events: none;\n    }\n    .svd-hero-dark .svd-hero-tag {\n        display: inline-block;\n        background-color: var(--svd-yellow);\n        color: var(--svd-dark);\n        font-size: 11px;\n        font-weight: 700;\n        text-transform: uppercase;\n        letter-spacing: 0.08em;\n        padding: 5px 12px;\n        border-radius: 6px;\n        margin-bottom: 16px;\n    }\n    .svd-hero-dark h1 {\n        font-size: 2.2rem;\n        font-weight: 800;\n        color: #ffffff;\n        margin: 0 0 14px 0;\n        line-height: 1.2;\n        max-width: 600px;\n    }\n    .svd-hero-dark p {\n        font-size: 16px;\n        color: rgba(255,255,255,0.7);\n        margin: 0;\n        max-width: 560px;\n        line-height: 1.65;\n    }\n\n    /* ── SECTION SPACING ── */\n    .svd-bye-page section {\n        margin-bottom: 48px;\n    }\n\n    /* ── HEADINGS ── */\n    .svd-bye-page h2 {\n        font-size: 1.6rem;\n        font-weight: 800;\n        color: var(--svd-dark);\n        margin: 0 0 20px 0;\n        line-height: 1.25;\n    }\n    .svd-heading-line {\n        display: inline-block;\n        padding-bottom: 10px;\n        border-bottom: 3px solid var(--svd-lime);\n    }\n    .svd-bye-page h3 {\n        font-size: 1.15rem;\n        font-weight: 700;\n        color: var(--svd-dark);\n        margin: 0 0 10px 0;\n        line-height: 1.3;\n    }\n    .svd-bye-page p {\n        margin: 0 0 16px 0;\n    }\n    .svd-bye-page a {\n        color: var(--svd-dark);\n        text-decoration: underline;\n        font-weight: 600;\n    }\n\n    /* ── JUMP NAV ── */\n    .svd-jump-nav {\n        background: var(--svd-bg);\n        border: 1px solid var(--svd-border);\n        border-left: 4px solid var(--svd-lime);\n        border-radius: var(--svd-radius);\n        padding: 20px 24px;\n        margin-bottom: 40px;\n    }\n    .svd-jump-nav h3 {\n        margin: 0 0 12px 0;\n        font-size: 14px;\n        text-transform: uppercase;\n        letter-spacing: 0.04em;\n        color: var(--svd-text-muted);\n    }\n    .svd-jump-nav ul {\n        list-style: none;\n        padding: 0;\n        margin: 0;\n        display: grid;\n        grid-template-columns: 1fr;\n        gap: 8px;\n    }\n    .svd-jump-nav a {\n        display: block;\n        padding: 10px 14px;\n        background: #ffffff;\n        border: 1px solid var(--svd-border);\n        border-radius: var(--svd-radius-sm);\n        color: var(--svd-dark);\n        text-decoration: none;\n        font-weight: 600;\n        font-size: 14px;\n        transition: all 0.15s ease;\n    }\n    .svd-jump-nav a:hover {\n        background: var(--svd-lime);\n        border-color: var(--svd-lime-dark);\n    }\n    .svd-jump-nav a span {\n        color: var(--svd-text-muted);\n        font-weight: 400;\n        margin-left: 4px;\n    }\n\n    /* ── NOTICE BANNER ── */\n    .svd-notice-banner {\n        background: var(--svd-yellow-bg);\n        border: 1px solid #f5e6b8;\n        border-left: 4px solid var(--svd-yellow);\n        border-radius: var(--svd-radius);\n        padding: 20px 24px;\n        margin-bottom: 40px;\n        display: flex;\n        align-items: flex-start;\n        gap: 14px;\n    }\n    .svd-notice-icon {\n        flex-shrink: 0;\n        width: 36px;\n        height: 36px;\n        background: var(--svd-yellow);\n        border-radius: 8px;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        font-size: 16px;\n    }\n    .svd-notice-banner strong {\n        display: block;\n        font-size: 14px;\n        font-weight: 700;\n        color: #4a3d00;\n        margin-bottom: 4px;\n    }\n    .svd-notice-banner span {\n        font-size: 13px;\n        color: #665500;\n        line-height: 1.6;\n    }\n\n    /* ── ALTERNATIEVEN GRID ── */\n    .svd-alt-grid {\n        display: grid;\n        grid-template-columns: 1fr;\n        gap: 16px;\n        margin: 24px 0;\n    }\n    .svd-alt-card {\n        background: #ffffff;\n        border: 1px solid var(--svd-border);\n        border-radius: var(--svd-radius);\n        padding: 24px 28px;\n        box-shadow: var(--svd-shadow);\n        border-top: 4px solid var(--svd-lime);\n    }\n    .svd-alt-card.lavender {\n        border-top-color: var(--svd-lavender);\n    }\n    .svd-alt-card .svd-alt-tag {\n        display: inline-block;\n        font-size: 10px;\n        font-weight: 700;\n        text-transform: uppercase;\n        letter-spacing: 0.06em;\n        padding: 3px 8px;\n        border-radius: 4px;\n        margin-bottom: 10px;\n    }\n    .svd-alt-card .tag-aanbevolen {\n        background: var(--svd-lime);\n        color: var(--svd-dark);\n    }\n    .svd-alt-card .tag-specialist {\n        background: var(--svd-lavender);\n        color: #3b0764;\n    }\n    .svd-alt-card h4 {\n        font-size: 1.1rem;\n        font-weight: 700;\n        color: var(--svd-dark);\n        margin: 0 0 8px 0;\n        line-height: 1.3;\n    }\n    .svd-alt-card p {\n        font-size: 14px;\n        color: var(--svd-text);\n        margin: 0 0 14px 0;\n        line-height: 1.6;\n    }\n    .svd-alt-card a.svd-alt-link {\n        display: inline-block;\n        font-size: 13px;\n        font-weight: 700;\n        text-decoration: none;\n        padding: 10px 20px;\n        border-radius: var(--svd-radius-sm);\n        transition: all 0.15s ease;\n    }\n    .svd-alt-card a.svd-alt-link.lime {\n        background: var(--svd-lime);\n        color: var(--svd-dark);\n    }\n    .svd-alt-card a.svd-alt-link.lime:hover {\n        background: var(--svd-lime-dark);\n    }\n    .svd-alt-card a.svd-alt-link.lavender {\n        background: var(--svd-lavender);\n        color: #3b0764;\n    }\n    .svd-alt-card a.svd-alt-link.lavender:hover {\n        background: #cda0ff;\n    }\n\n    /* ── VERGELIJKINGSTABEL ── */\n    .svd-compare-table-wrap {\n        overflow-x: auto;\n        border: 1px solid var(--svd-border);\n        border-radius: var(--svd-radius);\n        box-shadow: var(--svd-shadow);\n        margin: 24px 0;\n    }\n    .svd-compare-table {\n        width: 100%;\n        border-collapse: collapse;\n        font-size: 14px;\n    }\n    .svd-compare-table thead {\n        background: var(--svd-dark);\n        color: #ffffff;\n    }\n    .svd-compare-table th {\n        padding: 14px 18px;\n        font-size: 11px;\n        font-weight: 700;\n        text-transform: uppercase;\n        letter-spacing: 0.06em;\n        text-align: left;\n    }\n    .svd-compare-table td {\n        padding: 14px 18px;\n        border-bottom: 1px solid var(--svd-border);\n        vertical-align: top;\n        line-height: 1.55;\n    }\n    .svd-compare-table tbody tr:last-child td {\n        border-bottom: none;\n    }\n    .svd-compare-table tbody tr:nth-child(even) {\n        background: var(--svd-bg);\n    }\n    .svd-compare-table .bye-product {\n        font-weight: 700;\n        color: var(--svd-text-muted);\n    }\n    .svd-compare-table .alt-product {\n        color: var(--svd-text);\n    }\n    .svd-compare-table .alt-product a {\n        font-weight: 700;\n        color: var(--svd-dark);\n    }\n    .svd-compare-arrow {\n        display: inline-block;\n        background: var(--svd-lime);\n        color: var(--svd-dark);\n        font-size: 10px;\n        font-weight: 700;\n        padding: 2px 8px;\n        border-radius: 4px;\n        margin-right: 6px;\n    }\n\n    /* ── OVER BYE SECTIE ── */\n    .svd-about-block {\n        background: var(--svd-bg);\n        border: 1px solid var(--svd-border);\n        border-radius: var(--svd-radius);\n        padding: 24px 28px;\n        margin: 24px 0;\n    }\n    .svd-about-block h3 {\n        margin: 0 0 8px 0;\n    }\n    .svd-about-block p {\n        font-size: 14px;\n        line-height: 1.7;\n        margin: 0 0 12px 0;\n    }\n    .svd-about-block p:last-child {\n        margin-bottom: 0;\n    }\n\n    /* ── BADGES ── */\n    .svd-badges {\n        display: flex;\n        flex-wrap: wrap;\n        gap: 8px;\n        margin: 16px 0 24px 0;\n    }\n    .svd-badge {\n        display: inline-flex;\n        align-items: center;\n        gap: 6px;\n        padding: 6px 14px;\n        border-radius: 20px;\n        font-size: 12px;\n        font-weight: 600;\n        border: 1px solid var(--svd-border);\n        background: #ffffff;\n        color: var(--svd-text);\n    }\n    .svd-badge-dot {\n        width: 8px;\n        height: 8px;\n        border-radius: 50%;\n        flex-shrink: 0;\n    }\n    .dot-lime { background: var(--svd-lime); }\n    .dot-lavender { background: var(--svd-lavender); }\n    .dot-dark { background: var(--svd-dark); }\n    .dot-muted { background: #cccccc; }\n\n    /* ── FAQ ── */\n    .svd-faq-list {\n        margin: 24px 0 0 0;\n    }\n    .svd-faq-item {\n        border: 1px solid var(--svd-border);\n        border-radius: var(--svd-radius);\n        margin-bottom: 12px;\n        overflow: hidden;\n    }\n    .svd-faq-item details {\n        width: 100%;\n    }\n    .svd-faq-item summary {\n        padding: 16px 20px;\n        font-weight: 700;\n        font-size: 15px;\n        color: var(--svd-dark);\n        cursor: pointer;\n        list-style: none;\n        display: flex;\n        justify-content: space-between;\n        align-items: center;\n        background: #ffffff;\n        transition: background 0.15s ease;\n    }\n    .svd-faq-item summary:hover {\n        background: var(--svd-bg);\n    }\n    .svd-faq-item summary::-webkit-details-marker {\n        display: none;\n    }\n    .svd-faq-item summary::after {\n        content: '+';\n        font-size: 20px;\n        font-weight: 300;\n        color: var(--svd-text-muted);\n        flex-shrink: 0;\n        margin-left: 12px;\n    }\n    .svd-faq-item details[open] summary::after {\n        content: '−';\n    }\n    .svd-faq-item .svd-faq-answer {\n        padding: 0 20px 18px 20px;\n        font-size: 14px;\n        line-height: 1.7;\n        color: var(--svd-text);\n    }\n    .svd-faq-item .svd-faq-answer p {\n        margin: 0;\n    }\n\n    /* ── RESPONSIVE ── */\n    @media (min-width: 600px) {\n        .svd-jump-nav ul { grid-template-columns: 1fr 1fr; }\n        .svd-alt-grid { grid-template-columns: 1fr 1fr; }\n    }\n    @media (min-width: 900px) {\n        .svd-hero-dark { padding: 56px 40px; }\n        .svd-hero-dark h1 { font-size: 2.6rem; }\n    }\n</style>\n\n<div class=\"svd-bye-page\">\n\n    <!-- ═══ HERO (dark – niet meer verkrijgbaar) ═══ -->\n    <section class=\"svd-hero-dark\" id=\"intro\">\n        <span class=\"svd-hero-tag\">Niet meer verkrijgbaar</span>\n        <h1>BYE! Nutrition sportvoeding: vind het beste alternatief</h1>\n        <p>BYE! Nutrition (Boost Your Energy) stond bekend om 100% natuurlijke sportvoeding voor duursporters. Wij verkopen dit merk niet meer, maar helpen je graag met een gelijkwaardig of beter alternatief uit ons huidige assortiment.</p>\n    </section>\n\n    <!-- ═══ NOTICE ═══ -->\n    <div class=\"svd-notice-banner\">\n        <div class=\"svd-notice-icon\">⚠️</div>\n        <div>\n            <strong>BYE! Nutrition is niet meer beschikbaar bij SportvoedingDirect</strong>\n            <span>De producten staan nog op onze site als referentie. Bestellen is niet meer mogelijk. Hieronder vind je voor elk BYE! product een uitstekend alternatief van <a href=\"https://sportvoedingdirect.nl/collections/amacx\">Amacx</a> of <a href=\"https://sportvoedingdirect.nl/collections/precision\">Precision Fuel & Hydration</a>.</span>\n        </div>\n    </div>\n\n    <!-- ═══ JUMP NAV ═══ -->\n    <nav class=\"svd-jump-nav\" aria-label=\"Pagina navigatie\">\n        <h3>Op deze pagina</h3>\n        <ul>\n            <li><a href=\"#alternatieven\">Aanbevolen alternatieven <span>Amacx & Precision</span></a></li>\n            <li><a href=\"#vergelijking\">Productvergelijking <span>BYE! → alternatief</span></a></li>\n            <li><a href=\"#over-bye\">Over BYE! Nutrition <span>Het merk</span></a></li>\n            <li><a href=\"#faq\">Veelgestelde vragen <span>Over de overstap</span></a></li>\n        </ul>\n    </nav>\n\n    <!-- ═══ ALTERNATIEVEN ═══ -->\n    <section id=\"alternatieven\">\n        <h2><span class=\"svd-heading-line\">Aanbevolen alternatieven voor BYE! Nutrition</span></h2>\n        <p>Twee merken die dezelfde hoge standaard bieden als BYE!, met nog meer wetenschappelijke onderbouwing en dopingcertificering:</p>\n\n        <div class=\"svd-alt-grid\">\n            <div class=\"svd-alt-card\">\n                <span class=\"svd-alt-tag tag-aanbevolen\">Aanbevolen alternatief</span>\n                <h4>Amacx: de complete allrounder</h4>\n                <p>Nederlands merk, NZVT gekeurd en officieel voedingspartner van Team Visma | Lease a Bike. Biedt een compleet systeem met de bewezen 2:1 en geavanceerde 1:0.8 koolhydraatverhouding. Breed assortiment van gels, repen, dranken en supplementen. De beste 1-op-1 vervanging voor vrijwel elk BYE! product.</p>\n                <a class=\"svd-alt-link lime\" href=\"https://sportvoedingdirect.nl/collections/amacx\">Bekijk alle Amacx sportvoeding →</a>\n            </div>\n            <div class=\"svd-alt-card lavender\">\n                <span class=\"svd-alt-tag tag-specialist\">Specialist hydratatie</span>\n                <h4>Precision Fuel & Hydration: de specialist</h4>\n                <p>Brits merk, Informed Sport gecertificeerd. Unieke aanpak: scheidt brandstof (koolhydraten) en hydratatie (elektrolyten) volledig van elkaar. Ideaal als je je voedingsstrategie wilt personaliseren en de volledige controle wilt over je koolhydraat- en natriumintake.</p>\n                <a class=\"svd-alt-link lavender\" href=\"https://sportvoedingdirect.nl/collections/precision\">Bekijk alle Precision sportvoeding →</a>\n            </div>\n        </div>\n    </section>\n\n    <!-- ═══ VERGELIJKINGSTABEL ═══ -->\n    <section id=\"vergelijking\">\n        <h2><span class=\"svd-heading-line\">Productvergelijking: vind je nieuwe favoriet</span></h2>\n        <p>Gebruikte je altijd een specifiek product van BYE!? Hieronder vind je het beste alternatief uit ons huidige assortiment.</p>\n\n        <div class=\"svd-compare-table-wrap\">\n            <table class=\"svd-compare-table\">\n                <thead>\n                    <tr>\n                        <th>Je BYE! product</th>\n                        <th>Ons alternatief</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    <tr>\n                        <td class=\"bye-product\">BYE! 40 Carbs Fruit Gel<br><span style=\"font-weight:400;font-size:12px;color:#aaa;\">40 g koolhydraten, fruitbasis</span></td>\n                        <td class=\"alt-product\"><span class=\"svd-compare-arrow\">→</span><a href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-gel\">Amacx Turbo Gel</a><br>40 g koolhydraten in de 1:0.8 verhouding. Drinkbare gel, dezelfde hoeveelheid koolhydraten per portie.</td>\n                    </tr>\n                    <tr>\n                        <td class=\"bye-product\">BYE! Pro Fruit Gel<br><span style=\"font-weight:400;font-size:12px;color:#aaa;\">30 g koolhydraten, smoothietextuur</span></td>\n                        <td class=\"alt-product\"><span class=\"svd-compare-arrow\">→</span><a href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Amacx Drink Gel</a><br>30 g koolhydraten in een drinkbare, isotone formule (2:1 ratio). Mild van smaak en licht verteerbaar.</td>\n                    </tr>\n                    <tr>\n                        <td class=\"bye-product\">BYE! Pro Isotonic Gel<br><span style=\"font-weight:400;font-size:12px;color:#aaa;\">Met cafeïne en aminozuren</span></td>\n                        <td class=\"alt-product\"><span class=\"svd-compare-arrow\">→</span><a href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Amacx Drink Gel</a> + <a href=\"https://sportvoedingdirect.nl/products/amacx-cafeine-tabletten\">Caffeine Tabs</a><br>Combineer de Drink Gel met losse Caffeine Tabs voor dezelfde functie als de Pro-formule.</td>\n                    </tr>\n                    <tr>\n                        <td class=\"bye-product\">BYE! Isotone Sportdrank<br><span style=\"font-weight:400;font-size:12px;color:#aaa;\">Isotone drank, natuurlijke smaken</span></td>\n                        <td class=\"alt-product\"><span class=\"svd-compare-arrow\">→</span><a href=\"https://sportvoedingdirect.nl/products/amacx-energy-drink\">Amacx Energy Drink</a><br>Isotone sportdrank met 30 g koolhydraten (2:1 ratio) en elektrolyten. Fris en niet te zoet.</td>\n                    </tr>\n                    <tr>\n                        <td class=\"bye-product\">BYE! Endurance Bar<br><span style=\"font-weight:400;font-size:12px;color:#aaa;\">Havermout, ~25 g koolhydraten</span></td>\n                        <td class=\"alt-product\"><span class=\"svd-compare-arrow\">→</span><a href=\"https://sportvoedingdirect.nl/products/amacx-energy-oat-bar\">Amacx Energy Oat Bar</a><br>Dezelfde filosofie: echte havervlokken als basis voor langzame, stabiele energie.</td>\n                    </tr>\n                    <tr>\n                        <td class=\"bye-product\">BYE! All-in-One Recovery<br><span style=\"font-weight:400;font-size:12px;color:#aaa;\">Eiwitten + koolhydraten, stevia</span></td>\n                        <td class=\"alt-product\"><span class=\"svd-compare-arrow\">→</span><a href=\"https://sportvoedingdirect.nl/products/amacx-recovery-shake\">Amacx Recovery Shake</a><br>Ideale mix van eiwitten en koolhydraten voor snel herstel na zware inspanningen.</td>\n                    </tr>\n                    <tr>\n                        <td class=\"bye-product\">BYE! Magnesium Electrolyte Shot<br><span style=\"font-weight:400;font-size:12px;color:#aaa;\">Magnesiumcitraat ampul</span></td>\n                        <td class=\"alt-product\"><span class=\"svd-compare-arrow\">→</span><a href=\"https://sportvoedingdirect.nl/collections/precision\">Precision Fuel & Hydration</a><br>Precision biedt gespecialiseerde elektrolytproducten met hoog natriumgehalte voor optimale hydratatie.</td>\n                    </tr>\n                </tbody>\n            </table>\n        </div>\n    </section>\n\n    <!-- ═══ OVER BYE ═══ -->\n    <section id=\"over-bye\">\n        <h2><span class=\"svd-heading-line\">Over BYE! Nutrition</span></h2>\n\n        <div class=\"svd-badges\">\n            <span class=\"svd-badge\"><span class=\"svd-badge-dot dot-muted\"></span>Niet meer verkrijgbaar</span>\n            <span class=\"svd-badge\"><span class=\"svd-badge-dot dot-dark\"></span>Nederlands merk (Arnhem)</span>\n            <span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>100% natuurlijke basis</span>\n            <span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lavender\"></span>Opgericht door voormalig profwielrenner</span>\n        </div>\n\n        <div class=\"svd-about-block\">\n            <h3>Boost Your Energy</h3>\n            <p>BYE! Nutrition (voluit: Boost Your Energy) was een Nederlands sportvoedingsmerk uit Arnhem, opgericht door een voormalig professioneel wielrenner. Het merk onderscheidde zich door sportvoeding te ontwikkelen op een 100% natuurlijke basis, zonder kunstmatige kleur-, smaak- of conserveringsmiddelen.</p>\n            <p>De filosofie was eenvoudig: de ingrediënten komen van akkers, velden en boomgaarden, niet uit laboratoria. Het assortiment bestond uit energy gels (waaronder de populaire 40 Carbs Fruit Gel), de Endurance Bar op basis van havermout met echt fruit, isotone sportdranken, een hersteldrank (All-in-One Recovery) en supplementen zoals magnesium shots en cafeïne ampullen.</p>\n            <p>BYE! was actief sinds 2015 en werd vanaf 2016 ook beschikbaar voor de breedtesporter. Het merk werkte samen met onder andere de Ironman-organisatie en was een favoriet bij wielrenners, hardlopers en triatleten die waarde hechtten aan natuurlijke ingrediënten.</p>\n        </div>\n    </section>\n\n    <!-- ═══ FAQ ═══ -->\n    <section id=\"faq\">\n        <h2><span class=\"svd-heading-line\">Veelgestelde vragen over BYE! Nutrition</span></h2>\n\n        <div class=\"svd-faq-list\">\n            <div class=\"svd-faq-item\">\n                <details>\n                    <summary>Waarom verkopen jullie geen BYE! sportvoeding meer?</summary>\n                    <div class=\"svd-faq-answer\">\n                        <p>Om ons assortiment zo sterk en innovatief mogelijk te houden, maken we bewuste keuzes in de merken die we voeren. Met Amacx en Precision Fuel & Hydration hebben we twee merken in huis die voor elk BYE! product een gelijkwaardig of beter alternatief bieden, met aanvullende voordelen zoals NZVT- en Informed Sport certificering.</p>\n                    </div>\n                </details>\n            </div>\n            <div class=\"svd-faq-item\">\n                <details>\n                    <summary>Ik gebruikte altijd de BYE! 40 Carbs Fruit Gel. Wat is nu de beste keuze?</summary>\n                    <div class=\"svd-faq-answer\">\n                        <p>De <a href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-gel\">Amacx Turbo Gel</a> is het beste alternatief. Deze bevat ook 40 g koolhydraten per gel, maar dan in de geavanceerde 1:0.8 glucose/fructose verhouding voor een nog betere opname. Bovendien is het een drinkbare gel die je zonder water kunt innemen.</p>\n                    </div>\n                </details>\n            </div>\n            <div class=\"svd-faq-item\">\n                <details>\n                    <summary>Is de BYE! Endurance Bar vergelijkbaar met een Amacx reep?</summary>\n                    <div class=\"svd-faq-answer\">\n                        <p>Ja. De <a href=\"https://sportvoedingdirect.nl/products/amacx-energy-oat-bar\">Amacx Energy Oat Bar</a> deelt dezelfde filosofie: echte havervlokken als basis voor langzame, stabiele energie. De textuur is vergelijkbaar zacht en makkelijk te eten, ook bij hoge inspanning.</p>\n                    </div>\n                </details>\n            </div>\n            <div class=\"svd-faq-item\">\n                <details>\n                    <summary>Wat is het verschil tussen Amacx en Precision als alternatief?</summary>\n                    <div class=\"svd-faq-answer\">\n                        <p>Amacx biedt een compleet systeem met gels, repen, dranken en supplementen in één merk. Precision Fuel & Hydration is gespecialiseerd in het scheiden van brandstof (koolhydraten) en hydratatie (elektrolyten), wat je meer controle geeft over je voedingsstrategie. Beide merken zijn onafhankelijk getest op dopinggeduide stoffen.</p>\n                    </div>\n                </details>\n            </div>\n            <div class=\"svd-faq-item\">\n                <details>\n                    <summary>Zijn Amacx en Precision ook dopingvrij getest?</summary>\n                    <div class=\"svd-faq-answer\">\n                        <p>Ja. Alle Amacx producten zijn NZVT gekeurd (Nederlands Zekerheidssysteem Voedingssupplementen Topsport) en Precision producten zijn Informed Sport gecertificeerd. Beide systemen testen per batch op de afwezigheid van verboden stoffen conform de WADA-lijst.</p>\n                    </div>\n                </details>\n            </div>\n            <div class=\"svd-faq-item\">\n                <details>\n                    <summary>Kan ik nog BYE! producten bestellen op deze site?</summary>\n                    <div class=\"svd-faq-answer\">\n                        <p>Nee, bestellen is niet meer mogelijk. De productpagina's staan nog online als referentie, maar er is geen voorraad meer beschikbaar. Gebruik de vergelijkingstabel hierboven om snel het juiste alternatief te vinden.</p>\n                    </div>\n                </details>\n            </div>\n        </div>\n    </section>\n\n</div>\n\n<!-- ═══ STRUCTURED DATA ═══ -->\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n