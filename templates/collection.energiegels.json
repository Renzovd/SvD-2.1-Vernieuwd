hadow:0 4px 20px rgba(0,0,0,0.1)}\n.svd-product-card-rank{display:inline-block;background:var(--svd-lavender);color:#3b0764;font-size:11px;font-weight:800;padding:3px 10px;border-radius:4px;margin-bottom:10px;text-transform:uppercase;letter-spacing:0.06em}\n.svd-product-card h4{font-size:1.05rem;font-weight:700;color:var(--svd-dark);margin:0 0 8px 0;line-height:1.3}\n.svd-product-card p{font-size:14px;color:var(--svd-text);margin:0 0 12px 0;line-height:1.6}\n.svd-product-card a.svd-card-link{display:inline-block;font-size:13px;font-weight:700;color:#3b0764;text-decoration:none;padding:8px 16px;background:var(--svd-lavender);border-radius:var(--svd-radius-sm);transition:background 0.15s ease}\n.svd-product-card a.svd-card-link:hover{background:#cda0ff}\n.svd-scenario-grid{display:grid;grid-template-columns:1fr;gap:16px;margin:24px 0}\n.svd-scenario-card{background:#ffffff;border:1px solid var(--svd-border);border-radius:var(--svd-radius);padding:24px 28px;border-top:4px solid var(--svd-lime)}\n.svd-scenario-card.scenario-allround{border-top-color:var(--svd-lavender)}\n.svd-scenario-card.scenario-extreme{border-top-color:var(--svd-dark)}\n.svd-scenario-card .svd-scenario-tag{display:inline-block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;padding:3px 8px;border-radius:4px;margin-bottom:12px}\n.svd-scenario-card .tag-basis{background:var(--svd-lime);color:var(--svd-dark)}\n.svd-scenario-card .tag-wedstrijd{background:var(--svd-lavender);color:#3b0764}\n.svd-scenario-card .tag-elite{background:var(--svd-dark);color:#ffffff}\n.svd-scenario-card h3{margin:0 0 8px 0;font-size:1.05rem}\n.svd-scenario-card p{font-size:14px;color:var(--svd-text);margin:0 0 10px 0;line-height:1.6}\n.svd-scenario-card a{color:var(--svd-dark);text-decoration:underline;font-weight:600}\n.svd-scenario-card .svd-scenario-products{background:var(--svd-bg);border-radius:var(--svd-radius-sm);padding:12px 14px;margin-top:12px;font-size:13px;color:var(--svd-text-light)}\n.svd-scenario-card .svd-scenario-products strong{color:var(--svd-dark)}\n.svd-compare-table{width:100%;border-collapse:collapse;margin:24px 0;font-size:13px}\n.svd-compare-table th{background:var(--svd-dark);color:#ffffff;font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:0.04em;padding:12px 14px;text-align:left}\n.svd-compare-table td{padding:12px 14px;border-bottom:1px solid var(--svd-border);vertical-align:top}\n.svd-compare-table tr:nth-child(even) td{background:var(--svd-bg)}\n.svd-compare-table a{color:var(--svd-dark);text-decoration:underline;font-weight:600}\n.svd-table-badge{display:inline-block;font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;margin-right:4px}\n.badge-isotoon{background:var(--svd-lime);color:var(--svd-dark)}\n.badge-hydrogel{background:var(--svd-lavender);color:#3b0764}\n.badge-highcarb{background:#ff9f43;color:#fff}\n.badge-cafeine{background:#e74c3c;color:#fff}\n.badge-cyclodex{background:#00b894;color:#fff}\n.badge-natuur{background:#55efc4;color:var(--svd-dark)}\n.svd-brand-grid{display:grid;grid-template-columns:1fr;gap:12px;margin:24px 0}\n.svd-brand-card{background:#ffffff;border:1px solid var(--svd-border);border-radius:var(--svd-radius);padding:20px 22px}\n.svd-brand-card h4{font-size:1rem;font-weight:700;color:var(--svd-dark);margin:0 0 6px 0}\n.svd-brand-card h4 a{color:var(--svd-dark);text-decoration:underline}\n.svd-brand-card p{font-size:13px;color:var(--svd-text-light);margin:0;line-height:1.6}\n.svd-tips-grid{display:grid;grid-template-columns:1fr;gap:12px;margin:24px 0}\n.svd-tip-card{background:var(--svd-bg);border:1px solid var(--svd-border);border-radius:var(--svd-radius);padding:18px 20px;display:flex;align-items:flex-start;gap:12px}\n.svd-tip-number{flex-shrink:0;width:32px;height:32px;background:var(--svd-lime);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:800;color:var(--svd-dark)}\n.svd-tip-card p{font-size:14px;margin:0;line-height:1.6}\n.svd-faq-list{margin:24px 0 0 0}\n.svd-faq-item{border:1px solid var(--svd-border);border-radius:var(--svd-radius);margin-bottom:12px;overflow:hidden}\n.svd-faq-item details{width:100%}\n.svd-faq-item summary{padding:16px 20px;font-weight:700;font-size:15px;color:var(--svd-dark);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;background:#ffffff;transition:background 0.15s ease}\n.svd-faq-item summary:hover{background:var(--svd-bg)}\n.svd-faq-item summary::-webkit-details-marker{display:none}\n.svd-faq-item summary::after{content:'+';font-size:20px;font-weight:300;color:var(--svd-text-muted);flex-shrink:0;margin-left:12px}\n.svd-faq-item details[open] summary::after{content:'−'}\n.svd-faq-item .svd-faq-answer{padding:0 20px 18px 20px;font-size:14px;line-height:1.7;color:var(--svd-text)}\n.svd-faq-item .svd-faq-answer p{margin:0 0 10px 0}\n.svd-faq-item .svd-faq-answer p:last-child{margin:0}\n.svd-faq-item .svd-faq-answer a{color:var(--svd-dark);text-decoration:underline;font-weight:600}\n@media(min-width:600px){.svd-jump-nav ul{grid-template-columns:1fr 1fr}.svd-usp-grid{grid-template-columns:1fr 1fr}.svd-products-grid{grid-template-columns:1fr 1fr}.svd-scenario-grid{grid-template-columns:1fr 1fr 1fr}.svd-tips-grid{grid-template-columns:1fr 1fr}.svd-brand-grid{grid-template-columns:1fr 1fr 1fr}}\n@media(min-width:900px){.svd-hero{padding:56px 40px}.svd-hero h1{font-size:2.6rem}.svd-products-grid{grid-template-columns:repeat(3,1fr)}.svd-brand-grid{grid-template-columns:repeat(5,1fr)}}\n@media(max-width:599px){.svd-compare-table{font-size:12px}.svd-compare-table th,.svd-compare-table td{padding:10px 8px}}\n</style>\n\n<div class=\"svd-energiegels-page\">\n\n<!-- ═══ HERO ═══ -->\n<section class=\"svd-hero\" id=\"intro\">\n<span class=\"svd-hero-tag\">Directe brandstof</span>\n<h1>Energiegels: compacte energie voor training en wedstrijd</h1>\n<p>Van isotone drinkgels tot hydrogels en high-carb formules: ontdek de gel die past bij jouw sport, intensiteit en maag. 17 gels van 5 topmerken, wetenschappelijk onderbouwd en getest door profs.</p>\n</section>\n\n<!-- ═══ BADGES ═══ -->\n<div class=\"svd-badges\">\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>17 energiegels van 5 merken</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lavender\"></span>Hydrogel, cyclodextrine & isotone technologie</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-dark\"></span>NZVT · Informed Sport · Cologne List®</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>22 tot 300 gram koolhydraten per portie</span>\n</div>\n\n<!-- ═══ JUMP NAV ═══ -->\n<nav class=\"svd-jump-nav\" aria-label=\"Pagina navigatie\">\n<h3>Op deze pagina</h3>\n<ul>\n<li><a href=\"#soorten-gels\">3 soorten energiegels <span>Isotoon, high-carb & hydrogel</span></a></li>\n<li><a href=\"#top-producten\">Alle producten <span>Per merk</span></a></li>\n<li><a href=\"#kies-strategie\">Kies jouw strategie <span>3 scenario's</span></a></li>\n<li><a href=\"#vergelijking\">Vergelijkingstabel <span>17 gels op een rij</span></a></li>\n<li><a href=\"#merken\">Merkfilosofieen <span>5 merken</span></a></li>\n<li><a href=\"#tips\">Praktische tips <span>Timing & dosering</span></a></li>\n<li><a href=\"#faq\">Veelgestelde vragen <span>Over energiegels</span></a></li>\n</ul>\n</nav>\n\n<!-- ═══ SOORTEN GELS ═══ -->\n<section id=\"soorten-gels\">\n<h2><span class=\"svd-heading-line\">3 soorten energiegels</span></h2>\n<p>Niet elke gel is hetzelfde. Het type gel bepaalt hoeveel koolhydraten je binnenkrijgt, of je er water bij moet drinken en hoe snel de energie beschikbaar is. Wij onderscheiden drie hoofdtypen.</p>\n\n<div class=\"svd-usp-grid\">\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">💧</div>\n<div>\n<strong>Isotone drinkgels</strong>\n<span>Vloeibare gels met dezelfde deeltjesconcentratie als je lichaamsvocht. Worden razendsnel opgenomen zonder extra water. Ideaal voor hardlopers zonder bidon.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">⚡</div>\n<div>\n<strong>High-carb concentraatgels</strong>\n<span>Dikkere gels met 40-55g koolhydraten per portie. Leveren maximale energie uit een kleine verpakking. Vereisen altijd water erbij voor goede opname.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">🔬</div>\n<div>\n<strong>Hydrogels (Maurten)</strong>\n<span>Koolhydraten ingekapseld in een gel-matrix van alginaat en pectine. Soepel transport door de maag voor minimale maaglast bij hoge innames. Geen water nodig.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">☕</div>\n<div>\n<strong>Met cafeïne</strong>\n<span>Veel gels zijn verkrijgbaar met 53-100 mg cafeïne voor extra focus en verminderd vermoeidheidsgevoel. Strategisch inzetten in de tweede helft van je wedstrijd.</span>\n</div>\n</div>\n</div>\n</section>\n\n<!-- ═══ TOP PRODUCTEN ═══ -->\n<section id=\"top-producten\">\n<h2><span class=\"svd-heading-line\">Alle energiegels bij SportvoedingDirect</span></h2>\n\n<h3>Maurten – hydrogel-technologie</h3>\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">#1 Favoriet marathonlopers</span>\n<h4>Maurten Gel 100</h4>\n<p>25g koolhydraten · 85 mg natrium · 0.8:1 fructose:glucose ratio. Dé referentie onder energiegels. Hydrogel-technologie voor minimale maaglast. 6 natuurlijke ingredienten, vegan.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/maurten-gel-100\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">#2 Cafeïne + hydrogel</span>\n<h4>Maurten Gel 100 CAF 100</h4>\n<p>25g koolhydraten · 100 mg cafeïne · 85 mg natrium. Identiek aan de Gel 100, verrijkt met cafeïne. Hydrogel maskeert bittere smaak. Ideaal in finale van je wedstrijd.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/maurten-gel-100-caf-100\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">#3 High-carb hydrogel</span>\n<h4>Maurten Gel 160</h4>\n<p>40g koolhydraten in hydrogel. Grote broer van de Gel 100, voor sporters die maximale energie willen met minimale verpakkingen. Dezelfde maagvriendelijke technologie.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/maurten-gel-160\">Bekijk en bestel →</a>\n</div>\n</div>\n\n<h3>Amacx – Team Visma | Lease a Bike</h3>\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">#4 Isotone allrounder</span>\n<h4>Amacx Drink Gel</h4>\n<p>30g koolhydraten · 200 mg natrium · 2:1 glucose:fructose. Isotone drinkgel, geen water nodig. Cola-variant met 75 mg cafeïne. NZVT-gecertificeerd. Meerdere smaken.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">#5 Maximale opname</span>\n<h4>Amacx Turbo Drink Gel</h4>\n<p>40g koolhydraten · 200 mg natrium · 1:0.8 glucose:fructose. Ontworpen voor opname tot 120g/uur. Cassis-variant met 100 mg cafeïne. NZVT-gecertificeerd.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-gel\">Bekijk en bestel →</a>\n</div>\n</div>\n\n<h3>Precision Fuel & Hydration – personalisatie</h3>\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">#6 Milde smaak</span>\n<h4>Precision PF 30 Gel</h4>\n<p>30g koolhydraten · 2:1 ratio · bewust geen elektrolyten. Extreem milde, neutrale smaak tegen smaakmoeheid. Combineer met PH-tabletten in je bidon. Informed Sport.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/precision-pf-30-gel\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">#7 Focus-boost</span>\n<h4>Precision PF 30 Caffeine Gel</h4>\n<p>30g koolhydraten · 100 mg cafeïne. PF 30 verrijkt met cafeïne, zonder bittere nasmaak. Strategisch wapen voor de tweede helft van je race. Informed Sport.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/precision-pf-30-caffeine-gel\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Jumbo gel</span>\n<h4>Precision PF 90 Gel</h4>\n<p>90g koolhydraten · hersluitbare dop. Drie PF 30 Gels in een pouch. 2:1 ratio. Minder verpakkingen bij hoge koolhydraatdoelen. Informed Sport.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/precision-pf-90-gel\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Bulkverpakking</span>\n<h4>Precision PF Flow Gel 300</h4>\n<p>300g koolhydraten per pouch (10x PF 30). Giet in Flow Bottle of Flask en drink in slokjes. 2:1 ratio. Ideaal voor Ironman en ultralopers. Informed Sport.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/precision-flow-gel-300\">Bekijk en bestel →</a>\n</div>\n</div>\n\n<h3>226ERS – cyclodextrine & hoge ratio's</h3>\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Isotoon cyclodextrine</span>\n<h4>226ERS Isotonic Gel</h4>\n<p>22g koolhydraten op basis van cyclodextrine. Isotone gel, geen water nodig. Gelijkmatige energieafgifte zonder suikerpieken. Varianten met cafeïne en menthol. Cologne List®.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/226ers-isotonic-gel\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Compact cyclodextrine</span>\n<h4>226ERS High Energy Gel XS</h4>\n<p>30g koolhydraten · 1:1 complexe/snelle suikers. Cyclodextrine voor snelle maagpassage en lage osmolariteit. Cherry-variant met cafeïne. Cologne List®.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/226ers-high-energy-gel-xs\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">1:0.8 ratio compact</span>\n<h4>226ERS High Fructose Gel XS</h4>\n<p>30g koolhydraten · 140 mg natrium · 1:0.8 glucose:fructose. Compact formaat voor opname tot 120g/uur. Licht verteerbaar. Cologne List®.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/226ers-high-fructose-gel-xs\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Krachtpatser 55g</span>\n<h4>226ERS High Fructose Gel</h4>\n<p>55g koolhydraten · 250 mg natrium · 10:8 maltodextrine:fructose · 220 kcal. De krachtigste gel per portie in het assortiment. Cherry-variant met 160 mg cafeïne. Cologne List®.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/226ers-high-fructose-gel\">Bekijk en bestel →</a>\n</div>\n</div>\n\n<h3>BYE! Nutrition – 100% natuurlijk</h3>\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Fruit smoothie</span>\n<h4>BYE! Pro Fruit Gel</h4>\n<p>22g koolhydraten · magnesiumcitraat · vitamine C. Smaakt als verse fruit smoothie met min. 20% echt fruit. Vegan, zonder kunstmatige toevoegingen.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/bye-pro-fruit-gel\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">High-carb natuurlijk</span>\n<h4>BYE! 40 Carbs Fruit Gel</h4>\n<p>40g koolhydraten · 1:0.8 ratio · magnesiumcitraat. De krachtigere variant met echt fruitsap. Ideaal voor 80-120g/uur strategieen. 100% natuurlijk.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/bye-40-carbs-fruit-gel\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Pro formule</span>\n<h4>BYE! PRO Isotonic Gel</h4>\n<p>25g koolhydraten · 53 mg cafeïne · BCAA's · L-Arginine · L-Citrulline. Isotone gel met hersluitbare dop. De meest geavanceerde BYE! gel met complete pro formule.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/bye-pro-isotonic-gel\">Bekijk en bestel →</a>\n</div>\n</div>\n</section>\n\n<!-- ═══ KIES JOUW STRATEGIE ═══ -->\n<section id=\"kies-strategie\">\n<h2><span class=\"svd-heading-line\">Kies jouw gel-strategie per uur</span></h2>\n<p>Hoeveel koolhydraten je per uur nodig hebt, hangt af van de duur en intensiteit van je inspanning. Hier zijn drie bewezen strategieen.</p>\n\n<div class=\"svd-scenario-grid\">\n<div class=\"svd-scenario-card\">\n<span class=\"svd-scenario-tag tag-basis\">Solide basis</span>\n<h3>30-60g koolhydraten per uur</h3>\n<p>De instap voor de meeste duursporters. Ideaal voor trainingen, wedstrijden tot 3 uur en beginners die hun darmen nog trainen.</p>\n<div class=\"svd-scenario-products\">\n<strong>Jouw keuzes:</strong> 1-2x <a href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Amacx Drink Gel</a> · 1-2x <a href=\"https://sportvoedingdirect.nl/products/precision-pf-30-gel\">Precision PF 30 Gel</a> · 1-3x <a href=\"https://sportvoedingdirect.nl/products/maurten-gel-100\">Maurten Gel 100</a>\n</div>\n</div>\n<div class=\"svd-scenario-card scenario-allround\">\n<span class=\"svd-scenario-tag tag-wedstrijd\">Wedstrijd standaard</span>\n<h3>60-90g koolhydraten per uur</h3>\n<p>De gouden standaard voor serieuze duursporters tijdens marathons, triatlons en lange wielerwedstrijden. Vereist de 2:1 glucose:fructose ratio.</p>\n<div class=\"svd-scenario-products\">\n<strong>Jouw keuzes:</strong> 1x <a href=\"https://sportvoedingdirect.nl/products/maurten-gel-160\">Maurten Gel 160</a> (40g) + 1x Gel 100 (25g) · 1x <a href=\"https://sportvoedingdirect.nl/products/precision-pf-90-gel\">Precision PF 90 Gel</a> per uur · 3x <a href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Amacx Drink Gel</a>\n</div>\n</div>\n<div class=\"svd-scenario-card scenario-extreme\">\n<span class=\"svd-scenario-tag tag-elite\">Elite niveau</span>\n<h3>90-120g koolhydraten per uur</h3>\n<p>Alleen voor ervaren atleten met getrainde darmen. Vereist de geavanceerde 1:0.8 ratio voor maximale opname via beide transportroutes.</p>\n<div class=\"svd-scenario-products\">\n<strong>Jouw keuzes:</strong> <a href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-gel\">Amacx Turbo Gel</a> (40g) + sportdrank (80g) · 2x <a href=\"https://sportvoedingdirect.nl/products/226ers-high-fructose-gel\">226ERS HF Gel</a> (2x55g) · <a href=\"https://sportvoedingdirect.nl/products/precision-flow-gel-300\">Precision Flow 300</a> via flask\n</div>\n</div>\n</div>\n</section>\n\n<!-- ═══ VERGELIJKING ═══ -->\n<section id=\"vergelijking\">\n<h2><span class=\"svd-heading-line\">Alle energiegels vergeleken</span></h2>\n<p>Alle 17 energiegels op een rij. Vergelijk op koolhydraten, natrium, type formule en ideaal gebruik.</p>\n\n<div style=\"overflow-x:auto;border-radius:var(--svd-radius);border:1px solid var(--svd-border);box-shadow:var(--svd-shadow)\">\n<table class=\"svd-compare-table\">\n<thead>\n<tr><th>Product</th><th>Carbs</th><th>Natrium</th><th>Formule</th><th>Ideaal voor</th></tr>\n</thead>\n<tbody>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/maurten-gel-100\">Maurten Gel 100</a></td><td>25g</td><td>85 mg</td><td><span class=\"svd-table-badge badge-hydrogel\">hydrogel</span></td><td>Gevoelige maag, marathons</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/maurten-gel-100-caf-100\">Maurten Gel 100 CAF 100</a></td><td>25g</td><td>85 mg</td><td><span class=\"svd-table-badge badge-hydrogel\">hydrogel</span><span class=\"svd-table-badge badge-cafeine\">100mg caf</span></td><td>Finale wedstrijd, focus</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/maurten-gel-160\">Maurten Gel 160</a></td><td>40g</td><td>–</td><td><span class=\"svd-table-badge badge-hydrogel\">hydrogel</span><span class=\"svd-table-badge badge-highcarb\">high-carb</span></td><td>Hoge inname, lange afstanden</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Amacx Drink Gel</a></td><td>30g</td><td>200 mg</td><td><span class=\"svd-table-badge badge-isotoon\">isotoon</span></td><td>Training, allround favoriet</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Amacx Drink Gel Cola CAF</a></td><td>30g</td><td>200 mg</td><td><span class=\"svd-table-badge badge-isotoon\">isotoon</span><span class=\"svd-table-badge badge-cafeine\">75mg caf</span></td><td>Laatste uur wedstrijd</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-gel\">Amacx Turbo Drink Gel</a></td><td>40g</td><td>200 mg</td><td><span class=\"svd-table-badge badge-highcarb\">1:0.8 ratio</span></td><td>120g/uur, elite atleten</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/precision-pf-30-gel\">Precision PF 30 Gel</a></td><td>30g</td><td>0 mg</td><td><span class=\"svd-table-badge badge-isotoon\">isotoon</span></td><td>Milde smaak, lange races</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/precision-pf-30-caffeine-gel\">Precision PF 30 CAF Gel</a></td><td>30g</td><td>0 mg</td><td><span class=\"svd-table-badge badge-isotoon\">isotoon</span><span class=\"svd-table-badge badge-cafeine\">100mg caf</span></td><td>Mentale boost halverwege</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/precision-pf-90-gel\">Precision PF 90 Gel</a></td><td>90g</td><td>0 mg</td><td><span class=\"svd-table-badge badge-highcarb\">jumbo</span></td><td>Ironman, minder verpakkingen</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/precision-flow-gel-300\">Precision PF Flow 300</a></td><td>300g</td><td>0 mg</td><td><span class=\"svd-table-badge badge-highcarb\">bulk</span></td><td>Ultra-afstanden, flask</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/226ers-isotonic-gel\">226ERS Isotonic Gel</a></td><td>22g</td><td>–</td><td><span class=\"svd-table-badge badge-isotoon\">isotoon</span><span class=\"svd-table-badge badge-cyclodex\">cyclo</span></td><td>Gemak, stabiele afgifte</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/226ers-high-energy-gel-xs\">226ERS High Energy XS</a></td><td>30g</td><td>–</td><td><span class=\"svd-table-badge badge-cyclodex\">cyclodex</span></td><td>Compact, maagvriendelijk</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/226ers-high-fructose-gel-xs\">226ERS HF Gel XS</a></td><td>30g</td><td>140 mg</td><td><span class=\"svd-table-badge badge-highcarb\">1:0.8</span></td><td>Hoge opname + elektrolyten</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/226ers-high-fructose-gel\">226ERS HF Gel</a></td><td>55g</td><td>250 mg</td><td><span class=\"svd-table-badge badge-highcarb\">high-carb</span></td><td>Max energie + natrium</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/bye-pro-fruit-gel\">BYE! Pro Fruit Gel</a></td><td>22g</td><td>–</td><td><span class=\"svd-table-badge badge-natuur\">natuurlijk</span></td><td>Fruit smoothie, beginners</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/bye-40-carbs-fruit-gel\">BYE! 40 Carbs Fruit Gel</a></td><td>40g</td><td>–</td><td><span class=\"svd-table-badge badge-highcarb\">high-carb</span><span class=\"svd-table-badge badge-natuur\">natuur</span></td><td>Hoge energie, natuurlijk</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/bye-pro-isotonic-gel\">BYE! PRO Isotonic Gel</a></td><td>25g</td><td>–</td><td><span class=\"svd-table-badge badge-isotoon\">isotoon</span><span class=\"svd-table-badge badge-cafeine\">53mg caf</span></td><td>BCAA + cafeïne combo</td></tr>\n</tbody>\n</table>\n</div>\n</section>\n\n<!-- ═══ MERKEN ═══ -->\n<section id=\"merken\">\n<h2><span class=\"svd-heading-line\">5 merkfilosofieen</span></h2>\n<p>Elk merk heeft een unieke benadering van sportvoeding. Ontdek welke filosofie past bij jouw aanpak.</p>\n\n<div class=\"svd-brand-grid\">\n<div class=\"svd-brand-card\">\n<h4><a href=\"https://sportvoedingdirect.nl/collections/maurten\">Maurten</a></h4>\n<p>Hydrogel-technologie op basis van alginaat en pectine. Minimale ingredienten, maximaal maagcomfort. Keuze van marathon-wereldtoppers als Eliud Kipchoge.</p>\n</div>\n<div class=\"svd-brand-card\">\n<h4><a href=\"https://sportvoedingdirect.nl/collections/amacx\">Amacx</a></h4>\n<p>Isotone drinkgels die je zonder water inneemt. Vertrouwd door Team Visma | Lease a Bike. 2:1 en 1:0.8 ratio's beschikbaar. NZVT-gecertificeerd (dopingvrij).</p>\n</div>\n<div class=\"svd-brand-card\">\n<h4><a href=\"https://sportvoedingdirect.nl/collections/precision\">Precision Fuel &amp; Hydration</a></h4>\n<p>Scheidt brandstof (PF) en hydratatie (PH) voor ultieme controle. Milde, neutrale smaak. Van PF 30 tot PF 300. Informed Sport gecertificeerd.</p>\n</div>\n<div class=\"svd-brand-card\">\n<h4><a href=\"https://sportvoedingdirect.nl/collections/226ers\">226ERS</a></h4>\n<p>Cyclodextrine voor gelijkmatige energieafgifte. 10:8 ratio voor opname tot 120g/uur. Vertrouwd door Movistar Team. Cologne List® gecertificeerd.</p>\n</div>\n<div class=\"svd-brand-card\">\n<h4><a href=\"https://sportvoedingdirect.nl/collections/boost-your-energy\">BYE! Nutrition</a></h4>\n<p>100% natuurlijke sportvoeding met echt fruit. Magnesiumcitraat voor spierondersteuning. Nederlands merk, ontwikkeld met lokale topsporters. Vegan.</p>\n</div>\n</div>\n</section>\n\n<!-- ═══ TIPS ═══ -->\n<section id=\"tips\">\n<h2><span class=\"svd-heading-line\">6 praktische tips voor energiegels</span></h2>\n\n<div class=\"svd-tips-grid\">\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">1</div>\n<div><p><strong>Start na 45-60 minuten:</strong> neem je eerste gel na 45-60 minuten inspanning. Wacht niet tot je een energiedip voelt, maar wees de hongerklop voor.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">2</div>\n<div><p><strong>Elke 20-30 minuten herhalen:</strong> houd een constante stroom koolhydraten aan. Frequente kleine porties worden beter verdragen dan grote hoeveelheden in een keer.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">3</div>\n<div><p><strong>Test altijd in training:</strong> probeer nooit een nieuwe gel voor het eerst in een wedstrijd. Experimenteer met merken, smaken en timing tijdens trainingen.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">4</div>\n<div><p><strong>Water bij concentraatgels:</strong> dikke gels vereisen altijd een paar slokken water. Isotone drinkgels en Maurten hydrogels neem je zonder extra water.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">5</div>\n<div><p><strong>Train je darmen:</strong> wil je 80+ gram per uur? Bouw dit geleidelijk op over meerdere weken. Je darmen moeten wennen aan hoge koolhydraatinnames.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">6</div>\n<div><p><strong>Cafeïne strategisch inzetten:</strong> bewaar cafeïnegels voor de tweede helft van je wedstrijd. Maximaal 3-4 mg per kg lichaamsgewicht. Effect na 30-60 minuten.</p></div>\n</div>\n</div>\n</section>\n\n<!-- ═══ FAQ ═══ -->\n<section id=\"faq\">\n<h2><span class=\"svd-heading-line\">Veelgestelde vragen over energiegels</span></h2>\n\n<div class=\"svd-faq-list\">\n<div class=\"svd-faq-item\"><details>\n<summary>Wat is het verschil tussen een isotone gel en een concentraatgel?</summary>\n<div class=\"svd-faq-answer\">\n<p>Een isotone gel (drinkgel) heeft dezelfde deeltjesconcentratie als je lichaamsvocht en wordt razendsnel opgenomen zonder extra water. Voorbeelden zijn de <a href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Amacx Drink Gel</a> en de <a href=\"https://sportvoedingdirect.nl/products/precision-pf-30-gel\">Precision PF 30 Gel</a>. Een concentraatgel is dikker en bevat meer koolhydraten per portie, maar vereist altijd een paar slokken water erbij voor goede opname en om maagklachten te voorkomen.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Hoeveel energiegels moet ik per uur nemen?</summary>\n<div class=\"svd-faq-answer\">\n<p>De meeste sporters mikken op 60 gram koolhydraten per uur, wat neerkomt op 2 gels van 30g. Getrainde atleten kunnen met de juiste producten en darmtraining 90-120 gram per uur opnemen. Gebruik daarvoor high-carb gels zoals de <a href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-gel\">Amacx Turbo Gel</a> (40g) of de <a href=\"https://sportvoedingdirect.nl/products/maurten-gel-160\">Maurten Gel 160</a> (40g).</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Wat is hydrogel-technologie en waarom is het bijzonder?</summary>\n<div class=\"svd-faq-answer\">\n<p>Hydrogel-technologie van <a href=\"https://sportvoedingdirect.nl/collections/maurten\">Maurten</a> combineert twee natuurlijke vezels (alginaat en pectine) die in contact met maagzuur een beschermende gel-matrix vormen. Deze kapselt de koolhydraten in en transporteert ze soepel naar de darmen. Resultaat: hogere koolhydraatinnames met minimale kans op maagklachten.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Wat is het verschil tussen de 2:1 en 1:0.8 glucose:fructose ratio?</summary>\n<div class=\"svd-faq-answer\">\n<p>De 2:1 ratio is de bewezen standaard die opname tot 90g/uur mogelijk maakt. De nieuwere 1:0.8 ratio (te vinden in de <a href=\"https://sportvoedingdirect.nl/products/amacx-turbo-drink-gel\">Amacx Turbo Gel</a> en <a href=\"https://sportvoedingdirect.nl/products/bye-40-carbs-fruit-gel\">BYE! 40 Carbs</a>) benut de fructose-transportroute optimaler en maakt opname tot 120g/uur mogelijk. Dit vereist wel getrainde darmen.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Welke gel is het beste voor een marathon?</summary>\n<div class=\"svd-faq-answer\">\n<p>De <a href=\"https://sportvoedingdirect.nl/products/maurten-gel-100\">Maurten Gel 100</a> is de populairste marathongel dankzij de hydrogel-technologie die maagklachten minimaliseert. De <a href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Amacx Drink Gel</a> is ideaal voor hardlopers die geen bidon bij de hand hebben. De <a href=\"https://sportvoedingdirect.nl/products/precision-pf-30-gel\">Precision PF 30</a> is perfect als je last hebt van smaakmoeheid. Test altijd in training.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Kunnen energiegels maagklachten veroorzaken?</summary>\n<div class=\"svd-faq-answer\">\n<p>Ja, vooral bij concentraatgels zonder voldoende water erbij, of bij te hoge koolhydraatinname zonder darmtraining. Kies Maurten hydrogels of isotone drinkgels als je gevoelig bent. Bouw je koolhydraatinname geleidelijk op en test altijd in training. Begin met 30-60g/uur en verhoog pas na weken.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Moet ik water drinken bij een energiegel?</summary>\n<div class=\"svd-faq-answer\">\n<p>Bij isotone drinkgels (Amacx Drink Gel, Precision PF 30, BYE! PRO Isotonic, 226ERS Isotonic) en hydrogels (Maurten) is extra water niet nodig. Bij concentraatgels en high-carb gels altijd een paar slokken water erbij drinken voor snellere opname en minder maagklachten.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Waarom bevatten Precision gels geen elektrolyten?</summary>\n<div class=\"svd-faq-answer\">\n<p>Dit is een bewuste keuze. Precision scheidt brandstof (PF-lijn) en hydratatie (PH-lijn) zodat je beide onafhankelijk kunt doseren. Op een hete dag drink je meer elektrolyten maar dezelfde hoeveelheid koolhydraten. Combineer PF 30 Gels met <a href=\"https://sportvoedingdirect.nl/products/precision-ph-1000-electrolyte-tablets\">PH 1000 tabletten</a> in je bidon voor een compleet plan.</p>\n</div>\n</details></div>\n</div>\n</section>\n\n</div>\n\n<script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"CollectionPage\",\"name\":\"Energiegels\",\"description\":\"Energiegels kopen bij SportvoedingDirect. 17 gels van Maurten, Amacx, Precision, 226ERS en BYE! Van isotone drinkgels tot hydrogels en high-carb formules.\",\"url\":\"https://sportvoedingdirect.nl/collections/energiegels\",\"numberOfItems\":17,\"provider\":{\"@type\":\"Organization\",\"name\":\"SportvoedingDirect\",\"url\":\"https://sportvoedingdirect.nl\"}}</script>\n<script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Wat is het verschil tussen een isotone gel en een concentraatgel?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Een isotone gel heeft dezelfde deeltjesconcentratie als je lichaamsvocht en wordt razendsnel opgenomen zonder extra water. Een concentraatgel is dikker en bevat meer koolhydraten per portie, maar vereist altijd water erbij.\"}},{\"@type\":\"Question\",\"name\":\"Hoeveel energiegels moet ik per uur nemen?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"De meeste sporters mikken op 60 gram koolhydraten per uur (2x een 30g gel). Getrainde atleten kunnen 90-120 gram per uur opnemen met high-carb gels.\"}},{\"@type\":\"Question\",\"name\":\"Wat is hydrogel-technologie en waarom is het bijzonder?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Hydrogel-technologie van Maurten kapselt koolhydraten in een gel-matrix van alginaat en pectine voor soepel transport naar de darmen met minimale kans op maagklachten.\"}},{\"@type\":\"Question\",\"name\":\"Wat is het verschil tussen de 2:1 en 1:0.8 glucose:fructose ratio?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"De 2:1 ratio maakt opname tot 90g/uur mogelijk. De 1:0.8 ratio benut de fructose-transportroute optimaler en maakt opname tot 120g/uur mogelijk.\"}},{\"@type\":\"Question\",\"name\":\"Welke gel is het beste voor een marathon?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"De Maurten Gel 100 is populair vanwege hydrogel-technologie. De Amacx Drink Gel is ideaal zonder bidon. De Precision PF 30 helpt bij smaakmoeheid. Test altijd in training.\"}},{\"@type\":\"Question\",\"name\":\"Kunnen energiegels maagklachten veroorzaken?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Ja, vooral bij concentraatgels zonder water of te hoge inname. Kies hydrogels of isotone drinkgels als je gevoelig bent en bouw geleidelijk op.\"}},{\"@type\":\"Question\",\"name\":\"Moet ik water drinken bij een energiegel?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Bij isotone drinkgels en hydrogels is extra water niet nodig. Bij concentraatgels altijd een paar slokken water erbij drinken.\"}},{\"@type\":\"Question\",\"name\":\"Waarom bevatten Precision gels geen elektrolyten?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Precision scheidt brandstof en hydratatie voor ultieme controle. Combineer PF Gels met PH tabletten in je bidon.\"}}]}</script>",
