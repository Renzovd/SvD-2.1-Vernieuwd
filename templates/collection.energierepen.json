        "color_scheme": "scheme-2",
        "liquid": "<style>\n:root{--svd-lime:#d9ff36;--svd-lime-dark:#c8f00a;--svd-lavender:#dbb8ff;--svd-lavender-bg:#faf5ff;--svd-dark:#1a1a1a;--svd-text:#333333;--svd-text-light:#666666;--svd-text-muted:#888888;--svd-bg:#fafafa;--svd-border:#eeeeee;--svd-radius:12px;--svd-radius-sm:8px;--svd-shadow:0 2px 12px rgba(0,0,0,0.06)}\n.svd-energierepen-page{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;line-height:1.7;color:var(--svd-text);padding:0;-webkit-font-smoothing:antialiased}\n.svd-energierepen-page *{box-sizing:border-box}\n.svd-hero{background:linear-gradient(135deg,var(--svd-lime) 0%,var(--svd-lime-dark) 100%);padding:48px 32px;border-radius:var(--svd-radius);margin-bottom:40px;position:relative;overflow:hidden}\n.svd-hero::after{content:'BAR🍫';position:absolute;right:-10px;bottom:-30px;font-size:180px;font-weight:900;color:rgba(0,0,0,0.04);line-height:1;pointer-events:none}\n.svd-hero-tag{display:inline-block;background-color:var(--svd-dark);color:#ffffff;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;padding:5px 12px;border-radius:6px;margin-bottom:16px}\n.svd-hero h1{font-size:2.2rem;font-weight:800;color:var(--svd-dark);margin:0 0 14px 0;line-height:1.2;max-width:640px}\n.svd-hero p{font-size:16px;color:var(--svd-dark);margin:0;max-width:580px;line-height:1.65;opacity:0.85}\n.svd-energierepen-page section{margin-bottom:48px}\n.svd-energierepen-page h2{font-size:1.6rem;font-weight:800;color:var(--svd-dark);margin:0 0 20px 0;line-height:1.25}\n.svd-heading-line{display:inline-block;padding-bottom:10px;border-bottom:3px solid var(--svd-lime)}\n.svd-energierepen-page h3{font-size:1.15rem;font-weight:700;color:var(--svd-dark);margin:0 0 10px 0;line-height:1.3}\n.svd-energierepen-page p{margin:0 0 16px 0}\n.svd-jump-nav{background:var(--svd-bg);border:1px solid var(--svd-border);border-left:4px solid var(--svd-lime);border-radius:var(--svd-radius);padding:20px 24px;margin-bottom:40px}\n.svd-ju