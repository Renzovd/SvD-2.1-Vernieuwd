ight)}\n.svd-scenario-card .svd-scenario-products strong{color:var(--svd-dark)}\n.svd-compare-table{width:100%;border-collapse:collapse;margin:24px 0;font-size:13px}\n.svd-compare-table th{background:var(--svd-dark);color:#ffffff;font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:0.04em;padding:12px 14px;text-align:left}\n.svd-compare-table td{padding:12px 14px;border-bottom:1px solid var(--svd-border);vertical-align:top}\n.svd-compare-table tr:nth-child(even) td{background:var(--svd-bg)}\n.svd-compare-table a{color:var(--svd-dark);text-decoration:underline;font-weight:600}\n.svd-table-badge{display:inline-block;font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;margin-right:4px}\n.badge-haver{background:#e0f0ff;color:#0a5299}\n.badge-nougat{background:#ff9f43;color:#fff}\n.badge-chew{background:var(--svd-lavender);color:#3b0764}\n.badge-reep{background:var(--svd-lime);color:var(--svd-dark)}\n.badge-turbo{background:#e74c3c;color:#fff}\n.badge-natuur{background:#55efc4;color:var(--svd-dark)}\n.svd-brand-grid{display:grid;grid-template-columns:1fr;gap:12px;margin:24px 0}\n.svd-brand-card{background:#ffffff;border:1px solid var(--svd-border);border-radius:var(--svd-radius);padding:20px 22px}\n.svd-brand-card h4{font-size:1rem;font-weight:700;color:var(--svd-dark);margin:0 0 6px 0}\n.svd-brand-card h4 a{color:var(--svd-dark);text-decoration:underline}\n.svd-brand-card p{font-size:13px;color:var(--svd-text-light);margin:0;line-height:1.6}\n.svd-tips-grid{display:grid;grid-template-columns:1fr;gap:12px;margin:24px 0}\n.svd-tip-card{background:var(--svd-bg);border:1px solid var(--svd-border);border-radius:var(--svd-radius);padding:18px 20px;display:flex;align-items:flex-start;gap:12px}\n.svd-tip-number{flex-shrink:0;width:32px;height:32px;background:var(--svd-lime);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:800;color:var(--svd-dark)}\n.svd-tip-card p{font-size:14px;margin:0;line-height:1.6}\n.svd-faq-list{margin:24px 0 0 0}\n.svd-faq-item{border:1px solid var(--svd-border);border-radius:var(--svd-radius);margin-bottom:12px;overflow:hidden}\n.svd-faq-item details{width:100%}\n.svd-faq-item summary{padding:16px 20px;font-weight:700;font-size:15px;color:var(--svd-dark);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;background:#ffffff;transition:background 0.15s ease}\n.svd-faq-item summary:hover{background:var(--svd-bg)}\n.svd-faq-item summary::-webkit-details-marker{display:none}\n.svd-faq-item summary::after{content:'+';font-size:20px;font-weight:300;color:var(--svd-text-muted);flex-shrink:0;margin-left:12px}\n.svd-faq-item details[open] summary::after{content:'−'}\n.svd-faq-item .svd-faq-answer{padding:0 20px 18px 20px;font-size:14px;line-height:1.7;color:var(--svd-text)}\n.svd-faq-item .svd-faq-answer p{margin:0 0 10px 0}\n.svd-faq-item .svd-faq-answer p:last-child{margin:0}\n.svd-faq-item .svd-faq-answer a{color:var(--svd-dark);text-decoration:underline;font-weight:600}\n@media(min-width:600px){.svd-jump-nav ul{grid-template-columns:1fr 1fr}.svd-usp-grid{grid-template-columns:1fr 1fr}.svd-products-grid{grid-template-columns:1fr 1fr}.svd-scenario-grid{grid-template-columns:1fr 1fr 1fr}.svd-tips-grid{grid-template-columns:1fr 1fr}.svd-brand-grid{grid-template-columns:1fr 1fr 1fr 1fr}}\n@media(min-width:900px){.svd-hero{padding:56px 40px}.svd-hero h1{font-size:2.6rem}.svd-products-grid{grid-template-columns:repeat(3,1fr)}}\n@media(max-width:599px){.svd-compare-table{font-size:12px}.svd-compare-table th,.svd-compare-table td{padding:10px 8px}}\n</style>\n\n<div class=\"svd-energierepen-page\">\n\n<!-- ═══ HERO ═══ -->\n<section class=\"svd-hero\" id=\"intro\">\n<span class=\"svd-hero-tag\">Solide brandstof</span>\n<h1>Energierepen: vaste kracht voor lange trainingen en wedstrijden</h1>\n<p>Soms wil je gewoon iets kauwbaars. Energierepen geven geleidelijke, langdurige energie en stillen het hongergevoel. Van zachte havermutrepen tot high-carb chews: ontdek de reep die past bij jouw sport en moment.</p>\n</section>\n\n<!-- ═══ BADGES ═══ -->\n<div class=\"svd-badges\">\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>11 energierepen van 4 merken</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lavender\"></span>Havermout, nougat, fruit chews & solids</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-dark\"></span>NZVT · Informed Sport gecertificeerd</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>22 tot 40 gram koolhydraten per portie</span>\n</div>\n\n<!-- ═══ JUMP NAV ═══ -->\n<nav class=\"svd-jump-nav\" aria-label=\"Pagina navigatie\">\n<h3>Op deze pagina</h3>\n<ul>\n<li><a href=\"#wanneer-reep\">Wanneer kies je een reep? <span>Timing & inzet</span></a></li>\n<li><a href=\"#soorten-repen\">4 soorten energierepen <span>Haver, nougat, chew & solid</span></a></li>\n<li><a href=\"#top-producten\">Alle producten <span>Per merk</span></a></li>\n<li><a href=\"#kies-strategie\">Reep vs. gel: de juiste timing <span>3 scenario's</span></a></li>\n<li><a href=\"#vergelijking\">Vergelijkingstabel <span>11 repen op een rij</span></a></li>\n<li><a href=\"#merken\">Merkfilosofieen <span>4 merken</span></a></li>\n<li><a href=\"#tips\">Praktische tips <span>Gebruik & bewaren</span></a></li>\n<li><a href=\"#faq\">Veelgestelde vragen <span>Over energierepen</span></a></li>\n</ul>\n</nav>\n\n<!-- ═══ WANNEER EEN REEP ═══ -->\n<section id=\"wanneer-reep\">\n<h2><span class=\"svd-heading-line\">Wanneer kies je voor een energiereep?</span></h2>\n<p>Energierepen zijn de ideale brandstof voor de eerste fase van een lange training of wedstrijd. Omdat ze vaste voeding zijn, geven ze een meer geleidelijke en langdurige energietoevoer dan gels. Dit helpt om een solide basis te leggen voor de uren die komen gaan.</p>\n\n<div class=\"svd-usp-grid\">\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">🚴</div>\n<div>\n<strong>Lange, rustige duurinspanningen</strong>\n<span>Fietstochten, wandeltochten of rustige duurlopen. De constante inspanning laat je comfortabel kauwen en verteren.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">🏁</div>\n<div>\n<strong>Begin van een wedstrijd</strong>\n<span>Gebruik repen in de eerste helft van een marathon of cyclo om je voorraden op peil te houden. Schakel later over op gels.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">🍽️</div>\n<div>\n<strong>Hongergevoel stillen</strong>\n<span>Een reep geeft meer verzadiging dan een gel. Mentaal een groot voordeel bij inspanningen langer dan 3 uur.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">⏰</div>\n<div>\n<strong>30-60 minuten voor de start</strong>\n<span>Een energiereep vlak voor de inspanning is een perfecte manier om met een volle tank te beginnen.</span>\n</div>\n</div>\n</div>\n</section>\n\n<!-- ═══ SOORTEN REPEN ═══ -->\n<section id=\"soorten-repen\">\n<h2><span class=\"svd-heading-line\">4 soorten energierepen</span></h2>\n<p>Niet elke reep is hetzelfde. De textuur, samenstelling en koolhydraatbron bepalen wanneer je ze het beste kunt inzetten.</p>\n\n<div class=\"svd-usp-grid\">\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">🌾</div>\n<div>\n<strong>Havermoutrepen (oat bars)</strong>\n<span>Complexe koolhydraten uit havermout voor langzame, stabiele energieafgifte. Ideaal als basis voor de eerste uren. Voorbeelden: Amacx Oat Bar, BYE! Endurance Bar.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">🍬</div>\n<div>\n<strong>Nougat- en amandelrepen</strong>\n<span>Zachte textuur die makkelijk eet bij hogere hartslag. Snelle koolhydraten in de bewezen 2:1 ratio. Voorbeelden: Amacx Nougat, Amacx Fast Bar.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">🍇</div>\n<div>\n<strong>Fruit chews (kauwbaar)</strong>\n<span>Fruitgom-achtige blokjes met echt fruit. Plakken niet, eten als een snoepje. Perfecte afwisseling op gels en repen. Voorbeelden: Amacx Fruit Chew, Precision PF 30 Chew.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">🔬</div>\n<div>\n<strong>Solids (Maurten)</strong>\n<span>High-performance reep op basis van haver en rijst. 40g koolhydraten in 2 mini-repen voor flexibele dosering. Glutenvrij en vegan.</span>\n</div>\n</div>\n</div>\n</section>\n\n<!-- ═══ TOP PRODUCTEN ═══ -->\n<section id=\"top-producten\">\n<h2><span class=\"svd-heading-line\">Alle energierepen bij SportvoedingDirect</span></h2>\n\n<h3>Maurten – high-performance solid</h3>\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">#1 Keuze van de wereldtop</span>\n<h4>Maurten Solid 160</h4>\n<p>40g koolhydraten in 2 mini-repen van elk 20g. Op basis van glutenvrije haver en rijst met cacao smaak. Flexibele dosering: eet 20g of 40g koolhydraten per moment. Vegan, glutenvrij.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/maurten-solid-160-c\">Bekijk en bestel →</a>\n</div>\n</div>\n\n<h3>Amacx – Team Visma | Lease a Bike</h3>\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">#2 Langzame energie</span>\n<h4>Amacx Energy Oat Bar</h4>\n<p>31.5g koolhydraten uit havermout. Mix van snelle en complexe koolhydraten voor stabiele bloedsuiker. Magnesium en ijzer. Glutenvrij, vegan, NZVT. Smaken: Coconut, Lemon, Sweet Figs, Banana.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-oat-bar\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">#3 Zachte bite</span>\n<h4>Amacx Fast Bar</h4>\n<p>31g koolhydraten · 2:1 ratio · 45 mg natrium · 40% amandelen. Zacht als amandelspijs, makkelijk te eten bij hoge hartslag. Smaken: Lemon, Vanilla, Chocolate. NZVT.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-fast-bar\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">#4 Klassieke nougat</span>\n<h4>Amacx Energy Nougat</h4>\n<p>32g koolhydraten · 2:1 ratio · 45 mg natrium. Zachte nougatreep, hapt makkelijk weg tijdens het fietsen of lopen. Gluten- en lactosevrij. Smaken: Cranberry, Papaya, Speculoos. NZVT.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-energy-nougat\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">#5 Fruitgom 2:1</span>\n<h4>Amacx Fruit Chew</h4>\n<p>30g koolhydraten · 2:1 ratio · 51% echt fruitpulp. Kauwbaar als een snoepje, plakt niet dankzij suikerlaagje. Ideale afwisseling op gels. Vegan, NZVT. Smaken: Cassis, Cranberry.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-fruit-chew\">Bekijk en bestel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">#6 Turbo fruitgom</span>\n<h4>Amacx Turbo Fruit Chew</h4>\n<p>40g koolhydraten · 1:0.8 ratio · 51% echt fruit. De krachtigere variant voor opname tot 120g/uur. Zachte bite, gesuikerde buitenlaag. Vegan, NZVT. Smaak: Cassis.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/amacx-fruit-chew-turbo\">Bekijk en bestel →</a>\n</div>\n</div>\n\n<h3>Precision Fuel & Hydration – kauwbare blokjes</h3>\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Flexibel doseren</span>\n<h4>Precision PF 30 Chew</h4>\n<p>30g koolhydraten · 2:1 ratio · 2x 15g blokjes. Flexibel: eet 15g of 30g. Milde smaak tegen smaakmoeheid. Geen elektrolyten (combineer met PH-tabletten). Vegan, Informed Sport.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/precision-pf-30-chew\">Bekijk en bestel →</a>\n</div>\n</div>\n\n<h3>BYE! Nutrition – 100% natuurlijk</h3>\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Natuurlijke havermout</span>\n<h4>BYE! Endurance Bar</h4>\n<p>Langdurige energie uit havermout, fruit en zaden. MCT's uit kokosvet. Zachte textuur, geen coating. Smelt niet in de hitte, blijft zacht in de kou. 100% natuurlijk, vegan. Smaken: Appel/Kaneel, Cranberry, Coconut, Caramel.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/bye-endurance-bar\">Bekijk en bestel →</a>\n</div>\n</div>\n</section>\n\n<!-- ═══ REEP VS GEL ═══ -->\n<section id=\"kies-strategie\">\n<h2><span class=\"svd-heading-line\">Repen voor de basis, gels voor de finale</span></h2>\n<p>De gouden regel is simpel: gebruik vaste voeding in de eerste fase en schakel over op gels wanneer de intensiteit stijgt. Hier zijn drie scenario's.</p>\n\n<div class=\"svd-scenario-grid\">\n<div class=\"svd-scenario-card\">\n<span class=\"svd-scenario-tag tag-basis\">Voor de start</span>\n<h3>30-60 minuten voor de inspanning</h3>\n<p>Vul je glycogeenvoorraden met een reep als laatste vaste voeding voor de start. Kies iets dat goed valt op je maag.</p>\n<div class=\"svd-scenario-products\">\n<strong>Jouw keuzes:</strong> <a href=\"https://sportvoedingdirect.nl/products/amacx-oat-bar\">Amacx Oat Bar</a> · <a href=\"https://sportvoedingdirect.nl/products/maurten-solid-160-c\">Maurten Solid 160</a> · <a href=\"https://sportvoedingdirect.nl/products/bye-endurance-bar\">BYE! Endurance Bar</a>\n</div>\n</div>\n<div class=\"svd-scenario-card scenario-allround\">\n<span class=\"svd-scenario-tag tag-wedstrijd\">Eerste helft wedstrijd</span>\n<h3>Repen afwisselen met gels</h3>\n<p>In de eerste 1-2 uur is je hartslag stabieler en kun je comfortabel kauwen. Wissel repen af met gels en sportdrank voor variatie en betere verdraagzaamheid.</p>\n<div class=\"svd-scenario-products\">\n<strong>Jouw keuzes:</strong> <a href=\"https://sportvoedingdirect.nl/products/amacx-fast-bar\">Amacx Fast Bar</a> · <a href=\"https://sportvoedingdirect.nl/products/amacx-energy-nougat\">Amacx Nougat</a> · <a href=\"https://sportvoedingdirect.nl/products/amacx-fruit-chew\">Amacx Fruit Chew</a> · <a href=\"https://sportvoedingdirect.nl/products/precision-pf-30-chew\">Precision PF 30 Chew</a>\n</div>\n</div>\n<div class=\"svd-scenario-card scenario-extreme\">\n<span class=\"svd-scenario-tag tag-elite\">Ultra-afstanden</span>\n<h3>Vaste voeding als basis, de hele race</h3>\n<p>Bij ultra's en fietstochten 6+ uur blijf je vaste voeding gebruiken om de maag bezig te houden. Wissel af met gels, sportdranken en soms echt eten.</p>\n<div class=\"svd-scenario-products\">\n<strong>Jouw keuzes:</strong> <a href=\"https://sportvoedingdirect.nl/products/maurten-solid-160-c\">Maurten Solid 160</a> (40g) · <a href=\"https://sportvoedingdirect.nl/products/amacx-fruit-chew-turbo\">Amacx Turbo Chew</a> (40g) · afgewisseld met <a href=\"https://sportvoedingdirect.nl/collections/energiegels\">energiegels</a>\n</div>\n</div>\n</div>\n</section>\n\n<!-- ═══ VERGELIJKING ═══ -->\n<section id=\"vergelijking\">\n<h2><span class=\"svd-heading-line\">Alle energierepen vergeleken</span></h2>\n<p>Alle energierepen op een rij. Vergelijk op koolhydraten, type, ratio en ideaal moment.</p>\n\n<div style=\"overflow-x:auto;border-radius:var(--svd-radius);border:1px solid var(--svd-border);box-shadow:var(--svd-shadow)\">\n<table class=\"svd-compare-table\">\n<thead>\n<tr><th>Product</th><th>Carbs</th><th>Type</th><th>Ratio</th><th>Ideaal voor</th></tr>\n</thead>\n<tbody>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/maurten-solid-160-c\">Maurten Solid 160</a></td><td>40g</td><td><span class=\"svd-table-badge badge-reep\">solid</span></td><td>–</td><td>Flexibele dosering, wereldtop</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-oat-bar\">Amacx Oat Bar</a></td><td>31.5g</td><td><span class=\"svd-table-badge badge-haver\">haver</span></td><td>–</td><td>Langzame energie, voor de start</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-fast-bar\">Amacx Fast Bar</a></td><td>31g</td><td><span class=\"svd-table-badge badge-nougat\">amandel</span></td><td>2:1</td><td>Zachte bite, hoge hartslag</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-energy-nougat\">Amacx Energy Nougat</a></td><td>32g</td><td><span class=\"svd-table-badge badge-nougat\">nougat</span></td><td>2:1</td><td>Klassieke reep, wielrennen</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-fruit-chew\">Amacx Fruit Chew</a></td><td>30g</td><td><span class=\"svd-table-badge badge-chew\">chew</span></td><td>2:1</td><td>Snoepje als afwisseling</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/amacx-fruit-chew-turbo\">Amacx Turbo Fruit Chew</a></td><td>40g</td><td><span class=\"svd-table-badge badge-chew\">chew</span><span class=\"svd-table-badge badge-turbo\">turbo</span></td><td>1:0.8</td><td>Max opname, 120g/uur</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/precision-pf-30-chew\">Precision PF 30 Chew</a></td><td>30g</td><td><span class=\"svd-table-badge badge-chew\">2x chew</span></td><td>2:1</td><td>Flexibel doseren, milde smaak</td></tr>\n<tr><td><a href=\"https://sportvoedingdirect.nl/products/bye-endurance-bar\">BYE! Endurance Bar</a></td><td>–</td><td><span class=\"svd-table-badge badge-haver\">haver</span><span class=\"svd-table-badge badge-natuur\">natuur</span></td><td>–</td><td>Natuurlijk, ultra-afstanden</td></tr>\n</tbody>\n</table>\n</div>\n</section>\n\n<!-- ═══ MERKEN ═══ -->\n<section id=\"merken\">\n<h2><span class=\"svd-heading-line\">4 merkfilosofieen</span></h2>\n<p>Elk merk heeft een unieke benadering van vaste sportvoeding. Ontdek welke filosofie past bij jouw aanpak.</p>\n\n<div class=\"svd-brand-grid\">\n<div class=\"svd-brand-card\">\n<h4><a href=\"https://sportvoedingdirect.nl/collections/maurten\">Maurten</a></h4>\n<p>De Solid 160 is de enige reep in het Maurten-ecosysteem. Op basis van haver en rijst, 40g koolhydraten in 2 mini-repen. Glutenvrij, vegan. Aanvulling op hydrogel-voeding.</p>\n</div>\n<div class=\"svd-brand-card\">\n<h4><a href=\"https://sportvoedingdirect.nl/collections/amacx\">Amacx</a></h4>\n<p>Het breedste repenassortiment: Oat Bar, Fast Bar, Nougat en Fruit Chews. Zowel 2:1 als 1:0.8 ratio's. Gebruikt door Team Visma | Lease a Bike. NZVT-gecertificeerd.</p>\n</div>\n<div class=\"svd-brand-card\">\n<h4><a href=\"https://sportvoedingdirect.nl/collections/precision\">Precision Fuel &amp; Hydration</a></h4>\n<p>De PF 30 Chew: 2 blokjes van 15g voor flexibele dosering. Milde smaak, geen elektrolyten. Combineer met PH-tabletten. Informed Sport gecertificeerd.</p>\n</div>\n<div class=\"svd-brand-card\">\n<h4><a href=\"https://sportvoedingdirect.nl/collections/boost-your-energy\">BYE! Nutrition</a></h4>\n<p>100% natuurlijk met havermout, fruit en zaden. MCT-vetten uit kokos. Geen coating, smelt niet. Nederlands merk, vegan.</p>\n</div>\n</div>\n</section>\n\n<!-- ═══ TIPS ═══ -->\n<section id=\"tips\">\n<h2><span class=\"svd-heading-line\">6 praktische tips voor energierepen</span></h2>\n\n<div class=\"svd-tips-grid\">\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">1</div>\n<div><p><strong>Start met een reep, eindig met gels:</strong> gebruik repen in de eerste 1-2 uur als je hartslag stabieler is. Schakel over op gels wanneer de intensiteit stijgt en kauwen lastiger wordt.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">2</div>\n<div><p><strong>Snij repen in stukjes:</strong> snij je reep vooraf in kleine stukjes en bewaar ze in een zakje. Zo kun je makkelijk kleine porties pakken zonder te worstelen met verpakkingen.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">3</div>\n<div><p><strong>Drink er altijd water bij:</strong> vaste voeding vraagt meer vocht voor de vertering dan gels. Neem een paar slokken water of sportdrank na elke hap.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">4</div>\n<div><p><strong>Test in training:</strong> probeer nooit een nieuwe reep voor het eerst in een wedstrijd. Experimenteer met merken, smaken en timing tijdens trainingen.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">5</div>\n<div><p><strong>Let op de temperatuur:</strong> repen zonder coating (BYE! Endurance, Amacx Oat Bar) zijn ideaal voor warme omstandigheden. Chocolade-coating kan smelten boven 30 graden.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">6</div>\n<div><p><strong>Varieer je bronnen:</strong> wissel repen af met gels, chews en sportdranken. Variatie voorkomt smaakmoeheid en zorgt voor betere verdraagzaamheid bij lange inspanningen.</p></div>\n</div>\n</div>\n</section>\n\n<!-- ═══ FAQ ═══ -->\n<section id=\"faq\">\n<h2><span class=\"svd-heading-line\">Veelgestelde vragen over energierepen</span></h2>\n\n<div class=\"svd-faq-list\">\n<div class=\"svd-faq-item\"><details>\n<summary>Wanneer eet ik een energiereep: voor of tijdens het sporten?</summary>\n<div class=\"svd-faq-answer\">\n<p>Beide! Een reep 30-60 minuten voor de start vult je glycogeenvoorraden. Tijdens inspanningen langer dan 90 minuten neem je een reep om je energievoorraad op peil te houden. Kies voor de start een <a href=\"https://sportvoedingdirect.nl/products/amacx-oat-bar\">Amacx Oat Bar</a> (langzame energie) en tijdens de inspanning een <a href=\"https://sportvoedingdirect.nl/products/amacx-fast-bar\">Amacx Fast Bar</a> (snelle, zachte bite).</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Hoeveel koolhydraten bevat een gemiddelde energiereep?</summary>\n<div class=\"svd-faq-answer\">\n<p>De meeste energierepen leveren tussen de 22 en 40 gram koolhydraten per portie. De <a href=\"https://sportvoedingdirect.nl/products/maurten-solid-160-c\">Maurten Solid 160</a> en <a href=\"https://sportvoedingdirect.nl/products/amacx-fruit-chew-turbo\">Amacx Turbo Fruit Chew</a> leveren 40g, terwijl standaardrepen rond de 30-32g zitten.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Wanneer kies ik een energiereep en wanneer een energiegel?</summary>\n<div class=\"svd-faq-answer\">\n<p>De gouden regel: repen voor de basis, <a href=\"https://sportvoedingdirect.nl/collections/energiegels\">gels</a> voor de finale. Gebruik repen in de eerste helft wanneer je hartslag lager is en kauwen comfortabel is. Schakel over op gels wanneer de intensiteit stijgt, je vermoeid raakt of kauwen lastig wordt.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Wat is het verschil tussen een energiereep en een mueslireep?</summary>\n<div class=\"svd-faq-answer\">\n<p>Energierepen zijn wetenschappelijk samengesteld voor sporters. Ze bevatten specifieke koolhydraatbronnen (glucose, fructose, maltodextrine) voor snelle opname. Mueslirepen uit de supermarkt bevatten vaak meer vezels en vetten, wat de vertering tijdens inspanning vertraagt.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Zijn er glutenvrije energierepen beschikbaar?</summary>\n<div class=\"svd-faq-answer\">\n<p>Ja. De <a href=\"https://sportvoedingdirect.nl/products/maurten-solid-160-c\">Maurten Solid 160</a> is glutenvrij en vegan. De <a href=\"https://sportvoedingdirect.nl/products/amacx-oat-bar\">Amacx Oat Bar</a> gebruikt glutenvrije haver. De Amacx Fruit Chews en Nougat zijn eveneens glutenvrij. Check altijd de productpagina voor actuele allergeeninfo.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Zijn energierepen geschikt voor zowel zomer als winter?</summary>\n<div class=\"svd-faq-answer\">\n<p>Ja. Repen zonder chocoladecoating (zoals de <a href=\"https://sportvoedingdirect.nl/products/bye-endurance-bar\">BYE! Endurance Bar</a> en <a href=\"https://sportvoedingdirect.nl/products/amacx-oat-bar\">Amacx Oat Bar</a>) smelten niet in de hitte. Repen met een zachte textuur zoals nougat en fruit chews blijven goed eetbaar in de kou.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Wat is het verschil tussen de Amacx Fruit Chew en de Turbo Fruit Chew?</summary>\n<div class=\"svd-faq-answer\">\n<p>De standaard <a href=\"https://sportvoedingdirect.nl/products/amacx-fruit-chew\">Fruit Chew</a> levert 30g koolhydraten in de 2:1 ratio (opname tot 90g/uur). De <a href=\"https://sportvoedingdirect.nl/products/amacx-fruit-chew-turbo\">Turbo Fruit Chew</a> levert 40g koolhydraten in de 1:0.8 ratio voor opname tot 120g/uur. Beide zijn gemaakt met 51% echt fruit.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Waarom bevatten Precision chews geen elektrolyten?</summary>\n<div class=\"svd-faq-answer\">\n<p>Net als bij hun gels scheidt Precision bewust brandstof (PF-lijn) en hydratatie (PH-lijn). Dit geeft je ultieme controle: op een hete dag drink je meer elektrolyten maar eet je dezelfde hoeveelheid koolhydraten. Combineer de <a href=\"https://sportvoedingdirect.nl/products/precision-pf-30-chew\">PF 30 Chew</a> met <a href=\"https://sportvoedingdirect.nl/products/precision-ph-1000-electrolyte-tablets\">PH 1000 tabletten</a> in je bidon.</p>\n</div>\n</details></div>\n</div>\n</section>\n\n</div>\n\n<script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"CollectionPage\",\"name\":\"Energierepen\",\"description\":\"Energierepen kopen bij SportvoedingDirect. 11 repen van Maurten, Amacx, Precision en BYE! Van havermoutrepen tot fruit chews en solids.\",\"url\":\"https://sportvoedingdirect.nl/collections/energierepen\",\"numberOfItems\":11,\"provider\":{\"@type\":\"Organization\",\"name\":\"SportvoedingDirect\",\"url\":\"https://sportvoedingdirect.nl\"}}</script>\n<script type=\"application/ld+json\">{\"@context\":\"https://