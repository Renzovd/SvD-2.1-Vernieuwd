        "liquid": "<style>\n    /* ==================================================\n       Maurten Collectiepagina – SportvoedingDirect\n       Stijl: consistent met e-mail & pakbon designsysteem\n       Kleuren: lime #d9ff36, lavendel #dbb8ff, dark #1a1a1a\n       Typografie: -apple-system stack\n       Radius: 12px (cards), 8px (tags), 4px (small)\n    ================================================== */\n\n    :root {\n        --svd-lime: #d9ff36;\n        --svd-lime-dark: #c8f00a;\n        --svd-lavender: #dbb8ff;\n        --svd-lavender-bg: #faf5ff;\n        --svd-lavender-border: #e8ddf5;\n        --svd-dark: #1a1a1a;\n        --svd-text: #333333;\n        --svd-text-light: #666666;\n        --svd-text-muted: #888888;\n        --svd-bg: #fafafa;\n        --svd-border: #eeeeee;\n        --svd-radius: 12px;\n        --svd-radius-sm: 8px;\n        --svd-shadow: 0 2px 12px rgba(0,0,0,0.06);\n    }\n\n    .svd-maurten-page {\n        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;\n        line-height: 1.7;\n        color: var(--svd-text);\n        padding: 0;\n        -webkit-font-smoothing: antialiased;\n    }\n\n    .svd-maurten-page * {\n        box-sizing: border-box;\n    }\n\n    /* ── HERO ── */\n    .svd-hero {\n        background: linear-gradient(135deg, var(--svd-lime) 0%, var(--svd-lime-dark) 100%);\n        padding: 48px 32px;\n        border-radius: var(--svd-radius);\n        margin-bottom: 40px;\n        position: relative;\n        overflow: hidden;\n    }\n    .svd-hero::after {\n        content: 'M';\n        position: absolute;\n        right: -10px;\n        bottom: -45px;\n        font-size: 240px;\n        font-weight: 900;\n        color: rgba(0,0,0,0.04);\n        line-height: 1;\n        pointer-events: none;\n    }\n    .svd-hero-tag {\n        display: inline-block;\n        background-color: var(--svd-dark);\n        color: #ffffff;\n        font-size: 11px;\n        font-weight: 700;\n     