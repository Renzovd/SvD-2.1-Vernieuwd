ght: 600;\n    }\n\n    /* ── STRATEGY CARDS ── */\n    .svd-strategy-grid {\n        display: grid;\n        grid-template-columns: 1fr;\n        gap: 12px;\n        margin: 24px 0;\n    }\n    .svd-strategy-card {\n        background: var(--svd-bg);\n        border: 1px solid var(--svd-border);\n        border-radius: var(--svd-radius);\n        padding: 18px 20px;\n    }\n    .svd-strategy-card .svd-strategy-label {\n        display: inline-block;\n        font-size: 10px;\n        font-weight: 700;\n        text-transform: uppercase;\n        letter-spacing: 0.06em;\n        padding: 3px 8px;\n        border-radius: 4px;\n        margin-bottom: 10px;\n    }\n    .svd-strategy-card .label-voor { background: var(--svd-lime); color: var(--svd-dark); }\n    .svd-strategy-card .label-tijdens { background: var(--svd-dark); color: #ffffff; }\n    .svd-strategy-card .label-tip { background: var(--svd-lavender); color: #3b0764; }\n    .svd-strategy-card h4 {\n        font-size: 15px;\n        font-weight: 700;\n        color: var(--svd-dark);\n        margin: 0 0 6px 0;\n    }\n    .svd-strategy-card p {\n        font-size: 14px;\n        color: var(--svd-text);\n        margin: 0;\n        line-height: 1.6;\n    }\n    .svd-strategy-card a {\n        color: var(--svd-dark);\n        text-decoration: underline;\n        font-weight: 600;\n    }\n\n    /* ── VIDEO EMBED ── */\n    .svd-video-wrap {\n        max-width: 560px;\n        margin: 24px 0;\n        border-radius: var(--svd-radius);\n        overflow: hidden;\n        border: 1px solid var(--svd-border);\n        box-shadow: var(--svd-shadow);\n    }\n    .svd-video-inner {\n        position: relative;\n        padding-bottom: 56.25%;\n        height: 0;\n        overflow: hidden;\n    }\n    .svd-video-inner iframe {\n        position: absolute;\n        top: 0;\n        left: 0;\n        width: 100%;\n        height: 100%;\n        border: none;\n    }\n\n    /* ── FAQ ── */\n    .svd-faq-list { margin: 24px 0 0 0; }\n    .svd-faq-item {\n        border: 1px solid var(--svd-border);\n        border-radius: var(--svd-radius);\n        margin-bottom: 12px;\n        overflow: hidden;\n    }\n    .svd-faq-item details { width: 100%; }\n    .svd-faq-item summary {\n        padding: 16px 20px;\n        font-weight: 700;\n        font-size: 15px;\n        color: var(--svd-dark);\n        cursor: pointer;\n        list-style: none;\n        display: flex;\n        justify-content: space-between;\n        align-items: center;\n        background: #ffffff;\n        transition: background 0.15s ease;\n    }\n    .svd-faq-item summary:hover { background: var(--svd-bg); }\n    .svd-faq-item summary::-webkit-details-marker { display: none; }\n    .svd-faq-item summary::after {\n        content: '+';\n        font-size: 20px;\n        font-weight: 300;\n        color: var(--svd-text-muted);\n        flex-shrink: 0;\n        margin-left: 12px;\n    }\n    .svd-faq-item details[open] summary::after { content: '−'; }\n    .svd-faq-item .svd-faq-answer {\n        padding: 0 20px 18px 20px;\n        font-size: 14px;\n        line-height: 1.7;\n        color: var(--svd-text);\n    }\n    .svd-faq-item .svd-faq-answer p { margin: 0; }\n\n    /* ── RESPONSIVE ── */\n    @media (min-width: 600px) {\n        .svd-jump-nav ul { grid-template-columns: 1fr 1fr; }\n        .svd-usp-grid { grid-template-columns: 1fr 1fr; }\n        .svd-products-grid { grid-template-columns: 1fr 1fr; }\n        .svd-lines-grid { grid-template-columns: 1fr 1fr 1fr; }\n        .svd-strategy-grid { grid-template-columns: 1fr 1fr 1fr; }\n    }\n    @media (min-width: 900px) {\n        .svd-hero { padding: 56px 40px; }\n        .svd-hero h1 { font-size: 2.6rem; }\n        .svd-products-grid { grid-template-columns: repeat(3, 1fr); }\n    }\n</style>\n\n<div class=\"svd-maurten-page\">\n\n    <!-- ═══ HERO ═══ -->\n    <section class=\"svd-hero\" id=\"intro\">\n        <span class=\"svd-hero-tag\">Hydrogel Technology</span>\n        <h1>Maurten sportvoeding: maximale koolhydraten, nul maagklachten</h1>\n        <p>Maurten veranderde de duursportwereld met gepatenteerde hydrogel-technologie. Natuurlijke ingrediënten, geen kunstmatige smaakstoffen en vertrouwd door de wereldtop. Van marathons tot Ironman.</p>\n    </section>\n\n    <!-- ═══ BADGES ═══ -->\n    <div class=\"svd-badges\">\n        <span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>Gepatenteerde hydrogel-technologie</span>\n        <span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>100% veganistisch</span>\n        <span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lavender\"></span>Officieel IRONMAN partner</span>\n        <span class=\"svd-badge\"><span class=\"svd-badge-dot dot-dark\"></span>Geen kunstmatige toevoegingen</span>\n        <span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>Opgericht in Göteborg, Zweden (2015)</span>\n    </div>\n\n    <!-- ═══ JUMP NAV ═══ -->\n    <nav class=\"svd-jump-nav\" aria-label=\"Pagina navigatie\">\n        <h3>Op deze pagina</h3>\n        <ul>\n            <li><a href=\"#waarom-maurten\">Waarom Maurten? <span>De voordelen</span></a></li>\n            <li><a href=\"#hydrogel\">Hydrogel-technologie <span>Hoe het werkt</span></a></li>\n            <li><a href=\"#assortiment\">Het assortiment <span>Gels, Drinks, Solids</span></a></li>\n            <li><a href=\"#voedingsstrategie\">Voedingsstrategie <span>Get used to it</span></a></li>\n            <li><a href=\"#faq\">Veelgestelde vragen <span>Over Maurten</span></a></li>\n        </ul>\n    </nav>\n\n    <!-- ═══ WAAROM MAURTEN ═══ -->\n    <section id=\"waarom-maurten\">\n        <h2><span class=\"svd-heading-line\">Waarom kiezen duursporters voor Maurten?</span></h2>\n        <p>Maurten werd in 2015 opgericht in Göteborg, Zweden, door wetenschappers met een achtergrond in medische technologie en biotechnologie. Het idee: een sportvoeding die meer koolhydraten kan leveren met minder maagklachten. De hydrogel-technologie bleek zo effectief dat een jaar na de oprichting de beste marathonlopers ter wereld al overstapten.</p>\n\n        <div class=\"svd-usp-grid\">\n            <div class=\"svd-usp-card\">\n                <div class=\"svd-usp-icon\">⚡</div>\n                <div>\n                    <strong>Tot 100 g koolhydraten per uur</strong>\n                    <span>De hydrogel kapselt koolhydraten (fructose + glucose in 0.8:1 verhouding) in en transporteert ze efficiënt door de maag naar de darmen.</span>\n                </div>\n            </div>\n            <div class=\"svd-usp-card\">\n                <div class=\"svd-usp-icon\">💪</div>\n                <div>\n                    <strong>Minimale maaglast</strong>\n                    <span>De hydrogel beschermt de maagwand tegen direct contact met koolhydraten. Geen klotsend gevoel, geen krampen, geen misselijkheid.</span>\n                </div>\n            </div>\n            <div class=\"svd-usp-card\">\n                <div class=\"svd-usp-icon\">🏅</div>\n                <div>\n                    <strong>Vertrouwd door de wereldtop</strong>\n                    <span>Officieel partner van IRONMAN Global Series, T100 Triathlon World Tour, en World Marathon Majors zoals Berlijn, Chicago en Boston.</span>\n                </div>\n            </div>\n            <div class=\"svd-usp-card\">\n                <div class=\"svd-usp-icon\">🌿</div>\n                <div>\n                    <strong>Alleen natuurlijke ingrediënten</strong>\n                    <span>Geen toegevoegde kleurstoffen, conserveermiddelen of kunstmatige smaakstoffen. Slechts een handvol ingrediënten per product.</span>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- ═══ HYDROGEL TECHNOLOGIE ═══ -->\n    <section id=\"hydrogel\">\n        <h2><span class=\"svd-heading-line\">De hydrogel-technologie: hoe het werkt</span></h2>\n        <p>De kern van Maurten is een gepatenteerde technologie op basis van twee natuurlijke ingrediënten: alginaat (uit bruinwier) en pectine (uit fruit). Gecombineerd onder de juiste omstandigheden vormen ze een pH-gevoelige hydrogel.</p>\n\n        <div class=\"svd-science-block\">\n            <h3>Drink Mixen: hydrogel vormt in je maag</h3>\n            <p>Wanneer je een Drink Mix oplost in water en drinkt, komt de vloeistof in contact met het maagzuur. Op dat moment vormt zich direct een hydrogel die de koolhydraten inkapselt. De gel transporteert de koolhydraten soepel door de maag naar de darmen, waar ze worden opgenomen. Het resultaat: je kunt een <span class=\"svd-science-highlight\">concentratie van 80 g koolhydraten per 500 ml</span> drinken zonder maagklachten.</p>\n        </div>\n\n        <div class=\"svd-science-block\">\n            <h3>Gels: hydrogel al in de verpakking</h3>\n            <p>De Maurten Gels zijn al een hydrogel op het moment dat je ze opent. De gel is stevig (niet stroperig zoals traditionele gels) en kun je zonder water innemen. De hydrogel kapselt de koolhydraten in met dezelfde technologie als de Drink Mixen, maar dan al gevormd tijdens productie door natriumalginaat en calciumcarbonaat onder exacte omstandigheden te combineren.</p>\n        </div>\n    </section>\n\n    <!-- ═══ ASSORTIMENT ═══ -->\n    <section id=\"assortiment\">\n        <h2><span class=\"svd-heading-line\">Het Maurten assortiment</span></h2>\n        <p>Maurten houdt het bewust compact: drie productcategorieën die naadloos samenwerken in je voedingsstrategie.</p>\n\n        <div class=\"svd-lines-grid\">\n            <div class=\"svd-line-card\">\n                <span class=\"svd-line-tag tag-gel\">Gels</span>\n                <h4>Maurten Gel</h4>\n                <p>Stevig, niet stroperig. Zonder water in te nemen. Beschikbaar als <a href=\"https://sportvoedingdirect.nl/products/maurten-gel-100\">Gel 100</a> (25 g koolhydraten), <a href=\"https://sportvoedingdirect.nl/products/maurten-gel-160\">Gel 160</a> (40 g koolhydraten) en <a href=\"https://sportvoedingdirect.nl/products/maurten-gel-100-caf-100\">Gel 100 CAF 100</a> (25 g + 100 mg cafeïne).</p>\n            </div>\n            <div class=\"svd-line-card lavender\">\n                <span class=\"svd-line-tag tag-drink\">Drink Mixen</span>\n                <h4>Maurten Drink Mix</h4>\n                <p>De basis van je plan. <a href=\"https://sportvoedingdirect.nl/products/maurten-drink-mix-160\">Drink Mix 160</a> levert 40 g koolhydraten per 500 ml. <a href=\"https://sportvoedingdirect.nl/products/maurten-drink-mix-320\">Drink Mix 320</a> levert 80 g per 500 ml. Ook beschikbaar met <a href=\"https://sportvoedingdirect.nl/products/maurten-drink-mix-320-caf-100\">100 mg cafeïne</a>.</p>\n            </div>\n            <div class=\"svd-line-card dark\">\n                <span class=\"svd-line-tag tag-solid\">Solid</span>\n                <h4>Maurten Solid 160</h4>\n                <p>Kauwbare energiereep op basis van haver en rijst. 40 g koolhydraten. Deelbaar in twee gelijke helften. Ideaal als preload voor de start of tijdens langere, minder intensieve momenten. <a href=\"https://sportvoedingdirect.nl/products/maurten-solid-160-c\">Bekijk de Solid</a>.</p>\n            </div>\n        </div>\n\n        <p>Alle producten op een rij:</p>\n        <div class=\"svd-products-grid\">\n            <div class=\"svd-product-card\">\n                <span class=\"svd-product-card-rank\">Meest populair</span>\n                <h4>Gel 100</h4>\n                <p>25 g koolhydraten (0.8:1 fructose/glucose) per gel. Compact, stevig en zonder water in te nemen. De gel die de meeste profs gebruiken.</p>\n                <a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/maurten-gel-100\">Bekijk en bestel →</a>\n            </div>\n            <div class=\"svd-product-card\">\n                <span class=\"svd-product-card-rank\">Maximale energie</span>\n                <h4>Gel 160</h4>\n                <p>40 g koolhydraten per gel. Grotere portie voor wie meer energie per inname wil. Dezelfde hydrogel-technologie in een groter formaat.</p>\n                <a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/maurten-gel-160\">Bekijk en bestel →</a>\n            </div>\n            <div class=\"svd-product-card\">\n                <span class=\"svd-product-card-rank\">Met cafeïne</span>\n                <h4>Gel 100 CAF 100</h4>\n                <p>25 g koolhydraten + 100 mg cafeïne. Zet strategisch in tijdens de tweede helft van je wedstrijd voor een mentale en fysieke piek.</p>\n                <a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/maurten-gel-100-caf-100\">Bekijk en bestel →</a>\n            </div>\n            <div class=\"svd-product-card\">\n                <span class=\"svd-product-card-rank\">Basisdrank</span>\n                <h4>Drink Mix 160</h4>\n                <p>40 g koolhydraten per 500 ml. Vormt hydrogel in je maag. Ideaal als basis voor kortere sessies of in combinatie met gels.</p>\n                <a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/maurten-drink-mix-160\">Bekijk en bestel →</a>\n            </div>\n            <div class=\"svd-product-card\">\n                <span class=\"svd-product-card-rank\">Meeste koolhydraten</span>\n                <h4>Drink Mix 320</h4>\n                <p>80 g koolhydraten per 500 ml. De krachtigste sportdrank op de markt. Perfect voor wedstrijden, lange trainingen en carbo-loading.</p>\n                <a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/maurten-drink-mix-320\">Bekijk en bestel →</a>\n            </div>\n            <div class=\"svd-product-card\">\n                <span class=\"svd-product-card-rank\">Vaste brandstof</span>\n                <h4>Solid 160</h4>\n                <p>40 g koolhydraten in een kauwbare reep (haver + rijst). Deelbaar in twee helften. Perfecte preload of afwisseling op gels.</p>\n                <a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/maurten-solid-160-c\">Bekijk en bestel →</a>\n            </div>\n        </div>\n    </section>\n\n    <!-- ═══ VOEDINGSSTRATEGIE ═══ -->\n    <section id=\"voedingsstrategie\">\n        <h2><span class=\"svd-heading-line\">Jouw Maurten voedingsstrategie: get used to it</span></h2>\n        <p>Maurten's motto is \"Get used to it\": oefen je voedingsplan altijd eerst tijdens trainingen. Bouw geleidelijk op naar je wedstrijddoel.</p>\n\n        <div class=\"svd-strategy-grid\">\n            <div class=\"svd-strategy-card\">\n                <span class=\"svd-strategy-label label-voor\">Voor de inspanning</span>\n                <h4>Maximaliseer je glycogeen</h4>\n                <p>Gebruik de <a href=\"https://sportvoedingdirect.nl/products/maurten-drink-mix-320\">Drink Mix 320</a> 1 à 2 dagen voor je wedstrijd om je glycogeenvoorraden te maximaliseren. Een <a href=\"https://sportvoedingdirect.nl/products/maurten-solid-160-c\">Solid 160</a> is een goede koolhydraatbron 2 à 3 uur voor de start.</p>\n            </div>\n            <div class=\"svd-strategy-card\">\n                <span class=\"svd-strategy-label label-tijdens\">Tijdens de inspanning</span>\n                <h4>80 tot 100 g koolhydraten per uur</h4>\n                <p>Optie 1: één <a href=\"https://sportvoedingdirect.nl/products/maurten-drink-mix-320\">Drink Mix 320</a> (80 g) per uur. Optie 2: één <a href=\"https://sportvoedingdirect.nl/products/maurten-drink-mix-160\">Drink Mix 160</a> (40 g) aangevuld met twee <a href=\"https://sportvoedingdirect.nl/products/maurten-gel-100\">Gel 100</a>'s (2 × 25 g = 90 g totaal).</p>\n            </div>\n            <div class=\"svd-strategy-card\">\n                <span class=\"svd-strategy-label label-tip\">Cafeïne tip</span>\n                <h4>Strategisch inzetten</h4>\n                <p>Bewaar de <a href=\"https://sportvoedingdirect.nl/products/maurten-gel-100-caf-100\">Gel 100 CAF 100</a> of <a href=\"https://sportvoedingdirect.nl/products/maurten-drink-mix-320-caf-100\">Drink Mix 320 CAF 100</a> voor de tweede helft van je wedstrijd. Cafeïne werkt het beste wanneer je al vermoeid bent.</p>\n            </div>\n        </div>\n    </section>\n\n    <!-- ═══ FAQ ═══ -->\n    <section id=\"faq\">\n        <h2><span class=\"svd-heading-line\">Veelgestelde vragen over Maurten</span></h2>\n\n        <div class=\"svd-faq-list\">\n            <div class=\"svd-faq-item\">\n                <details>\n                    <summary>Wat is het voordeel van de hydrogel-technologie?</summary>\n                    <div class=\"svd-faq-answer\">\n                        <p>De hydrogel kapselt koolhydraten in en transporteert ze soepel door de maag naar de darmen. Hierdoor kun je tot 100 g koolhydraten per uur consumeren met minimaal risico op maag- en darmklachten. Zonder hydrogel belast een hoge concentratie koolhydraten de maag direct, wat leidt tot misselijkheid en krampen.</p>\n                    </div>\n                </details>\n            </div>\n            <div class=\"svd-faq-item\">\n                <details>\n                    <summary>Wat is het verschil tussen Drink Mix 160 en Drink Mix 320?</summary>\n                    <div class=\"svd-faq-answer\">\n                        <p>Het getal verwijst naar het aantal calorieën. Het belangrijkste verschil is de hoeveelheid koolhydraten: de Drink Mix 160 levert 40 g per 500 ml, de Drink Mix 320 levert het dubbele: 80 g per 500 ml. Kies de 320 voor maximale energie per bidon of de 160 als je aanvult met gels.</p>\n                    </div>\n                </details>\n            </div>\n            <div class=\"svd-faq-item\">\n                <details>\n                    <summary>Waarom heeft Maurten geen smaakjes?</summary>\n                    <div class=\"svd-faq-answer\">\n                        <p>Maurten kiest bewust voor functionaliteit boven smaak. Kunstmatige smaakstoffen voegen geen energie toe en kunnen het risico op maagklachten verhogen. De smaak is licht zoet en neutraal, wat veel atleten juist prettig vinden tijdens lange inspanningen wanneer sterke smaken gaan tegenstaan.</p>\n                    </div>\n                </details>\n            </div>\n            <div class=\"svd-faq-item\">\n                <details>\n                    <summary>Heb ik water nodig bij een Maurten gel?</summary>\n                    <div class=\"svd-faq-answer\">\n                        <p>Nee, dat is niet nodig. De gels zijn al een hydrogel in de verpakking en kunnen zonder water worden ingenomen. Ze zijn stevig van textuur (niet stroperig), waardoor ze makkelijker in te nemen zijn dan traditionele gels. Hydrateren blijft natuurlijk belangrijk, maar hoeft niet op hetzelfde moment als de gel.</p>\n                    </div>\n                </details>\n            </div>\n            <div class=\"svd-faq-item\">\n                <details>\n                    <summary>Wat is het verschil tussen Gel 100 en Gel 160?</summary>\n                    <div class=\"svd-faq-answer\">\n                        <p>De Gel 100 bevat 25 g koolhydraten per zakje, de Gel 160 bevat 40 g. Kies de Gel 100 als je vaker kleinere porties wilt innemen. Kies de Gel 160 als je meer energie per inname wilt. Beide gebruiken dezelfde hydrogel-technologie met fructose en glucose in een 0.8:1 verhouding.</p>\n                    </div>\n                </details>\n            </div>\n            <div class=\"svd-faq-item\">\n                <details>\n                    <summary>Zijn Maurten producten veganistisch en glutenvrij?</summary>\n                    <div class=\"svd-faq-answer\">\n                        <p>Ja. Alle Maurten Gels, Drink Mixen en Solids zijn 100% veganistisch. De Gels en Drink Mixen zijn bovendien glutenvrij. De Solid is gebaseerd op haver en rijst. Controleer altijd de productpagina voor de meest actuele samenstelling.</p>\n                    </div>\n                </details>\n            </div>\n            <div class=\"svd-faq-item\">\n                <details>\n                    <summary>Hoe begin ik het beste met Maurten?</summary>\n                    <div class=\"svd-faq-answer\">\n                        <p>Start met de Drink Mix 160 en de Gel 100 tijdens je trainingen. Bouw de hoeveelheid koolhydraten per uur langzaam op richting je wedstrijddoel. Gebruik nooit voor het eerst een nieuw product tijdens een wedstrijd.</p>\n                    </div>\n                </details>\n            </div>\n            <div class=\"svd-faq-item\">\n                <details>\n                    <summary>Heeft Maurten ook herstelproducten?</summary>\n                    <div class=\"svd-faq-answer\">\n                        <p>Nee. Maurten richt zich uitsluitend op brandstof voor, tijdens en direct na de inspanning. Er zijn geen herstelproducten met een hoog eiwitgehalte. De Solid kan wel dienen als koolhydraatbron direct na de finish. Voor specifieke herstelproducten kun je kijken bij <a href=\"https://sportvoedingdirect.nl/collections/amacx\">Amacx Recovery</a>.</p>\n                    </div>\n                </details>\n            </div>\n        </div>\n    </section>\n\n</div>\n\n<!-- ═══ STRUCTURED DATA ═══ -->\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"CollectionPage\",\n  \"name\": \"Maurten Sportvoeding kopen | Hydrogel Gels, Drink Mixen en Solids\",\n  \"description\": \"Ontdek Maurten sportvoeding bij SportvoedingDirect. Gepatenteerde hydrogel-technologie voor maximale koolhydraatopname zonder maagklachten. Gels, Drink Mixen en Solids. Vertrouwd door de wereldtop.\",\n  \"url\": \"https://sportvoedingdirect.nl/collections/maurten\",\n  \"mainEntity\": {\n    \"@type\": \"ItemList\",\n    \"name\": \"Maurten assortiment\",\n    \"itemListElement\": [\n      {\n        \"@type\": \"ListItem\",