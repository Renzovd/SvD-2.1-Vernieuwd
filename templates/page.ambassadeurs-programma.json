ground:var(--amb-lavender);border-radius:2px 0 0 2px}\n.amb-profile-icon{flex-shrink:0;width:48px;height:48px;background:var(--amb-lavender-soft);border:2px solid var(--amb-lavender);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px}\n.amb-profile-card h3{font-size:1rem;font-weight:800;color:var(--amb-dark);margin:0 0 4px 0;letter-spacing:-0.01em}\n.amb-profile-card p{font-size:13px;color:var(--amb-text-light);margin:0;line-height:1.6}\n\n/* ─── LAVENDER SECTION (WAAROM) ─── */\n.amb-lavender-section{background:linear-gradient(135deg,var(--amb-lavender-soft) 0%,rgba(219,184,255,0.06) 100%);border:1px solid rgba(219,184,255,0.25);border-radius:var(--amb-radius);padding:48px 36px;margin-bottom:56px}\n.amb-why-grid{display:grid;grid-template-columns:1fr;gap:16px}\n.amb-why-card{background:#ffffff;border:1px solid rgba(219,184,255,0.3);border-radius:var(--amb-radius);padding:28px;position:relative;overflow:hidden;transition:all 0.2s ease;box-shadow:0 2px 12px rgba(219,184,255,0.08)}\n.amb-why-card:hover{border-color:var(--amb-lavender);box-shadow:0 6px 24px rgba(219,184,255,0.18);transform:translateY(-2px)}\n.amb-why-card .amb-why-number{font-size:4rem;font-weight:900;color:var(--amb-lavender);opacity:0.15;position:absolute;top:-8px;right:12px;line-height:1;pointer-events:none}\n.amb-why-card h3{font-size:1.1rem;font-weight:800;color:var(--amb-dark);margin:0 0 8px 0;position:relative;z-index:1}\n.amb-why-card p{font-size:14px;color:var(--amb-text);margin:0;line-height:1.65;position:relative;z-index:1}\n\n/* ─── PERKS SECTION (lime accents) ─── */\n.amb-perks-grid{display:grid;grid-template-columns:1fr;gap:14px;margin:24px 0}\n.amb-perk{display:flex;align-items:flex-start;gap:16px;padding:22px 24px;background:linear-gradient(135deg,var(--amb-lime-soft) 0%,rgba(217,255,54,0.04) 100%);border:1px solid rgba(200,240,10,0.25);border-radius:var(--amb-radius);transition:all 0.2s ease}\n.amb-perk:hover{border-color:var(--amb-lime-dark);background:linear-gradient(135deg,rgba(217,255,54,0.18) 0%,rgba(217,255,54,0.06) 100%)}\n.amb-perk-dot{flex-shrink:0;width:12px;height:12px;background:var(--amb-lime-dark);border-radius:50%;margin-top:6px;box-shadow:0 0 8px rgba(200,240,10,0.4)}\n.amb-perk strong{display:block;font-size:14px;font-weight:800;color:var(--amb-dark);margin-bottom:2px}\n.amb-perk span{font-size:13px;color:var(--amb-text-light);line-height:1.6}\n\n/* ─── QUOTE (lime bg) ─── */\n.amb-quote{position:relative;padding:40px 36px;margin:48px 0;background:var(--amb-lime);border-radius:var(--amb-radius);overflow:hidden}\n.amb-quote::before{content:'\"';position:absolute;top:0;left:16px;font-size:120px;font-weight:900;color:var(--amb-dark);opacity:0.06;line-height:1;pointer-events:none}\n.amb-quote::after{content:'';position:absolute;bottom:0;right:0;width:40%;height:100%;background:radial-gradient(ellipse at 100% 50%,var(--amb-lavender) 0%,transparent 70%);opacity:0.2;pointer-events:none}\n.amb-quote p{font-size:1.3rem;font-weight:700;color:var(--amb-dark);margin:0;line-height:1.4;letter-spacing:-0.01em;position:relative;z-index:1}\n.amb-quote span{display:block;font-size:13px;font-weight:600;color:var(--amb-dark);opacity:0.5;margin-top:12px;position:relative;z-index:1}\n\n/* ─── FAQ ─── */\n.amb-faq-list{margin:24px 0 0 0}\n.amb-faq-item{border:1px solid var(--amb-border);border-radius:var(--amb-radius);margin-bottom:12px;overflow:hidden;transition:border-color 0.15s ease}\n.amb-faq-item:hover{border-color:#ddd}\n.amb-faq-item details{width:100%}\n.amb-faq-item summary{padding:18px 22px;font-weight:700;font-size:15px;color:var(--amb-dark);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;background:#ffffff;transition:background 0.15s ease}\n.amb-faq-item summary:hover{background:var(--amb-bg)}\n.amb-faq-item summary::-webkit-details-marker{display:none}\n.amb-faq-item summary::after{content:'+';font-size:22px;font-weight:300;color:#bbb;flex-shrink:0;margin-left:12px}\n.amb-faq-item details[open] summary::after{content:'−';color:var(--amb-lavender-dark)}\n.amb-faq-item details[open] summary{background:var(--amb-lavender-soft)}\n.amb-faq-item .amb-faq-answer{padding:0 22px 20px 22px;font-size:14px;line-height:1.7;color:#555}\n.amb-faq-item .amb-faq-answer p{margin:0}\n\n/* ─── BOTTOM CTA (lime + lavender gradient) ─── */\n.amb-bottom-cta{background:linear-gradient(135deg,var(--amb-lime) 0%,var(--amb-lavender) 100%);border-radius:var(--amb-radius);padding:56px 36px;text-align:center;position:relative;overflow:hidden;margin-top:48px}\n.amb-bottom-cta::before{content:'';position:absolute;top:50%;left:50%;width:500px;height:500px;background:radial-gradient(circle,#ffffff 0%,transparent 60%);opacity:0.15;transform:translate(-50%,-50%);pointer-events:none}\n.amb-bottom-cta h2{font-size:2rem;font-weight:900;color:var(--amb-dark);margin:0 0 12px 0;letter-spacing:-0.02em;position:relative}\n.amb-bottom-cta p{color:var(--amb-dark);opacity:0.7;font-size:16px;margin:0 0 32px 0;max-width:480px;display:inline-block;position:relative}\n.amb-bottom-cta .amb-hero-cta{font-size:16px;padding:16px 44px}\n\n/* ─── RESPONSIVE ─── */\n@media(min-width:600px){.amb-profile-grid{grid-template-columns:1fr 1fr}.amb-why-grid{grid-template-columns:1fr 1fr}.amb-perks-grid{grid-template-columns:1fr 1fr}}\n@media(min-width:900px){.amb-hero{padding:72px 48px 64px}.amb-hero h1{font-size:3.4rem}.amb-why-grid{grid-template-columns:1fr 1fr 1fr}.amb-lavender-section{padding:56px 48px}.amb-bottom-cta{padding:72px 48px}.amb-bottom-cta h2{font-size:2.4rem}}\n@media(max-width:599px){.amb-stats{grid-template-columns:1fr}.amb-stat:not(:last-child)::after{width:60%;height:1px;top:auto;bottom:0;left:20%;right:auto}.amb-hero h1{font-size:2rem}}\n</style>\n\n<div class=\"svd-amb\">\n\n<!-- ═══ HERO (lime naar lavender gradient) ═══ -->\n<section class=\"amb-hero\">\n<span class=\"amb-hero-eyebrow\">Ambassadeursprogramma</span>\n<h1>Deel jouw passie.<br>Inspireer anderen.<br><em>Groei met ons mee.</em></h1>\n<p class=\"amb-hero-sub\">Ben jij een gepassioneerde duursporter die niets liever doet dan grenzen verleggen? Geloof jij, net als wij, dat de juiste voeding het verschil maakt tussen een goede en een geweldige prestatie? Dan zoeken we jou!</p>\n<a class=\"amb-hero-cta\" href=\"#aanmelden\">Ik wil ambassadeur worden →</a>\n</section>\n\n<!-- ═══ STATS BAR (lime achtergrond) ═══ -->\n<div class=\"amb-stats\">\n<div class=\"amb-stat\">\n<span class=\"amb-stat-number\">5</span>\n<span class=\"amb-stat-label\">Topmerken</span>\n</div>\n<div class=\"amb-stat\">\n<span class=\"amb-stat-number\">100%</span>\n<span class=\"amb-stat-label\">Passie voor sport</span>\n</div>\n<div class=\"amb-stat\">\n<span class=\"amb-stat-number\">∞</span>\n<span class=\"amb-stat-label\">Mogelijkheden</span>\n</div>\n</div>\n\n<!-- ═══ WIE ZOEKEN WIJ (lavender accenten) ═══ -->\n<section id=\"wie-zoeken-wij\">\n<h2>Wie zoeken wij?</h2>\n<p class=\"amb-section-sub\">Authentieke sporters die hun passie willen delen. Jij bent de perfecte match als je:</p>\n\n<div class=\"amb-profile-grid\">\n<div class=\"amb-profile-card\">\n<div class=\"amb-profile-icon\">🚴</div>\n<div>\n<h3>Actief in duursport</h3>\n<p>Wielrennen, hardlopen, triatlon, trailrunning, atletiek of schaatsen. Jij leeft voor de kilometers.</p>\n</div>\n</div>\n<div class=\"amb-profile-card\">\n<div class=\"amb-profile-icon\">⚡</div>\n<div>\n<h3>Gepassioneerd over voeding</h3>\n<p>Je weet dat sportvoeding het verschil maakt en je wilt je prestaties continu optimaliseren.</p>\n</div>\n</div>\n<div class=\"amb-profile-card\">\n<div class=\"amb-profile-icon\">📸</div>\n<div>\n<h3>Deelt graag ervaringen</h3>\n<p>Trainingen, wedstrijden, tips. Jij vindt het leuk om anderen mee te nemen in jouw sportieve reis.</p>\n</div>\n</div>\n<div class=\"amb-profile-card\">\n<div class=\"amb-profile-icon\">📱</div>\n<div>\n<h3>Actief op social media</h3>\n<p>Een authentieke en positieve uitstraling op TikTok, Instagram of Strava, met een betrokken community en minimaal 1500 volgers.</p>\n</div>\n</div>\n</div>\n</section>\n\n<!-- ═══ WAAROM SAMENWERKEN (lavender sectie) ═══ -->\n<div class=\"amb-lavender-section\" id=\"waarom-samenwerken\">\n<h2>Waarom samenwerken met SportvoedingDirect?</h2>\n<p class=\"amb-section-sub\">Als ambassadeur ben je meer dan een uithangbord. Je bent een partner.</p>\n\n<div class=\"amb-why-grid\">\n<div class=\"amb-why-card\">\n<span class=\"amb-why-number\">01</span>\n<h3>Toegang tot de beste merken</h3>\n<p>Als multi brand platform bieden we jou topmerken onder één dak, zoals <a href=\"https://sportvoedingdirect.nl/collections/amacx\">Amacx</a>, <a href=\"https://sportvoedingdirect.nl/collections/maurten\">Maurten</a>, <a href=\"https://sportvoedingdirect.nl/collections/precision\">Precision</a>, <a href=\"https://sportvoedingdirect.nl/collections/boost-your-energy\">BYE!</a> en <a href=\"https://sportvoedingdirect.nl/collections/226ers\">226ERS</a>. Zo kun jij de voeding gebruiken die perfect bij jou past.</p>\n</div>\n<div class=\"amb-why-card\">\n<span class=\"amb-why-number\">02</span>\n<h3>Eerlijk en deskundig advies</h3>\n<p>Wij zijn je sportvoedingcoach, geen schreeuwerige verkoper. Je krijgt van ons eerlijke en praktische ondersteuning bij het samenstellen van jouw voedingsplan.</p>\n</div>\n<div class=\"amb-why-card\">\n<span class=\"amb-why-number\">03</span>\n<h3>Groei met ons mee</h3>\n<p>We zijn een ambitieus en snelgroeiend sportvoedingwebshop. Als ambassadeur groei je met ons mee en krijg je de kans om jezelf in de kijker te spelen.</p>\n</div>\n</div>\n</div>\n\n<!-- ═══ WAT KUN JE VERWACHTEN (lime accenten) ═══ -->\n<section id=\"wat-kun-je-verwachten\">\n<h2>Wat kun je van ons verwachten?</h2>\n<p class=\"amb-section-sub\">Een ambassadeurschap is een samenwerking. Jij deelt jouw verhaal, wij bieden de support.</p>\n\n<div class=\"amb-perks-grid\">\n<div class=\"amb-perk\">\n<div class=\"amb-perk-dot\"></div>\n<div>\n<strong>Sportvoeding op maat</strong>\n<span>Je ontvangt (afhankelijk van je profiel en bereik) korting om jouw prestaties te ondersteunen.</span>\n</div>\n</div>\n<div class=\"amb-perk\">\n<div class=\"amb-perk-dot\"></div>\n<div>\n<strong>Exclusieve kortingscode</strong>\n<span>Een persoonlijke kortingscode voor je sportvoeding die je kunt delen met jouw community.</span>\n</div>\n</div>\n<div class=\"amb-perk\">\n<div class=\"amb-perk-dot\"></div>\n<div>\n<strong>Zichtbaarheid</strong>\n<span>We delen jouw content en prestaties graag via onze eigen kanalen om je bereik te vergroten.</span>\n</div>\n</div>\n<div class=\"amb-perk\">\n<div class=\"amb-perk-dot\"></div>\n<div>\n<strong>Een partnerschap op maat</strong>\n<span>We kijken samen hoe we de samenwerking het beste kunnen vormgeven met ruimte voor jouw ideeën.</span>\n</div>\n</div>\n</div>\n</section>\n\n<!-- ═══ QUOTE (lime achtergrond + lavender glow) ═══ -->\n<div class=\"amb-quote\">\n<p>Jij deelt jouw passie voor sport. Wij zorgen voor de brandstof. Samen inspireren we de volgende generatie sporters.</p>\n<span>Het team van SportvoedingDirect</span>\n</div>\n\n<!-- ═══ FAQ ═══ -->\n<section id=\"faq\">\n<h2>Veelgestelde vragen</h2>\n<p class=\"amb-section-sub\">Alles wat je wilt weten over het ambassadeursprogramma.</p>\n\n<div class=\"amb-faq-list\">\n\n<div class=\"amb-faq-item\"><details>\n<summary>Moet ik duizenden volgers hebben om ambassadeur te worden?</summary>\n<div class=\"amb-faq-answer\">\n<p>Nee, absoluut niet. We vinden authenticiteit en passie voor de sport veel belangrijker dan het aantal volgers. Een kleinere, maar betrokken community is voor ons net zo waardevol.</p>\n</div>\n</details></div>\n\n<div class=\"amb-faq-item\"><details>\n<summary>Voor welke sporten zoeken jullie ambassadeurs?</summary>\n<div class=\"amb-faq-answer\">\n<p>We staan open voor alle soorten duursporters. Of je nu fietst, hardloopt, zwemt, een triatleet bent of aan trailrunning doet, als jij gepassioneerd bent, horen we graag van je.</p>\n</div>\n</details></div>\n\n<div class=\"amb-faq-item\"><details>\n<summary>Moet ik een professionele atleet zijn?</summary>\n<div class=\"amb-faq-answer\">\n<p>Zeker niet! We werken graag samen met sporters van alle niveaus, van fanatieke recreanten tot competitieve atleten. Jouw unieke verhaal en reis zijn wat telt.</p>\n</div>\n</details></div>\n\n<div class=\"amb-faq-item\"><details>\n<summary>Hoe werkt het aanmeldproces?</summary>\n<div class=\"amb-faq-answer\">\n<p>Klik op de aanmeldknop en vul het formulier in. Geef ons een zo goed mogelijk beeld van wie je bent en waarom je ambassadeur wilt worden. We bekijken elke aanmelding persoonlijk en nemen zo snel mogelijk contact met je op.</p>\n</div>\n</details></div>\n\n</div>\n</section>\n\n<!-- ═══ BOTTOM CTA (lime naar lavender gradient) ═══ -->\n<div class=\"amb-bottom-cta\" id=\"aanmelden\">\n<h2>Klaar om samen te groeien?</h2>\n<p>Word onderdeel van de SportvoedingDirect familie. Vertel ons jouw verhaal en ontdek hoe we samen andere sporters kunnen inspireren.</p>\n<a class=\"amb-hero-cta\" href=\"#aanmeldformulier\">Ik wil ambassadeur worden →</a>\n</div>\n\n</div>\n\n<script type=\"application/ld+json\">\n{\"@context\":\"https://schema.org\",\"@type\":\"WebPage\",\"name\":\"Ambassadeursprogramma SportvoedingDirect\",\"description\":\"Word ambassadeur van SportvoedingDirect. Deel jouw passie voor duursport, ontvang sportvoeding op maat en groei met ons mee. Voor wielrenners, hardlopers, triatleten en trailrunners.\",\"url\":\"https://sportvoedingdirect.nl/pages/ambassadeur-worden\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"SportvoedingDirect\",\"url\":\"https://sportvoedingdirect.nl\"}}\n</script>\n<script type=\"application/ld+json\">\n{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Moet ik duizenden volgers hebben om ambassadeur te worden?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Nee, absoluut niet. We vinden authenticiteit en passie voor de sport veel belangrijker dan het aantal volgers. Een kleinere, maar betrokken community is voor ons net zo waardevol.\"}},{\"@type\":\"Question\",\"name\":\"Voor welke sporten zoeken jullie ambassadeurs?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"We staan open voor alle soorten duursporters. Of je nu fietst, hardloopt, zwemt, een triatleet bent of aan trailrunning doet, als jij gepassioneerd bent, horen we graag van je.\"}},{\"@type\":\"Question\",\"name\":\"Moet ik een professionele atleet zijn?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Zeker niet! We werken graag samen met sporters van alle niveaus, van fanatieke recreanten tot competitieve atleten. Jouw unieke verhaal en reis zijn wat telt.\"}},{\"@type\":\"Question\",\"name\":\"Hoe werkt het aanmeldproces?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Klik op de aanmeldknop en vul het formulier in. Geef ons een zo goed mogelijk beeld van wie je bent en waarom je ambassadeur wilt worden. We bekijken elke aanmelding persoonlijk en nemen zo snel mogelijk contact met je op.\"}}]}\n</script>",
