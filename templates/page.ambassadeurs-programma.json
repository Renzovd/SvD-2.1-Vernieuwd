        "liquid": "<style>\n@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800;900&display=swap');\n\n:root{--amb-lime:#d9ff36;--amb-lime-dark:#c8f00a;--amb-lime-soft:rgba(217,255,54,0.12);--amb-lavender:#dbb8ff;--amb-lavender-dark:#c89dff;--amb-lavender-soft:rgba(219,184,255,0.12);--amb-dark:#1a1a1a;--amb-text:#333;--amb-text-light:#666;--amb-text-muted:#999;--amb-bg:#fafafa;--amb-border:#eee;--amb-radius:16px;--amb-radius-sm:10px}\n\n.svd-amb{font-family:'Outfit',sans-serif;line-height:1.7;color:var(--amb-text);-webkit-font-smoothing:antialiased}\n.svd-amb *{box-sizing:border-box}\n\n/* ─── HERO (lime + lavender gradient) ─── */\n.amb-hero{background:linear-gradient(135deg,var(--amb-lime) 0%,var(--amb-lime-dark) 40%,var(--amb-lavender) 100%);padding:64px 36px 56px;border-radius:var(--amb-radius);margin-bottom:48px;position:relative;overflow:hidden}\n.amb-hero::before{content:'';position:absolute;top:0;right:0;width:50%;height:100%;background:radial-gradient(ellipse at 80% 30%,rgba(219,184,255,0.4) 0%,transparent 60%);pointer-events:none}\n.amb-hero::after{content:'';position:absolute;bottom:0;left:0;width:60%;height:50%;background:radial-gradient(ellipse at 20% 90%,rgba(217,255,54,0.3) 0%,transparent 60%);pointer-events:none}\n.amb-hero-eyebrow{display:inline-block;background:var(--amb-dark);color:#ffffff;font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:0.12em;padding:6px 14px;border-radius:6px;margin-bottom:20px;position:relative;z-index:1}\n.amb-hero h1{font-size:2.8rem;font-weight:900;color:var(--amb-dark);margin:0 0 20px 0;line-height:1.1;max-width:600px;letter-spacing:-0.02em;position:relative;z-index:1}\n.amb-hero h1 em{font-style:normal;background:var(--amb-dark);color:var(--amb-lime);padding:2px 12px;border-radius:6px;display:inline-block}\n.amb-hero-sub{font-size:17px;color:var(--amb-dark);opacity:0.8;margin:0 0 32px 0;max-width:520px;line-height:1.65;font-weight:400;position:relative;z-index:1}\n.amb-h