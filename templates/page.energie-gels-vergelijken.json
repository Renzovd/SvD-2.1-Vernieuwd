r r=carbOpts.filter(function(o){return o.l===s.carbs[i];})[0];\nif(r&&g.carbs>=r.mn&&g.carbs<=r.mx){ok=true;break;}\n}\nif(!ok)return false;\n}\nreturn true;\n});\n}\n\nfunction srt(list){\nvar v=document.getElementById(\"gt-sort\").value;\nif(v===\"carbs-desc\")list.sort(function(a,b){return b.carbs-a.carbs;});\nelse if(v===\"carbs-asc\")list.sort(function(a,b){return a.carbs-b.carbs;});\nelse list.sort(function(a,b){return a.n.localeCompare(b.n);});\nreturn list;\n}\n\nwindow.gtToggleCmp=function(name){tg(s.cmp,name);gtRender();};\nwindow.gtClearAll=function(){s.brand=[];s.tech=[];s.ratio=[];s.carbs=[];s.caf=[];s.diet=[];s.cmp=[];gtRender();};\n\nwindow.gtRender=function(){\nchips(\"gt-f-brand\",brands,s.brand,\"al\",false);\nchips(\"gt-f-tech\",techs,s.tech,\"av\",true);\nchips(\"gt-f-ratio\",ratioOpts,s.ratio,\"al\",true);\nchips(\"gt-f-carbs\",carbOpts,s.carbs,\"al\",true);\nchips(\"gt-f-caf\",cafOpts,s.caf,\"ad\",true);\nchips(\"gt-f-diet\",dietOpts,s.diet,\"ad\",true);\n\nvar hf=s.brand.length||s.tech.length||s.ratio.length||s.carbs.length||s.caf.length||s.diet.length;\ndocument.getElementById(\"gt-clear\").style.display=hf?\"block\":\"none\";\n\nvar fl=srt(filt());\nvar cc=s.cmp.length;\ndocument.getElementById(\"gt-cnt\").innerHTML=fl.length+(fl.length===1?\" gel\":\" gels\")+\" gevonden\"+(cc>0?\" &middot; \"+cc+\" geselecteerd om te vergelijken\":\"\");\n\nvar gd=document.getElementById(\"gt-grid\");\nif(!fl.length){\ngd.innerHTML='<div class=\"svd-gt-empty\"><div class=\"svd-gt-empty-ico\">\\uD83D\\uDD0D</div><p>Geen gels gevonden met deze filters</p><button onclick=\"gtClearAll()\">Filters wissen</button></div>';\n}else{\nvar h=\"\";\nfl.forEach(function(g){\nvar ic=s.cmp.indexOf(g.n)>-1;\nh+='<div class=\"svd-gt-card'+(ic?\" cmp\":\"\")+'\">';\nh+='<div class=\"svd-gt-card-top\"><div class=\"svd-gt-badges\"><span class=\"svd-gt-emoji\">'+g.emoji+'</span>'+rtBdg(g.rt,g.ratio);\nif(g.caf>0)h+=bdg(\"gt-caf\",g.caf+\" mg caf\");\nh+=bdg(\"gt-br\",g.brand)+