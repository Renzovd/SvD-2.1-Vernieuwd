    "custom_liquid_RRHjPh": {
      "type": "custom-liquid",
      "name": "t:sections.custom_liquid.name",
      "settings": {
        "color_scheme": "scheme-3",
        "liquid": "<style>\n:root{--svd-lime:#d9ff36;--svd-lime-dark:#c8f00a;--svd-lavender:#dbb8ff;--svd-lavender-bg:#faf5ff;--svd-dark:#1a1a1a;--svd-text:#333333;--svd-text-light:#666666;--svd-text-muted:#888888;--svd-bg:#fafafa;--svd-border:#eeeeee;--svd-radius:12px;--svd-radius-sm:8px;--svd-shadow:0 2px 12px rgba(0,0,0,0.06)}\n.svd-faq-page{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;line-height:1.7;color:var(--svd-text);padding:0;-webkit-font-smoothing:antialiased}\n.svd-faq-page *{box-sizing:border-box}\n\n/* HERO */\n.svd-hero{background:linear-gradient(135deg,var(--svd-lime) 0%,var(--svd-lime-dark) 100%);padding:48px 32px;border-radius:var(--svd-radius);margin-bottom:40px;position:relative;overflow:hidden}\n.svd-hero::after{content:'FAQ❓';position:absolute;right:-10px;bottom:-30px;font-size:160px;font-weight:900;color:rgba(0,0,0,0.04);line-height:1;pointer-events:none}\n.svd-hero-tag{display:inline-block;background-color:var(--svd-dark);color:#ffffff;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;padding:5px 12px;border-radius:6px;margin-bottom:16px}\n.svd-hero h1{font-size:2.2rem;font-weight:800;color:var(--svd-dark);margin:0 0 14px 0;line-height:1.2;max-width:640px}\n.svd-hero p{font-size:16px;color:var(--svd-dark);margin:0;max-width:580px;line-height:1.65;opacity:0.85}\n\n/* SECTIONS */\n.svd-faq-page section{margin-bottom:48px}\n.svd-faq-page h2{font-size:1.6rem;font-weight:800;color:var(--svd-dark);margin:0 0 20px 0;line-height:1.25}\n.svd-heading-line{display:inline-block;padding-bottom:10px;border-bottom:3px solid var(--svd-lime)}\n.svd-faq-page h3{font-size:1.15rem;font-weight:700;color:var(--svd-dark);margin:0 0 10px 0;line-height:1.3}\n.svd-faq-page p{margin:0 0 16px 0}\n\n/* BADGES */\n.svd-badges{display:flex;flex-wrap:wrap;gap:8px;margin:24px 0}\n.svd-badge{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:20px;font-size:12px;font-weight:600;border:1px solid var(--svd-border);background:#ffffff;color:var(--svd-text)}\n.svd-badge-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}\n.dot-lime{background:var(--svd-lime)}.dot-lavender{background:var(--svd-lavender)}.dot-dark{background:var(--svd-dark)}\n\n/* JUMP NAV */\n.svd-jump-nav{background:var(--svd-bg);border:1px solid var(--svd-border);border-left:4px solid var(--svd-lime);border-radius:var(--svd-radius);padding:20px 24px;margin-bottom:40px}\n.svd-jump-nav h3{margin:0 0 12px 0;font-size:14px;text-transform:uppercase;letter-spacing:0.04em;color:var(--svd-text-muted)}\n.svd-jump-nav ul{list-style:none;padding:0;margin:0;display:grid;grid-template-columns:1fr;gap:8px}\n.svd-jump-nav a{display:block;padding:10px 14px;background:#ffffff;border:1px solid var(--svd-border);border-radius:var(--svd-radius-sm);color:var(--svd-dark);text-decoration:none;font-weight:600;font-size:14px;transition:all 0.15s ease}\n.svd-jump-nav a:hover{background:var(--svd-lime);border-color:var(--svd-lime-dark)}\n.svd-jump-nav a span{color:var(--svd-text-muted);font-weight:400;margin-left:4px}\n\n/* SECTION INTRO CARD */\n.svd-section-intro{background:var(--svd-bg);border:1px solid var(--svd-border);border-radius:var(--svd-radius);padding:18px 22px;margin-bottom:20px;font-size:14px;color:var(--svd-text-light);line-height:1.65}\n.svd-section-intro a{color:var(--svd-dark);text-decoration:underline;font-weight:600}\n\n/* FAQ ACCORDIONS */\n.svd-faq-list{margin:0}\n.svd-faq-item{border:1px solid var(--svd-border);border-radius:var(--svd-radius);margin-bottom:12px;overflow:hidden}\n.svd-faq-item details{width:100%}\n.svd-faq-item summary{padding:16px 20px;font-weight:700;font-size:15px;color:var(--svd-dark);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;background:#ffffff;transition:background 0.15s ease}\n.svd-faq-item summary:hover{background:var(--svd-bg)}\n.svd-faq-item summary::-webkit-details-marker{display:none}\n.svd-faq-item summary::after{content:'+';font-size:20px;font-weight:300;color:var(--svd-text-muted);flex-shrink:0;margin-left:12px}\n.svd-faq-item details[open] summary::after{content:'−'}\n.svd-faq-item .svd-faq-answer{padding:0 20px 18px 20px;font-size:14px;line-height:1.7;color:var(--svd-text)}\n.svd-faq-item .svd-faq-answer p{margin:0 0 10px 0}\n.svd-faq-item .svd-faq-answer p:last-child{margin:0}\n.svd-faq-item .svd-faq-answer a{color:var(--svd-dark);text-decoration:underline;font-weight:600}\n.svd-faq-item .svd-faq-answer strong{color:var(--svd-dark)}\n\n/* CTA CARD */\n.svd-cta-card{background:linear-gradient(135deg,var(--svd-lime) 0%,var(--svd-lime-dark) 100%);border-radius:var(--svd-radius);padding:32px;text-align:center;margin-top:48px}\n.svd-cta-card h2{font-size:1.4rem;color:var(--svd-dark);margin:0 0 10px 0;border:none;padding:0}\n.svd-cta-card p{color:var(--svd-dark);opacity:0.85;font-size:15px;margin:0 0 20px 0}\n.svd-cta-card a.svd-cta-btn{display:inline-block;background:var(--svd-dark);color:#ffffff;padding:12px 28px;border-radius:var(--svd-radius-sm);font-weight:700;font-size:14px;text-decoration:none;transition:background 0.15s ease}\n.svd-cta-card a.svd-cta-btn:hover{background:#333333}\n\n/* RESPONSIVE */\n@media(min-width:600px){.svd-jump-nav ul{grid-template-columns:1fr 1fr}}\n@media(min-width:900px){.svd-hero{padding:56px 40px}.svd-hero h1{font-size:2.6rem}}\n</style>\n\n<div class=\"svd-faq-page\">\n\n<!-- ═══ HERO ═══ -->\n<section class=\"svd-hero\">\n<span class=\"svd-hero-tag\">Hulp & advies</span>\n<h1>Veelgestelde vragen</h1>\n<p>Alles wat je wilt weten over bestellen, verzenden, betalen en sportvoeding. Staat je vraag er niet bij? Mail ons op <a href=\"mailto:nu@sportvoedingdirect.nl\" style=\"color:var(--svd-dark);text-decoration:underline;font-weight:700\">nu@sportvoedingdirect.nl</a>.</p>\n</section>\n\n<!-- ═══ BADGES ═══ -->\n<div class=\"svd-badges\">\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>Gratis verzending vanaf €50</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lavender\"></span>Voor 13:00 besteld = vandaag verzonden</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-dark\"></span>14 dagen bedenktijd</span>\n</div>\n\n<!-- ═══ JUMP NAV ═══ -->\n<nav class=\"svd-jump-nav\" aria-label=\"FAQ categorieën\">\n<h3>Spring naar categorie</h3>\n<ul>\n<li><a href=\"#bestellen\">Bestellen & verzenden <span>6 vragen</span></a></li>\n<li><a href=\"#betalen\">Betalen & facturatie <span>4 vragen</span></a></li>\n<li><a href=\"#directplus\">Direct+ & spaarpunten <span>4 vragen</span></a></li>\n<li><a href=\"#producten\">Producten & bewaren <span>5 vragen</span></a></li>\n<li><a href=\"#sportvoeding\">Sportvoeding & advies <span>7 vragen</span></a></li>\n<li><a href=\"#retourneren\">Retourneren & ruilen <span>4 vragen</span></a></li>\n<li><a href=\"#samenwerking\">Sponsoring & samenwerking <span>2 vragen</span></a></li>\n</ul>\n</nav>\n\n<!-- ═══════════════════════════════════════════════ -->\n<!-- CATEGORIE 1: BESTELLEN & VERZENDEN            -->\n<!-- ═══════════════════════════════════════════════ -->\n<section id=\"bestellen\">\n<h2><span class=\"svd-heading-line\">Bestellen & verzenden</span></h2>\n<div class=\"svd-section-intro\">Wij verzenden via DHL en PostNL. Lees alle details op onze <a href=\"https://sportvoedingdirect.nl/pages/bezorging-van-sportvoedingdirect\">verzendpagina</a>.</div>\n\n<div class=\"svd-faq-list\">\n\n<div class=\"svd-faq-item\"><details>\n<summary>Hoe plaats ik een bestelling?</summary>\n<div class=\"svd-faq-answer\">\n<p>Kies je producten, voeg ze toe aan je winkelmandje en klik op 'Afrekenen'. Volg de stappen op het scherm en je bent binnen een paar minuten klaar. Je ontvangt direct een bevestigingsmail met je bestelnummer.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Wat is de levertijd?</summary>\n<div class=\"svd-faq-answer\">\n<p>Bestel je op een werkdag <strong>vóór 13:00 uur</strong>, dan wordt je pakket doorgaans de volgende werkdag bezorgd. Bestellingen na 13:00 uur worden dezelfde avond verwerkt en meestal één werkdag later afgeleverd. In het weekend en op feestdagen kan de bezorging één extra werkdag duren.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Wat zijn de verzendkosten?</summary>\n<div class=\"svd-faq-answer\">\n<p>Bij een bestelling <strong>vanaf €50</strong> is de verzending gratis. Zit je daaronder, dan betaal je €5,95 verzendkosten. Het exacte tarief wordt altijd duidelijk getoond in je winkelmand en bij het afrekenen.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Kan ik mijn bestelling volgen met track & trace?</summary>\n<div class=\"svd-faq-answer\">\n<p>Ja. Zodra je bestelling ons magazijn verlaat, ontvang je een e-mail met een persoonlijke track & trace-link. Zo volg je je pakket stap voor stap. Heel kleine zendingen die als brievenbuspost gaan, kunnen zonder track & trace worden verzonden.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Kan ik mijn bestelling nog wijzigen of annuleren?</summary>\n<div class=\"svd-faq-answer\">\n<p>Dat kan, zolang je bestelling nog niet is ingepakt en verzonden. Neem zo snel mogelijk contact op via <a href=\"mailto:nu@sportvoedingdirect.nl\">nu@sportvoedingdirect.nl</a>. We doen ons best om het voor je te regelen.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Mijn bestelling is beschadigd of onvolledig?</summary>\n<div class=\"svd-faq-answer\">\n<p>Vervelend! Laat het ons meteen weten via <a href=\"mailto:nu@sportvoedingdirect.nl\">nu@sportvoedingdirect.nl</a>. We zorgen dat je snel de juiste producten ontvangt of dat je je geld terugkrijgt. Een foto van de schade helpt ons om dit sneller af te handelen.</p>\n</div>\n</details></div>\n\n</div>\n</section>\n\n<!-- ═══════════════════════════════════════════════ -->\n<!-- CATEGORIE 2: BETALEN & FACTURATIE              -->\n<!-- ═══════════════════════════════════════════════ -->\n<section id=\"betalen\">\n<h2><span class=\"svd-heading-line\">Betalen & facturatie</span></h2>\n\n<div class=\"svd-faq-list\">\n\n<div class=\"svd-faq-item\"><details>\n<summary>Welke betaalmethoden accepteren jullie?</summary>\n<div class=\"svd-faq-answer\">\n<p>Je kunt bij ons betalen met <strong>iDEAL</strong> en <strong>creditcard</strong>. Tijdens het afrekenen zie je welke opties voor jou beschikbaar zijn.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Is betalen bij SportvoedingDirect veilig?</summary>\n<div class=\"svd-faq-answer\">\n<p>Ja. We gebruiken de beveiligde betaalomgeving van Mollie, een betrouwbare payment provider. Je gegevens worden versleuteld verstuurd en wij slaan geen betaalgegevens op. Zo bestel je zorgeloos en veilig.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Kan ik achteraf betalen?</summary>\n<div class=\"svd-faq-answer\">\n<p>Nee, achteraf betalen is op dit moment niet mogelijk bij SportvoedingDirect. Je betaalt altijd vooraf via iDEAL of creditcard.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Ontvang ik een factuur bij mijn bestelling?</summary>\n<div class=\"svd-faq-answer\">\n<p>Ja, je krijgt altijd een digitale factuur per mail. Heb je die niet ontvangen of zoek je een oude factuur? Stuur een mailtje naar <a href=\"mailto:nu@sportvoedingdirect.nl\">nu@sportvoedingdirect.nl</a>, dan sturen we hem direct opnieuw.</p>\n</div>\n</details></div>\n\n</div>\n</section>\n\n<!-- ═══════════════════════════════════════════════ -->\n<!-- CATEGORIE 3: DIRECT+ & SPAARPUNTEN            -->\n<!-- ═══════════════════════════════════════════════ -->\n<section id=\"directplus\">\n<h2><span class=\"svd-heading-line\">Direct+ & spaarpunten</span></h2>\n\n<div class=\"svd-faq-list\">\n\n<div class=\"svd-faq-item\"><details>\n<summary>Wat is Direct+?</summary>\n<div class=\"svd-faq-answer\">\n<p>Direct+ is ons loyaliteitsprogramma voor trouwe klanten. Als Direct+ lid profiteer je standaard van <strong>hogere korting</strong> op alle sportvoeding en spaar je <strong>dubbel zo snel punten</strong>. Zo haal je nog meer uit jouw bestelling.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Hoe word ik Direct+ lid?</summary>\n<div class=\"svd-faq-answer\">\n<p>Je wordt automatisch Direct+ lid na het aanmaken van een account en het plaatsen van bestellingen. Log in op <a href=\"https://sportvoedingdirect.nl/account\">je account</a> om je status en punten in te zien.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Hoe werkt het spaarpuntensysteem?</summary>\n<div class=\"svd-faq-answer\">\n<p>Bij elke bestelling spaar je punten die je kunt inwisselen voor korting op je volgende aankoop. Als Direct+ lid spaar je dubbel zo snel. Je puntensaldo is zichtbaar in je account.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Kan ik een kortingscode combineren met Direct+ korting?</summary>\n<div class=\"svd-faq-answer\">\n<p>In de meeste gevallen is het niet mogelijk om een kortingscode te combineren met de standaard Direct+ korting. Je ontvangt altijd de hoogste korting die van toepassing is. Twijfel je? Neem gerust contact met ons op.</p>\n</div>\n</details></div>\n\n</div>\n</section>\n\n<!-- ═══════════════════════════════════════════════ -->\n<!-- CATEGORIE 4: PRODUCTEN & BEWAREN               -->\n<!-- ═══════════════════════════════════════════════ -->\n<section id=\"producten\">\n<h2><span class=\"svd-heading-line\">Producten & bewaren</span></h2>\n\n<div class=\"svd-faq-list\">\n\n<div class=\"svd-faq-item\"><details>\n<summary>Welke merken verkopen jullie?</summary>\n<div class=\"svd-faq-answer\">\n<p>Wij werken uitsluitend met topmerken die worden vertrouwd door (top)sporters: <a href=\"https://sportvoedingdirect.nl/collections/amacx\">Amacx</a>, <a href=\"https://sportvoedingdirect.nl/collections/maurten\">Maurten</a>, <a href=\"https://sportvoedingdirect.nl/collections/precision\">Precision Fuel & Hydration</a>, <a href=\"https://sportvoedingdirect.nl/collections/boost-your-energy\">BYE! Nutrition</a> en <a href=\"https://sportvoedingdirect.nl/collections/226ers\">226ERS</a>. Elk merk is zorgvuldig geselecteerd op kwaliteit, innovatie en betrouwbaarheid.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Zijn jullie producten geschikt voor veganisten?</summary>\n<div class=\"svd-faq-answer\">\n<p>Ja, een groot deel van ons assortiment is vegan. Dit geldt voor de meeste energiegels, sportdranken en veel energierepen. Check het 'vegan'-label op de productpagina. Twijfel je? Neem gerust <a href=\"mailto:nu@sportvoedingdirect.nl\">contact op</a> voor persoonlijk advies.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Wat betekent NZVT-gecertificeerd?</summary>\n<div class=\"svd-faq-answer\">\n<p>NZVT staat voor het <strong>Nederlands Zekerheidssysteem Voedingssupplementen Topsport</strong>. Het garandeert dat een product batchgewijs is gecontroleerd op de afwezigheid van dopinggeduide stoffen. Veel Amacx-producten zijn NZVT-gecertificeerd. 226ERS-producten zijn Cologne List®-gecertificeerd, een vergelijkbare internationale standaard.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Hoe lang zijn de producten houdbaar?</summary>\n<div class=\"svd-faq-answer\">\n<p>Dit verschilt per product. Wij hanteren een minimale houdbaarheidsdatum van <strong>4 maanden</strong> bij verzending. De meeste sportdranken, gels en repen zijn maandenlang houdbaar. De uiterste datum staat altijd op de verpakking.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Hoe bewaar ik mijn sportvoeding het beste?</summary>\n<div class=\"svd-faq-answer\">\n<p>Bewaar je sportvoeding op een <strong>koele, droge plaats</strong>, uit direct zonlicht. Sluit verpakkingen na gebruik goed af. Sportdrankpoeder is gevoelig voor vocht, bewaar het in een afgesloten pot of zak. Zo blijft de smaak optimaal en de voedingswaarde intact.</p>\n</div>\n</details></div>\n\n</div>\n</section>\n\n<!-- ═══════════════════════════════════════════════ -->\n<!-- CATEGORIE 5: SPORTVOEDING & ADVIES             -->\n<!-- ═══════════════════════════════════════════════ -->\n<section id=\"sportvoeding\">\n<h2><span class=\"svd-heading-line\">Sportvoeding & advies</span></h2>\n<div class=\"svd-section-intro\">Uitgebreide informatie over koolhydraten, ratio's en voedingsstrategieën vind je ook op onze <a href=\"https://sportvoedingdirect.nl/blogs/nieuws\">bloggids</a> en in onze collectiepagina's voor <a href=\"https://sportvoedingdirect.nl/collections/sportvoeding-met-2-1-ratio\">2:1 ratio</a> en <a href=\"https://sportvoedingdirect.nl/collections/sportvoeding-met-1-0-8-ratio\">1:0.8 ratio</a>.</div>\n\n<div class=\"svd-faq-list\">\n\n<div class=\"svd-faq-item\"><details>\n<summary>Hoeveel koolhydraten heb ik nodig per uur?</summary>\n<div class=\"svd-faq-answer\">\n<p>Dat hangt af van de duur en intensiteit van je inspanning. Een vuistregel:</p>\n<p><strong>Tot 1 uur:</strong> water en eventueel elektrolyten volstaan.</p>\n<p><strong>1-2,5 uur:</strong> 30-60 gram koolhydraten per uur.</p>\n<p><strong>Langer dan 2,5 uur:</strong> 60-90 gram per uur (met 2:1 ratio) of 80-120 gram per uur (met 1:0.8 ratio).</p>\n<p>Meer weten? Lees onze <a href=\"https://sportvoedingdirect.nl/blogs/nieuws/hoeveel-koolhydraten-per-uur-sportvoeding-gids\">complete gids over koolhydraten per uur</a>.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Wat is het verschil tussen de 2:1 en de 1:0.8 koolhydraatratio?</summary>\n<div class=\"svd-faq-answer\">\n<p>Beide ratio's combineren glucose en fructose om twee transportkanalen in je darmen te benutten.</p>\n<p>De <strong><a href=\"https://sportvoedingdirect.nl/collections/sportvoeding-met-2-1-ratio\">2:1 ratio</a></strong> is de bewezen gouden standaard, geschikt voor de meeste sporters, en maakt een opname tot <strong>90 gram per uur</strong> mogelijk.</p>\n<p>De <strong><a href=\"https://sportvoedingdirect.nl/collections/sportvoeding-met-1-0-8-ratio\">1:0.8 ratio</a></strong> is de nieuwste, geavanceerde verhouding die de opname kan verhogen tot <strong>120 gram per uur</strong>. Ideaal voor getrainde duursporters tijdens lange, intensieve inspanningen.</p>\n<p>Je kunt ze ook combineren. Lees meer in ons <a href=\"https://sportvoedingdirect.nl/blogs/nieuws/koolhydraatratio-1-0-8-vs-2-1-sportdrank\">uitgebreide blog over koolhydraatratio's</a>.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Hoe kies ik de juiste sportvoeding voor mijn sport?</summary>\n<div class=\"svd-faq-answer\">\n<p>Kijk naar de <strong>duur en intensiteit</strong> van je inspanning:</p>\n<p><strong>Korte trainingen (tot 1,5 uur):</strong> een sportdrank met elektrolyten en eventueel één energiegel is voldoende.</p>\n<p><strong>Lange duurinspanningen (2+ uur):</strong> combineer een isotone sportdrank met energiegels en/of repen. Streef naar 60-90g koolhydraten per uur.</p>\n<p><strong>Na inspanning:</strong> neem een <a href=\"https://sportvoedingdirect.nl/collections/herstel\">herstelshake</a> met eiwitten en koolhydraten binnen 30-45 minuten.</p>\n<p>Kom je er niet uit? Stuur ons gerust een berichtje via <a href=\"mailto:nu@sportvoedingdirect.nl\">nu@sportvoedingdirect.nl</a> – we zoeken samen de perfecte match.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Wat is 'train your gut' en waarom is het belangrijk?</summary>\n<div class=\"svd-faq-answer\">\n<p>'Train your gut' betekent dat je je maag-darmstelsel geleidelijk went aan het opnemen van koolhydraten tijdens inspanning. Net zoals je je spieren traint, kun je ook je darmen trainen om meer energie te verwerken.</p>\n<p>Begin met <strong>30-40 gram per uur</strong> tijdens rustige trainingen en verhoog stapsgewijs naar je wedstrijddosis over meerdere weken. Probeer nooit een nieuwe inname of een nieuw product voor het eerst op wedstrijddag.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Wat is het verschil tussen een energiegel en een energiereep?</summary>\n<div class=\"svd-faq-answer\">\n<p><strong><a href=\"https://sportvoedingdirect.nl/collections/energiegels\">Energiegels</a></strong> leveren snelle, vloeibare energie en zijn makkelijk in te nemen bij hoge intensiteit. Ideaal voor de tweede helft van een wedstrijd, wanneer kauwen lastiger wordt.</p>\n<p><strong><a href=\"https://sportvoedingdirect.nl/collections/energierepen\">Energierepen</a></strong> zijn vaste voeding die geleidelijk energie afgeeft. Ideaal voor de eerste fase van een lange inspanning, wanneer kauwen nog comfortabel is.</p>\n<p>De beste strategie is een mix van beiden: start met repen en wissel gedurende de inspanning over naar gels.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Welke producten helpen bij spierherstel?</summary>\n<div class=\"svd-faq-answer\">\n<p>Een goede <a href=\"https://sportvoedingdirect.nl/collections/herstel\">herstelshake</a> combineert eiwitten (voor spieropbouw) met koolhydraten (voor glycogeenherstel). Neem je shake bij voorkeur <strong>binnen 30-45 minuten</strong> na inspanning.</p>\n<p>Populaire keuzes zijn de <a href=\"https://sportvoedingdirect.nl/products/amacx-recovery-shake\">Amacx Recovery Shake</a> (20g eiwit + 30g koolhydraten) en de <a href=\"https://sportvoedingdirect.nl/products/bye-all-in-one-recovery\">BYE! All-in-One Recovery</a> (met 22 vitamines & mineralen).</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Hebben jullie een energiegel die ik kan drinken zonder water?</summary>\n<div class=\"svd-faq-answer\">\n<p>Ja! De <a href=\"https://sportvoedingdirect.nl/products/amacx-drink-gel\">Amacx Drink Gel</a> is een drinkbare, isotone gel die je zonder extra water inneemt. Met 30g koolhydraten in de 2:1 ratio is het een van onze bestverkochte producten. Ook de <a href=\"https://sportvoedingdirect.nl/products/226ers-isotonic-gel\">226ERS Isotonic Gel</a> (22g koolhydraten, cyclodextrine) hoeft niet met water te worden ingenomen.</p>\n</div>\n</details></div>\n\n</div>\n</section>\n\n<!-- ═══════════════════════════════════════════════ -->\n<!-- CATEGORIE 6: RETOURNEREN & RUILEN              -->\n<!-- ═══════════════════════════════════════════════ -->\n<section id=\"retourneren\">\n<h2><span class=\"svd-heading-line\">Retourneren & ruilen</span></h2>\n\n<div class=\"svd-faq-list\">\n\n<div class=\"svd-faq-item\"><details>\n<summary>Kan ik mijn bestelling retourneren?</summary>\n<div class=\"svd-faq-answer\">\n<p>Ja. Bij SportvoedingDirect geldt de wettelijke bedenktijd van <strong>14 dagen</strong>. Neem contact op via <a href=\"mailto:nu@sportvoedingdirect.nl\">nu@sportvoedingdirect.nl</a>, dan sturen we je de retourinstructies.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Hoe werkt het retourproces?</summary>\n<div class=\"svd-faq-answer\">\n<p>Meld je retour aan bij ons, pak de producten zorgvuldig in en stuur ze terug naar het adres dat we je geven. Zodra wij je pakketje ontvangen, verwerken we de retour en krijg je een bevestiging per mail.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Hoe lang duurt het voordat mijn geld wordt teruggestort?</summary>\n<div class=\"svd-faq-answer\">\n<p>Meestal heb je je geld binnen <strong>5 werkdagen</strong> terug, afhankelijk van je bank of betaalmethode. We houden je via mail op de hoogte.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Kan ik een geopend product terugsturen?</summary>\n<div class=\"svd-faq-answer\">\n<p>Als de verzegeling of verpakking open is, kunnen we het product helaas niet meer verkopen. We accepteren daarom alleen ongeopende producten, tenzij er een duidelijke kwaliteitsklacht is. Twijfel je? Neem contact op – we zoeken graag samen een oplossing.</p>\n</div>\n</details></div>\n\n</div>\n</section>\n\n<!-- ═══════════════════════════════════════════════ -->\n<!-- CATEGORIE 7: SPONSORING & SAMENWERKING         -->\n<!-- ═══════════════════════════════════════════════ -->\n<section id=\"samenwerking\">\n<h2><span class=\"svd-heading-line\">Sponsoring & samenwerking</span></h2>\n\n<div class=\"svd-faq-list\">\n\n<div class=\"svd-faq-item\"><details>\n<summary>Bieden jullie een ambassadeurs- of sponsorprogramma aan?</summary>\n<div class=\"svd-faq-answer\">\n<p>Ja! We werken graag samen met sporters en teams die onze passie voor topprestaties delen. Of je nu een fanatieke triatleet, wielrenner of hardloper bent – stuur ons je verhaal. Dat kan via ons <a href=\"https://sportvoedingdirect.nl/pages/ambassadeur-worden\">ambassadeursprogramma</a>.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Hoe kan ik een sponsoraanvraag indienen?</summary>\n<div class=\"svd-faq-answer\">\n<p>Ga naar onze <a href=\"https://sportvoedingdirect.nl/pages/ambassadeur-worden\">ambassadeurspagina</a> en vul het aanvraagformulier in. Vertel ons over je sport, je doelen en waarom je bij SportvoedingDirect past. We nemen zo snel mogelijk contact met je op. Bekijk ook onze <a href=\"https://sportvoedingdirect.nl/pages/onze-partners\">huidige partners & sporters</a>.</p>\n</div>\n</details></div>\n\n</div>\n</section>\n\n<!-- ═══ CTA ═══ -->\n<div class=\"svd-cta-card\">\n<h2>Staat je vraag er niet bij?</h2>\n<p>Ons team staat klaar om je persoonlijk te helpen met productadvies, bestellingen of wat je verder nodig hebt.</p>\n<a class=\"svd-cta-btn\" href=\"mailto:nu@sportvoedingdirect.nl\">Mail ons: nu@sportvoedingdirect.nl</a>\n</div>\n\n</div>\n\n<script type=\"application/ld+json\">\n{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Hoe plaats ik een bestelling?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Kies je producten, voeg ze toe aan je winkelmandje en klik op 'Afrekenen'. Volg de stappen op het scherm en je bent binnen een paar minuten klaar. Je ontvangt direct een bevestigingsmail met je bestelnummer.\"}},{\"@type\":\"Question\",\"name\":\"Wat is de levertijd?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Bestel je op een werkdag vóór 13:00 uur, dan wordt je pakket doorgaans de volgende werkdag bezorgd. Bestellingen na 13:00 uur worden dezelfde avond verwerkt en meestal één werkdag later afgeleverd. In het weekend en op feestdagen kan de bezorging één extra werkdag duren.\"}},{\"@type\":\"Question\",\"name\":\"Wat zijn de verzendkosten?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Bij een bestelling vanaf €50 is de verzending gratis. Zit je daaronder, dan betaal je €5,95 verzendkosten.\"}},{\"@type\":\"Question\",\"name\":\"Kan ik mijn bestelling volgen met track & trace?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Ja. Zodra je bestelling ons magazijn verlaat, ontvang je een e-mail met een persoonlijke track & trace-link. Zo volg je je pakket stap voor stap.\"}},{\"@type\":\"Question\",\"name\":\"Kan ik mijn bestelling nog wijzigen of annuleren?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Dat kan, zolang je bestelling nog niet is ingepakt en verzonden. Neem zo snel mogelijk contact op via nu@sportvoedingdirect.nl.\"}},{\"@type\":\"Question\",\"name\":\"Mijn bestelling is beschadigd of onvolledig – wat nu?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Laat het ons meteen weten via nu@sportvoedingdirect.nl. We zorgen dat je snel de juiste producten ontvangt of dat je je geld terugkrijgt. Een foto van de schade helpt ons om dit sneller af te handelen.\"}},{\"@type\":\"Question\",\"name\":\"Welke betaalmethoden accepteren jullie?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Je kunt bij ons betalen met iDEAL en creditcard. Tijdens het afrekenen zie je welke opties voor jou beschikbaar zijn.\"}},{\"@type\":\"Question\",\"name\":\"Is betalen bij SportvoedingDirect veilig?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Ja. We gebruiken de beveiligde betaalomgeving van Mollie, een betrouwbare payment provider. Je gegevens worden versleuteld verstuurd en wij slaan geen betaalgegevens op.\"}},{\"@type\":\"Question\",\"name\":\"Kan ik achteraf betalen?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Nee, achteraf betalen is op dit moment niet mogelijk bij SportvoedingDirect. Je betaalt altijd vooraf via iDEAL of creditcard.\"}},{\"@type\":\"Question\",\"name\":\"Ontvang ik een factuur bij mijn bestelling?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Ja, je krijgt altijd een digitale factuur per mail. Heb je die niet ontvangen? Stuur een mailtje naar nu@sportvoedingdirect.nl, dan sturen we hem direct opnieuw.\"}},{\"@type\":\"Question\",\"name\":\"Wat is Direct+?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Direct+ is ons loyaliteitsprogramma voor trouwe klanten. Als Direct+ lid profiteer je standaard van hogere korting op alle sportvoeding en spaar je dubbel zo snel punten.\"}},{\"@type\":\"Question\",\"name\":\"Hoe word ik Direct+ lid?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Je wordt automatisch Direct+ lid na het aanmaken van een account en het plaatsen van bestellingen. Log in op je account om je status en punten in te zien.\"}},{\"@type\":\"Question\",\"name\":\"Hoe werkt het spaarpuntensysteem?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Bij elke bestelling spaar je punten die je kunt inwisselen voor korting op je volgende aankoop. Als Direct+ lid spaar je dubbel zo snel.\"}},{\"@type\":\"Question\",\"name\":\"Kan ik een kortingscode combineren met Direct+ korting?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"In de meeste gevallen is het niet mogelijk om een kortingscode te combineren met de standaard Direct+ korting. Je ontvangt altijd de hoogste korting die van toepassing is.\"}},{\"@type\":\"Question\",\"name\":\"Welke merken verkopen jullie?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Wij werken uitsluitend met topmerken: Amacx, Maurten, Precision Fuel & Hydration, BYE! Nutrition en 226ERS. Elk merk is zorgvuldig geselecteerd op kwaliteit, innovatie en betrouwbaarheid.\"}},{\"@type\":\"Question\",\"name\":\"Zijn jullie producten geschikt voor veganisten?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Ja, een groot deel van ons assortiment is vegan. Dit geldt voor de meeste energiegels, sportdranken en veel energierepen. Check het vegan-label op de productpagina.\"}},{\"@type\":\"Question\",\"name\":\"Wat betekent NZVT-gecertificeerd?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"NZVT staat voor het Nederlands Zekerheidssysteem Voedingssupplementen Topsport. Het garandeert dat een product batchgewijs is gecontroleerd op de afwezigheid van dopinggeduide stoffen. 226ERS-producten zijn Cologne List-gecertificeerd, een vergelijkbare internationale standaard.\"}},{\"@type\":\"Question\",\"name\":\"Hoe lang zijn de producten houdbaar?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Dit verschilt per product. Wij hanteren een minimale houdbaarheidsdatum van 4 maanden bij verzending. De meeste sportdranken, gels en repen zijn maandenlang houdbaar.\"}},{\"@type\":\"Question\",\"name\":\"Hoe bewaar ik mijn sportvoeding het beste?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Bewaar je sportvoeding op een koele, droge plaats, uit direct zonlicht. Sluit verpakkingen na gebruik goed af.\"}},{\"@type\":\"Question\",\"name\":\"Hoeveel koolhydraten heb ik nodig per uur?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Tot 1 uur: water en eventueel elektrolyten volstaan. 1-2,5 uur: 30-60 gram koolhydraten per uur. Langer dan 2,5 uur: 60-90 gram per uur (met 2:1 ratio) of 80-120 gram per uur (met 1:0.8 ratio).\"}},{\"@type\":\"Question\",\"name\":\"Wat is het verschil tussen de 2:1 en de 1:0.8 koolhydraatratio?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Beide ratio's combineren glucose en fructose. De 2:1 ratio is de bewezen gouden standaard voor opname tot 90 gram per uur. De 1:0.8 ratio is de nieuwste verhouding die de opname kan verhogen tot 120 gram per uur, ideaal voor getrainde duursporters.\"}},{\"@type\":\"Question\",\"name\":\"Hoe kies ik de juiste sportvoeding voor mijn sport?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Kijk naar de duur en intensiteit van je inspanning. Korte trainingen (tot 1,5 uur): een sportdrank met elektrolyten is voldoende. Lange duurinspanningen (2+ uur): combineer sportdrank met energiegels en repen. Na inspanning: neem een herstelshake binnen 30-45 minuten.\"}},{\"@type\":\"Question\",\"name\":\"Wat is 'train your gut' en waarom is het belangrijk?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Train your gut betekent dat je je maag-darmstelsel geleidelijk went aan het opnemen van koolhydraten tijdens inspanning. Begin met 30-40 gram per uur en verhoog stapsgewijs. Probeer nooit een nieuwe inname voor het eerst op wedstrijddag.\"}},{\"@type\":\"Question\",\"name\":\"Wat is het verschil tussen een energiegel en een energiereep?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Energiegels leveren snelle, vloeibare energie en zijn makkelijk in te nemen bij hoge intensiteit. Energierepen zijn vaste voeding die geleidelijk energie afgeeft, ideaal voor de eerste fase van een lange inspanning.\"}},{\"@type\":\"Question\",\"name\":\"Welke producten helpen bij spierherstel?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Een goede herstelshake combineert eiwitten met koolhydraten. Neem je shake bij voorkeur binnen 30-45 minuten na inspanning. Populaire keuzes zijn de Amacx Recovery Shake en de BYE! All-in-One Recovery.\"}},{\"@type\":\"Question\",\"name\":\"Hebben jullie een energiegel die ik kan drinken zonder water?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Ja! De Amacx Drink Gel is een drinkbare, isotone gel die je zonder extra water inneemt, met 30g koolhydraten. Ook de 226ERS Isotonic Gel hoeft niet met water te worden ingenomen.\"}},{\"@type\":\"Question\",\"name\":\"Kan ik mijn bestelling retourneren?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Ja. Bij SportvoedingDirect geldt de wettelijke bedenktijd van 14 dagen. Neem contact op via nu@sportvoedingdirect.nl voor de retourinstructies.\"}},{\"@type\":\"Question\",\"name\":\"Hoe werkt het retourproces?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Meld je retour aan, pak de producten zorgvuldig in en stuur ze terug. Zodra wij je pakketje ontvangen, verwerken we de retour en krijg je een bevestiging per mail.\"}},{\"@type\":\"Question\",\"name\":\"Hoe lang duurt het voordat mijn geld wordt teruggestort?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Meestal heb je je geld binnen 5 werkdagen terug, afhankelijk van je bank of betaalmethode.\"}},{\"@type\":\"Question\",\"name\":\"Kan ik een geopend product terugsturen?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Als de verzegeling open is, kunnen we het product niet meer verkopen. We accepteren alleen ongeopende producten, tenzij er een duidelijke kwaliteitsklacht is.\"}},{\"@type\":\"Question\",\"name\":\"Bieden jullie een ambassadeurs- of sponsorprogramma aan?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Ja! We werken graag samen met sporters en teams. Stuur ons je verhaal via ons ambassadeursprogramma op sportvoedingdirect.nl/pages/ambassadeur-worden.\"}},{\"@type\":\"Question\",\"name\":\"Hoe kan ik een sponsoraanvraag indienen?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Ga naar onze ambassadeurspagina en vul het aanvraagformulier in. Vertel ons over je sport, je doelen en waarom je bij SportvoedingDirect past.\"}}]}\n</script>",
