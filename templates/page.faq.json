          }
        },
        "question_FjVgyp": {
          "type": "question",
          "settings": {
            "question": "Ontvang ik een factuur bij mijn bestelling?  ",
            "answer": "<p>Zeker! Je krijgt altijd een digitale factuur per mail. Heb je die niet ontvangen of zoek je een oude factuur? Laat het ons weten, dan sturen we ‘m direct nog een keer.</p>",
            "icon": "none",
