        "question_MGcLYf": {
          "type": "question",
          "settings": {
            "question": "Welke betaalmethoden accepteren jullie? ",
            "answer": "<p>Je kunt bij ons betalen met iDEAL en creditcard. Tijdens het afrekenen zie je vanzelf welke opties voor jou beschikbaar zijn.</p>",
            "icon": "none",
            "icon_width": 24,
            "mobile_icon_width": 20
          }
        },
        "question_WxmAGp": {
          "type": "question",
          "settings": {
            "question": "Is betalen veilig bij SportvoedingDirect.nl?  ",
            "answer": "<p>Ja. We gebruiken beveiligde betaalomgevingen van Mollie een betrouwbare payment provider. Zo bestel je zorgeloos en veilig bij sportvoedingdirect.</p>",
            "icon": "none",
            "icon_width": 24,
