{"sections":{"main":{"type":"main-page","disabled":true,"settings":{"color_scheme":"scheme-2","show_title":false,"content_width":"md"}},"custom_liquid_RUh7yr":{"type":"custom-liquid","name":"t:sections.custom_liquid.name","settings":{"color_scheme":"","liquid":"\u003cstyle\u003e\n    #planner-container { font-family: Arial, sans-serif; color: #333; margin: 0 auto; padding: 2em 0; }\n    #planner-form { background: white; padding: 2em; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); width: 100%; max-width: 600px; margin: 0 auto; }\n    #planner-form h1 { text-align: center; color: #333; margin-bottom: 1.5em; font-size: 1.8em; }\n    .form-step { display: none; }\n    .form-step.active-step { display: block; }\n    .form-group { margin-bottom: 1.5em; }\n    .form-group label { display: block; font-weight: bold; margin-bottom: 0.5em; }\n    .form-group p { margin-top: 0; font-size: 0.9em; color: #666; }\n    input[type=\"text\"], input[type=\"email\"], input[type=\"number\"], input[type=\"date\"], select { width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; margin-bottom: 0.5em; transition: border-color .3s, box-shadow .3s; }\n    input:focus, select:focus { border-color: #d9ff36; box-shadow: 0 0 5px rgba(217, 255, 54, 0.5); outline: none; }\n    input::placeholder { color: #999; opacity: 1; }\n    .radio-group, .radio-group-vertical { display: flex; flex-wrap: wrap; gap: 1em; align-items: center; }\n    .radio-group-vertical { flex-direction: column; gap: 1em; align-items: flex-start; }\n    .radio-group-vertical label, .radio-group label { display: flex; align-items: center; cursor: pointer; }\n    .checkbox-group label { font-weight: normal; margin-bottom: 0; cursor: pointer; }\n    input[type=\"radio\"], input[type=\"checkbox\"] { appearance: none; -webkit-appearance: none; -moz-appearance: none; width: 1.3em; height: 1.3em; border: 2px solid #dbb8ff; border-radius: 50%; margin-right: 0.5em; cursor: pointer; position: relative; transition: background-color 0.2s, border-color 0.2s; flex-shrink: 0; }\n    input[type=\"checkbox\"] { border-radius: 4px; }\n    input[type=\"radio\"]:checked, input[type=\"checkbox\"]:checked { background-color: #d9ff36; border-color: #d9ff36; }\n    input[type=\"radio\"]:checked::after { content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 0.6em; height: 0.6em; border-radius: 50%; background: #000; }\n    input[type=\"checkbox\"]:checked::after { content: '✔'; position: absolute; color: #000; font-size: 1em; font-weight: bold; top: 50%; left: 50%; transform: translate(-50%, -55%); }\n    .time-inputs span { display: block; margin-bottom: 10px; }\n    .time-inputs input { width: 60px; text-align: center; }\n    .button-group { display: flex; justify-content: space-between; margin-top: 2em; }\n    button { padding: 12px 25px; border: none; border-radius: 4px; cursor: pointer; font-size: 1em; font-weight: bold; transition: background-color .3s; }\n    #prev-btn { background-color: #dbb8ff; color: #000; }\n    #next-btn, #submit-btn { background-color: #d9ff36; color: #000; }\n    #next-btn:hover, #submit-btn:hover { background-color: #c3e631; }\n    #prev-btn:hover { background-color: #c9a2e6; }\n    .hidden { display: none; }\n    .conditional-group { display: none; }\n    #result-plan { background: white; padding: 2em; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); width: 100%; max-width: 600px; margin: 2em auto; }\n    #result-plan h2 { color: #333; text-align: center; }\n    #result-plan h3 { color: #dbb8ff; border-bottom: 2px solid #f0f0f0; padding-bottom: 5px; margin-top: 1.5em; }\n    #result-plan ul { list-style: none; padding: 0; }\n    #result-plan li { background: #f9f9f9; border: 1px solid #eee; border-radius: 4px; padding: 10px; margin-bottom: 10px; }\n    #result-plan li strong { display: block; margin-bottom: 5px; }\n    #result-plan .fallback-note { font-style: italic; font-size: 0.9em; color: #666; margin-top: 5px; }\n    #result-plan .disclaimer { font-size: 0.8em; text-align: center; color: #777; margin-top: 2em; }\n\u003c\/style\u003e\n\n\u003cdiv id=\"planner-container\"\u003e\n    \u003cform id=\"planner-form\"\u003e\n        \u003ch1\u003eStel jouw persoonlijke brandstof- \u0026 hydratatieplan samen\u003c\/h1\u003e\n        \n        \u003cdiv class=\"form-step active-step\"\u003e\n            \u003cdiv class=\"form-group\"\u003e\n                \u003clabel for=\"sport\"\u003eVoor welke sport maak je een plan?\u003c\/label\u003e\n                \u003cselect id=\"sport\" name=\"sport\" required\u003e\n                    \u003coption value=\"\"\u003e-- Kies een sport --\u003c\/option\u003e\n                    \u003coption value=\"triathlon\"\u003eTriathlon\u003c\/option\u003e\n                    \u003coption value=\"running\"\u003eHardlopen\u003c\/option\u003e\n                    \u003coption value=\"cycling\"\u003eWielrennen\u003c\/option\u003e\n                    \u003coption value=\"swimrun\"\u003eSwimrun\u003c\/option\u003e\n                    \u003coption value=\"other\"\u003eAnders\u003c\/option\u003e\n                \u003c\/select\u003e\n            \u003c\/div\u003e\n        \u003c\/div\u003e\n\n        \u003cdiv class=\"form-step\"\u003e\n            \u003cdiv id=\"triathlon-questions\" class=\"conditional-group\"\u003e\n                \u003cdiv class=\"form-group\"\u003e\u003clabel for=\"triathlon-distance\"\u003eWelke afstand doe je?\u003c\/label\u003e\u003cselect id=\"triathlon-distance\" name=\"triathlon-distance\"\u003e\u003coption value=\"sprint\"\u003eSprint\u003c\/option\u003e\u003coption value=\"olympic\"\u003eOlympische Afstand\u003c\/option\u003e\u003coption value=\"middle\"\u003eMiddenafstand (70.3)\u003c\/option\u003e\u003coption value=\"full\"\u003eHele Afstand (140.6)\u003c\/option\u003e\u003c\/select\u003e\u003c\/div\u003e\n            \u003c\/div\u003e\n            \u003cdiv id=\"running-questions\" class=\"conditional-group\"\u003e\n                \u003cdiv class=\"form-group\"\u003e\u003clabel for=\"running-distance\"\u003eWelke afstand loop je?\u003c\/label\u003e\u003cselect id=\"running-distance\" name=\"running-distance\"\u003e\u003coption value=\"5k\"\u003e5km\u003c\/option\u003e\u003coption value=\"10k\"\u003e10km\u003c\/option\u003e\u003coption value=\"half-marathon\"\u003eHalve Marathon\u003c\/option\u003e\u003coption value=\"marathon\"\u003eMarathon\u003c\/option\u003e\u003coption value=\"50k\"\u003e50km\u003c\/option\u003e\u003coption value=\"50m\"\u003e50 mijl\u003c\/option\u003e\u003coption value=\"100k\"\u003e100km\u003c\/option\u003e\u003coption value=\"100m\"\u003e100 mijl\u003c\/option\u003e\u003c\/select\u003e\u003c\/div\u003e\n            \u003c\/div\u003e\n            \u003cdiv id=\"cycling-questions\" class=\"conditional-group\"\u003e\n                \u003cdiv class=\"form-group\"\u003e\u003clabel for=\"cycling-type\"\u003eWat voor soort rit maak je?\u003c\/label\u003e\u003cselect id=\"cycling-type\" name=\"cycling-type\"\u003e\u003coption value=\"time-trial\"\u003eTijdrit\u003c\/option\u003e\u003coption value=\"road\"\u003eWegrit\u003c\/option\u003e\u003coption value=\"gravel\"\u003eGravel\u003c\/option\u003e\u003coption value=\"mtb\"\u003eMTB\u003c\/option\u003e\u003c\/select\u003e\u003c\/div\u003e\n                \u003cdiv class=\"form-group\"\u003e\u003clabel for=\"cycling-distance\"\u003eTotale afstand (in km):\u003c\/label\u003e\u003cinput type=\"number\" id=\"cycling-distance\" name=\"cycling-distance\" min=\"1\" max=\"500\" placeholder=\"bv. 120\"\u003e\u003c\/div\u003e\n            \u003c\/div\u003e\n        \u003c\/div\u003e\n\n        \u003cdiv class=\"form-step\"\u003e\n            \u003cdiv class=\"form-group\"\u003e\n                \u003clabel\u003eHeb je een voorkeursmerk?\u003c\/label\u003e\n                \u003cdiv class=\"radio-group-vertical\"\u003e\n                    \u003clabel\u003e\u003cinput type=\"radio\" name=\"brand\" value=\"any\" checked\u003eGeen voorkeur\u003c\/label\u003e\n                    \u003clabel\u003e\u003cinput type=\"radio\" name=\"brand\" value=\"precision\"\u003ePrecision\u003c\/label\u003e\n                    \u003clabel\u003e\u003cinput type=\"radio\" name=\"brand\" value=\"amacx\"\u003eAmacx\u003c\/label\u003e\n                    \u003clabel\u003e\u003cinput type=\"radio\" name=\"brand\" value=\"maurten\"\u003eMaurten\u003c\/label\u003e\n                    \u003clabel\u003e\u003cinput type=\"radio\" name=\"brand\" value=\"bye\"\u003eBYE\u003c\/label\u003e\n                \u003c\/div\u003e\n            \u003c\/div\u003e\n        \u003c\/div\u003e\n\n        \u003cdiv class=\"form-step\"\u003e\n            \u003cdiv class=\"form-group\"\u003e\u003clabel\u003eWat zijn de verwachte weersomstandigheden?\u003c\/label\u003e\u003cdiv class=\"radio-group\"\u003e\u003clabel\u003e\u003cinput type=\"radio\" name=\"conditions\" value=\"cold\"\u003eKoud (\u0026lt;10°C)\u003c\/label\u003e\u003clabel\u003e\u003cinput type=\"radio\" name=\"conditions\" value=\"mild\"\u003eGematigd (10-20°C)\u003c\/label\u003e\u003clabel\u003e\u003cinput type=\"radio\" name=\"conditions\" value=\"hot\"\u003eWarm (20-28°C)\u003c\/label\u003e\u003clabel\u003e\u003cinput type=\"radio\" name=\"conditions\" value=\"very-hot\"\u003eErg heet (\u0026gt;28°C)\u003c\/label\u003e\u003c\/div\u003e\u003c\/div\u003e\n        \u003c\/div\u003e\n        \n        \u003cdiv class=\"form-step\"\u003e\n            \u003cdiv class=\"form-group\"\u003e\u003clabel\u003eHoe ga je de race aanpakken?\u003c\/label\u003e\u003cp\u003eKies de uitspraak die het beste bij je past.\u003c\/p\u003e\u003cdiv class=\"radio-group-vertical\"\u003e\u003clabel\u003e\u003cinput type=\"radio\" name=\"approach\" value=\"fun\"\u003e\"Ik wil gewoon finishen en plezier hebben\"\u003c\/label\u003e\u003clabel\u003e\u003cinput type=\"radio\" name=\"approach\" value=\"hard\"\u003e\"Ik ga mijn best doen, maar niet tot het uiterste\"\u003c\/label\u003e\u003clabel\u003e\u003cinput type=\"radio\" name=\"approach\" value=\"limit\"\u003e\"Ik ben van plan om op mijn absolute limiet te racen\"\u003c\/label\u003e\u003c\/div\u003e\u003c\/div\u003e\n        \u003c\/div\u003e\n        \n        \u003cdiv class=\"form-step\" id=\"sprint-times-step\"\u003e\n             \u003cdiv class=\"form-group\"\u003e\u003clabel\u003eWat zijn je streeftijden?\u003c\/label\u003e\u003cdiv class=\"time-inputs\"\u003e\u003cspan\u003eZwemmen: \u003cinput type=\"number\" name=\"swim_hr\" min=\"0\" max=\"2\" placeholder=\"uu\" value=\"0\"\u003e: \u003cinput type=\"number\" name=\"swim_min\" min=\"0\" max=\"59\" placeholder=\"mm\" value=\"20\"\u003e\u003c\/span\u003e\u003cspan\u003eFietsen: \u003cinput type=\"number\" name=\"bike_hr\" min=\"0\" max=\"5\" placeholder=\"uu\" value=\"1\"\u003e: \u003cinput type=\"number\" name=\"bike_min\" min=\"0\" max=\"59\" placeholder=\"mm\" value=\"0\"\u003e\u003c\/span\u003e\u003cspan\u003eLopen: \u003cinput type=\"number\" name=\"run_hr\" min=\"0\" max=\"5\" placeholder=\"uu\" value=\"0\"\u003e: \u003cinput type=\"number\" name=\"run_min\" min=\"0\" max=\"59\" placeholder=\"mm\" value=\"45\"\u003e\u003c\/span\u003e\u003c\/div\u003e\u003c\/div\u003e\n        \u003c\/div\u003e\n        \n        \u003cdiv class=\"form-step\"\u003e\n            \u003cdiv class=\"form-group\"\u003e\u003clabel for=\"cramps\"\u003eHoe vaak heb je last van spierkramp?\u003c\/label\u003e\u003cselect id=\"cramps\" name=\"cramps\"\u003e\u003coption value=\"never\"\u003eNooit\u003c\/option\u003e\u003coption value=\"rarely\"\u003eZelden\u003c\/option\u003e\u003coption value=\"sometimes\"\u003eSoms\u003c\/option\u003e\u003coption value=\"often\"\u003eVaak\u003c\/option\u003e\u003c\/select\u003e\u003c\/div\u003e\n        \u003c\/div\u003e\n        \n        \u003cdiv class=\"form-step\"\u003e\n            \u003cdiv class=\"form-group\"\u003e\u003clabel\u003eEen beetje over jou\u003c\/label\u003e\u003cinput type=\"date\" name=\"dob\" placeholder=\"Geboortedatum\"\u003e\u003cinput type=\"number\" name=\"weight\" placeholder=\"Gewicht (in kg)\"\u003e\u003cselect name=\"sex\"\u003e\u003coption value=\"male\"\u003eMan\u003c\/option\u003e\u003coption value=\"female\"\u003eVrouw\u003c\/option\u003e\u003coption value=\"prefer-not-say\"\u003eZeg ik liever niet\u003c\/option\u003e\u003c\/select\u003e\u003c\/div\u003e\n            \u003cdiv class=\"form-group\"\u003e\u003clabel\u003eVertel ons waar we je plan naartoe kunnen sturen\u003c\/label\u003e\u003cinput type=\"text\" name=\"firstName\" placeholder=\"Voornaam\" required\u003e\u003cinput type=\"text\" name=\"lastName\" placeholder=\"Achternaam\" required\u003e\u003cinput type=\"email\" name=\"email\" placeholder=\"E-mailadres\" required\u003e\u003c\/div\u003e\n            \u003cdiv class=\"form-group checkbox-group\"\u003e\u003clabel\u003e\u003cinput type=\"checkbox\" id=\"consent\" name=\"consent\" required\u003eGebruik deze gegevens om mijn plan te maken. Ik ben ouder dan 16 of heb toestemming van mijn ouders.\u003c\/label\u003e\u003c\/div\u003e\n            \u003cdiv class=\"form-group checkbox-group\"\u003e\u003clabel\u003e\u003cinput type=\"checkbox\" id=\"send-plan\" name=\"send-plan\" checked\u003eStuur mijn nieuwe plan per e-mail en een korte serie e-mails met uitleg over mijn nieuwe strategie.\u003c\/label\u003e\u003c\/div\u003e\n            \u003cdiv class=\"form-group checkbox-group\"\u003e\u003clabel\u003e\u003cinput type=\"checkbox\" id=\"send-advice\" name=\"send-advice\"\u003eStuur me regelmatig prestatie-advies e-mails, met tips van experts en topsporters.\u003c\/label\u003e\u003c\/div\u003e\n        \u003c\/div\u003e\n        \n        \u003cdiv class=\"button-group\"\u003e\n            \u003cbutton type=\"button\" id=\"prev-btn\" class=\"hidden\"\u003eVorige\u003c\/button\u003e\n            \u003cbutton type=\"button\" id=\"next-btn\"\u003eVolgende\u003c\/button\u003e\n            \u003cbutton type=\"submit\" id=\"submit-btn\" class=\"hidden\"\u003eMaak mijn plan\u003c\/button\u003e\n        \u003c\/div\u003e\n    \u003c\/form\u003e\n    \n    \u003cdiv id=\"result-plan\" style=\"display: none;\"\u003e\u003c\/div\u003e\n\u003c\/div\u003e\n\n\u003cscript\u003e\ndocument.addEventListener('DOMContentLoaded', () =\u003e {\n    const allProducts = [\n        { id: 'p_pf30_gel', brand: 'precision', name: 'Precision PF 30 Gel', url: 'https:\/\/sportvoedingdirect.nl\/products\/precision-pf-30-gel', type: 'gel', carbs: 30, caffeine: 0 },\n        { id: 'p_pf30_caffeine_gel', brand: 'precision', name: 'Precision PF 30 Cafeïne Gel', url: 'https:\/\/sportvoedingdirect.nl\/products\/precision-pf-30-caffeine-gel', type: 'gel', carbs: 30, caffeine: 100 },\n        { id: 'p_ph1500', brand: 'precision', name: 'Precision PH 1500 Tabletten', url: 'https:\/\/sportvoedingdirect.nl\/products\/precision-ph-1500-electrolyte-tablets', type: 'elektrolyten', strength: 1500 },\n        { id: 'p_ph1000', brand: 'precision', name: 'Precision PH 1000 Tabletten', url: 'https:\/\/sportvoedingdirect.nl\/products\/precision-ph-1000-electrolyte-tablets', type: 'elektrolyten', strength: 1000 },\n        { id: 'p_ph500', brand: 'precision', name: 'Precision PH 500 Tabletten', url: 'https:\/\/sportvoedingdirect.nl\/products\/precision-ph-500-electrolyte-tablets', type: 'elektrolyten', strength: 500 },\n        { id: 'a_drink_gel', brand: 'amacx', name: 'Amacx Drink Gel', url: 'https:\/\/sportvoedingdirect.nl\/products\/amacx-drink-gel', type: 'gel', carbs: 30, caffeine: 0 },\n        { id: 'a_hydro_tabs', brand: 'amacx', name: 'Amacx Hydro Tabs', url: 'https:\/\/sportvoedingdirect.nl\/products\/amacx-hydro-tabs', type: 'elektrolyten', strength: 1000 },\n        { id: 'a_recovery_shake', brand: 'amacx', name: 'Amacx Recovery Shake', url: 'https:\/\/sportvoedingdirect.nl\/products\/amacx-recovery-shake', type: 'herstel' },\n        { id: 'b_pro_fruit_gel', brand: 'bye', name: 'BYE Pro Fruit Gel', url: 'https:\/\/sportvoedingdirect.nl\/products\/bye-pro-fruit-gel', type: 'gel', carbs: 30 },\n        { id: 'b_recovery', brand: 'bye', name: 'BYE All-in-one Recovery', url: 'https:\/\/sportvoedingdirect.nl\/products\/bye-all-in-one-recovery', type: 'herstel' },\n        { id: 'm_gel100', brand: 'maurten', name: 'Maurten Gel 100', url: 'https:\/\/sportvoedingdirect.nl\/products\/maurten-gel-100', type: 'gel', carbs: 25 },\n        { id: 'm_gel100caf', brand: 'maurten', name: 'Maurten Gel 100 CAF 100', url: 'https:\/\/sportvoedingdirect.nl\/products\/maurten-gel-100-caf-100', type: 'gel', carbs: 25, caffeine: 100 },\n    ];\n\n    function findProduct(products, type, properties = {}) {\n        return products.find(p =\u003e {\n            if (p.type !== type) return false;\n            for (const key in properties) { if (p[key] !== properties[key]) return false; }\n            return true;\n        });\n    }\n\n    function generatePlan(data) {\n        const preferredProducts = data.brand === 'any' ? allProducts : allProducts.filter(p =\u003e p.brand === data.brand);\n        let planHTML = `\u003ch2\u003eJouw Persoonlijke Voedingsplan\u003c\/h2\u003e`;\n        let totalHours = 0;\n        if (data.sport === 'triathlon') {\n            const swimMin = parseInt(data.swim_hr || 0) * 60 + parseInt(data.swim_min || 0);\n            const bikeMin = parseInt(data.bike_hr || 0) * 60 + parseInt(data.bike_min || 0);\n            const runMin = parseInt(data.run_hr || 0) * 60 + parseInt(data.run_min || 0);\n            totalHours = (swimMin + bikeMin + runMin) \/ 60;\n        } else if (data.sport === 'running') {\n            const distanceInKm = { '5k': 5, '10k': 10, 'half-marathon': 21, 'marathon': 42, '50k': 50, '50m': 80, '100k': 100, '100m': 161 };\n            const km = distanceInKm[data['running-distance']] || 0;\n            const paceMinutesPerKm = data.approach === 'limit' ? 5 : (data.approach === 'hard' ? 6 : 7);\n            totalHours = (km * paceMinutesPerKm) \/ 60;\n        } else if (data.sport === 'cycling') {\n            const km = parseInt(data['cycling-distance'] || 0);\n            const averageSpeedKmh = 29;\n            totalHours = km \u003e 0 ? (km \/ averageSpeedKmh) : 0;\n        }\n\n        if (totalHours \u003c= 0.75) return \"\u003ch3\u003eVoor een inspanning korter dan 45 minuten is water meestal voldoende. Veel succes!\u003c\/h3\u003e\";\n        let carbsPerHour = 60;\n        if (totalHours \u003e 2.5) carbsPerHour = data.approach === 'limit' ? 90 : (data.approach === 'hard' ? 75 : 60);\n\n        function recommend(product, fallbackNote = \"\") { return `\u003cstrong\u003eProduct:\u003c\/strong\u003e \u003ca href=\"${product.url}\" target=\"_blank\"\u003e${product.name}\u003c\/a\u003e ${fallbackNote ? `\u003cdiv class=\"fallback-note\"\u003e${fallbackNote}\u003c\/div\u003e` : ''}`; }\n        \n        let preRaceProduct = findProduct(allProducts, 'elektrolyten', { strength: 1500 });\n        if(preRaceProduct) { planHTML += `\u003ch3\u003eVoor de race\u003c\/h3\u003e\u003cul\u003e\u003cli\u003e${recommend(preRaceProduct)}\u003c\/li\u003e\u003cli\u003e\u003cstrong\u003eHoeveelheid:\u003c\/strong\u003e 1 tablet in 500ml water\u003c\/li\u003e\u003cli\u003e\u003cstrong\u003eInstructie:\u003c\/strong\u003e Om met een top-hydratatie te starten, drink je dit de avond voor je race.\u003c\/li\u003e\u003c\/ul\u003e`; }\n        let hydrationText = \"Drink naar dorst, maar probeer rond de 500ml per uur te mikken.\";\n        if (data.conditions === 'hot' || data.conditions === 'very-hot') { hydrationText = \"Let op: met dit warme weer is hydratatie cruciaal om oververhitting en kramp te voorkomen. Drink elke 15-20 minuten een paar flinke slokken.\" }\n        let hydrationProduct;\n        if (data.conditions === 'very-hot' || data.cramps === 'often') hydrationProduct = findProduct(preferredProducts, 'elektrolyten', { strength: 1500 }) || findProduct(allProducts, 'elektrolyten', { strength: 1500 });\n        else if (data.conditions === 'hot' || data.cramps === 'sometimes') hydrationProduct = findProduct(preferredProducts, 'elektrolyten', { strength: 1000 }) || findProduct(allProducts, 'elektrolyten', { strength: 1000 });\n        else hydrationProduct = findProduct(preferredProducts, 'elektrolyten', { strength: 500 }) || findProduct(allProducts, 'elektrolyten', { strength: 500 }) || findProduct(allProducts, 'elektrolyten');\n        if (hydrationProduct) {\n             const fallback = hydrationProduct.brand !== data.brand \u0026\u0026 data.brand !== 'any';\n             const totalHydrationTablets = Math.ceil(totalHours);\n             planHTML += `\u003ch3\u003eTijdens de race: Hydratatie\u003c\/h3\u003e\u003cul\u003e\u003cli\u003e${recommend(hydrationProduct, fallback ? 'Let op: we konden geen passend hydratatieproduct vinden van je voorkeursmerk, we raden dit alternatief aan.' : '')}\u003c\/li\u003e\u003cli\u003e\u003cstrong\u003eHoeveelheid:\u003c\/strong\u003e ${totalHydrationTablets} tablet(ten)\u003c\/li\u003e\u003cli\u003e\u003cstrong\u003eInstructie:\u003c\/strong\u003e ${hydrationText}\u003c\/li\u003e\u003c\/ul\u003e`;\n        }\n        let energyText;\n        switch(data.approach) {\n            case 'fun': energyText = \"Neem rustig de tijd en pak ongeveer elke 30-40 minuten een gel om je energiek te blijven voelen.\"; break;\n            case 'hard': energyText = \"Houd een vast schema aan en neem elke 25-30 minuten een gel om je tempo vast te houden.\"; break;\n            case 'limit': energyText = \"Voor een maximale prestatie is een strak voedingsschema cruciaal. Neem elke 20-25 minuten een gel, start na 45 minuten.\"; break;\n            default: energyText = \"Neem elke 20-30 minuten een gel.\";\n        }\n        let energyGel = findProduct(preferredProducts, 'gel', { caffeine: 0 }) || findProduct(preferredProducts, 'gel') || findProduct(allProducts, 'gel');\n        if (energyGel) {\n            const totalCarbsNeeded = Math.round(totalHours * carbsPerHour);\n            const numGels = Math.ceil(totalCarbsNeeded \/ energyGel.carbs);\n            const fallback = energyGel.brand !== data.brand \u0026\u0026 data.brand !== 'any';\n            planHTML += `\u003ch3\u003eTijdens de race: Energie (ca. ${totalCarbsNeeded}g koolhydraten)\u003c\/h3\u003e\u003cul\u003e\u003cli\u003e${recommend(energyGel, fallback ? 'Let op: je voorkeursmerk heeft geen standaard gel, we raden dit alternatief aan.' : '')}\u003c\/li\u003e\u003cli\u003e\u003cstrong\u003eHoeveelheid:\u003c\/strong\u003e ${numGels} gel(s)\u003c\/li\u003e\u003cli\u003e\u003cstrong\u003eInstructie:\u003c\/strong\u003e ${energyText}\u003c\/li\u003e\u003c\/ul\u003e`;\n        }\n        if (data.approach === 'limit' \u0026\u0026 totalHours \u003e 1.5) {\n            let caffeineGel = findProduct(preferredProducts, 'gel', { caffeine: 100 }) || findProduct(allProducts, 'gel', { caffeine: 100 });\n            if(caffeineGel) {\n                const fallback = caffeineGel.brand !== data.brand \u0026\u0026 data.brand !== 'any';\n                planHTML += `\u003cul\u003e\u003cli\u003e\u003cstrong\u003eOptionele eindsprint:\u003c\/strong\u003e ${recommend(caffeineGel, fallback ? 'Let op: geen cafeïnegel van je voorkeursmerk gevonden, we raden dit alternatief aan.' : '')}\u003c\/li\u003e\u003cli\u003e\u003cstrong\u003eHoeveelheid:\u003c\/strong\u003e 1 of 2 gel(s)\u003c\/li\u003e\u003cli\u003e\u003cstrong\u003eInstructie:\u003c\/strong\u003e Neem één cafeïnegel 45-60 minuten voor de finish voor een mentale en fysieke boost.\u003c\/li\u003e\u003c\/ul\u003e`;\n            }\n        }\n        if (totalHours \u003e 1.5) {\n            let recoveryProduct = findProduct(preferredProducts, 'herstel') || findProduct(allProducts, 'herstel');\n            if(recoveryProduct) {\n                const fallback = recoveryProduct.brand !== data.brand \u0026\u0026 data.brand !== 'any';\n                planHTML += `\u003ch3\u003eNa de race: Herstel\u003c\/h3\u003e\u003cul\u003e\u003cli\u003e${recommend(recoveryProduct, fallback ? 'Let op: geen herstelproduct van je voorkeursmerk gevonden, we raden dit alternatief aan.' : '')}\u003c\/li\u003e\u003cli\u003e\u003cstrong\u003eHoeveelheid:\u003c\/strong\u003e 1 shake\u003c\/li\u003e\u003cli\u003e\u003cstrong\u003eInstructie:\u003c\/strong\u003e Neem je herstelshake binnen 30 minuten na de finish om je spieren optimaal te laten herstellen.\u003c\/li\u003e\u003c\/ul\u003e`;\n            }\n        }\n        planHTML += `\u003cp class=\"disclaimer\"\u003eLet op: dit is een geautomatiseerd advies. Test je voedingsstrategie altijd eerst in training.\u003c\/p\u003e`;\n        return planHTML;\n    }\n\n    const plannerForm = document.getElementById('planner-form');\n    if (plannerForm.dataset.initialized) { return; }\n    plannerForm.dataset.initialized = 'true';\n    const formSteps = Array.from(document.querySelectorAll('.form-step'));\n    const nextBtn = document.getElementById('next-btn');\n    const prevBtn = document.getElementById('prev-btn');\n    const submitBtn = document.getElementById('submit-btn');\n    const resultDiv = document.getElementById('result-plan');\n    let currentStep = 0;\n    \n    function showStep(stepIndex) { formSteps.forEach((step, index) =\u003e { step.classList.toggle('active-step', index === stepIndex); }); prevBtn.classList.toggle('hidden', stepIndex === 0); nextBtn.classList.toggle('hidden', stepIndex === formSteps.length - 1); submitBtn.classList.toggle('hidden', stepIndex !== formSteps.length - 1); }\n    \n    function goToNextStep() {\n        if (currentStep \u003c formSteps.length - 1) {\n            currentStep++;\n            if (formSteps[currentStep].id === 'sprint-times-step') {\n                const sport = document.getElementById('sport').value;\n                const triathlonDistance = document.getElementById('triathlon-distance').value;\n                if (sport !== 'triathlon' || triathlonDistance !== 'sprint') { currentStep++; }\n            }\n            showStep(currentStep);\n        }\n    }\n\n    function goToPrevStep() {\n        if (currentStep \u003e 0) {\n            currentStep--;\n            if (formSteps[currentStep].id === 'sprint-times-step') {\n                const sport = document.getElementById('sport').value;\n                const triathlonDistance = document.getElementById('triathlon-distance').value;\n                if (sport !== 'triathlon' || triathlonDistance !== 'sprint') { currentStep--; }\n            }\n            showStep(currentStep);\n        }\n    }\n\n    const sportSelect = document.getElementById('sport');\n    const conditionalGroups = document.querySelectorAll('.conditional-group');\n    sportSelect.addEventListener('change', () =\u003e { const selectedSport = sportSelect.value; conditionalGroups.forEach(group =\u003e group.style.display = 'none'); if (selectedSport) { const groupToShow = document.getElementById(`${selectedSport}-questions`); if (groupToShow) { groupToShow.style.display = 'block'; } } });\n    \n    nextBtn.addEventListener('click', goToNextStep);\n    prevBtn.addEventListener('click', goToPrevStep);\n\n    plannerForm.addEventListener('submit', (e) =\u003e {\n        e.preventDefault();\n        const formData = new FormData(plannerForm);\n        const data = Object.fromEntries(formData.entries());\n        const planResultHTML = generatePlan(data);\n        plannerForm.style.display = 'none';\n        resultDiv.innerHTML = planResultHTML;\n        resultDiv.style.display = 'block';\n    });\n    \n    showStep(currentStep);\n});\n\u003c\/script\u003e","text_alignment":"left","add_vertical_spacing":true,"add_horizontal_spacing":true}}},"order":["main","custom_liquid_RUh7yr"]}