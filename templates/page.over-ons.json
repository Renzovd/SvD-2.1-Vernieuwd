        "color_scheme": "scheme-3",
        "liquid": "<style>\n:root{--svd-lime:#d9ff36;--svd-lime-dark:#c8f00a;--svd-lavender:#dbb8ff;--svd-lavender-bg:#faf5ff;--svd-dark:#1a1a1a;--svd-text:#333333;--svd-text-light:#666666;--svd-text-muted:#888888;--svd-bg:#fafafa;--svd-border:#eeeeee;--svd-radius:12px;--svd-radius-sm:8px;--svd-shadow:0 2px 12px rgba(0,0,0,0.06)}\n.svd-over-ons-page{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;line-height:1.7;color:var(--svd-text);padding:0;-webkit-font-smoothing:antialiased}\n.svd-over-ons-page *{box-sizing:border-box}\n.svd-hero{background:linear-gradient(135deg,var(--svd-lime) 0%,var(--svd-lime-dark) 100%);padding:48px 32px;border-radius:var(--svd-radius);margin-bottom:40px;position:relative;overflow:hidden}\n.svd-hero::after{content:'SVD💪';position:absolute;right:-10px;bottom:-30px;font-size:160px;font-weight:900;color:rgba(0,0,0,0.04);line-height:1;pointer-events:none}\n.svd-hero-tag{display:inline-block;background-color:var(--svd-dark);color:#ffffff;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;padding:5px 12px;border-radius:6px;margin-bottom:16px}\n.svd-hero h1{font-size:2.2rem;font-weight:800;color:var(--svd-dark);margin:0 0 14px 0;line-height:1.2;max-width:640px}\n.svd-hero p{font-size:16px;color:var(--svd-dark);margin:0;max-width:580px;line-height:1.65;opacity:0.85}\n.svd-over-ons-page section{margin-bottom:48px}\n.svd-over-ons-page h2{font-size:1.6rem;font-weight:800;color:var(--svd-dark);margin:0 0 20px 0;line-height:1.25}\n.svd-heading-line{display:inline-block;padding-bottom:10px;border-bottom:3px solid var(--svd-lime)}\n.svd-over-ons-page h3{font-size:1.15rem;font-weight:700;color:var(--svd-dark);margin:0 0 10px 0;line-height:1.3}\n.svd-over-ons-page p{margin:0 0 16px 0}\n.svd-over-ons-page p:last-child{margin:0}\n.svd-badges{display:flex;flex-wrap:wrap;gap:8px;margin:24px 0}\n.svd-badge{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:20px;font-size:12px;font-weight:600;border:1px solid var(--svd-border);background:#ffffff;color:var(--svd-text)}\n.svd-badge-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}\n.dot-lime{background:var(--svd-lime)}.dot-lavender{background:var(--svd-lavender)}.dot-dark{background:var(--svd-dark)}\n\n/* ═══ INTRO BLOCK ═══ */\n.svd-intro-block{background:#ffffff;border:1px solid var(--svd-border);border-radius:var(--svd-radius);padding:32px;box-shadow:var(--svd-shadow);margin-bottom:40px}\n.svd-intro-block p{font-size:15px;line-height:1.75;color:var(--svd-text)}\n.svd-intro-block p:first-child{font-size:17px;font-weight:600;color:var(--svd-dark)}\n\n/* ═══ VALUES GRID ═══ */\n.svd-values-grid{display:grid;grid-template-columns:1fr;gap:12px;margin:24px 0}\n.svd-value-card{background:var(--svd-bg);border:1px solid var(--svd-border);border-radius:var(--svd-radius);padding:22px 24px;display:flex;align-items:flex-start;gap:14px}\n.svd-value-icon{flex-shrink:0;width:44px;height:44px;background:var(--svd-lime);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:700}\n.svd-value-card strong{display:block;font-size:15px;font-weight:700;color:var(--svd-dark);margin-bottom:4px}\n.svd-value-card span{font-size:13px;color:var(--svd-text-light);line-height:1.6}\n\n/* ═══ MISSION BLOCK ═══ */\n.svd-mission-block{background:linear-gradient(135deg,#faf5ff 0%,#f3e8ff 100%);border:1px solid var(--svd-lavender);border-radius:var(--svd-radius);padding:32px;margin:24px 0}\n.svd-mission-block h3{font-size:1.2rem;margin:0 0 12px 0;color:#3b0764}\n.svd-mission-block p{font-size:15px;line-height:1.75;color:var(--svd-text);margin:0 0 12px 0}\n.svd-mission-block p:last-child{margin:0}\n\n/* ═══ BRANDS BAR ═══ */\n.svd-brands-bar{display:flex;flex-wrap:wrap;gap:10px;margin:20px 0;justify-content:center}\n.svd-brand-pill{display:inline-block;padding:8px 18px;background:#ffffff;border:1px solid var(--svd-border);border-radius:20px;font-size:13px;font-weight:700;color:var(--svd-dark)}\n.svd-brand-pill a{color:var(--svd-dark);text-decoration:none}\n.svd-brand-pill a:hover{text-decoration:underline}\n\n/* ═══ GUARANTEES GRID ═══ */\n.svd-guarantees-grid{display:grid;grid-template-columns:1fr;gap:16px;margin:24px 0}\n.svd-guarantee-card{background:#ffffff;border:1px solid var(--svd-border);border-radius:var(--svd-radius);padding:24px 28px;box-shadow:var(--svd-shadow);border-top:4px solid var(--svd-lime);transition:box-shadow 0.15s ease}\n.svd-guarantee-card:hover{box-shadow:0 4px 20px rgba(0,0,0,0.1)}\n.svd-guarantee-card:nth-child(2){border-top-color:var(--svd-lavender)}\n.svd-guarantee-card:nth-child(3){border-top-color:#ff9f43}\n.svd-guarantee-card:nth-child(4){border-top-color:var(--svd-dark)}\n.svd-guarantee-card h4{font-size:1.05rem;font-weight:700;color:var(--svd-dark);margin:0 0 8px 0;line-height:1.3}\n.svd-guarantee-card p{font-size:14px;color:var(--svd-text);margin:0;line-height:1.65}\n\n/* ═══ CTA BLOCK ═══ */\n.svd-cta-block{background:var(--svd-dark);border-radius:var(--svd-radius);padding:40px 32px;text-align:center;margin:40px 0}\n.svd-cta-block h3{font-size:1.4rem;font-weight:800;color:#ffffff;margin:0 0 10px 0}\n.svd-cta-block p{font-size:15px;color:rgba(255,255,255,0.75);margin:0 0 24px 0}\n.svd-cta-btn{display:inline-block;padding:14px 32px;background:var(--svd-lime);color:var(--svd-dark);font-size:15px;font-weight:800;text-decoration:none;border-radius:var(--svd-radius-sm);transition:background 0.15s ease}\n.svd-cta-btn:hover{background:var(--svd-lime-dark)}\n\n/* ═══ CONTACT FOOTER ═══ */\n.svd-contact-footer{background:var(--svd-bg);border:1px solid var(--svd-border);border-radius:var(--svd-radius);padding:24px 28px;margin-top:40px;display:flex;flex-wrap:wrap;gap:24px;align-items:flex-start}\n.svd-contact-footer div{flex:1;min-width:200px}\n.svd-contact-footer h4{font-size:14px;font-weight:700;color:var(--svd-dark);margin:0 0 6px 0;text-transform:uppercase;letter-spacing:0.04em}\n.svd-contact-footer p{font-size:13px;color:var(--svd-text-light);margin:0;line-height:1.6}\n\n@media(min-width:600px){.svd-values-grid{grid-template-columns:1fr 1fr 1fr}.svd-guarantees-grid{grid-template-columns:1fr 1fr}}\n@media(min-width:900px){.svd-hero{padding:56px 40px}.svd-hero h1{font-size:2.6rem}.svd-guarantees-grid{grid-template-columns:repeat(4,1fr)}}\n</style>\n\n<div class=\"svd-over-ons-page\">\n\n<!-- ═══ HERO ═══ -->\n<section class=\"svd-hero\">\n<span class=\"svd-hero-tag\">Over ons</span>\n<h1>Voor wie grenzen wil verleggen</h1>\n<p>Bij SportvoedingDirect draait alles om één simpel doel: jou helpen het allerbeste uit jezelf te halen.</p>\n</section>\n\n<!-- ═══ BADGES ═══ -->\n<div class=\"svd-badges\">\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>Alleen topmerken</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lavender\"></span>Van beginner tot pro</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-dark\"></span>Persoonlijk advies & service</span>\n</div>\n\n<!-- ═══ INTRO ═══ -->\n<div class=\"svd-intro-block\">\n<p>SportvoedingDirect helpt je over de finishlijn. Of je nu traint voor je eerste triatlon, een persoonlijk record najaagt op de marathon of simpelweg sterker op de fiets stapt.</p>\n<p>Haal alles uit jouw volgende uitdaging. Wij zorgen dat je voeding meewerkt. Niet tegenwerkt.</p>\n<p>We weten hoe frustrerend twijfel is. Te veel merken, eindeloos veel verpakkingen en nog meer meningen over wat je moet innemen. Geen ingewikkelde marketingverhalen of keuzestress bij SportvoedingDirect. Je wilt simpelweg weten wat werkt en waarom. Daarom maken wij het makkelijk voor je en vind je hier direct de juiste voeding.</p>\n</div>\n\n<!-- ═══ EENVOUD KWALITEIT VERTROUWEN ═══ -->\n<section>\n<h2><span class=\"svd-heading-line\">Eenvoud. Kwaliteit. Vertrouwen.</span></h2>\n<p>Wij geloven niet in eindeloze keuzelijsten. Wij geloven in een ijzersterke selectie. Wij selecteren alleen sportvoeding waar we helemaal achter staan. Bij ons vind je gewoon de beste gels, sportrepen en sportdrank van absolute topmerken.</p>\n\n<div class=\"svd-brands-bar\">\n<span class=\"svd-brand-pill\"><a href=\"https://sportvoedingdirect.nl/collections/amacx\">Amacx</a></span>\n<span class=\"svd-brand-pill\"><a href=\"https://sportvoedingdirect.nl/collections/maurten\">Maurten</a></span>\n<span class=\"svd-brand-pill\"><a href=\"https://sportvoedingdirect.nl/collections/precision\">Precision Fuel & Hydration</a></span>\n<span class=\"svd-brand-pill\"><a href=\"https://sportvoedingdirect.nl/collections/226ers\">226ERS</a></span>\n</div>\n\n<p>Dit is sportvoeding die we zelf gebruiken. Effectief, eerlijk en puur gericht op jouw prestaties. Gels en sportrepen die professionele atleten testen en die keer op keer presteren onder zware druk. Zo weet jij zeker dat elke sportdrank in onze webshop een logische keuze is.</p>\n</section>\n\n<!-- ═══ MISSIE ═══ -->\n<section>\n<div class=\"svd-mission-block\">\n<h3>Van training tot finish</h3>\n<p>Onze missie is kraakhelder. We helpen jou, van beginner tot pro, met duidelijke informatie en persoonlijke service. Gewoon eerlijke uitleg over welke sportvoeding je nodig hebt en hoe je deze het beste toepast in de praktijk.</p>\n<p>Ontdek precies welke sportrepen en gels bij jouw doelen passen via onze voedingscheck, testpakketten en persoonlijke consults. Zo sta jij vol vertrouwen aan de start en herstel je optimaal na de finishlijn.</p>\n</div>\n</section>\n\n<!-- ═══ WAAR WE VOOR STAAN ═══ -->\n<section>\n<h2><span class=\"svd-heading-line\">Waar we voor staan</span></h2>\n\n<div class=\"svd-values-grid\">\n<div class=\"svd-value-card\">\n<div class=\"svd-value-icon\">✦</div>\n<div>\n<strong>Simpel</strong>\n<span>Sportvoeding zonder ruis, zodat jij direct weet wat werkt.</span>\n</div>\n</div>\n<div class=\"svd-value-card\">\n<div class=\"svd-value-icon\">✓</div>\n<div>\n<strong>Betrouwbaar</strong>\n<span>Uitsluitend merken die we kennen en vertrouwen.</span>\n</div>\n</div>\n<div class=\"svd-value-card\">\n<div class=\"svd-value-icon\">♡</div>\n<div>\n<strong>Toegankelijk</strong>\n<span>We bieden advies en sportvoeding voor ieder niveau sporter.</span>\n</div>\n</div>\n</div>\n\n<p>Jij focust op wat echt telt: bewegen, sneller worden en genieten van elke kilometer. Wij regelen de rest.</p>\n</section>\n\n<!-- ═══ GARANTIES ═══ -->\n<section>\n<h2><span class=\"svd-heading-line\">Onze garanties voor jouw prestaties</span></h2>\n\n<div class=\"svd-guarantees-grid\">\n<div class=\"svd-guarantee-card\">\n<h4>Topmerken & Kwaliteit</h4>\n<p>Kies altijd voor betrouwbare sportvoeding die topsporters dagelijks gebruiken. Zo haal jij het maximale uit elke training en wedstrijd.</p>\n</div>\n<div class=\"svd-guarantee-card\">\n<h4>Snelle Levering</h4>\n<p>Bestel je op werkdagen voor 13:00 uur? Dan verzenden we jouw sportvoeding dezelfde dag nog. Razendsnel bij jou bezorgd, zodat jij vol energie aan de start staat.</p>\n</div>\n<div class=\"svd-guarantee-card\">\n<h4>Voordeel met Direct+</h4>\n<p>Als lid ontvang je standaard hogere korting op alle sportvoeding en spaar je dubbel zo snel punten. Zo haal je nog meer uit jouw bestelling.</p>\n</div>\n<div class=\"svd-guarantee-card\">\n<h4>Vragen of Persoonlijk Advies?</h4>\n<p>Twijfel je over de juiste keuze? Vraag het onze experts! Wij helpen je direct aan de perfecte sportdrank, gel of reep voor jouw specifieke doel. Stuur ons een bericht via mail, bel ons of start een chat.</p>\n</div>\n</div>\n</section>\n\n<!-- ═══ CTA ═══ -->\n<div class=\"svd-cta-block\">\n<h3>Laat de concurrentie achter je</h3>\n<p>Vind vandaag nog jouw ideale brandstof.</p>\n<a class=\"svd-cta-btn\" href=\"https://sportvoedingdirect.nl/collections/all\">Bekijk direct alle sportvoeding →</a>\n</div>\n\n<!-- ═══ CONTACT ═══ -->\n<div class=\"svd-contact-footer\">\n<div>\n<h4>Adres</h4>\n<p>SportvoedingDirect<br>Dorpsstraat 20<br>1534 NJ Oostknollendam</p>\n</div>\n<div>\n<h4>Registratie</h4>\n<p>KVK: 96928301<br>BTW: NL867837366B01</p>\n</div>\n</div>\n\n</div>\n\n<script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"AboutPage\",\"name\":\"Over SportvoedingDirect\",\"description\":\"Bij SportvoedingDirect draait alles om één simpel doel: jou helpen het allerbeste uit jezelf te halen. Topmerken als Amacx, Maurten, Precision Fuel & Hydration en 226ERS.\",\"url\":\"https://sportvoedingdirect.nl/pages/over-ons\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"SportvoedingDirect\",\"url\":\"https://sportvoedingdirect.nl\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"Dorpsstraat 20\",\"postalCode\":\"1534 NJ\",\"addressLocality\":\"Oostknollendam\",\"addressCountry\":\"NL\"}}}</script>",
