nsition:box-shadow 0.15s ease}\n.svd-product-card:hover{box-shadow:0 4px 20px rgba(0,0,0,0.1)}\n.svd-product-card-rank{display:inline-block;background:var(--svd-lavender);color:#3b0764;font-size:11px;font-weight:800;padding:3px 10px;border-radius:4px;margin-bottom:10px;text-transform:uppercase;letter-spacing:0.06em}\n.svd-product-card h4{font-size:1.05rem;font-weight:700;color:var(--svd-dark);margin:0 0 8px 0;line-height:1.3}\n.svd-product-card p{font-size:14px;color:var(--svd-text);margin:0 0 12px 0;line-height:1.6}\n.svd-product-card a.svd-card-link{display:inline-block;font-size:13px;font-weight:700;color:#3b0764;text-decoration:none;padding:8px 16px;background:var(--svd-lavender);border-radius:var(--svd-radius-sm);transition:background 0.15s ease}\n.svd-product-card a.svd-card-link:hover{background:#cda0ff}\n.svd-compare-table{width:100%;border-collapse:collapse;margin:24px 0;font-size:13px}\n.svd-compare-table th{background:var(--svd-dark);color:#ffffff;font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:0.04em;padding:12px 14px;text-align:left}\n.svd-compare-table td{padding:12px 14px;border-bottom:1px solid var(--svd-border);vertical-align:top}\n.svd-compare-table tr:nth-child(even) td{background:var(--svd-bg)}\n.svd-compare-table a{color:var(--svd-dark);text-decoration:underline;font-weight:600}\n.svd-table-badge{display:inline-block;font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;margin-right:4px}\n.badge-basis{background:var(--svd-lime);color:var(--svd-dark)}\n.badge-caf{background:#e74c3c;color:#fff}\n.svd-scenario-grid{display:grid;grid-template-columns:1fr;gap:16px;margin:24px 0}\n.svd-scenario-card{background:#ffffff;border:1px solid var(--svd-border);border-radius:var(--svd-radius);padding:24px 28px;border-top:4px solid var(--svd-lime)}\n.svd-scenario-card.scenario-caf{border-top-color:var(--svd-lavender)}\n.svd-scenario-card.scenario-tip{border-top-color:var(--svd-dark)}\n.svd-scenario-card .svd-scenario-tag{display:inline-block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;padding:3px 8px;border-radius:4px;margin-bottom:12px}\n.tag-basis{background:var(--svd-lime);color:var(--svd-dark)}\n.tag-boost{background:var(--svd-lavender);color:#3b0764}\n.tag-tip{background:var(--svd-dark);color:#ffffff}\n.svd-scenario-card h3{margin:0 0 8px 0;font-size:1.05rem}\n.svd-scenario-card p{font-size:14px;color:var(--svd-text);margin:0 0 10px 0;line-height:1.6}\n.svd-info-card{background:var(--svd-bg);border:1px solid var(--svd-border);border-left:4px solid var(--svd-lavender);border-radius:var(--svd-radius);padding:20px 24px;margin:24px 0}\n.svd-info-card h3{margin:0 0 8px 0;font-size:1rem}\n.svd-info-card p{font-size:14px;line-height:1.7;margin:0}\n.svd-faq-list{margin:24px 0 0 0}\n.svd-faq-item{border:1px solid var(--svd-border);border-radius:var(--svd-radius);margin-bottom:12px;overflow:hidden}\n.svd-faq-item details{width:100%}\n.svd-faq-item summary{padding:16px 20px;font-weight:700;font-size:15px;color:var(--svd-dark);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;background:#ffffff;transition:background 0.15s ease}\n.svd-faq-item summary:hover{background:var(--svd-bg)}\n.svd-faq-item summary::-webkit-details-marker{display:none}\n.svd-faq-item summary::after{content:'+';font-size:20px;font-weight:300;color:var(--svd-text-muted);flex-shrink:0;margin-left:12px}\n.svd-faq-item details[open] summary::after{content:'−'}\n.svd-faq-item .svd-faq-answer{padding:0 20px 18px 20px;font-size:14px;line-height:1.7;color:var(--svd-text)}\n.svd-faq-item .svd-faq-answer p{margin:0 0 10px 0}\n.svd-faq-item .svd-faq-answer p:last-child{margin:0}\n.svd-cta-card{background:linear-gradient(135deg,var(--svd-lime) 0%,var(--svd-lime-dark) 100%);border-radius:var(--svd-radius);padding:32px;text-align:center;margin-top:48px}\n.svd-cta-card h2{font-size:1.4rem;color:var(--svd-dark);margin:0 0 10px 0;border:none;padding:0}\n.svd-cta-card p{color:var(--svd-dark);opacity:0.85;font-size:15px;margin:0 0 20px 0}\n.svd-cta-links{display:flex;flex-wrap:wrap;gap:12px;justify-content:center}\n.svd-cta-btn{display:inline-block;padding:12px 28px;border-radius:var(--svd-radius-sm);font-weight:700;font-size:14px;text-decoration:none !important;transition:all 0.15s ease}\n.svd-cta-btn.btn-dark{background:var(--svd-dark);color:#ffffff !important}\n.svd-cta-btn.btn-dark:hover{background:#333}\n.svd-cta-btn.btn-outline{background:#ffffff;color:var(--svd-dark) !important;border:2px solid var(--svd-dark)}\n.svd-cta-btn.btn-outline:hover{background:var(--svd-dark);color:#ffffff !important}\n@media(min-width:600px){.svd-jump-nav ul{grid-template-columns:1fr 1fr}.svd-usp-grid{grid-template-columns:1fr 1fr}.svd-products-grid{grid-template-columns:1fr 1fr}.svd-scenario-grid{grid-template-columns:1fr 1fr 1fr}}\n@media(min-width:900px){.svd-hero{padding:56px 40px}.svd-hero h1{font-size:2.6rem}}\n@media(max-width:599px){.svd-compare-table{font-size:12px}.svd-compare-table th,.svd-compare-table td{padding:10px 8px}}\n</style>\n\n<div class=\"svd-precision-gels\">\n\n<!-- ═══ HERO ═══ -->\n<section class=\"svd-hero\">\n<span class=\"svd-hero-tag\">Precision Fuel & Hydration</span>\n<h1>Precision Gels: snelle en maagvriendelijke energie</h1>\n<p>Het getal vertelt je alles. PF 30 = 30 gram koolhydraten. Geen giswerk, geen ingewikkelde etiketten. Gewoon tellen hoeveel gels je nodig hebt per uur en focussen op je prestatie.</p>\n</section>\n\n<!-- ═══ BADGES ═══ -->\n<div class=\"svd-badges\">\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>30g koolhydraten per gel</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lavender\"></span>2:1 glucose fructose ratio</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-dark\"></span>Informed Sport gecertificeerd</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>Vegan & glutenvrij</span>\n</div>\n\n<!-- ═══ JUMP NAV ═══ -->\n<nav class=\"svd-jump-nav\" aria-label=\"Pagina navigatie\">\n<h3>Op deze pagina</h3>\n<ul>\n<li><a href=\"#filosofie\">De Precision filosofie <span>Eenvoud & effectiviteit</span></a></li>\n<li><a href=\"#waarom\">Waarom Precision gels werken <span>De gedeelde basis</span></a></li>\n<li><a href=\"#varianten\">De twee varianten <span>Met of zonder cafeïne</span></a></li>\n<li><a href=\"#vergelijking\">Vergelijkingstabel <span>In één oogopslag</span></a></li>\n<li><a href=\"#strategie\">Jouw gel strategie <span>Zo gebruik je ze</span></a></li>\n<li><a href=\"#hydratatie\">Vergeet je hydratatie niet <span>PH + PF systeem</span></a></li>\n<li><a href=\"#faq\">Veelgestelde vragen <span>5 vragen</span></a></li>\n</ul>\n</nav>\n\n<!-- ═══ FILOSOFIE ═══ -->\n<section id=\"filosofie\">\n<h2><span class=\"svd-heading-line\">De Precision filosofie: eenvoud en effectiviteit</span></h2>\n<p>De kern van alle Precision sportvoeding is eenvoud. De naam van de gel vertelt je precies wat je krijgt: 'PF 30' staat voor Precision Fuel, 30 gram koolhydraten. Dit haalt het giswerk uit je voedingsplan. Je hoeft geen ingewikkelde voedingsetiketten meer te ontcijferen tijdens je inspanning; je telt gewoon het aantal gels dat je nodig hebt om je doel per uur te bereiken.</p>\n</section>\n\n<!-- ═══ WAAROM ═══ -->\n<section id=\"waarom\">\n<h2><span class=\"svd-heading-line\">Waarom Precision gels werken</span></h2>\n<p>Beide gels delen dezelfde krachtige en maagvriendelijke basis, ontworpen voor maximale prestaties.</p>\n\n<div class=\"svd-usp-grid\">\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">🔬</div>\n<div>\n<strong>2:1 glucose fructose ratio</strong>\n<span>Door twee verschillende soorten koolhydraten te combineren kan je lichaam meer energie per uur opnemen (tot 90 gram) met een lager risico op maagklachten.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">😌</div>\n<div>\n<strong>Milde, neutrale smaak</strong>\n<span>De \"Original\" smaak is bewust subtiel gehouden. Dit voorkomt smaakmoeheid: het fenomeen waarbij je na uren sporten een afkeer krijgt van zoete smaken.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">💧</div>\n<div>\n<strong>Zachte, niet plakkerige textuur</strong>\n<span>De gels zijn makkelijk door te slikken, zelfs zonder een slok water. Minder stroperig dan veel andere gels, wat prettig is bij een hoge hartslag.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">🌱</div>\n<div>\n<strong>Pure ingrediënten</strong>\n<span>Vrij van kunstmatige toevoegingen en onnodige extra's. Alleen wat je nodig hebt voor je prestatie. Vegan, glutenvrij en Informed Sport gecertificeerd.</span>\n</div>\n</div>\n</div>\n</section>\n\n<!-- ═══ VARIANTEN ═══ -->\n<section id=\"varianten\">\n<h2><span class=\"svd-heading-line\">De twee varianten: met of zonder cafeïne?</span></h2>\n<p>Het Precision gel systeem biedt twee varianten die je strategisch kunt inzetten.</p>\n\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">Het werkpaard</span>\n<h4>Precision PF 30 Gel</h4>\n<p>De betrouwbare, standaard brandstof. Dit is de gel die je gebruikt voor het grootste deel van je training of wedstrijd. Levert een constante, voorspelbare stroom van 30 gram koolhydraten om je energieniveau op peil te houden, uur na uur. Milde smaak, zachte textuur, geen elektrolyten.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/precision-pf-30-gel\">Bekijk PF 30 Gel →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank\">De strategische boost</span>\n<h4>Precision PF 30 Caffeine Gel</h4>\n<p>Je specialistische tool voor de zwaarste momenten. Dezelfde 30 gram koolhydraten, maar met 100 mg cafeïne. Cafeïne verhoogt de alertheid en verlaagt de ervaren inspanning. Pak deze gel voor die zware klim, de laatste 10 kilometer van je marathon, of wanneer de mentale vermoeidheid toeslaat.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/precision-pf-30-caffeine-gel\">Bekijk PF 30 + Caffeine →</a>\n</div>\n</div>\n</section>\n\n<!-- ═══ VERGELIJKING ═══ -->\n<section id=\"vergelijking\">\n<h2><span class=\"svd-heading-line\">De gels in één oogopslag</span></h2>\n\n<div style=\"overflow-x:auto;border-radius:var(--svd-radius);border:1px solid var(--svd-border);box-shadow:var(--svd-shadow)\">\n<table class=\"svd-compare-table\">\n<thead>\n<tr><th>Kenmerk</th><th><a href=\"https://sportvoedingdirect.nl/products/precision-pf-30-gel\">PF 30 Gel</a></th><th><a href=\"https://sportvoedingdirect.nl/products/precision-pf-30-caffeine-gel\">PF 30 Caffeine Gel</a></th></tr>\n</thead>\n<tbody>\n<tr><td><strong>Koolhydraten</strong></td><td>30 gram</td><td>30 gram</td></tr>\n<tr><td><strong>Ratio</strong></td><td>2:1 glucose fructose</td><td>2:1 glucose fructose</td></tr>\n<tr><td><strong>Cafeïne</strong></td><td><span class=\"svd-table-badge badge-basis\">0 mg</span></td><td><span class=\"svd-table-badge badge-caf\">100 mg</span></td></tr>\n<tr><td><strong>Belangrijkste doel</strong></td><td>Snelle, duurzame energie</td><td>Energie + mentale focus</td></tr>\n<tr><td><strong>Ideaal voor</strong></td><td>Basisbrandstof, gehele inspanning</td><td>Strategisch: eindsprint, zware momenten</td></tr>\n<tr><td><strong>Smaak</strong></td><td>Original (mild, neutraal)</td><td>Original (mild, neutraal)</td></tr>\n<tr><td><strong>Elektrolyten</strong></td><td>Nee (combineer met PH)</td><td>Nee (combineer met PH)</td></tr>\n<tr><td><strong>Certificering</strong></td><td>Informed Sport, vegan</td><td>Informed Sport, vegan</td></tr>\n</tbody>\n</table>\n</div>\n</section>\n\n<!-- ═══ STRATEGIE ═══ -->\n<section id=\"strategie\">\n<h2><span class=\"svd-heading-line\">Jouw gel strategie</span></h2>\n<p>Een goed voedingsplan is de sleutel tot succes. Combineer de twee gels voor een optimaal effect.</p>\n\n<div class=\"svd-scenario-grid\">\n<div class=\"svd-scenario-card\">\n<span class=\"svd-scenario-tag tag-basis\">Basisbrandstof</span>\n<h3>60 tot 90 gram per uur</h3>\n<p>Begin je inspanning met de reguliere <a href=\"https://sportvoedingdirect.nl/products/precision-pf-30-gel\">PF 30 Gels</a>. Neem er 2 tot 3 per uur om aan je koolhydraatdoelstelling te voldoen. Combineer met een <a href=\"https://sportvoedingdirect.nl/products/precision-carb-electrolyte-drink-mix\">Carb & Electrolyte Drink</a> voor extra koolhydraten en vocht.</p>\n</div>\n<div class=\"svd-scenario-card scenario-caf\">\n<span class=\"svd-scenario-tag tag-boost\">Cafeïne boost</span>\n<h3>Strategische momenten</h3>\n<p>Schakel over op de <a href=\"https://sportvoedingdirect.nl/products/precision-pf-30-caffeine-gel\">PF 30 Caffeine Gel</a> op cruciale momenten. Neem één cafeïne gel ongeveer 60 minuten voordat je de eindsprint inzet, of wissel in het laatste deel een gewone gel af met een cafeïne gel.</p>\n</div>\n<div class=\"svd-scenario-card scenario-tip\">\n<span class=\"svd-scenario-tag tag-tip\">Let op</span>\n<h3>Cafeïne limiet</h3>\n<p>Neem maximaal 1 cafeïne gel per uur en maximaal 4 per dag. Test je tolerantie altijd eerst in training, nooit voor het eerst op wedstrijddag. Oefen je volledige voedingsplan tijdens lange duurtrainingen.</p>\n</div>\n</div>\n</section>\n\n<!-- ═══ HYDRATATIE ═══ -->\n<section id=\"hydratatie\">\n<h2><span class=\"svd-heading-line\">Vergeet je hydratatie niet</span></h2>\n\n<div class=\"svd-info-card\">\n<h3>💡 Het PF + PH systeem: brandstof en hydratatie apart</h3>\n<p>Beide Precision gels bevatten bewust geen elektrolyten. Dit stelt je in staat je hydratatie apart te beheren met de <a href=\"https://sportvoedingdirect.nl/products/precision-ph-1000-electrolyte-tablets\">Precision Hydration tabletten</a>. Zo kun je op een hete dag veel drinken met een hoge zoutconcentratie (bijvoorbeeld PH 1000) en op een koele dag minder, terwijl je energie inname via de gels constant blijft. Dit is de kracht van het Precision systeem: totale controle over zowel je brandstof als je hydratatie.</p>\n</div>\n</section>\n\n<!-- ═══ FAQ ═══ -->\n<section id=\"faq\">\n<h2><span class=\"svd-heading-line\">Veelgestelde vragen over de Precision Gels</span></h2>\n\n<div class=\"svd-faq-list\">\n\n<div class=\"svd-faq-item\"><details>\n<summary>Wat is het belangrijkste verschil tussen de twee Precision gels?</summary>\n<div class=\"svd-faq-answer\">\n<p>Het enige verschil is de 100 mg cafeïne in de PF 30 Caffeine Gel. De basis (30g koolhydraten, 2:1 ratio, smaak en textuur) is voor beide gels identiek.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Kan ik alleen de cafeïne gel gebruiken tijdens mijn wedstrijd?</summary>\n<div class=\"svd-faq-answer\">\n<p>Dit wordt afgeraden. Te veel cafeïne kan nadelige effecten hebben. De cafeïne gel is ontworpen als een strategische tool, niet als je primaire brandstof. Gebruik de reguliere PF 30 Gel als basis en de cafeïne variant voor de cruciale momenten, met een maximum van 4 per dag.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Waarom hebben de Precision gels geen uitgesproken fruitsmaak?</summary>\n<div class=\"svd-faq-answer\">\n<p>De milde, neutrale smaak is een bewuste keuze om smaakmoeheid te voorkomen. Tijdens lange inspanningen kan een sterke, zoete smaak gaan tegenstaan. De subtiele smaak van Precision zorgt ervoor dat je makkelijker kunt blijven eten, ook na uren sporten.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Moet ik water drinken bij het innemen van de gels?</summary>\n<div class=\"svd-faq-answer\">\n<p>De textuur is ontworpen om de gels makkelijk door te slikken zonder water. Het is wel altijd belangrijk om goed gehydrateerd te blijven. Combineer de gels daarom met je <a href=\"https://sportvoedingdirect.nl/products/precision-ph-1000-electrolyte-tablets\">Precision Hydration</a> drank voor optimale resultaten.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Zijn beide gels vegan en getest op doping?</summary>\n<div class=\"svd-faq-answer\">\n<p>Ja, zowel de Precision PF 30 Gel als de PF 30 Caffeine Gel zijn veganistisch, glutenvrij en Informed Sport gecertificeerd. Dit garandeert dat ze vrij zijn van verboden middelen en veilig zijn voor alle sporters.</p>\n</div>\n</details></div>\n\n</div>\n</section>\n\n<!-- ═══ CTA ═══ -->\n<div class=\"svd-cta-card\">\n<h2>Stel jouw perfecte gel strategie samen</h2>\n<p>Of je nu op zoek bent naar constante energie of een strategische boost, de gels van Precision bieden de oplossing.</p>\n<div class=\"svd-cta-links\">\n<a class=\"svd-cta-btn btn-dark\" href=\"https://sportvoedingdirect.nl/products/precision-pf-30-gel\">Bekijk PF 30 Gel</a>\n<a class=\"svd-cta-btn btn-outline\" href=\"https://sportvoedingdirect.nl/products/precision-pf-30-caffeine-gel\">Bekijk PF 30 + Caffeine</a>\n</div>\n</div>\n\n</div>\n\n<script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Wat is het belangrijkste verschil tussen de twee Precision gels?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Het enige verschil is de 100 mg cafeïne in de PF 30 Caffeine Gel. De basis (30g koolhydraten, 2:1 ratio, smaak en textuur) is voor beide gels identiek.\"}},{\"@type\":\"Question\",\"name\":\"Kan ik alleen de cafeïne gel gebruiken tijdens mijn wedstrijd?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Dit wordt afgeraden. Te veel cafeïne kan nadelige effecten hebben. De cafeïne gel is ontworpen als een strategische tool, niet als je primaire brandstof. Gebruik de reguliere PF 30 Gel als basis en de cafeïne variant voor de cruciale momenten, met een maximum van 4 per dag.\"}},{\"@type\":\"Question\",\"name\":\"Waarom hebben de Precision gels geen uitgesproken fruitsmaak?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"De milde, neutrale smaak is een bewuste keuze om smaakmoeheid te voorkomen. Tijdens lange inspanningen kan een sterke, zoete smaak gaan tegenstaan. De subtiele smaak van Precision zorgt ervoor dat je makkelijker kunt blijven eten.\"}},{\"@type\":\"Question\",\"name\":\"Moet ik water drinken bij het innemen van de gels?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"De textuur is ontworpen om de gels makkelijk door te slikken zonder water. Het is wel altijd belangrijk om goed gehydrateerd te blijven. Combineer de gels met Precision Hydration drank voor optimale resultaten.\"}},{\"@type\":\"Question\",\"name\":\"Zijn beide gels vegan en getest op doping?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Ja, zowel de Precision PF 30 Gel als de PF 30 Caffeine Gel zijn veganistisch, glutenvrij en Informed Sport gecertificeerd. Dit garandeert dat ze vrij zijn van verboden middelen en veilig zijn voor alle sporters.\"}}]}</script>",
