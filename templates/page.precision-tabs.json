lime);color:var(--svd-dark)}\n.badge-ph1500{background:var(--svd-lavender);color:#3b0764}\n.badge-amacx{background:var(--svd-dark);color:#fff}\n.svd-tips-grid{display:grid;grid-template-columns:1fr;gap:12px;margin:24px 0}\n.svd-tip-card{background:var(--svd-bg);border:1px solid var(--svd-border);border-radius:var(--svd-radius);padding:18px 20px;display:flex;align-items:flex-start;gap:12px}\n.svd-tip-number{flex-shrink:0;width:32px;height:32px;background:var(--svd-lime);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:800;color:var(--svd-dark)}\n.svd-tip-card p{font-size:14px;margin:0;line-height:1.6}\n.svd-scenario-grid{display:grid;grid-template-columns:1fr;gap:16px;margin:24px 0}\n.svd-scenario-card{background:#ffffff;border:1px solid var(--svd-border);border-radius:var(--svd-radius);padding:24px 28px;border-top:4px solid var(--svd-lime)}\n.svd-scenario-card.scenario-tijdens{border-top-color:var(--svd-lavender)}\n.svd-scenario-card.scenario-na{border-top-color:var(--svd-dark)}\n.svd-scenario-card .svd-scenario-tag{display:inline-block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;padding:3px 8px;border-radius:4px;margin-bottom:12px}\n.tag-voor{background:var(--svd-lime);color:var(--svd-dark)}\n.tag-tijdens{background:var(--svd-lavender);color:#3b0764}\n.tag-na{background:var(--svd-dark);color:#ffffff}\n.svd-scenario-card h3{margin:0 0 8px 0;font-size:1.05rem}\n.svd-scenario-card p{font-size:14px;color:var(--svd-text);margin:0 0 10px 0;line-height:1.6}\n.svd-faq-list{margin:24px 0 0 0}\n.svd-faq-item{border:1px solid var(--svd-border);border-radius:var(--svd-radius);margin-bottom:12px;overflow:hidden}\n.svd-faq-item details{width:100%}\n.svd-faq-item summary{padding:16px 20px;font-weight:700;font-size:15px;color:var(--svd-dark);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;background:#ffffff;transition:background 0.15s ease}\n.svd-faq-item summary:hover{background:var(--svd-bg)}\n.svd-faq-item summary::-webkit-details-marker{display:none}\n.svd-faq-item summary::after{content:'+';font-size:20px;font-weight:300;color:var(--svd-text-muted);flex-shrink:0;margin-left:12px}\n.svd-faq-item details[open] summary::after{content:'−'}\n.svd-faq-item .svd-faq-answer{padding:0 20px 18px 20px;font-size:14px;line-height:1.7;color:var(--svd-text)}\n.svd-faq-item .svd-faq-answer p{margin:0 0 10px 0}\n.svd-faq-item .svd-faq-answer p:last-child{margin:0}\n.svd-cta-card{background:linear-gradient(135deg,var(--svd-lime) 0%,var(--svd-lime-dark) 100%);border-radius:var(--svd-radius);padding:32px;text-align:center;margin-top:48px}\n.svd-cta-card h2{font-size:1.4rem;color:var(--svd-dark);margin:0 0 10px 0;border:none;padding:0}\n.svd-cta-card p{color:var(--svd-dark);opacity:0.85;font-size:15px;margin:0 0 20px 0}\n.svd-cta-links{display:flex;flex-wrap:wrap;gap:12px;justify-content:center}\n.svd-cta-btn{display:inline-block;padding:12px 28px;border-radius:var(--svd-radius-sm);font-weight:700;font-size:14px;text-decoration:none !important;transition:all 0.15s ease}\n.svd-cta-btn.btn-dark{background:var(--svd-dark);color:#ffffff !important}\n.svd-cta-btn.btn-dark:hover{background:#333}\n.svd-cta-btn.btn-outline{background:#ffffff;color:var(--svd-dark) !important;border:2px solid var(--svd-dark)}\n.svd-cta-btn.btn-outline:hover{background:var(--svd-dark);color:#ffffff !important}\n@media(min-width:600px){.svd-jump-nav ul{grid-template-columns:1fr 1fr}.svd-usp-grid{grid-template-columns:1fr 1fr}.svd-products-grid{grid-template-columns:1fr 1fr 1fr}.svd-tips-grid{grid-template-columns:1fr 1fr}.svd-scenario-grid{grid-template-columns:1fr 1fr 1fr}}\n@media(min-width:900px){.svd-hero{padding:56px 40px}.svd-hero h1{font-size:2.6rem}}\n@media(max-width:599px){.svd-compare-table{font-size:11px}.svd-compare-table th,.svd-compare-table td{padding:8px 6px}}\n</style>\n\n<div class=\"svd-precision-ph\">\n\n<!-- ═══ HERO ═══ -->\n<section class=\"svd-hero\">\n<span class=\"svd-hero-tag\">Precision Fuel & Hydration</span>\n<h1>Precision Hydration tabletten: elektrolyten op maat</h1>\n<p>Wanneer je zweet verlies je niet alleen vocht, maar ook cruciale mineralen. De Precision Hydration tabletten vullen precies aan wat jij verliest. Geen standaard sportdrank, maar een gepersonaliseerd systeem in drie sterktes.</p>\n</section>\n\n<!-- ═══ BADGES ═══ -->\n<div class=\"svd-badges\">\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>3 sterktes: PH 500, 1000, 1500</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lavender\"></span>Hypotone formule</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-dark\"></span>Informed Sport gecertificeerd</span>\n<span class=\"svd-badge\"><span class=\"svd-badge-dot dot-lime\"></span>Geen suiker, minimale calorieën</span>\n</div>\n\n<!-- ═══ JUMP NAV ═══ -->\n<nav class=\"svd-jump-nav\" aria-label=\"Pagina navigatie\">\n<h3>Op deze pagina</h3>\n<ul>\n<li><a href=\"#wat-zijn\">Wat zijn PH tabletten? <span>De basis</span></a></li>\n<li><a href=\"#filosofie\">Waarom geen suiker? <span>PF + PH systeem</span></a></li>\n<li><a href=\"#sterktes\">De drie sterktes <span>PH 500, 1000, 1500</span></a></li>\n<li><a href=\"#vergelijking\">Vergelijkingstabel <span>Precision vs. Amacx</span></a></li>\n<li><a href=\"#keuze\">Hoe kies ik de juiste sterkte? <span>4 signalen</span></a></li>\n<li><a href=\"#gebruik\">Hoe en wanneer gebruiken? <span>Voor, tijdens, na</span></a></li>\n<li><a href=\"#faq\">Veelgestelde vragen <span>6 vragen</span></a></li>\n</ul>\n</nav>\n\n<!-- ═══ WAT ZIJN PH TABLETTEN ═══ -->\n<section id=\"wat-zijn\">\n<h2><span class=\"svd-heading-line\">Wat zijn Precision Hydration tabletten?</span></h2>\n<p>De producten uit de PH lijn zijn bruistabletten die je oplost in water. Ze zijn ontworpen met één specifiek doel: het aanvullen van de elektrolyten die je verliest via zweet, met een sterke focus op natrium. In tegenstelling tot traditionele sportdranken bevatten ze geen of zeer weinig suiker.</p>\n\n<div class=\"svd-usp-grid\">\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">💧</div>\n<div>\n<strong>Hypotone formule</strong>\n<span>De concentratie deeltjes in de drank is lager dan in je bloed. Hierdoor neemt je lichaam het water en de elektrolyten razendsnel op.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">🧂</div>\n<div>\n<strong>Focus op natrium</strong>\n<span>Natrium is de meest cruciale elektrolyt die je verliest bij het zweten. Elke sterkte bevat ook kalium, calcium en magnesium.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">0️⃣</div>\n<div>\n<strong>Geen suiker</strong>\n<span>Zeer weinig tot geen suiker en minimale calorieën. Je hydratatie staat volledig los van je energie inname.</span>\n</div>\n</div>\n<div class=\"svd-usp-card\">\n<div class=\"svd-usp-icon\">🎚️</div>\n<div>\n<strong>Drie sterktes</strong>\n<span>PH 500, PH 1000 en PH 1500. Het getal is de hoeveelheid natrium per liter water. Kies de sterkte die past bij jouw zweetprofiel.</span>\n</div>\n</div>\n</div>\n</section>\n\n<!-- ═══ FILOSOFIE ═══ -->\n<section id=\"filosofie\">\n<h2><span class=\"svd-heading-line\">Waarom alleen elektrolyten (en geen suiker)?</span></h2>\n<p>Dit is de kern van de Precision filosofie: het scheiden van brandstof (fuel) en hydratatie (hydration). Door je koolhydraatinname (via <a href=\"https://sportvoedingdirect.nl/products/precision-pf-30-gel\">gels</a> of <a href=\"https://sportvoedingdirect.nl/products/precision-pf-30-chew\">chews</a>) los te koppelen van je elektrolyteninname, krijg je maximale flexibiliteit.</p>\n\n<div class=\"svd-info-card\">\n<h3>💡 Het PF + PH systeem: totale controle</h3>\n<p>Op een hete dag waarop je veel zweet maar rustig traint, heb je veel elektrolyten nodig maar weinig koolhydraten. Op een koude dag tijdens een intense race heb je juist veel koolhydraten nodig maar verlies je minder zout.</p>\n<p>Met de Precision tabletten kun je je hydratatie perfect afstemmen op de omstandigheden, zonder onnodige suikers binnen te krijgen. Dit is de kracht van het Precision systeem.</p>\n</div>\n</section>\n\n<!-- ═══ DE DRIE STERKTES ═══ -->\n<section id=\"sterktes\">\n<h2><span class=\"svd-heading-line\">De drie sterktes: PH 500, 1000 & 1500</span></h2>\n<p>Het unieke aan de Precision Hydration tabletten is dat ze verkrijgbaar zijn in verschillende sterktes. De naam geeft de hoeveelheid natrium per liter water aan.</p>\n\n<div class=\"svd-products-grid\">\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank rank-mild\">Lichte hydratatie</span>\n<h4>PH 500</h4>\n<p>500 mg natrium per liter (250 mg per tablet in 500 ml). De mildste formule, ideaal voor kortere of minder intensieve trainingen, koelere omstandigheden en atleten die van nature weinig zout uitzweten. 15 tabletten per koker.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/precision-ph-500-electrolyte-tablets\">Bekijk PH 500 →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank rank-allround\">Allround standaard</span>\n<h4>PH 1000</h4>\n<p>1000 mg natrium per liter (500 mg per tablet in 500 ml). De meest gebruikte tablet en het perfecte startpunt voor de meeste duursporters. Voor langere of intensieve trainingen en wedstrijden in gematigde tot warme omstandigheden. 10 tabletten per koker.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/precision-pf-1000-electrolyte-tablets\">Bekijk PH 1000 →</a>\n</div>\n<div class=\"svd-product-card\">\n<span class=\"svd-product-card-rank rank-max\">Maximale sterkte</span>\n<h4>PH 1500</h4>\n<p>1500 mg natrium per liter (750 mg per tablet in 500 ml). De krachtigste formule, specifiek voor preloading vóór belangrijke wedstrijden, extreem warme en vochtige omstandigheden en atleten die erg veel en/of erg zout zweten. 10 tabletten per koker.</p>\n<a class=\"svd-card-link\" href=\"https://sportvoedingdirect.nl/products/precision-ph-1500-electrolyte-tablets\">Bekijk PH 1500 →</a>\n</div>\n</div>\n</section>\n\n<!-- ═══ VERGELIJKING ═══ -->\n<section id=\"vergelijking\">\n<h2><span class=\"svd-heading-line\">Vergelijking: Precision vs. Amacx</span></h2>\n<p>Om je te helpen de juiste keuze te maken, hebben we de belangrijkste eigenschappen van de Precision Hydration tabletten en de Amacx Hydro Tabs naast elkaar gezet.</p>\n\n<div style=\"overflow-x:auto;border-radius:var(--svd-radius);border:1px solid var(--svd-border);box-shadow:var(--svd-shadow)\">\n<table class=\"svd-compare-table\">\n<thead>\n<tr><th>Kenmerk</th><th><a href=\"https://sportvoedingdirect.nl/products/precision-ph-500-electrolyte-tablets\">PH 500</a></th><th><a href=\"https://sportvoedingdirect.nl/products/precision-pf-1000-electrolyte-tablets\">PH 1000</a></th><th><a href=\"https://sportvoedingdirect.nl/products/precision-ph-1500-electrolyte-tablets\">PH 1500</a></th><th>Amacx Hydro Tabs</th></tr>\n</thead>\n<tbody>\n<tr><td><strong>Primaire focus</strong></td><td><span class=\"svd-table-badge badge-ph500\">mild</span> Lichte hydratatie</td><td><span class=\"svd-table-badge badge-ph1000\">allround</span> Standaard</td><td><span class=\"svd-table-badge badge-ph1500\">max</span> Preloading & hitte</td><td><span class=\"svd-table-badge badge-amacx\">amacx</span> Suikervrije hydratatie</td></tr>\n<tr><td><strong>Natrium per tablet</strong></td><td>250 mg (in 500 ml)</td><td>500 mg (in 500 ml)</td><td>750 mg (in 500 ml)</td><td>205 mg (in 500 tot 750 ml)</td></tr>\n<tr><td><strong>Andere elektrolyten</strong></td><td>Kalium, Calcium, Magnesium</td><td>Kalium, Calcium, Magnesium</td><td>Kalium, Calcium, Magnesium</td><td>Kalium, Calcium, Magnesium + Vitamine C</td></tr>\n<tr><td><strong>Koolhydraten</strong></td><td>1,7g (voor opname)</td><td>2,2g (voor opname)</td><td>1,8g (voor opname)</td><td>0g (100% suikervrij)</td></tr>\n<tr><td><strong>Calorieën</strong></td><td>11 kcal</td><td>16 kcal</td><td>16 kcal</td><td>&lt; 1 kcal</td></tr>\n<tr><td><strong>Ideaal voor</strong></td><td>Korte/koele trainingen</td><td>Lange trainingen, wedstrijden, warm weer</td><td>Preloaden voor races, extreme hitte</td><td>Korte trainingen, hitte, koolhydraatarm dieet</td></tr>\n<tr><td><strong>Inhoud koker</strong></td><td>15 tabletten</td><td>10 tabletten</td><td>10 tabletten</td><td>20 tabletten</td></tr>\n<tr><td><strong>Certificering</strong></td><td>Informed Sport</td><td>Informed Sport</td><td>Informed Sport</td><td>NZVT</td></tr>\n</tbody>\n</table>\n</div>\n</section>\n\n<!-- ═══ HOE KIES IK ═══ -->\n<section id=\"keuze\">\n<h2><span class=\"svd-heading-line\">Hoe kies ik de juiste sterkte?</span></h2>\n<p>De beste manier om je exacte zweetprofiel te bepalen is via een zweettest. Je kunt ook een goede schatting maken door op de volgende signalen te letten.</p>\n\n<div class=\"svd-tips-grid\">\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">1</div>\n<div><p><strong>Zweet je veel?</strong> Kies eerder voor een hogere sterkte. Hoe meer je zweet, hoe meer natrium je verliest per uur.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">2</div>\n<div><p><strong>Witte zoutvlekken op je kleding?</strong> Dit duidt op 'zout zweten'. De PH 1000 of PH 1500 is dan waarschijnlijk de juiste keuze voor jou.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">3</div>\n<div><p><strong>Vaak last van kramp?</strong> Kramp tijdens of na inspanning kan een teken zijn van een elektrolytentekort. Probeer een hogere sterkte.</p></div>\n</div>\n<div class=\"svd-tip-card\">\n<div class=\"svd-tip-number\">4</div>\n<div><p><strong>Hoe zijn de omstandigheden?</strong> Hoe heter en vochtiger, hoe meer je zweet en hoe hoger de benodigde sterkte. Pas je sterkte aan per seizoen.</p></div>\n</div>\n</div>\n\n<div class=\"svd-info-card\">\n<h3>💡 Tip: begin met PH 1000</h3>\n<p>Niet zeker welke sterkte je nodig hebt? Start met de PH 1000 als algemene basis en experimenteer tijdens je trainingen om te ontdekken wat voor jou het beste werkt.</p>\n</div>\n</section>\n\n<!-- ═══ HOE GEBRUIKEN ═══ -->\n<section id=\"gebruik\">\n<h2><span class=\"svd-heading-line\">Hoe en wanneer gebruik je de tabletten?</span></h2>\n<p>Los één tablet op in een <a href=\"https://sportvoedingdirect.nl/products/precision-bidon\">bidon</a> van 500 ml water. De hoeveelheid natrium die je dan binnenkrijgt is de helft van de naam (bijvoorbeeld 1 PH 1000 tablet in 500 ml = 500 mg natrium).</p>\n\n<div class=\"svd-scenario-grid\">\n<div class=\"svd-scenario-card\">\n<span class=\"svd-scenario-tag tag-voor\">Vóór inspanning</span>\n<h3>Preloaden</h3>\n<p>Gebruik 1 tablet PH 1500 in 500 ml water de avond vóór je wedstrijd. Drink nogmaals 1 tablet PH 1500 in 500 ml water, ongeveer 90 minuten voor de start. Probeer dit uiterlijk 45 minuten voor de start op te drinken.</p>\n</div>\n<div class=\"svd-scenario-card scenario-tijdens\">\n<span class=\"svd-scenario-tag tag-tijdens\">Tijdens inspanning</span>\n<h3>Hydrateren</h3>\n<p>Begin met drinken in de eerste 30 minuten. Neem daarna regelmatig kleine slokjes, drinkend op dorst. De algemene richtlijn is ongeveer één bidon van 500 ml per uur, afhankelijk van de hitte en intensiteit.</p>\n</div>\n<div class=\"svd-scenario-card scenario-na\">\n<span class=\"svd-scenario-tag tag-na\">Na inspanning</span>\n<h3>Rehydrateren</h3>\n<p>Als je snel moet herstellen voor een volgende inspanning, kan het drinken van een bidon met een PH 1500 tablet helpen om je vocht en elektrolytenbalans snel weer op peil te brengen.</p>\n</div>\n</div>\n</section>\n\n<!-- ═══ FAQ ═══ -->\n<section id=\"faq\">\n<h2><span class=\"svd-heading-line\">Veelgestelde vragen over de tabletten</span></h2>\n\n<div class=\"svd-faq-list\">\n\n<div class=\"svd-faq-item\"><details>\n<summary>Wat is het verschil tussen deze tabletten en een gewone sportdrank?</summary>\n<div class=\"svd-faq-answer\">\n<p>Het grootste verschil is dat deze tabletten focussen op elektrolyten (met name natrium) en zeer weinig tot geen suiker bevatten. Hierdoor kun je je hydratatie loskoppelen van je energie inname. Bovendien zijn de sterktes aanpasbaar aan jouw persoonlijke behoeften.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Hoeveel tabletten kan ik per dag gebruiken?</summary>\n<div class=\"svd-faq-answer\">\n<p>Dit is volledig afhankelijk van je zweetverlies, de duur en de intensiteit van je inspanning. Tijdens een lange, hete Ironman kan een atleet meerdere tabletten nodig hebben, terwijl voor een korte, koele training één tablet voldoende kan zijn. Luister naar je lichaam en gebruik je dorstgevoel als leidraad.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Kan ik een tablet doormidden breken voor een lagere dosering?</summary>\n<div class=\"svd-faq-answer\">\n<p>Hoewel het fysiek kan, is het niet aan te raden. De tabletten zijn ontworpen om in hun geheel op te lossen voor de juiste concentratie. Kies liever een product met een lagere sterkte, zoals de PH 500, als je minder natrium nodig hebt.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Zijn de tabletten gekeurd voor topsport?</summary>\n<div class=\"svd-faq-answer\">\n<p>Ja, alle Precision Fuel & Hydration producten zijn Informed Sport gecertificeerd. Dit betekent dat elke batch wordt getest op verboden middelen, waardoor ze veilig zijn voor topsporters.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Wat is de smaak van de tabletten?</summary>\n<div class=\"svd-faq-answer\">\n<p>De tabletten hebben een zeer milde, lichte citrussmaak. Dit is bewust gedaan om smaakmoeheid tijdens lange inspanningen te voorkomen, zodat je kunt blijven drinken zonder dat de smaak gaat tegenstaan.</p>\n</div>\n</details></div>\n\n<div class=\"svd-faq-item\"><details>\n<summary>Waar kan ik de Precision Hydration tabletten kopen?</summary>\n<div class=\"svd-faq-answer\">\n<p>Je kunt het volledige assortiment Precision Hydration tabletten kopen bij <a href=\"https://sportvoedingdirect.nl/collections/precision\">SportvoedingDirect.nl</a>. Als officiële aanbieder in Nederland ben je hier verzekerd van het juiste advies en snelle levering.</p>\n</div>\n</details></div>\n\n</div>\n</section>\n\n<!-- ═══ CTA ═══ -->\n<div class=\"svd-cta-card\">\n<h2>Vind de juiste sterkte voor jouw zweetprofiel</h2>\n<p>Van lichte hydratatie tot preloading voor je belangrijkste wedstrijd. Kies de tablet die past bij jouw behoeften.</p>\n<div class=\"svd-cta-links\">\n<a class=\"svd-cta-btn btn-dark\" href=\"https://sportvoedingdirect.nl/products/precision-ph-500-electrolyte-tablets\">PH 500</a>\n<a class=\"svd-cta-btn btn-dark\" href=\"https://sportvoedingdirect.nl/products/precision-pf-1000-electrolyte-tablets\">PH 1000</a>\n<a class=\"svd-cta-btn btn-dark\" href=\"https://sportvoedingdirect.nl/products/precision-ph-1500-electrolyte-tablets\">PH 1500</a>\n<a class=\"svd-cta-btn btn-outline\" href=\"https://sportvoedingdirect.nl/collections/precision\">Alle Precision sportvoeding</a>\n</div>\n</div>\n\n</div>\n\n<script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Wat is het verschil tussen deze tabletten en een gewone sportdrank?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Het grootste verschil is dat deze tabletten focussen op elektrolyten (met name natrium) en zeer weinig tot geen suiker bevatten. Hierdoor kun je je hydratatie loskoppelen van je energie inname. Bovendien zijn de sterktes aanpasbaar aan jouw persoonlijke behoeften.\"}},{\"@type\":\"Question\",\"name\":\"Hoeveel tabletten kan ik per dag gebruiken?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Dit is volledig afhankelijk van je zweetverlies, de duur en de intensiteit van je inspanning. Luister naar je lichaam en gebruik je dorstgevoel als leidraad.\"}},{\"@type\":\"Question\",\"name\":\"Kan ik een tablet doormidden breken voor een lagere dosering?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Hoewel het fysiek kan, is het niet aan te raden. De tabletten zijn ontworpen om in hun geheel op te lossen voor de juiste concentratie. Kies liever een product met een lagere sterkte, zoals de PH 500.\"}},{\"@type\":\"Question\",\"name\":\"Zijn de tabletten gekeurd voor topsport?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Ja, alle Precision Fuel & Hydration producten zijn Informed Sport gecertificeerd. Dit betekent dat elke batch wordt getest op verboden middelen.\"}},{\"@type\":\"Question\",\"name\":\"Wat is de smaak van de tabletten?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"De tabletten hebben een zeer milde, lichte citrussmaak. Dit is bewust gedaan om smaakmoeheid tijdens lange inspanningen te voorkomen.\"}},{\"@type\":\"Question\",\"name\":\"Waar kan ik de Precision Hydration tabletten kopen?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Je kunt het volledige assortiment kopen bij SportvoedingDirect.nl. Als officiële aanbieder in Nederland ben je hier verzekerd van het juiste advies en snelle levering.\"}}]}</script>",
