"\\uD83E\\uDDCA\"},\n{name:\"Maurten Solid 160\",brand:\"Maurten\",url:\"https://sportvoedingdirect.nl/products/maurten-solid-160-c\",carbs:40,ratio:\"Glucose + fructose\",rt:\"complex\",weight:\"55g (2\\u00d727,5g)\",sodium:\"Aanwezig (zout)\",texture:\"Solid bar\",texDesc:\"Stevig, kauwbaar, 2 mini repen\",carbSrc:\"Haver, rijst, maltodextrine, fructose\",fiber:\"Aanwezig (haver)\",fat:\"Laag (zonnebloemolie)\",extras:\"2 mini repen van elk 20g carbs\",vegan:true,gf:true,cert:\"Informed Sport\",flavors:\"Cacao (C)\",ideal:\"Begin inspanning, flexibel doseren\",emoji:\"\\uD83E\\uDDF1\"},\n{name:\"BYE! Endurance Bar\",brand:\"BYE!\",url:\"https://sportvoedingdirect.nl/products/bye-endurance-bar\",carbs:25,ratio:\"Complex mix\",rt:\"complex\",weight:\"40g\",sodium:\"Per smaak wisselend\",texture:\"Endurance reep\",texDesc:\"Zacht, smeu\\u00efg als appeltaart, smelt niet\",carbSrc:\"Havermout, fruit, dadelstroop, MCT vetten\",fiber:\"Rijk aan vezels\",fat:\"Gemiddeld (MCT uit kokosvet)\",extras:\"MCT vetzuren, 100% natuurlijk\",vegan:true,gf:false,cert:\"\",flavors:\"Appel/Kaneel, Cranberry, Coconut, Caramel Salt\",ideal:\"Begin van lange duurinspanningen\",emoji:\"\\uD83C\\uDF4E\"},\n{name:\"Amacx Recovery Bar\",brand:\"Amacx\",url:\"https://sportvoedingdirect.nl/products/amacx-recovery-bar\",carbs:22,ratio:\"Herstel\",rt:\"herstel\",weight:\"55g\",sodium:\"nvt\",texture:\"Herstelreep\",texDesc:\"Stevig, met coating, snackreep gevoel\",carbSrc:\"Koolhydraten + 20g whey eiwit\",fiber:\"Laag\",fat:\"Gemiddeld\",extras:\"20g eiwit voor spierherstel\",vegan:false,gf:false,cert:\"NZVT\",flavors:\"Chocolade, Salty Caramel\",ideal:\"Na inspanning, binnen 30 tot 45 min\",emoji:\"\\uD83D\\uDCAA\"}\n];\n\nvar brands=[\"Amacx\",\"Precision\",\"Maurten\",\"BYE!\"];\nvar textures=[\"Haverreep\",\"Nougatreep\",\"Amandelreep\",\"Fruit chew\",\"Chew blokjes\",\"Solid bar\",\"Endurance reep\",\"Herstelreep\"];\nvar ratioOpts=[{l:\"2:1 ratio\",v:\"21\"},{l:\"1:0.8 ratio\",v:\"108\"},{l:\"Complex mix\",v:\"complex\"},{l:\"Herstel\",v:\"herstel\"}];\nvar carbOpts=[{l:\"20 tot 29g\",min:20,max:29.9},{l:\"30 tot 35g\",min:30,max:35},{l:\"36 tot 40g\",min:36,max:40}];\nvar dietOpts=[{l:\"Vegan\",k:\"vegan\"},{l:\"Glutenvrij\",k:\"gf\"}];\n\nvar sel={brand:[],texture:[],ratio:[],carbs:[],diet:[],compare:[]};\n\nfunction toggle(arr,val){var i=arr.indexOf(val);if(i>-1)arr.splice(i,1);else arr.push(val);return arr;}\n\nfunction makeChips(containerId,items,selArr,style,isObj){\nvar c=document.getElementById(containerId);c.innerHTML=\"\";\nitems.forEach(function(item){\nvar label=isObj?item.l:item;\nvar value=isObj?(item.v||item.k||item.l):item;\nvar btn=document.createElement(\"button\");\nbtn.className=\"svd-chip\";\nbtn.textContent=label;\nif(selArr.indexOf(value)>-1) btn.className=\"svd-chip active-\"+style;\nbtn.onclick=function(){toggle(selArr,value);svdRender();};\nc.appendChild(btn);\n});\n}\n\nfunction rtBadge(rt,label){\nvar cls=\"tb-complex\";\nif(rt===\"21\")cls=\"tb-21\";\nelse if(rt===\"108\")cls=\"tb-108\";\nelse if(rt===\"herstel\")cls=\"tb-herstel\";\nreturn '<span class=\"svd-tb '+cls+'\">'+label+'</span>';\n}\n\nfunction badge(cls,text){return '<span class=\"svd-tb '+cls+'\">'+text+'</span>';}\n\nfunction carbBar(val){\nvar pct=Math.min((val/40)*100,100);\nvar cls=pct>85?\"svd-carb-fill high\":\"svd-carb-fill\";\nreturn '<div class=\"svd-carb-bar\"><div class=\"svd-carb-track\"><div class=\"'+cls+'\" style=\"width:'+pct+'%\"></div></div><span class=\"svd-carb-val\">'+val+'g</span></div>';\n}\n\nfunction filterBars(){\nreturn bars.filter(function(b){\nif(sel.brand.length&&sel.brand.indexOf(b.brand)<0)return false;\nif(sel.texture.length&&sel.texture.indexOf(b.texture)<0)return false;\nif(sel.ratio.length&&sel.ratio.indexOf(b.rt)<0)return false;\nif(sel.diet.indexOf(\"vegan\")>-1&&!b.vegan)return false;\nif(sel.diet.indexOf(\"gf\")>-1&&!b.gf)return false;\nif(sel.carbs.length){\nvar match=false;\nfor(var i=0;i<sel.carbs.length;i++){\nvar r=carbOpts.filter(function(o){return o.l===sel.carbs[i];})[0];\nif(r&&b.carbs>=r.min&&b.carbs<=r.max){match=true;break;}\n}\nif(!match)return false;\n}\nreturn true;\n});\n}\n\nfunction sortBars(list){\nvar s=document.getElementById(\"svd-sort\").value;\nif(s===\"carbs-desc\")list.sort(function(a,b){return b.carbs-a.carbs;});\nelse if(s===\"carbs-asc\")list.sort(function(a,b){return a.carbs-b.carbs;});\nelse list.sort(function(a,b){return a.name.localeCompare(b.name);});\nreturn list;\n}\n\nwindow.svdToggleCompare=function(name){\ntoggle(sel.compare,name);\nsvdRender();\n};\n\nwindow.svdClearAll=function(){\nsel.brand=[];sel.texture=[];sel.ratio=[];sel.carbs=[];sel.diet=[];sel.compare=[];\nsvdRender();\n};\n\nwindow.svdRender=function(){\nmakeChips(\"filter-brand\",brands,sel.brand,\"lime\",false);\nmakeChips(\"filter-texture\",textures,sel.texture,\"lav\",false);\nmakeChips(\"filter-ratio\",ratioOpts,sel.ratio,\"lime\",true);\nmakeChips(\"filter-carbs\",carbOpts,sel.carbs,\"lime\",true);\nmakeChips(\"filter-diet\",dietOpts,sel.diet,\"dark\",true);\n\nvar hasF=sel.brand.length||sel.texture.length||sel.ratio.length||sel.carbs.length||sel.diet.length;\ndocument.getElementById(\"svd-clear-btn\").style.display=hasF?\"block\":\"none\";\n\nvar filtered=sortBars(filterBars());\nvar compCount=sel.compare.length;\ndocument.getElementById(\"svd-count\").innerHTML=filtered.length+(filtered.length===1?\" reep\":\" repen\")+\" gevonden\"+(compCount>0?\" &middot; \"+compCount+\" geselecteerd om te vergelijken\":\"\");\n\nvar grid=document.getElementById(\"svd-grid\");\nif(filtered.length===0){\ngrid.innerHTML='<div class=\"svd-empty\" style=\"grid-column:1/-1\"><div class=\"svd-empty-icon\">\\uD83D\\uDD0D</div><p>Geen repen gevonden met deze filters</p><button onclick=\"svdClearAll()\">Filters wissen</button></div>';\n}else{\nvar html=\"\";\nfiltered.forEach(function(b){\nvar isCmp=sel.compare.indexOf(b.name)>-1;\nhtml+='<div class=\"svd-card'+(isCmp?\" comparing\":\"\")+'\">';\nhtml+='<div class=\"svd-card-top\"><div class=\"svd-card-badges\"><span class=\"svd-card-emoji\">'+b.emoji+'</span>'+rtBadge(b.rt,b.ratio)+badge(\"tb-brand\",b.brand)+'</div>';\nhtml+='<label class=\"svd-compare-check'+(isCmp?\" checked\":\"\")+'\"><input type=\"checkbox\" '+(isCmp?\"checked\":\"\")+' onchange=\"svdToggleCompare(\\''+b.name.replace(/'/g,\"\\\\'\")+'\\')\"> Vergelijk</label></div>';\nhtml+='<h4><a href=\"'+b.url+'\">'+b.name+'</a></h4>';\nhtml+=carbBar(b.carbs);\nhtml+='<div class=\"svd-card-details\">';\nhtml+='<div><strong>Textuur:</strong> '+b.texDesc+'</div>';\nhtml+='<div><strong>Koolhydraatbron:</strong> '+b.carbSrc+'</div>';\nhtml+='<div><strong>Natrium:</strong> '+b.sodium+'</div>';\nhtml+='<div><strong>Vezels:</strong> '+b.fiber+' &middot; <strong>Vet:</strong> '+b.fat+'</div>';\nif(b.extras)html+='<div><strong>Extra\\'s:</strong> '+b.extras+'</div>';\nhtml+='<div style=\"margin-top:4px\">';\nif(b.vegan)html+=badge(\"tb-vegan\",\"Vegan\");\nif(b.gf)html+=badge(\"tb-gf\",\"Glutenvrij\");\nif(b.cert)html+=badge(b.cert===\"NZVT\"?\"tb-nzvt\":\"tb-is\",b.cert);\nhtml+='</div></div>';\nhtml+='<div class=\"svd-card-footer\"><strong>Ideaal voor:</strong> '+b.ideal+'<br><strong>Smaken:</strong> '+b.flavors+'</div>';\nhtml+='<a class=\"svd-card-cta\" href=\"'+b.url+'\">Bekijk product \\u2192</a>';\nhtml+='</div>';\n});\ngrid.innerHTML=html;\n}\n\n// Compare table\nvar compSec=document.getElementById(\"svd-compare-section\");\nvar comparing=bars.filter(function(b){return sel.compare.indexOf(b.name)>-1;});\nif(comparing.length>=2){\nvar rows=[\n{l:\"Koolhydraten\",f:function(b){return b.carbs+\"g\";}},\n{l:\"Ratio\",f:function(b){return b.ratio;}},\n{l:\"Gewicht\",f:function(b){return b.weight;}},\n{l:\"Natrium\",f:function(b){return b.sodium;}},\n{l:\"Textuur\",f:function(b){return b.texDesc;}},\n{l:\"Koolhydraatbron\",f:function(b){return b.carbSrc;}},\n{l:\"Vezels\",f:function(b){return b.fiber;}},\n{l:\"Vet\",f:function(b){return b.fat;}},\n{l:\"Extra\\'s\",f:function(b){return b.extras||\"Geen\";}},\n{l:\"Dieet\",f:function(b){var d=[];if(b.vegan)d.push(\"Vegan\");if(b.gf)d.push(\"Glutenvrij\");return d.length?d.join(\", \"):\"Geen\";}},\n{l:\"Keurmerk\",f:function(b){return b.cert||\"Geen\";}},\n{l:\"Smaken\",f:function(b){return b.flavors;}},\n{l:\"Ideaal voor\",f:function(b){return b.ideal;}}\n];\nvar t='<div class=\"svd-comp-section\"><h3><span>Jouw vergelijking ('+comparing.length+' repen)</span></h3><p class=\"svd-comp-hint\">Scrol horizontaal om alle kolommen te zien.</p>';\nt+='<div class=\"svd-comp-wrap\"><table class=\"svd-comp-table\"><thead><tr><th>Eigenschap</th>';\ncomparing.forEach(function(b){t+='<th>'+b.name+'</th>';});\nt+='</tr></thead><tbody>';\nrows.forEach(function(r,ri){\nt+='<tr><td>'+r.l+'</td>';\ncomparing.forEach(function(b){t+='<td>'+r.f(b)+'</td>';});\nt+='</tr>';\n});\nt+='</tbody></table></div></div>';\ncompSec.innerHTML=t;\n}else if(comparing.length===1){\ncompSec.innerHTML='<div class=\"svd-comp-msg\">Selecteer nog minimaal 1 reep om de vergelijkingstabel te zien.</div>';\n}else{\ncompSec.innerHTML=\"\";\n}\n};\n\nsvdRender();\n})();\n</script>",
        "text_alignment": "left",
        "add_vertical_spacing": true,
        "add_horizontal_spacing": true
      }
    }
  },
