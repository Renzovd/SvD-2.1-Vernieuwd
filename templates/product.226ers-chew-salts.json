el":3}},"custom_liquid_FGWnLa":{"type":"custom-liquid","name":"t:sections.custom_liquid.name","settings":{"color_scheme":"scheme-2","liquid":"<style>\n    :root {\n        --neon: #d9ff36;\n        --neon-hover: #c8ee2a;\n        --black: #000000;\n        --dark: #1a1a1a;\n        --gray-900: #222222;\n        --gray-700: #555555;\n        --gray-500: #888888;\n        --gray-300: #cccccc;\n        --gray-100: #f4f4f4;\n        --white: #ffffff;\n        --radius: 8px;\n        --radius-pill: 100px;\n    }\n\n    .svd-product-content {\n        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;\n        color: var(--dark);\n        line-height: 1.65;\n        max-width: 100%;\n        padding: 0;\n    }\n\n    \/* ===== SECTION TITLE ===== *\/\n    .svd-product-content .svd-section-title {\n        font-size: 1.4rem;\n        font-weight: 800;\n        text-transform: uppercase;\n        letter-spacing: -0.01em;\n        color: var(--black);\n        margin: 48px 0 28px;\n    }\n\n    \/* ===== MINERAL CARDS ===== *\/\n    .svd-mineral-cards {\n        display: grid;\n        grid-template-columns: repeat(4, 1fr);\n        gap: 16px;\n        margin-bottom: 32px;\n    }\n    .svd-mineral-card {\n        background: var(--gray-100);\n        border-radius: var(--radius);\n        padding: 24px 20px;\n        text-align: center;\n        transition: transform 0.25s;\n    }\n    .svd-mineral-card:hover { transform: translateY(-3px); }\n    .svd-mineral-card .svd-value {\n        font-size: 1.8rem;\n        font-weight: 900;\n        color: var(--black);\n        line-height: 1;\n    }\n    .svd-mineral-card .svd-unit {\n        font-size: 0.75rem;\n        font-weight: 600;\n        color: var(--gray-500);\n    }\n    .svd-mineral-card .svd-name {\n        margin-top: 6px;\n        font-size: 0.78rem;\n        font-weight: 700;\n        text-transform: uppercase;\n        letter-spacing: 0.06em;\n        color: var(--gray-700);\n    }\n    .svd-mineral-card .svd-function {\n        font-size: 0.72rem;\n        color: var(--gray-500);\n        margin-top: 2px;\n    }\n\n    \/* ===== ACCORDION ===== *\/\n    .svd-accordion {\n        border-top: 1px solid var(--gray-300);\n    }\n    .svd-accordion-item {\n        border-bottom: 1px solid var(--gray-300);\n    }\n    .svd-accordion-trigger {\n        width: 100%;\n        background: transparent;\n        border: none;\n        padding: 20px 0;\n        font-family: inherit;\n        font-size: 0.95rem;\n        font-weight: 700;\n        color: var(--black);\n        text-align: left;\n        cursor: pointer;\n        display: flex;\n        justify-content: space-between;\n        align-items: center;\n        transition: color 0.2s;\n    }\n    .svd-accordion-trigger:hover { color: var(--gray-700); }\n    .svd-accordion-icon {\n        font-size: 1.4rem;\n        font-weight: 300;\n        transition: transform 0.3s;\n        color: var(--black);\n    }\n    .svd-accordion-item.open .svd-accordion-icon {\n        transform: rotate(45deg);\n    }\n    .svd-accordion-content {\n        max-height: 0;\n        overflow: hidden;\n        transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1);\n    }\n    .svd-accordion-item.open .svd-accordion-content {\n        max-height: 1500px;\n    }\n    .svd-accordion-inner {\n        padding: 0 0 24px;\n        font-size: 0.88rem;\n        color: var(--gray-700);\n        line-height: 1.8;\n    }\n\n    \/* ===== NUTRITION TABLE ===== *\/\n    .svd-nutrition-table {\n        width: 100%;\n        border-collapse: collapse;\n        margin-bottom: 16px;\n    }\n    .svd-nutrition-table th,\n    .svd-nutrition-table td {\n        padding: 10px 0;\n        font-size: 0.85rem;\n        text-align: left;\n        border-bottom: 1px solid var(--gray-100);\n    }\n    .svd-nutrition-table th {\n        font-weight: 700;\n        color: var(--black);\n        font-size: 0.78rem;\n        text-transform: uppercase;\n        letter-spacing: 0.06em;\n    }\n    .svd-nutrition-table td { color: var(--gray-700); }\n    .svd-nutrition-table td:first-child {\n        font-weight: 600;\n        color: var(--black);\n    }\n\n    \/* ===== USAGE CARDS ===== *\/\n    .svd-usage-grid {\n        display: grid;\n        grid-template-columns: repeat(3, 1fr);\n        gap: 16px;\n        margin-bottom: 24px;\n    }\n    .svd-usage-card {\n        background: var(--gray-100);\n        border-radius: var(--radius);\n        padding: 28px 24px;\n    }\n    .svd-usage-card .svd-step-num {\n        font-size: 2.5rem;\n        font-weight: 900;\n        color: var(--neon);\n        line-height: 1;\n        margin-bottom: 12px;\n    }\n    .svd-usage-card h4 {\n        font-size: 0.9rem;\n        font-weight: 800;\n        text-transform: uppercase;\n        letter-spacing: 0.02em;\n        margin-bottom: 8px;\n        color: var(--black);\n    }\n    .svd-usage-card p {\n        font-size: 0.82rem;\n        color: var(--gray-700);\n        line-height: 1.65;\n    }\n\n    \/* ===== TIP BOX ===== *\/\n    .svd-tip-box {\n        background: var(--gray-100);\n        border-left: 4px solid var(--neon);\n        border-radius: 0 var(--radius) var(--radius) 0;\n        padding: 20px 24px;\n        display: flex;\n        gap: 12px;\n        align-items: flex-start;\n    }\n    .svd-tip-label {\n        background: var(--neon);\n        color: var(--black);\n        font-size: 0.65rem;\n        font-weight: 800;\n        text-transform: uppercase;\n        letter-spacing: 0.1em;\n        padding: 3px 8px;\n        border-radius: 4px;\n        flex-shrink: 0;\n        margin-top: 2px;\n    }\n    .svd-tip-box p {\n        font-size: 0.85rem;\n        color: var(--gray-700);\n        line-height: 1.65;\n    }\n    .svd-tip-box a {\n        color: var(--black);\n        font-weight: 600;\n        text-decoration: underline;\n        text-decoration-color: var(--neon);\n        text-underline-offset: 3px;\n        text-decoration-thickness: 2px;\n    }\n\n    \/* ===== FAQ ===== *\/\n    .svd-faq-block p {\n        margin-bottom: 16px;\n    }\n    .svd-faq-block p strong {\n        color: var(--black);\n        display: block;\n        margin-bottom: 4px;\n    }\n\n    \/* ===== RESPONSIVE ===== *\/\n    @media (max-width: 768px) {\n        .svd-mineral-cards { grid-template-columns: 1fr 1fr; }\n        .svd-usage-grid { grid-template-columns: 1fr; }\n        .svd-mineral-card { padding: 16px 12px; }\n        .svd-mineral-card .svd-value { font-size: 1.4rem; }\n    }\n<\/style>\n\n<div class=\"svd-product-content\">\n\n    <h2 class=\"svd-section-title\">226ERS Hydrazero Chew Salts<\/h2>\n\n    <!-- Mineralen overzicht -->\n    <div class=\"svd-mineral-cards\">\n        <div class=\"svd-mineral-card\">\n            <div class=\"svd-value\">200 <span class=\"svd-unit\">mg<\/span><\/div>\n            <div class=\"svd-name\">Natrium<\/div>\n            <div class=\"svd-function\">Vochtbalans<\/div>\n        <\/div>\n        <div class=\"svd-mineral-card\">\n            <div class=\"svd-value\">60 <span class=\"svd-unit\">mg<\/span><\/div>\n            <div class=\"svd-name\">Kalium<\/div>\n            <div class=\"svd-function\">Spierfunctie<\/div>\n        <\/div>\n        <div class=\"svd-mineral-card\">\n            <div class=\"svd-value\">20 <span class=\"svd-unit\">mg<\/span><\/div>\n            <div class=\"svd-name\">Calcium<\/div>\n            <div class=\"svd-function\">Energieomzetting<\/div>\n        <\/div>\n        <div class=\"svd-mineral-card\">\n            <div class=\"svd-value\">12 <span class=\"svd-unit\">mg<\/span><\/div>\n            <div class=\"svd-name\">Magnesium<\/div>\n            <div class=\"svd-function\">Vermindert vermoeidheid<\/div>\n        <\/div>\n    <\/div>\n\n    <!-- Accordions -->\n    <div class=\"svd-accordion\">\n\n        <!-- 1. Voedingswaarden -->\n        <div class=\"svd-accordion-item\">\n            <button class=\"svd-accordion-trigger\" onclick=\"this.parentElement.classList.toggle('open')\">\n                Voedingswaarden & ingrediënten\n                <span class=\"svd-accordion-icon\">+<\/span>\n            <\/button>\n            <div class=\"svd-accordion-content\">\n                <div class=\"svd-accordion-inner\">\n                    <table class=\"svd-nutrition-table\">\n                        <thead>\n                            <tr>\n                                <th>Voedingswaarde<\/th>\n                                <th>Per tablet<\/th>\n                                <th>Per 4 tabletten<\/th>\n                            <\/tr>\n                        <\/thead>\n                        <tbody>\n                            <tr><td>Natrium<\/td><td>200 mg<\/td><td>800 mg<\/td><\/tr>\n                            <tr><td>Kalium<\/td><td>60 mg<\/td><td>240 mg (26,2% RI)<\/td><\/tr>\n                            <tr><td>Calcium<\/td><td>20 mg<\/td><td>80 mg (9,9% RI)<\/td><\/tr>\n                            <tr><td>Magnesium<\/td><td>12 mg<\/td><td>48 mg (12,8% RI)<\/td><\/tr>\n                            <tr><td>Cafeïne <small style=\"color:var(--gray-500);\">(alleen Red Fruits)<\/small><\/td><td>50 mg<\/td><td>200 mg<\/td><\/tr>\n                        <\/tbody>\n                    <\/table>\n                    <p style=\"font-size:0.75rem;color:var(--gray-500);margin-bottom:16px;\">RI = Referentie-inname<\/p>\n\n                    <p><strong>Ingrediënten:<\/strong> Natriumcitraat, Dimenx® gedehydrateerde glucosestroop (EMDEX®), Maltodextrine (uit maïs), aroma, monokaliumcitraat, calciumgluconaat, watervrij magnesiumcitraat, watervrije cafeïne (alleen Red Fruits), antiklontermiddelen (siliciumdioxide en magnesiumstearaat), zoetstof (sucralose).<\/p>\n                    <br>\n                    <p style=\"font-size:0.8rem;color:var(--gray-500);\">Voedingssupplement met mineralen en watervrije cafeïne (alleen Red Fruits). Met zoetstof. Bevat cafeïne (max. 200 mg per 4 tabletten). Niet aanbevolen voor kinderen en zwangere vrouwen. Vrij van allergenen en sporen. Bewaren: koel, droog en goed afgesloten. Houdbaarheid: circa 24 maanden na productie.<\/p>\n                <\/div>\n            <\/div>\n        <\/div>\n\n        <!-- 2. Meer informatie -->\n        <div class=\"svd-accordion-item\">\n            <button class=\"svd-accordion-trigger\" onclick=\"this.parentElement.classList.toggle('open')\">\n                Meer informatie over de Hydrazero Chew Salts\n                <span class=\"svd-accordion-icon\">+<\/span>\n            <\/button>\n            <div class=\"svd-accordion-content\">\n                <div class=\"svd-accordion-inner\">\n                    <p>Tijdens intensieve of lange inspanningen verlies je via zweet essentiële zouten (elektrolyten). Een tekort aan deze mineralen, met name natrium, verstoort de zenuwsignalen en spiercontracties. Dit leidt tot de beruchte kramp of een plotselinge zoutdip.<\/p>\n                    <br>\n                    <p>De <strong>Hydrazero Chew Salts<\/strong> leveren een complete mix van vier essentiële mineralen: <strong>natrium<\/strong> (vochtbalans), <strong>kalium<\/strong> (spierfunctie), <strong>calcium<\/strong> (energie) en <strong>magnesium<\/strong> (vermindering van vermoeidheid). Deze directe en snelle aanvulling via kauwtabletten zorgt ervoor dat je elektrolytenbalans stabiel blijft en je spieren optimaal blijven functioneren tot de finish.<\/p>\n                    <br>\n                    <p>Wij selecteren alleen elektrolyten die écht werken, getest door duursporters en vriendelijk voor de maag.<\/p>\n                <\/div>\n            <\/div>\n        <\/div>\n\n        <!-- 3. Gebruiksadvies -->\n        <div class=\"svd-accordion-item\">\n            <button class=\"svd-accordion-trigger\" onclick=\"this.parentElement.classList.toggle('open')\">\n                Gebruiksadvies\n                <span class=\"svd-accordion-icon\">+<\/span>\n            <\/button>\n            <div class=\"svd-accordion-content\">\n                <div class=\"svd-accordion-inner\">\n                    <div class=\"svd-usage-grid\">\n                        <div class=\"svd-usage-card\">\n                            <div class=\"svd-step-num\">01<\/div>\n                            <h4>Dosering<\/h4>\n                            <p>Neem <strong>1 tablet elke 30 tot 60 minuten<\/strong> tijdens inspanning. Pas aan op basis van intensiteit, temperatuur en zweetverlies.<\/p>\n                        <\/div>\n                        <div class=\"svd-usage-card\">\n                            <div class=\"svd-step-num\">02<\/div>\n                            <h4>Inname<\/h4>\n                            <p>Kauw de tablet en slik door. Er is <strong>geen water nodig<\/strong> voor de inname. Je voelt doorgaans binnen 5 tot 10 minuten effect.<\/p>\n                        <\/div>\n                        <div class=\"svd-usage-card\">\n                            <div class=\"svd-step-num\">03<\/div>\n                            <h4>Maximum<\/h4>\n                            <p>Overschrijd de dagelijkse dosis van <strong>6 tabletten niet<\/strong>. Geschikt tijdens trainingen, wedstrijden en lange ritten.<\/p>\n                        <\/div>\n                    <\/div>\n\n                    <div class=\"svd-tip-box\">\n                        <div class=\"svd-tip-label\">Tip<\/div>\n                        <p>Combineer met een <a href=\"https:\/\/sportvoedingdirect.nl\/products\/226ers-elektrolyten-bruistabletten\">Hydrazero Effervescent Bruistablet<\/a> in je bidon voor continue hydratatie en gebruik de Chew Salts als strategische boost in de laatste fase van een race.<\/p>\n                    <\/div>\n                <\/div>\n            <\/div>\n        <\/div>\n\n        <!-- 4. Veelgestelde vragen -->\n        <div class=\"svd-accordion-item\">\n            <button class=\"svd-accordion-trigger\" onclick=\"this.parentElement.classList.toggle('open')\">\n                Veelgestelde vragen\n                <span class=\"svd-accordion-icon\">+<\/span>\n            <\/button>\n            <div class=\"svd-accordion-content\">\n                <div class=\"svd-accordion-inner svd-faq-block\">\n                    <p>\n                        <strong>Wanneer kies ik voor kauwtabletten in plaats van capsules of poeder?<\/strong>\n                        Kauwtabletten zijn ideaal als je snel en direct zouten wilt aanvullen zonder te stoppen om water te mengen of capsules te slikken. Ze bieden een snelle, smakelijke en directe oplossing tegen beginnende kramp of vermoeidheid.\n                    <\/p>\n                    <p>\n                        <strong>Hoe snel werken Hydrazero Chew Salts?<\/strong>\n                        Omdat de mineralen direct in de mond worden opgenomen en via het kauwen worden afgebroken, is de opname zeer snel. Je voelt doorgaans binnen 5 tot 10 minuten een effect. Dit is sneller dan een capsule die eerst in de maag moet oplossen.\n                    <\/p>\n                    <p>\n                        <strong>Wat is het voordeel van de Red Fruits smaak met cafeïne?<\/strong>\n                        De toevoeging van 50 mg cafeïne in de Red Fruits smaak biedt een dubbele boost: het helpt bij de zoutbalans én stimuleert het centrale zenuwstelsel. Dit is perfect voor de laatste zware uren van een lange race of wanneer je extra focus nodig hebt.\n                    <\/p>\n                    <p>\n                        <strong>Kan ik deze kauwtabletten gebruiken naast mijn energiegels?<\/strong>\n                        Absoluut. Dit is de perfecte combinatie. De gels leveren koolhydraten (energie) en de Chew Salts zorgen voor de zout en mineralenbalans. Ze vullen elkaar aan zonder dat je een te geconcentreerde (hypertone) drank hoeft te drinken.\n                    <\/p>\n                <\/div>\n            <\/div>\n        <\/div>\n\n    <\/div>\n\n<\/div>\n\n<script type=\"application\/ld+json\">\n{\n  \"@context\":\"https:\/\/schema.org\",\n  \"@type\":\"FAQPage\",\n  \"mainEntity\":[\n    {\"@type\":\"Question\",\"name\":\"Wanneer kies ik voor kauwtabletten in plaats van capsules of poeder?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Kauwtabletten zijn ideaal als je snel en direct zouten wilt aanvullen zonder te stoppen om water te mengen of capsules te slikken. Ze bieden een snelle, smakelijke en directe oplossing tegen beginnende kramp of vermoeidheid.\"}},\n    {\"@type\":\"Question\",\"name\":\"Hoe snel werken Hydrazero Chew Salts?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Omdat de mineralen direct in de mond worden opgenomen en via het kauwen worden afgebroken, is de opname zeer snel. Je voelt doorgaans binnen 5 tot 10 minuten een effect.\"}},\n    {\"@type\":\"Question\",\"name\":\"Wat is het voordeel van de Red Fruits smaak met cafeïne?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"De toevoeging van 50 mg cafeïne biedt een dubbele boost: het helpt bij de zoutbalans en stimuleert het centrale zenuwstelsel. Perfect voor de laatste zware uren van een lange race.\"}},\n    {\"@type\":\"Question\",\"name\":\"Kan ik deze kauwtabletten gebruiken naast mijn energiegels?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Absoluut. De gels leveren koolhydraten en de Chew Salts zorgen voor de zout en mineralenbalans. Ze vullen elkaar aan.\"}}\n  ]\n}\n<\/script>","text_alignment":"left","add_vertical_spacing":true,"add_horizontal_spacing":true}},"related-products":{"type":"related-products","blocks":{"section-header":{"type":"_section-header","static":true,"settings":{"subheading":"","title":"Favorieten van andere sporters:","content":"","button_text":"","button_link":"","button_style":"outline","text_alignment":"left","heading_size":"h3","title_icon":"none","show_scrolling_title":false},"blocks":{}}},"settings":{"color_scheme":"scheme-2","stack_products":true,"recommendations_count":4,"products_per_row_mobile":"1","products_per_row_desktop":4,"show_view_all_button":true,"show_scrolling_bar":true}}},"order":["main","custom_liquid_FGWnLa","related-products"]}