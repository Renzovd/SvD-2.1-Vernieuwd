{"sections":{"main":{"type":"main-product","blocks":{"title":{"type":"title","settings":{"heading_tag":"h3"}},"badges":{"type":"badges","settings":{}},"price":{"type":"price","settings":{"show_taxes_notice":false}},"rating":{"type":"rating","settings":{"show_empty":false}},"payment_terms":{"type":"payment_terms","settings":{}},"separator":{"type":"separator","settings":{}},"description":{"type":"description","settings":{"collapse_content":false,"uppercase_title":false}},"inventory_bYJRPC":{"type":"inventory","settings":{"show_in_stock_quantity":true,"low_inventory_threshold":6,"show_progress_bar":false,"progress_bar_max_value":25}},"variant_picker":{"type":"variant_picker","settings":{"hide_sold_out_variants":false,"separate_options":false,"selector_style":"block","swatch_selector_style":"swatch","swatch_selector_size":"lg","block_selector_style":"outline","variant_image_options":"","size_chart_page":""}},"button_TXDRn7":{"type":"button","disabled":true,"settings":{"link":"","text":"Houd mij op de hoogte","style":"solid","stretch":true,"background":"","text_color":""}},"buy_buttons":{"type":"buy_buttons","settings":{"show_payment_button":true,"show_gift_card_recipient":true,"show_quantity_selector":true,"add_quantity_selector_spacing":true,"atc_button_style":"solid","atc_button_background":"","atc_button_text_color":"","payment_button_background":"","payment_button_text_color":""}}},"block_order":["title","badges","price","rating","payment_terms","separator","description","inventory_bYJRPC","variant_picker","button_TXDRn7","buy_buttons"],"settings":{"color_scheme":"scheme-7","allow_transparent_header":false,"transparent_header_use_primary_colors":false,"add_top_spacing":true,"show_sticky_add_to_cart":true,"product_media_size":50,"content_alignment":"left","desktop_media_layout":"carousel","desktop_carousel_controls":"thumbnails_under","mobile_controls":"thumbnails","enable_media_autoplay":true,"enable_video_looping":true,"enable_image_zoom":true,"max_image_zoom_level":3}},"custom_liquid_FGWnLa":{"type":"custom-liquid","name":"Productomschrijving","settings":{"color_scheme":"scheme-2","liquid":"<div class=\"seo-product-description\">\n\n    <h2>Amacx Energy Nougat: de lekkerste manier om je energie aan te vullen<\/h2>\n    <p>\n        Ben je die plakkerige, moeilijk weg te krijgen energierepen beu? Ontdek de <strong>Amacx Energy Nougat<\/strong>: de perfecte combinatie van een klassieke, heerlijke smaak en hoogwaardige sportvoeding. Deze <strong>zachte energiereep<\/strong> is speciaal ontwikkeld als een smakelijk en <strong>licht verteerbaar<\/strong> alternatief. Elke reep levert <strong>30-32 gram koolhydraten<\/strong> voor langdurige energie en is de ideale, vaste brandstof voor elke wielrenner, mountainbiker of wandelaar die op zoek is naar een prettige afwisseling op gels en traditionele repen.\n    <\/p>\n\n    <div class=\"page-nav-box\">\n        <h4>Spring direct naar:<\/h4>\n        <ul>\n            <li><a href=\"#overzicht\">Voordelen in het kort<\/a><\/li>\n            <li><a href=\"#afwisseling\">De kracht van afwisseling<\/a><\/li>\n            <li><a href=\"#gebruik\">Wanneer & hoe te gebruiken?<\/a><\/li>\n            <li><a href=\"#strategie\">Stel jouw perfecte voedingsplan samen<\/a><\/li>\n            <li><a href=\"#faq\">Veelgestelde vragen (FAQ)<\/a><\/li>\n            <li><a href=\"#voeding\">Ingrediënten & voedingswaarden<\/a><\/li>\n        <\/ul>\n    <\/div>\n\n    <div id=\"overzicht\" class=\"product-summary-box\">\n        <h3>De Amacx Energy Nougat in een notendop<\/h3>\n        <div class=\"summary-columns\">\n            <div class=\"summary-column pros\">\n                <h4>Pluspunten<\/h4>\n                <ul>\n                    <li>✓ Heerlijke, zachte nougat textuur die makkelijk eet<\/li>\n                    <li>✓ Licht verteerbaar, geen 'zwaar' gevoel op de maag<\/li>\n                    <li>✓ 30-32 gram koolhydraten voor langdurige energie<\/li>\n                    <li>✓ Perfecte afwisseling om smaakmoeheid te voorkomen<\/li>\n                    <li>✓ Fantastische smaak, ook geschikt als lekkere snack<\/li>\n                    <li>✓ Met natrium om de elektrolytenbalans te ondersteunen<\/li>\n                    <li>✓ NZVT-gecertificeerd (100% dopingvrij)<\/li>\n                <\/ul>\n            <\/div>\n            <div class=\"summary-column cons\">\n                <h4>Aandachtspunten<\/h4>\n                <ul>\n                    <li>Verpakking kan onderweg lastig te openen zijn (Tip: scheur vooraf in!)<\/li>\n                    <li>Bevat noten (amandelen) en ei als allergenen<\/li>\n                <\/ul>\n            <\/div>\n        <\/div>\n    <\/div>\n\n    <h3 id=\"afwisseling\">De kracht van afwisseling in je voedingsplan<\/h3>\n    <p>\n        Tijdens lange duurinspanningen is het essentieel om je energietoevoer gevarieerd te houden. Constant alleen maar vloeibare gels of sportdrank consumeren kan leiden tot <strong>'smaakmoeheid'<\/strong> en een ontevreden gevoel in de maag. Het strategisch toevoegen van vaste voeding is hier de oplossing.\n    <\/p>\n    <p>\n        De <strong>Amacx Energy Nougat<\/strong> is hiervoor de perfecte kandidaat. De zachte, niet-plakkerige textuur geeft je het gevoel van 'echt' eten, wat mentaal een enorme boost kan geven. Het biedt een welkome afwisseling in smaak en textuur, waardoor het makkelijker wordt om je voedingsplan vol te houden, uur na uur.\n    <\/p>\n\n    <h3 id=\"gebruik\">Wanneer & hoe te gebruiken?<\/h3>\n    <p>\n        De Amacx Energy Nougat is een veelzijdige energiereep die je flexibel kunt inzetten om je prestaties te ondersteunen.\n    <\/p>\n    <ul>\n        <li><strong>Vóór de inspanning:<\/strong> Neem een reep 30-60 minuten voor de start om je koolhydraatvoorraden volledig aan te vullen.<\/li>\n        <li><strong>Tijdens lange, rustige inspanningen:<\/strong> Ideaal voor de eerste uren van een lange fietstocht of wandeling, wanneer de intensiteit lager is en je lichaam vaste voeding goed kan verwerken.<\/li>\n        <li><strong>Als afwisseling:<\/strong> Neem elke 2-3 uur een nougatreep als afwisseling op je gels en sportdrank om je maag en smaakpapillen tevreden te houden.<\/li>\n    <\/ul>\n    <p>Een algemene richtlijn is om te streven naar een totale koolhydraatinname van 60-90 gram per uur. Eén nougatreep (ca. 30g) in combinatie met een bidon <a href=\"https:\/\/sportvoedingdirect.nl\/products\/amacx-energy-drink\">Energy Drink<\/a> (30g) is een perfecte combinatie voor één uur sporten.<\/p>\n\n    <h3 id=\"strategie\">Stel jouw perfecte voedingsplan samen<\/h3>\n    <p>\n        De Energy Nougat is de perfecte 'vaste hap' in een gevarieerd voedingsplan. Combineer hem met andere sportvoeding uit de <a href=\"https:\/\/sportvoedingdirect.nl\/collections\/amacx\">Amacx collectie<\/a> voor een complete strategie.\n    <\/p>\n    <ul>\n        <li><strong>De basis-combinatie:<\/strong> Drink naast de nougatreep de <a href=\"https:\/\/sportvoedingdirect.nl\/products\/amacx-energy-drink\">Amacx Energy Drink<\/a> om je hydratatie en elektrolyten op peil te houden.<\/li>\n        <li><strong>Vloeibare versnelling:<\/strong> Wissel de nougat af met een <a href=\"https:\/\/sportvoedingdirect.nl\/products\/amacx-drink-gel\">Amacx Drink Gel<\/a> voor de momenten dat je supersnelle, vloeibare energie nodig hebt, zoals op een steile klim.<\/li>\n        <li><strong>Krokante afwisseling:<\/strong> Houd je van een stevige bite? Probeer dan ook eens de <a href=\"https:\/\/sportvoedingdirect.nl\/products\/amacx-fast-bar\">Amacx Fast Bar<\/a> als ander vast voedingsmoment.<\/li>\n    <\/ul>\n\n    <h3 id=\"faq\">Veelgestelde vragen (FAQ) over Amacx Energy Nougat<\/h3>\n    <dl class=\"faq-list\">\n        <dt>V1: Is deze nougatreep niet lastig te eten tijdens het sporten?<\/dt>\n        <dd>A: Integendeel! De zachte, luchtige textuur is juist een van de grootste voordelen. Veel sporters ervaren deze als zeer prettig en 'licht verteerbaar' in vergelijking met compacte, droge energierepen. De reep hapt makkelijk weg, zelfs tijdens het fietsen of lopen.<\/dd>\n\n        <dt>V2: Wordt de reep niet keihard in de kou of een plakkerige bende in de hitte?<\/dt>\n        <dd>A: De reep is ontworpen om zijn zachte textuur onder de meeste omstandigheden te behouden. Bij vrieskou kan hij iets steviger worden, maar hij blijft goed eetbaar. In de hitte wordt hij niet overdreven plakkerig. Een tip voor koude dagen: bewaar de reep in een achterzakje dicht op je lichaam.<\/dd>\n        \n        <dt>V3: Wat is het verschil tussen de Energy Nougat en de Amacx Oat Bar?<\/dt>\n        <dd>A: Het grootste verschil zit in de samenstelling en textuur. De Energy Nougat is zacht en levert voornamelijk snelle suikers. De <a href=\"https:\/\/sportvoedingdirect.nl\/products\/amacx-oat-bar\">Amacx Oat Bar<\/a> is een compacte havermoutreep met complexere koolhydraten, die zorgt voor een meer geleidelijke en langdurige energielevering. Ideaal voor het begin van een lange tocht.<\/dd>\n\n        <dt>V4: Kan ik deze reep ook gewoon als tussendoortje eten?<\/dt>\n        <dd>A: Absoluut! Vanwege de heerlijke smaak en kwalitatieve ingrediënten is het een verantwoorde en lekkere snack voor elk moment van de dag, bijvoorbeeld bij een kop koffie.<\/dd>\n\n        <dt>V5: Bevat de Energy Nougat belangrijke allergenen?<\/dt>\n        <dd>A: Ja, dit is belangrijk om te weten. De basis van de reep bevat <strong>amandelen en ei<\/strong>. Afhankelijk van de smaak kunnen er ook andere noten (zoals pistache) of sulfiet in zitten. Raadpleeg altijd de specifieke ingrediëntenlijst op de verpakking als je een allergie hebt.<\/dd>\n    <\/dl>\n    \n    <h3 id=\"voeding\">Ingrediënten & voedingswaarden per smaak<\/h3>\n    <p>Hieronder vind je de details per smaak. Raadpleeg voor de zekerheid altijd de productverpakking.<\/p>\n\n    <h4>Smaak: Papaya<\/h4>\n    <p><strong>Ingrediënten:<\/strong> Suiker, glucosestroop, gedroogde papaja 16,3% (papaja 62%, suiker, conserveermiddel: E223 (SULFIET)), AMANDEL 3,5%, PISTACHE 2,3%, honing, fructose, invertsuiker, ouwel (aardappelzetmeel), EI-eiwit, zout, natuurlijk vanille aroma.<\/p>\n    <table class=\"nutrition-table-amacx\">\n        <thead>\n            <tr><th>Voedingswaarden<\/th><th>Per 100 g<\/th><th>Per reep (35 g)<\/th><\/tr>\n        <\/thead>\n        <tbody>\n            <tr><td><strong>Energie<\/strong><\/td><td>1708 kJ \/ 403 kcal<\/td><td>598 kJ \/ 141 kcal<\/td><\/tr>\n            <tr><td><strong>Vetten<\/strong><\/td><td>3.0 g<\/td><td>1.1 g<\/td><\/tr>\n            <tr class=\"sub-item\"><td><em>waarvan verzadigd<\/em><\/td><td>0.3 g<\/td><td>0.1 g<\/td><\/tr>\n            <tr><td><strong>Koolhydraten<\/strong><\/td><td>92 g<\/td><td>32 g<\/td><\/tr>\n            <tr class=\"sub-item\"><td><em>waarvan suikers<\/em><\/td><td>69 g<\/td><td>24 g<\/td><\/tr>\n            <tr><td><strong>Vezels<\/strong><\/td><td>0.6 g<\/td><td>0.2 g<\/td><\/tr>\n            <tr><td><strong>Eiwitten<\/strong><\/td><td>1.6 g<\/td><td>0.6 g<\/td><\/tr>\n            <tr><td><strong>Zout<\/strong><\/td><td>0.38 g<\/td><td>0.13 g<\/td><\/tr>\n        <\/tbody>\n    <\/table>\n\n    <h4 style=\"margin-top: 30px;\">Smaak: Cranberry<\/h4>\n    <p><strong>Ingrediënten:<\/strong> Suiker, glucosestroop, AMANDELEN 12%, gedroogde veenbessen 12% (veenbes min. 50%, suiker, zonnebloemolie), honing, fructose, ouwel (aardappelzetmeel), EI-eiwit, zout.<\/p>\n    <table class=\"nutrition-table-amacx\">\n        <thead>\n            <tr><th>Voedingswaarden<\/th><th>Per 100 g<\/th><th>Per reep (37 g)<\/th><\/tr>\n        <\/thead>\n        <tbody>\n            <tr><td><strong>Energie<\/strong><\/td><td>1780 kJ \/ 421 kcal<\/td><td>658 kJ \/ 156 kcal<\/td><\/tr>\n            <tr><td><strong>Vetten<\/strong><\/td><td>6.7 g<\/td><td>2.5 g<\/td><\/tr>\n            <tr class=\"sub-item\"><td><em>waarvan verzadigd<\/em><\/td><td>0.5 g<\/td><td>0.2 g<\/td><\/tr>\n            <tr><td><strong>Koolhydraten<\/strong><\/td><td>87 g<\/td><td>32 g<\/td><\/tr>\n            <tr class=\"sub-item\"><td><em>waarvan suikers<\/em><\/td><td>65 g<\/td><td>24 g<\/td><\/tr>\n            <tr><td><strong>Vezels<\/strong><\/td><td>2 g<\/td><td>0.7 g<\/td><\/tr>\n            <tr><td><strong>Eiwitten<\/strong><\/td><td>3.2 g<\/td><td>1.2 g<\/td><\/tr>\n            <tr><td><strong>Zout<\/strong><\/td><td>0.33 g<\/td><td>0.12 g<\/td><\/tr>\n        <\/tbody>\n    <\/table>\n    <h4 style=\"margin-top: 30px;\">Smaak: Speculoos<\/h4>\n    <p><strong>Ingrediënten:<\/strong> suiker, glucosestroop, amandel 18%, fructose, honing, maltodextrine, speculaaskruiden 0,9% (kaneel 60-80%, kruidnagel, gember, nootmuskaat, piment, korianderzaad, foelie, kardemom), ouwel (aardappelzetmeel), Ei-eiwit, zout 0,34%. Kan andere noten bevatten.<\/p>\n    <table class=\"nutrition-table-amacx\">\n        <thead>\n            <tr><th>Voedingswaarden<\/th><th>Per 100 g<\/th><th>Per reep (37 g)<\/th><\/tr>\n        <\/thead>\n        <tbody>\n            <tr><td><strong>Energie<\/strong><\/td><td>1878 kJ \/ 445 kcal<\/td><td>695 kJ \/ 165 kcal<\/td><\/tr>\n            <tr><td><strong>Vetten<\/strong><\/td><td>10 g<\/td><td>3.9 g<\/td><\/tr>\n            <tr class=\"sub-item\"><td><em>waarvan verzadigd<\/em><\/td><td>0.8 g<\/td><td>0.3 g<\/td><\/tr>\n            <tr><td><strong>Koolhydraten<\/strong><\/td><td>82 g<\/td><td>30 g<\/td><\/tr>\n            <tr class=\"sub-item\"><td><em>waarvan suikers<\/em><\/td><td>60 g<\/td><td>22 g<\/td><\/tr>\n            <tr><td><strong>Vezels<\/strong><\/td><td>1.7 g<\/td><td>0.6 g<\/td><\/tr>\n            <tr><td><strong>Eiwitten<\/strong><\/td><td>4.7 g<\/td><td>1.8 g<\/td><\/tr>\n            <tr><td><strong>Zout<\/strong><\/td><td>0.34 g<\/td><td>0.13 g<\/td><\/tr>\n        <\/tbody>\n    <\/table>\n<\/div>\n\n<script type=\"application\/ld+json\">\n{\n  \"@context\": \"https:\/\/schema.org\",\n  \"@type\": \"FAQPage\",\n  \"mainEntity\": [\n    {\n      \"@type