ignment":"left","add_vertical_spacing":true,"add_horizontal_spacing":true}},"related-products":{"type":"related-products","blocks":{"section-header":{"type":"_section-header","static":true,"settings":{"subheading":"","title":"Favorieten van andere sporters:","content":"","button_text":"","button_link":"","button_style":"outline","text_alignment":"left","heading_size":"h3","title_icon":"none","show_scrolling_title":false},"blocks":{}}},"settings":{"color_scheme":"scheme-2","stack_products":true,"recommendations_count":4,"products_per_row_mobile":"1","products_per_row_desktop":4,"show_view_all_button":true,"show_scrolling_bar":true}}},"order":["main","custom_liquid_FGWnLa","related-products"]}