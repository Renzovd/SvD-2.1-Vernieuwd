cceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Ja, dit is sterk aan te raden. Je maag-darmstelsel kan, net als je spieren, getraind worden om grotere hoeveelheden koolhydraten te verwerken. Begin in je trainingen met lagere doseringen en bouw dit geleidelijk op naar je wedstrijddoel.\"\n        }\n    },\n    {\n        \"@type\": \"Question\",\n        \"name\": \"Is de Amacx Turbo Drink veilig voor topsporters?\",\n        \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Absoluut. De Amacx Turbo Drink is NZVT-gekeurd. Dit betekent dat elke batch wordt gecontroleerd op de afwezigheid van dopinggeduide stoffen, wat jou als sporter 100% zekerheid biedt.\"\n        }\n    }\n  ]\n}\n<\/script>","text_alignment":"left","add_vertical_spacing":true,"add_horizontal_spacing":true}},"related-products":{"type":"related-products","blocks":{"section-header":{"type":"_section-header","static":true,"settings":{"subheading":"","title":"Favorieten van andere sporters:","content":"","button_text":"","button_link":"","button_style":"outline","text_alignment":"left","heading_size":"h3","title_icon":"none","show_scrolling_title":false},"blocks":{}}},"settings":{"color_scheme":"scheme-2","stack_products":true,"recommendations_count":4,"products_per_row_mobile":"1","products_per_row_desktop":4,"show_view_all_button":true,"show_scrolling_bar":true}}},"order":["main","custom_liquid_FGWnLa","related-products"]}