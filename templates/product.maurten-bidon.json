{"sections":{"main":{"type":"main-product","blocks":{"title":{"type":"title","settings":{"heading_tag":"h3"}},"badges":{"type":"badges","settings":{}},"price":{"type":"price","settings":{"show_taxes_notice":false}},"description":{"type":"description","settings":{"collapse_content":false,"uppercase_title":false}},"inventory_bYJRPC":{"type":"inventory","disabled":true,"settings":{"show_in_stock_quantity":false,"low_inventory_threshold":30,"show_progress_bar":false,"progress_bar_max_value":35}},"variant_picker":{"type":"variant_picker","settings":{"hide_sold_out_variants":false,"separate_options":false,"selector_style":"block","swatch_selector_style":"swatch","swatch_selector_size":"lg","block_selector_style":"outline","variant_image_options":"","size_chart_page":""}},"buy_buttons":{"type":"buy_buttons","settings":{"show_payment_button":true,"show_gift_card_recipient":true,"show_quantity_selector":true,"add_quantity_selector_spacing":true,"atc_button_style":"solid","atc_button_background":"","atc_button_text_color":"","payment_button_background":"","payment_button_text_color":""}}},"block_order":["title","badges","price","description","inventory_bYJRPC","variant_picker","buy_buttons"],"settings":{"color_scheme":"scheme-7","allow_transparent_header":false,"transparent_header_use_primary_colors":false,"add_top_spacing":true,"show_sticky_add_to_cart":true,"product_media_size":50,"content_alignment":"left","desktop_media_layout":"carousel","desktop_carousel_controls":"thumbnails_under","mobile_controls":"thumbnails","enable_media_autoplay":true,"enable_video_looping":true,"enable_image_zoom":true,"max_image_zoom_level":3}},"custom_liquid_GVqtPR":{"type":"custom-liquid","name":"Productomschrijving","settings":{"color_scheme":"scheme-2","liquid":"<div class=\"seo-product-description\">\n\n    <h2>Maurten Bidons & Flasks: De Hardware voor Hydrogel<\/h2>\n    <p>\n        De hydrogeltechnologie van Maurten is uniek, en de hardware om het te gebruiken ook. Elk product is specifiek ontworpen om jouw voedingsstrategie te vereenvoudigen en te optimaliseren. Of je nu je gels wilt bundelen voor een trailrun, je Drink Mix perfect wilt oplossen voor in je hardloopvest, of een betrouwbare bidon met duidelijke menginstructies voor op de fiets zoekt, hier vind je de juiste tool. Gebruik deze gids om jouw perfecte Maurten-partner te kiezen.\n    <\/p>\n\n    <div class=\"page-nav-box\">\n        <h4>Spring direct naar:<\/h4>\n        <ul>\n            <li><a href=\"#vergelijking\">Alle opties vergeleken<\/a><\/li>\n            <li><a href=\"#gelflask\">Gelflask 150 ml (voor Gels)<\/a><\/li>\n            <li><a href=\"#drinkflask\">Drinkflask 550 ml (voor Drink Mix)<\/a><\/li>\n            <li><a href=\"#klassieke-bidons\">Klassieke Bidons (voor Drink Mix)<\/a><\/li>\n            <li><a href=\"#faq\">Veelgestelde vragen (FAQ)<\/a><\/li>\n        <\/ul>\n    <\/div>\n\n    <h3 id=\"vergelijking\">Alle Opties Vergeleken<\/h3>\n    <p>Gebruik deze tabel om in één oogopslag de belangrijkste verschillen te zien en de beste keuze voor jou te maken.<\/p>\n    <table class=\"nutrition-table-amacx\">\n        <thead>\n            <tr>\n                <th>Eigenschap<\/th>\n                <th>Gelflask 150ml<\/th>\n                <th>Drinkflask 550ml<\/th>\n                <th>Bidon 500ml<\/th>\n                <th>Bidon 750ml<\/th>\n            <\/tr>\n        <\/thead>\n        <tbody>\n            <tr>\n                <td><strong>Primair Gebruik<\/strong><\/td>\n                <td>Bundelen van Gels<\/td>\n                <td colspan=\"3\">Mixen van Drink Mix met water<\/td>\n            <\/tr>\n            <tr>\n                <td><strong>Type<\/strong><\/td>\n                <td>Soft Flask (klein)<\/td>\n                <td>Soft Flask (groot)<\/td>\n                <td>Klassieke Bidon<\/td>\n                <td>Klassieke Bidon<\/td>\n            <\/tr>\n            <tr>\n                <td><strong>Ideaal voor<\/strong><\/td>\n                <td>Trailrunning, Gravel<\/td>\n                <td>Trailrunning, hardlopen<\/td>\n                <td>Fietsen, Fitness<\/td>\n                <td>Fietsen (lange ritten)<\/td>\n            <\/tr>\n            <tr>\n                <td><strong>Hydrogel Capaciteit<\/strong><\/td>\n                <td>3x <a href=\"https:\/\/sportvoedingdirect.nl\/products\/maurten-gel-160\">Gel 160<\/a> \/ 5x <a href=\"https:\/\/sportvoedingdirect.nl\/products\/maurten-gel-100\">Gel 100<\/a><\/td>\n                <td>1x <a href=\"https:\/\/sportvoedingdirect.nl\/products\/maurten-drink-mix-160\">Drink Mix 160<\/a> of <a href=\"https:\/\/sportvoedingdirect.nl\/products\/maurten-drink-mix-320\">320<\/a><\/td>\n                <td>1x <a href=\"https:\/\/sportvoedingdirect.nl\/products\/maurten-drink-mix-160\">Drink Mix 160<\/a> of <a href=\"https:\/\/sportvoedingdirect.nl\/products\/maurten-drink-mix-320\">320<\/a><\/td>\n                <td>1x <a href=\"https:\/\/sportvoedingdirect.nl\/products\/maurten-drink-mix-160\">Drink Mix 160<\/a> of <a href=\"https:\/\/sportvoedingdirect.nl\/products\/maurten-drink-mix-320\">320<\/a><\/td>\n            <\/tr>\n            <tr>\n                <td><strong>Unieke Feature<\/strong><\/td>\n                <td>Flip-top dop voor dikke gel<\/td>\n                <td>Anti-klots, past in loopvest<\/td>\n                <td>Menginstructies op de fles<\/td>\n                <td>Menginstructies op de fles<\/td>\n            <\/tr>\n        <\/tbody>\n    <\/table>\n\n    <h3 id=\"gelflask\">Gelflask 150 ml: Gels Bundelen Zonder Gedoe<\/h3>\n    <p>\n        Stop met het meenemen van losse sachets. De Gelflask is ontworpen om je brandstoftoevoer tijdens lange en veeleisende trainingen te stroomlijnen. Je kunt de inhoud van 3x Gel 160 of 5x Gel 100 consolideren in deze compacte, zachte fles. De extra grote opening maakt het vullen eenvoudig en de flip-top dop is perfect voor snelle, gedoseerde inname van de dikkere hydrogel.\n    <\/p>\n\n    <h3 id=\"drinkflask\">Drinkflask 550 ml: Hydrogel voor op de Trails<\/h3>\n    <p>\n        Speciaal ontwikkeld voor trailrunners. Deze soft flask heeft een volume van 550 ml, die extra 50 ml is cruciale 'schudruimte' om je Drink Mix perfect te laten oplossen tot een hydrogel. De fles krimpt terwijl je drinkt, waardoor het klotsen van vloeistof wordt geëlimineerd – een enorm voordeel op technisch terrein. Hij is ontworpen om perfect in de borstzakken van de meeste hardloopvesten te passen.\n    <\/p>\n\n    <h3 id=\"klassieke-bidons\">De Klassieke Bidons (500ml & 750ml): Eenvoud en Precisie op de Fiets<\/h3>\n    <p>\n        De iconische Maurten-bidon, geoptimaliseerd voor fietsers en gebruik in de sportschool. Het belangrijkste kenmerk zijn de duidelijke menginstructies die op de zijkant van de fles zijn gedrukt. Vul met water tot de lijn, voeg je Drink Mix toe en schud. Geen giswerk, altijd de perfecte hydrogel. Verkrijgbaar in een compact 500ml-formaat en een 750ml-versie voor langere ritten.\n    <\/p>\n\n    <h3 id=\"faq\">Veelgestelde vragen (FAQ)<\/h3>\n    <dl class=\"faq-list\">\n        <dt>V1: Wat is het verschil tussen de Gelflask en de Drinkflask?<\/dt>\n        <dd>A: De Gelflask (150ml) is klein en specifiek bedoeld om pure, onverdunde gels in te bewaren en te doseren. De Drinkflask (550ml) is groter en ontworpen om je Drink Mix poeder in op te lossen met water, om zo een drinkbare hydrogel te creëren.<\/dd>\n\n        <dt>V2: Waarom is de Drinkflask 550ml en niet gewoon 500ml?<\/dt>\n        <dd>A: De extra 50ml volume is de zogenaamde 'schudruimte'. Dit is essentieel om de Maurten Drink Mix goed te kunnen schudden en activeren tot een homogene hydrogel, zonder klontjes.<\/dd>\n        \n        <dt>V3: Kan ik de Gelflask ook gebruiken voor water of sportdrank?<\/dt>\n        <dd>A: Het kan, maar hij is er niet voor geoptimaliseerd. Het volume is erg klein en de flip-top dop is ontworpen voor dikke substanties. Voor vloeistoffen is de Drinkflask of een van de klassieke bidons een veel betere keuze.<\/dd>\n\n        <dt>V4: Passen de klassieke bidons (500ml & 750ml) in elke standaard bidonhouder?<\/dt>\n        <dd>A: Ja, beide formaten hebben een standaard diameter die is ontworpen om in vrijwel alle bidonhouders voor op de fiets te passen.<\/dd>\n    <\/dl>\n    \n<\/div>\n\n<script type=\"application\/ld+json\">\n{\n  \"@context\": \"https:\/\/schema.org\",\n  \"@type\": \"FAQPage\",\n  \"mainEntity\": [\n    {\n      \"@type\": \"Question\",\n      \"name\": \"V1: Wat is het verschil tussen de Gelflask en de Drinkflask?\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"A: De Gelflask (150ml) is klein en specifiek bedoeld om pure, onverdunde gels in te bewaren en te doseren. De Drinkflask (550ml) is groter en ontworpen om je Drink Mix poeder in op te lossen met water, om zo een drinkbare hydrogel te creëren.\"\n      }\n    },\n    {\n      \"@type\": \"Question\",\n      \"name\": \"V2: Waarom is de Drinkflask 550ml en niet gewoon 500ml?\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"A: De extra 50ml volume is de zogenaamde 'schudruimte'. Dit is essentieel om de Maurten Drink Mix goed te kunnen schudden en activeren tot een homogene hydrogel, zonder klontjes.\"\n      }\n    },\n    {\n      \"@type\": \"Question\",\n      \"name\": \"V3: Kan ik de Gelflask ook gebruiken voor water of sportdrank?\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"A: Het kan, maar hij is er niet voor geoptimaliseerd. Het volume is erg klein en de flip-top dop is ontworpen voor dikke substanties. Voor vloeistoffen is de Drinkflask of een van de klassieke bidons een veel betere keuze.\"\n      }\n    },\n    {\n      \"@type\": \"Question\",\n      \"name\": \"V4: Passen de klassieke bidons (500ml & 750ml) in elke standaard bidonhouder?\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"A: Ja, beide formaten hebben een standaard diameter die is ontworpen om in vrijwel alle bidonhouders voor op de fiets te passen.\"\n      }\n    }\n  ]\n}\n<\/script>\n\n<style>\n    \/* CSS voor soepel scrollen *\/\n    html {\n        scroll-behavior: smooth;\n    }\n\n    \/* Algemene styling voor de container *\/\n    .seo-product-description {\n        line-height: 1.6;\n        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;\n        color: #333;\n    }\n\n    \/* Styling voor witruimte van de content *\/\n    .seo-product-description h2, \n    .seo-product-description h3,\n    .seo-product-description h4 {\n        margin-top: 40px;\n        margin-bottom: 15px;\n        color: #111;\n    }\n    .seo-product-description h2:first-of-type,\n    .seo-product-description h3:first-of-type,\n    .seo-product-description .product-summary-box + h3,\n    .seo-product-description blockquote + .page-nav-box {\n        margin-top: 40px !important;\n    }\n    .seo-product-description p,\n    .seo-product-description ul,\n    .seo-product-description ol {\n        margin-bottom: 20px;\n    }\n    .seo-product-description ul {\n        list-style-position: inside;\n        padding-left: 10px;\n    }\n    .seo-product-description li {\n        margin-bottom: 10px;\n    }\n    \n    \/* Styling voor de Navigatie Box *\/\n    .page-nav-box {\n        background: rgba(217, 255, 54, 0.1);\n        border: 1px solid #d9ff36;\n        border-radius: 8px;\n        padding: 15px 25px;\n        margin: 30px 0;\n    }\n    .page-nav-box h4 {\n        margin-top: 0;\n        margin-bottom: 10px;\n        color: #333;\n    }\n    .page-nav-box ul {\n        list-style: none;\n        padding: 0;\n        margin: 0;\n        display: flex;\n        flex-wrap: wrap;\n        gap: 15px;\n    }\n    .page-nav-box ul li a {\n        text-decoration: none;\n        color: #0056b3;\n        font-weight: 500;\n    }\n    .page-nav-box ul li a:hover {\n        text-decoration: underline;\n    }\n\n    \/* Styling voor de 'Voordelen in het Kort' box *\/\n    .product-summary-box {\n        background-color: #f9f9f9;\n        border: 1px solid #e0e0e0;\n        border-radius: 8px;\n        padding: 20px;\n        margin: 40px 0;\n    }\n    .product-summary-box h3 { margin-top: 0; text-align: center; margin-bottom: 25px; }\n    .summary-columns { display: flex; justify-content: space-between; gap: 20px; }\n    .summary-column { width: 48%; }\n    .summary-column h4 { margin-top: 0; margin-bottom: 10px; border-bottom: 2px solid; padding-bottom: 5px; }\n    .summary-column.pros h4 { border-color: #28a745; }\n    .summary-column.cons h4 { border-color: #dbb8ff; }\n    .summary-column ul { list-style: none; padding: 0; margin: 0; }\n    .summary-column ul li { margin-bottom: 8px; }\n\n    \/* Styling voor de voedingstabel *\/\n    .nutrition-table-amacx{width:100%;border-collapse:collapse;margin:25px 0;font-size:15px;color:#333;background-color:#fff}.nutrition-table-amacx thead tr{background-color:#f2f2f2;color:#222;text-align:left;font-weight:700}.nutrition-table-amacx th,.nutrition-table-amacx td{padding:12px 15px;border-bottom:1px solid #e8e8e8}.nutrition-table-amacx tbody tr{transition:background-color .2s ease}.nutrition-table-amacx tbody tr:nth-child(even){background-color:#f9f9f9}.nutrition-table-amacx tbody tr:hover{background-color:#f1f1f1}.nutrition-table-amacx .sub-item{color:#555}.nutrition-table-amacx .sub-item td{padding-left:30px;}.nutrition-table-amacx strong{font-weight:600}\n\n    \/* FAQ Styling *\/\n    .faq-list { margin-top: 25px; }\n    .faq-list dt { font-weight: bold; margin-top: 20px; color: #111; }\n    .faq-list dd { margin-left: 0; margin-top: 5px; padding-bottom: 20px; border-bottom: 1px solid #e8e8e8; color: #555; }\n    .faq-list dd a { text-decoration: underline; color: #007bff; }\n    .faq-list dd a:hover { text-decoration: none; }\n\n    \/* Media Query voor mobiele apparaten *\/\n    @media (max-width