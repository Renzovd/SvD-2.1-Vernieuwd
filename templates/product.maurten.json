orters in staat om langer op hoog niveau te presteren en hun grenzen te verleggen.<\/p>","position":"middle_left"}},"button_aiJzix":{"type":"button","settings":{"text":"Lees verder","url":"","position":"middle_left","style":"link","background":"","text_color":""}}},"block_order":["heading_kXEmq3","richtext_7Kc9w7","button_aiJzix"],"settings":{"color_scheme":"scheme-2","content_position":"start","content_percentage_width":50,"overlay_color":"#000000","overlay_opacity":0,"add_media_spacing":false,"autoplay_video":true,"primary_image":"shopify:\/\/shop_images\/Categorieen5.jpg","secondary_media_width":60,"secondary_media_mobile_width":60,"show_secondary_media_on_mobile":true,"secondary_media_alignment":"place-self-start","secondary_media_shape":"none"}}},"order":["main","specifications_V483eH","related-products","text_with_media_kt4rKV"]}