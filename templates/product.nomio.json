--- Navigatieblok (page-nav-box) --- *\/\n    .amacx-product-page-content .page-nav-box {\n        background: var(--svd-light-background);\n        border-left: 5px solid var(--svd-primary-color);\n        padding: 20px;\n        margin: 40px 0;\n        border-radius: var(--svd-border-radius);\n    }\n    .amacx-product-page-content .page-nav-box ul {\n        list-style: none;\n        padding: 0;\n        display: grid;\n        grid-template-columns: 1fr 1fr;\n        gap: 10px;\n    }\n    .amacx-product-page-content .page-nav-box li a {\n        background: white;\n        padding: 10px 14px;\n        border-radius: var(--svd-border-radius);\n        box-shadow: var(--svd-box-shadow);\n        display: block;\n    }\n\n    \/* --- Pluspunten \/ aandachtspunten (summary-grid) --- *\/\n    .summary-grid {\n        display: grid;\n        grid-template-columns: 1fr;\n        gap: 2rem;\n        margin-top: 20px;\n    }\n    .summary-column h4 {\n        font-size: 1.25rem; margin: 0 0 1rem 0; padding-bottom: 0.75rem;\n        border-bottom-width: 2px; border-bottom-style: solid;\n    }\n    .summary-column.pluspunten h4 { border-bottom-color: var(--svd-primary-color); }\n    .summary-column.aandachtspunten h4 { border-bottom-color: var(--svd-secondary-color); }\n    .summary-column.pluspunten ul { list-style-type: \"✓  \"; }\n    .summary-column.aandachtspunten ul { list-style-type: \"• \"; }\n    .summary-column ul { list-style-position: inside; padding: 0; margin: 0; }\n    .summary-column li { line-height: 1.6; margin-bottom: 0.75rem; }\n\n    \/* --- NIEUWE TESTIMONIAL STIJLEN --- *\/\n    .testimonial-grid {\n        display: grid;\n        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\n        gap: 30px;\n        margin-top: 30px;\n    }\n    .testimonial-card {\n        background: var(--svd-light-background);\n        padding: 25px;\n        border-radius: var(--svd-border-radius);\n        box-shadow: var(--svd-box-shadow);\n        border-top: 5px solid var(--svd-primary-color);\n        display: flex;\n        flex-direction: column;\n        justify-content: space-between;\n    }\n    .testimonial-card blockquote {\n        font-style: italic;\n        font-size: 1.1rem;\n        margin: 0 0 20px 0;\n        padding: 0;\n        border-left: none; \/* Standaard blockquote stijl overschrijven *\/\n    }\n    .testimonial-card footer {\n        font-weight: bold;\n        color: var(--svd-dark-color);\n        margin-top: auto; \/* Zorgt ervoor dat de naam altijd onderaan staat *\/\n    }\n    .testimonial-card footer span {\n        display: block;\n        font-weight: normal;\n        font-size: 0.9rem;\n        color: #555;\n    }\n\n\n    \/* --- Tabellen (table-wrapper) --- *\/\n    .table-wrapper {\n        overflow-x: auto;\n        border: 1px solid #ddd;\n        border-radius: var(--svd-border-radius);\n        box-shadow: var(--svd-box-shadow);\n        margin-top: 15px;\n    }\n    table {\n        width: 100%;\n        border-collapse: collapse;\n        text-align: left;\n    }\n    th, td {\n        padding: 14px;\n        border-bottom: 1px solid #ddd;\n        vertical-align: top;\n    }\n    thead {\n        background-color: var(--svd-dark-color);\n        color: white;\n    }\n    tbody tr:nth-child(even) { background-color: var(--svd-light-background); }\n\n    \/* --- FAQ --- *\/\n    .faq-list dt {\n        font-weight: bold;\n        margin-top: 20px;\n    }\n    .faq-list dd {\n        margin-left: 20px;\n        margin-bottom: 15px;\n    }\n\n    \/* --- Media Queries voor Responsiviteit --- *\/\n    @media (min-width: 768px) {\n        .summary-grid { grid-template-columns: 1fr 1fr; }\n    }\n    @media (max-width: 600px) {\n        .amacx-product-page-content h1 { font-size: 2rem; }\n        .amacx-product-page-content h2 { font-size: 1.6rem; }\n        .amacx-product-page-content .page-nav-box ul { grid-template-columns: 1fr; }\n    }\n<\/style>\n\n<div class=\"amacx-product-page-content\" itemscope itemtype=\"https:\/\/schema.org\/Product\">\n\n    <section id=\"intro\">\n        <h1 itemprop=\"name\">Nomio: de natuurlijke prestatiebooster voor uithoudingsvermogen<\/h1>\n        <p class=\"lead\" itemprop=\"description\">\n            De <strong>Nomio<\/strong> is een baanbrekend, volledig natuurlijk supplement. Klinisch getest met topatleten, verbetert het je uithoudingsvermogen door de aanmaak van <strong>melkzuur te verminderen<\/strong> en een sneller herstel en spieradaptatie te bevorderen. Het helpt je om langer en harder te trainen, en sneller te herstellen.\n            <br>\n            De kracht zit in de Isothiocyanaten (ITC's) uit broccoli-spruitextracten. Een dosis komt overeen met de ITC's van 2,5 tot 3 kg rauwe broccoli!\n        <\/p>\n    <\/section>\n\n    <nav class=\"page-nav-box\">\n        <h3>Spring direct naar:<\/h3>\n        <ul>\n            <li><a href=\"#pluspunten\">Belangrijkste eigenschappen<\/a><\/li>\n            <li><a href=\"#wetenschap\">De wetenschap: NRF2 en melkzuur<\/a><\/li>\n            <li><a href=\"#gebruik\">Gebruiksprotocol en dosering<\/a><\/li>\n            <li><a href=\"#ervaringen\">Ervaringen van topatleten<\/a><\/li>\n            <li><a href=\"#voedingswaarden\">Voedingswaarden en ingrediënten<\/a><\/li>\n            <li><a href=\"#faq\">Veelgestelde vragen<\/a><\/li>\n        <\/ul>\n    <\/nav>\n\n    <section id=\"pluspunten\">\n        <h2>Nomio in het kort<\/h2>\n        <div class=\"summary-grid\">\n            <div class=\"summary-column pluspunten\">\n                <h4>Belangrijkste eigenschappen<\/h4>\n                <ul>\n                    <li><strong>Vermindert Melkzuur:<\/strong> Klinisch bewezen gemiddelde van <strong>12% minder lactaat<\/strong> bij vaste intensiteit.<\/li>\n                    <li><strong>Versnelt Adaptatie:<\/strong> Stimuleert de NRF2-route voor snellere spier- en mitochondriën-aanmaak.<\/li>\n                    <li><strong>Sneller Herstel:<\/strong> Helpt het lichaam beter om te gaan met oxidatieve stress na inspanning.<\/li>\n                    <li><strong>Natuurlijke Kracht:<\/strong> Bevat ITC's uit broccoli-spruitextracten.<\/li>\n                    <li>Ontwikkeld op basis van 8+ jaar onderzoek aan het Karolinska Instituut.<\/li>\n                    <li>Vertrouwd door Europese recordhouders en Pro Cyclisten.<\/li>\n                <\/ul>\n            <\/div>\n            <div class=\"summary-column aandachtspunten\">\n                <h4>Aandachtspunten<\/h4>\n                <ul>\n                    <li>Gebruik voor maximale effectiviteit bij je belangrijkste\/zwaarste sessies.<\/li>\n                    <li>Voor het optimale resultaat wordt consistent gebruik aanbevolen.<\/li>\n                    <li>Bewaren is het beste gekoeld, maar 8 weken houdbaar op kamertemperatuur.<\/li>\n                <\/ul>\n            <\/div>\n        <\/div>\n    <\/section>\n\n    <section id=\"wetenschap\">\n        <h2>De wetenschap: NRF2-activatie, melkzuur en training adaptatie<\/h2>\n        <p>De actieve componenten in Nomio zijn <strong>Isothiocyanaten (ITC's)<\/strong>. ITC's activeren het <strong>NRF2-systeem<\/strong> – de hoofdregulator van fysieke stress in het lichaam. Door NRF2 te activeren vóór je training, bereidt je je lichaam beter voor op de fysieke belasting, wat leidt tot meerdere positieve uitkomsten:<\/p>\n        \n        <h3>NRF2-activatie en lactaatvermindering<\/h3>\n        <p>Activatie van NRF2 helpt het lichaam om vrije radicalen te beheersen die tijdens inspanning ontstaan. Dit is direct gekoppeld aan de reductie van melkzuur. Onderzoek toont een gemiddelde reductie van 12% in lactaat bij een vaste intensiteit, een duidelijk signaal van een verbeterd vermogen om zware oefening aan te kunnen.<\/p>\n        \n        <h3>Versnelde training adaptaties<\/h3>\n        <p>Tijdens zware trainingsperiodes kan de NRF2-route verstoord raken, wat leidt tot langzamere adaptaties. Het innemen van ITC's ondersteunt deze paden, wat een sterker signaal geeft aan het lichaam om meer spiervezels en mitochondriën te produceren. Dit resulteert in <strong>snellere fitnessverbeteringen<\/strong>, waardoor je sneller verbetert dan je anders zou doen.<\/p>\n    <\/section>\n\n    <section id=\"gebruik\">\n        <h2>Gebruiksprotocol en dosering<\/h2>\n        <p>Nomio dient zowel als een trainingsproduct als een prestatieproduct. Door het tijdens je sleutelsessies te gebruiken, stimuleer je snellere trainingsadaptaties. Gebruik het op wedstrijddagen om melkzuuropbouw en oxidatieve stress te minimaliseren.<\/p>\n\n        <div class=\"table-wrapper\">\n            <table>\n                <thead>\n                    <tr>\n                        <th>Gebruiksprotocol<\/th>\n                        <th>Sessie Intensiteit<\/th>\n                        <th>Dosering (Nomio doses)<\/th>\n                    <\/tr>\n                <\/thead>\n                <tbody>\n                    <tr><td>Geen Nomio<\/td><td>Light<\/td><td>0 (Geen dosis)<\/td><\/tr>\n                    <tr><td>1 dosis vóór de sessie<\/td><td>Medium<\/td><td>1 dosis vóór de sessie<\/td><\/tr>\n                    <tr><td>2 doses: 1 vóór de sessie, 1 vóór het slapengaan<\/td><td>Hard<\/td><td>2 doses: 1 vóór de sessie, 1 vóór het slapengaan<\/td><\/tr>\n                    <tr><td>2 doses: 1 vóór de sessie, 1 vóór het slapengaan<\/td><td>Race<\/td><td>2 doses: 1 vóór de sessie, 1 vóór het slapengaan<\/td><\/tr>\n                <\/tbody>\n            <\/table>\n        <\/div>\n        \n        <p><strong>Aanbevolen Gebruik:<\/strong> Neem een dosis Nomio vóór je training of race. Voor harde sessies en wedstrijden kun je een extra dosis vóór het slapengaan nemen om het herstel en de adaptaties te maximaliseren.<\/p>\n    <\/section>\n\n    <section id=\"ervaringen\">\n        <h2>Ervaringen van topatleten<\/h2>\n        <p>Nomio wordt wereldwijd gebruikt door professionele duursporters en atleten op topniveau die streven naar marginale winst en sneller herstel.<\/p>\n        \n        <div class=\"testimonial-grid\">\n            <div class=\"testimonial-card\">\n                <blockquote>\n                    \"Met Nomio voel ik me compleet anders op de fiets. Tijdens Gent-Wevelgem behaalde ik een 90-minuten all-time best op 400W. Het gekke is dat zelfs toen ik alles gaf, ik nog steeds snel kon herstellen na elke klim.\"\n                <\/blockquote>\n                <footer>\n                    Mads Pedersen\n                    <span>Voormalig wereldkampioen Wielrennen & Profwielrenner Lidl-Trek<\/span>\n                <\/footer>\n            <\/div>\n            \n            <div class=\"testimonial-card\">\n                <blockquote>\n                    \"Nomio helpt me tijdens tempoduurloopjes om langer sneller te gaan. Het helpt me ook om te herstellen wanneer ik train ter voorbereiding op mijn races.\"\n                <\/blockquote>\n                <footer>\n                    Suldan Hassan\n                    <span>2:05 Marathonloper & Zweeds Recordhouder<\/span>\n                <\/footer>\n            <\/div>\n            \n            <div class=\"testimonial-card\">\n                <blockquote>\n                    \"Het is duidelijk dat wanneer ik Nomio gebruik, mijn HRV (Heart Rate Variability) verbetert en ik beter slaap, waardoor ik vaker op een hoger niveau kan trainen.\"\n                <\/blockquote>\n                <footer>\n                    Tilda Månson\n                    <span>Olympisch Triatleet<\/span>\n                <\/footer>\n            <\/div>\n        <\/div>\n    <\/section>\n\n    <section id=\"voedingswaarden\">\n        <h2>Voedingswaarden en ingrediënten<\/h2>\n        \n        <h3>Ingrediënten<\/h3>\n        <p>De Nomio bestaat uit:<\/p>\n        <ul>\n            <li>Broccoli-spruitextracten (80%)<\/li>\n            <li>Limoen (15%)<\/li>\n            <li>Suiker (5%)<\/li>\n        <\/ul>\n\n        <h3>Voedingswaarden<\/h3>\n        <div class=\"table-wrapper\" itemprop=\"nutrition\" itemscope itemtype=\"https:\/\/schema.org\/NutritionInformation\">\n            <table>\n                <thead>\n                    <tr>\n                        <th>Voedingswaarde<\/th>\n                        <th>Per 100 ml<\/th>\n                    <\/tr>\n                <\/thead>\n                <tbody>\n                    <tr><td>Energie kJ\/kcal<\/td><td>113\/27<\/td><\/tr>\n                    <tr><td>Eiwit<\/td><td>>0,3 g<\/td><\/tr>\n                    <tr><td>Vet<\/td><td>>0,1 g<\/td><\/tr>\n                    <tr><td>Koolhydraten<\/td><td>6,7 g<\/td><\/tr>\n                    <tr><td>Waarvan suikers<\/td><td>6,1 g<\/td><\/tr>\n                    <tr><td>Natrium<\/td><td>4,8 mg<\/td><\/tr>\n                <\/tbody>\n            <\/table>\n        <\/div>\n\n        <p><strong>Bewaren:<\/strong> Nomio is gekoeld 8 maanden houdbaar. Het is echter ook tot 8 weken houdbaar op kamertemperatuur, wat het ideaal maakt om mee te nemen op trainingskamp of reizen.<\/p>\n    <\/section>\n\n    <section id=\"faq\">\n        <h2>Veelgestelde vragen over Nomio<\/h2>\n        <dl class=\"faq-list\">\n            <dt>Voor wie is Nomio bedoeld?<\/dt>\n            <dd>Nomio is zeer gunstig voor atleten van bijna elk niveau, in het bijzonder voor duursporters. Het effect is sterker bij goed getrainde atleten. De onderzoeken zijn uitgevoerd op een gemengde groep deelnemers, variërend van sub-elite tot recreatieve duursporters.<\/dd>\n\n            <dt>Hoe lang duurt het voordat ik het effect van Nomio merk?<\/dt>\n            <dd>Hoewel de effecten het sterkst zijn ongeveer 3 uur na consumptie (acute lactaatvermindering), bouwt het voordeel zich op door consistent gebruik. Onze onderzoeken tonen aan dat door Nomio tijdens je belangrijkste sessies voor langere periodes te gebruiken, je snellere trainingsadaptaties krijgt.<\/dd>\n            \n            <dt>Waarom zijn de ITC's zo belangrijk en waarom niet gewoon broccoli eten?<\/dt>\n            <dd>ITC's (Isothiocyanaten) zijn de actieve fytochemicaliën. Vanwege hun fragiele aard en de benodigde hoge dosis is het moeilijk om via normale voeding (broccoli) een effectieve hoeveelheid binnen te krijgen. Nomio levert een krachtige, gestandaardiseerde dosis die overeenkomt met de ITC's in 2,5-3 kg rauwe broccoli.<\/dd>\n\n            <dt>Hoe moet ik mijn Nomio bewaren?<\/dt>\n            <dd>Nomio is 8 maanden na productie houdbaar indien gekoeld bewaard. Het is echter ook tot 8 weken houdbaar op kamertemperatuur, wat het gemakkelijk maakt om mee te nemen naar trainingen of op reis.<\/dd>\n\n            <dt>Kan ik Nomio combineren met andere supplementen zoals nitraat of cafeïne?<\/dt>\n            <dd>Ja, Nomio kan veilig worden gecombineerd met andere supplementen, waaronder nitraat en cafeïne, om een maximaal prestatievoordeel te behalen. Het mechanisme van Nomio (NRF2-activatie) werkt complementair aan veel andere populaire prestatiebevorderende middelen.<\/dd>\n\n            <dt>Wat is de Nomio-smaak?<\/dt>\n            <dd>Nomio heeft een lichte citroensmaak met een subtiele broccolitoon die snel verdwijnt. Het is een snel shot van 60 ml dat over het algemeen als verrassend mild en gemakkelijk in te nemen wordt ervaren, zelfs door atleten die niet van groene groenten houden.<\/dd>\n        <\/dl>\n    <\/section>\n\n<\/div>\n\n<script type=\"application\/ld+json\">\n{\n  \"@context\": \"https:\/\/schema.org\",\n  \"@type\": \"Product\",\n  \"name\": \"Nomio – De Natuurlijke Prestatiebooster\",\n  \"description\": \"Klinisch bewezen drank met Isothiocyanaten (ITC's) om melkzuur te verminderen en herstel\/adaptatie te versnellen. Ideaal voor duursporters. Per 4 stuks verpakt.\",\n  \"category\": \"Sportvoeding > Prestatie & Herstel\",\n  \"brand\": {\"@type\": \"Brand\", \"name\": \"Nomio\"},\n  \"image\": \"https:\/\/sportvoedingdirect.nl\/placeholder-image-nomio-drink.jpg\",\n  \"sku\": \"NOMIO-BOX-4\",\n  \"mpn\": \"NOMIO-DRINK-4PK\",\n  \"offers\": {\n    \"@type\": \"Offer\",\n    \"priceCurrency\": \"EUR\",\n    \"price\": \"NADER TE BEPALEN\",\n    \"availability\": \"https:\/\/schema.org\/InStock\",\n    \"url\": \"https:\/\/sportvoedingdirect.nl\/products\/nomio\"\n  }\n}\n<\/script>\n\n<script type=\"application\/ld+json\">\n{\n  \"@context\":\"https:\/\/schema.org\",\n  \"@type\":\"FAQPage\",\n  \"mainEntity\":[\n    {\n      \"@type\":\"Question\",\n      \"name\":\"Voor wie is Nomio bedoeld?\",\n      \"acceptedAnswer\":{\n        \"@type\":\"Answer\",\n        \"text\":\"Nomio is zeer gunstig voor atleten van bijna elk niveau. Het effect lijkt het sterkst te zijn bij elite-atleten en minder sterk bij mensen die zelden of nooit trainen. De onderzoeken zijn uitgevoerd op een gemengde groep deelnemers, variërend van sub-elite tot recreatieve duursporters.\"\n      }\n    },\n    {\n      \"@type\":\"Question\",\n      \"name\":\"Hoe lang duurt het voordat ik het effect van Nomio merk?\",\n      \"acceptedAnswer\":{\n        \"@type\":\"Answer\",\n        \"text\":\"Hoewel de effecten het sterkst zijn ongeveer 3 uur na consumptie (acute lactaatvermindering), bouwt het voordeel zich op door consistent gebruik. Onze onderzoeken tonen aan dat door Nomio tijdens je belangrijkste sessies voor langere periodes te gebruiken, je snellere trainingsadaptaties krijgt.\"\n      }\n    },\n    {\n      \"@type\":\"Question\",\n      \"name\":\"Waarom zijn de ITC's zo belangrijk en waarom niet gewoon broccoli eten?\",\n      \"acceptedAnswer\":{\n        \"@type\":\"Answer\",\n        \"text\":\"ITC's (Isothiocyanaten) zijn de actieve fytochemicaliën. Vanwege hun fragiele aard en de benodigde hoge dosis is het moeilijk om via normale voeding (broccoli) een effectieve hoeveelheid binnen te krijgen. Nomio levert een krachtige, gestandaardiseerde dosis die overeenkomt met de ITC's in 2,5-3 kg rauwe broccoli.\"\n      }\n    },\n    {\n      \"@typ