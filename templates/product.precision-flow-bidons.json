{"sections":{"main":{"type":"main-product","blocks":{"title":{"type":"title","settings":{"heading_tag":"h3"}},"badges":{"type":"badges","settings":{}},"price":{"type":"price","settings":{"show_taxes_notice":false}},"description":{"type":"description","settings":{"collapse_content":false,"uppercase_title":false}},"inventory_bYJRPC":{"type":"inventory","disabled":true,"settings":{"show_in_stock_quantity":false,"low_inventory_threshold":30,"show_progress_bar":false,"progress_bar_max_value":35}},"variant_picker":{"type":"variant_picker","settings":{"hide_sold_out_variants":false,"separate_options":false,"selector_style":"block","swatch_selector_style":"swatch","swatch_selector_size":"lg","block_selector_style":"outline","variant_image_options":"","size_chart_page":""}},"buy_buttons":{"type":"buy_buttons","settings":{"show_payment_button":true,"show_gift_card_recipient":true,"show_quantity_selector":true,"add_quantity_selector_spacing":true,"atc_button_style":"solid","atc_button_background":"","atc_button_text_color":"","payment_button_background":"","payment_button_text_color":""}}},"block_order":["title","badges","price","description","inventory_bYJRPC","variant_picker","buy_buttons"],"settings":{"color_scheme":"scheme-7","allow_transparent_header":false,"transparent_header_use_primary_colors":false,"add_top_spacing":true,"show_sticky_add_to_cart":true,"product_media_size":50,"content_alignment":"left","desktop_media_layout":"carousel","desktop_carousel_controls":"thumbnails_under","mobile_controls":"thumbnails","enable_media_autoplay":true,"enable_video_looping":true,"enable_image_zoom":true,"max_image_zoom_level":3}},"custom_liquid_GVqtPR":{"type":"custom-liquid","name":"Productomschrijving","settings":{"color_scheme":"scheme-2","liquid":"<div class=\"seo-product-description\">\n\n    <h2>Precision Flow Bottle & Flasks: De bidon voor je Flow Gel<\/h2>\n    <p>\n        Speciaal ontworpen voor gebruik met onze <a href=\"https:\/\/sportvoedingdirect.nl\/products\/precision-flow-gel-300\">PF 300 Flow Gel<\/a>, maken de Flow Bottle en Flasks het eenvoudiger dan ooit om je koolhydraatinname bij te houden en je doelen te halen. We hebben talloze bidons en flasks getest om de modellen te vinden met de allerbeste doorstroming voor onze unieke gel. Het resultaat is een systeem dat giswerk elimineert en je in staat stelt om je te focussen op wat echt telt: je prestatie.\n    <\/p>\n\n    <div class=\"page-nav-box\">\n        <h4>Spring direct naar:<\/h4>\n        <ul>\n            <li><a href=\"#overzicht\">Het Flow Systeem in het kort<\/a><\/li>\n            <li><a href=\"#waarom-flow\">Waarom kiezen voor het Flow Systeem?<\/a><\/li>\n            <li><a href=\"#kies-jouw-flow\">Kies jouw perfecte Flow Partner<\/a><\/li>\n            <li><a href=\"#gebruikstips\">Gebruik en onderhoud<\/a><\/li>\n            <li><a href=\"#faq\">Veelgestelde vragen (FAQ)<\/a><\/li>\n        <\/ul>\n    <\/div>\n\n    <div id=\"overzicht\" class=\"product-summary-box\">\n        <h3>Het Flow Systeem in een notendop<\/h3>\n        <div class=\"summary-columns\">\n            <div class=\"summary-column pros\">\n                <h4>Pluspunten<\/h4>\n                <ul>\n                    <li>✓ Specifiek ontworpen voor de <a href=\"https:\/\/sportvoedingdirect.nl\/products\/precision-flow-gel-300\">PF 300 Flow Gel<\/a><\/li>\n                    <li>✓ Duidelijke schaalverdeling om je koolhydraatinname te meten<\/li>\n                    <li>✓ Maakt je brandstofplan simpeler en nauwkeuriger<\/li>\n                    <li>✓ Keuze uit een klassieke bidon of flexibele, opvouwbare soft flasks<\/li>\n                    <li>✓ Getest voor de beste doorstroming van de gel<\/li>\n                    <li>✓ Lichtgewicht en BPA\/PVC-vrij<\/li>\n                <\/ul>\n            <\/div>\n            <div class=\"summary-column cons\">\n                <h4>Aandachtspunten<\/h4>\n                <ul>\n                    <li>De schaalverdeling is gekalibreerd voor de Precision Flow Gel<\/li>\n                    <li>Elk model heeft unieke eigenschappen (hard vs. zacht)<\/li>\n                <\/ul>\n            <\/div>\n        <\/div>\n    <\/div>\n\n    <h3 id=\"waarom-flow\">Waarom kiezen voor het Flow Systeem?<\/h3>\n    <p>\n        Succes in duursport draait om het consistent halen van je nummers. Het Precision Flow Systeem haalt de complexiteit uit je brandstofplan. Geen gedoe meer met het tellen van lege gelverpakkingen of schatten hoeveel je hebt genomen.\n    <\/p>\n    <ul>\n        <li><strong>Nauwkeurigheid:<\/strong> De duidelijke schaalverdeling op de zijkant toont precies hoeveel gram koolhydraten je hebt verbruikt.<\/li>\n        <li><strong>Efficiëntie:<\/strong> Giet één zak <a href=\"https:\/\/sportvoedingdirect.nl\/products\/precision-gel-300-carbs\">Flow Gel<\/a> in je fles en je hebt brandstof voor uren. Dit bespaart tijd voor de start en cruciale seconden tijdens de wedstrijd.<\/li>\n        <li><strong>Keuzevrijheid:<\/strong> Of je nu de voorkeur geeft aan de stevigheid van een klassieke bidon of de flexibiliteit van een soft flask die niet klotst, er is altijd een perfecte match voor jou.<\/li>\n    <\/ul>\n    \n    <h3 id=\"kies-jouw-flow\">Kies jouw perfecte Flow Partner<\/h3>\n    <p>Vergelijk de drie opties en kies het model dat het beste bij jouw sport en voorkeuren past.<\/p>\n    <table class=\"nutrition-table-amacx\">\n        <thead>\n            <tr>\n                <th>Eigenschap<\/th>\n                <th>Flow Bottle 300<\/th>\n                <th>Flow Flask 300<\/th>\n                <th>Flow Flask 120<\/th>\n            <\/tr>\n        <\/thead>\n        <tbody>\n            <tr>\n                <td><strong>Type<\/strong><\/td>\n                <td>Klassieke bidon (hard)<\/td>\n                <td>Soft Flask (zacht)<\/td>\n                <td>Kleine Soft Flask (zacht)<\/td>\n            <\/tr>\n            <tr>\n                <td><strong>Ideaal voor<\/strong><\/td>\n                <td>Fietsen, team sporten<\/td>\n                <td>Hardlopen, trailrunning, triatlon<\/td>\n                <td>Kortere trainingen, marathons<\/td>\n            <\/tr>\n            <tr>\n                <td><strong>Capaciteit<\/strong><\/td>\n                <td>500 ml (1x PF 300 Flow Gel)<\/td>\n                <td>500 ml (1x PF 300 Flow Gel)<\/td>\n                <td>200 ml (120g Flow Gel)<\/td>\n            <\/tr>\n            <tr>\n                <td><strong>Gewicht (leeg)<\/strong><\/td>\n                <td>51 gram<\/td>\n                <td>29 gram<\/td>\n                <td>25 gram<\/td>\n            <\/tr>\n            <tr>\n                <td><strong>Dop<\/strong><\/td>\n                <td>Push-pull drinktuit<\/td>\n                <td>Snelstromend bijtventiel<\/td>\n                <td>Snelstromend bijtventiel<\/td>\n            <\/tr>\n            <tr>\n                <td><strong>Schaalverdeling (koolhydraten)<\/strong><\/td>\n                <td>60g - 300g<\/td>\n                <td>60g - 300g<\/td>\n                <td>30g - 120g<\/td>\n            <\/tr>\n            <tr>\n                <td><strong>Unieke Features<\/strong><\/td>\n                <td>Zachte, knijpbare body<\/td>\n                <td>Krimpt tijdens drinken (anti-klots), opvouwbaar<\/td>\n                <td>Krimpt tijdens drinken (anti-klots), opvouwbaar, compact<\/td>\n            <\/tr>\n            <tr>\n                <td><strong>Materiaal<\/strong><\/td>\n                <td colspan=\"3\">BPA\/PVC-vrij TPU, smaakneutraal<\/td>\n            <\/tr>\n        <\/tbody>\n    <\/table>\n\n    <h3 id=\"gebruikstips\">Gebruik en onderhoud<\/h3>\n    <p>Haal het maximale uit je Flow Bottle of Flask:<\/p>\n    <ul>\n        <li><strong>Voorbereiding:<\/strong> Spoel de fles of flask voor het eerste gebruik en voor elke vulling even met water. Dit zorgt voor de beste doorstroming van de gel.<\/li>\n        <li><strong>Vullen:<\/strong> Giet een volledige zak <a href=\"https:\/\/sportvoedingdirect.nl\/products\/precision-gel-300-carbs\">PF 300 Flow Gel<\/a> in de Bottle 300 of Flask 300. Vul de Flask 120 tot de 120g-markering.<\/li>\n        <li><strong>Schoonmaken:<\/strong> Maak na gebruik direct schoon met warm water en een beetje zeep. Laat aan de lucht drogen met de dop eraf.<\/li>\n    <\/ul>\n\n    <h3 id=\"faq\">Veelgestelde vragen (FAQ) over de Flow Bottle & Flasks<\/h3>\n    <dl class=\"faq-list\">\n        <dt>V1: Wat is het belangrijkste verschil tussen de Bottle en de Flask?<\/dt>\n        <dd>A: De Flow Bottle is een traditionele, ietwat hardere bidon die je kunt knijpen, met een push-pull dop. De Flow Flasks zijn zachte, flexibele flesjes met een bijtventiel. Ze krimpen als je drinkt (wat klotsen voorkomt) en zijn volledig opvouwbaar als ze leeg zijn.<\/dd>\n\n        <dt>V2: Kan ik ook water of sportdrank in de Flow-producten gebruiken?<\/dt>\n        <dd>A: Jazeker. Hoewel ze ontworpen zijn voor de Flow Gel, functioneren ze ook uitstekend als gewone water- of sportdrankfles. De Flasks hebben zelfs extra maatstreepjes voor vloeistoffen, waardoor ze ideaal zijn voor het mixen van je <a href=\"https:\/\/sportvoedingdirect.nl\/collections\/precision?filter.p.product_type=Elektrolyten\">PH elektrolyten<\/a>.<\/dd>\n        \n        <dt>V3: Waarom zou ik deze gebruiken in plaats van een normale bidon met gel?<\/dt>\n        <dd>A: De unieke schaalverdeling is de gamechanger. Deze is gekalibreerd voor de koolhydraten in de Flow Gel, waardoor je met één blik weet hoeveel brandstof je hebt genomen. Dit maakt het uitvoeren van je voedingsplan tijdens een wedstrijd vele malen eenvoudiger en nauwkeuriger.<\/dd>\n    <\/dl>\n    \n<\/div>\n\n<script type=\"application\/ld+json\">\n{\n  \"@context\": \"https:\/\/schema.org\",\n  \"@type\": \"FAQPage\",\n  \"mainEntity\": [\n    {\n      \"@type\": \"Question\",\n      \"name\": \"V1: Wat is het belangrijkste verschil tussen de Bottle en de Flask?\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"A: De Flow Bottle is een traditionele, ietwat hardere bidon die je kunt knijpen, met een push-pull dop. De Flow Flasks zijn zachte, flexibele flesjes met een bijtventiel. Ze krimpen als je drinkt (wat klotsen voorkomt) en zijn volledig opvouwbaar als ze leeg zijn.\"\n      }\n    },\n    {\n      \"@type\": \"Question\",\n      \"name\": \"V2: Kan ik ook water of sportdrank in de Flow-producten gebruiken?\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"A: Jazeker. Hoewel ze ontworpen zijn voor de Flow Gel, functioneren ze ook uitstekend als gewone water- of sportdrankfles. De Flasks hebben zelfs extra maatstreepjes voor vloeistoffen, waardoor ze ideaal zijn voor het mixen van je PH elektrolyten.\"\n      }\n    },\n    {\n      \"@type\": \"Question\",\n      \"name\": \"V3: Waarom zou ik deze gebruiken in plaats van een normale bidon met gel?\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"A: De unieke schaalverdeling is de gamechanger. Deze is gekalibreerd voor de koolhydraten in de Flow Gel, waardoor je met één blik weet hoeveel brandstof je hebt genomen. Dit maakt het uitvoeren van je voedingsplan tijdens een wedstrijd vele malen eenvoudiger en nauwkeuriger.\"\n      }\n    }\n  ]\n}\n<\/script>\n\n<style>\n    \/* CSS voor soepel scrollen *\/\n    html {\n        scroll-behavior: smooth;\n    }\n\n    \/* Algemene styling voor de container *\/\n    .seo-product-description {\n        line-height: 1.6;\n        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;\n        color: #333;\n    }\n\n    \/* Styling voor witruimte van de content *\/\n    .seo-product-description h2, \n    .seo-product-description h3,\n    .seo-product-description h4 {\n        margin-top: 40px;\n        margin-bottom: 15px;\n        color: #111;\n    }\n    .seo-product-description h2:first-of-type,\n    .seo-product-description h3:first-of-type,\n    .seo-product-description .product-summary-box + h3,\n    .seo-product-description blockquote + .page-nav-box {\n        margin-top: 40px !important;\n    }\n    .seo-product-description p,\n    .seo-product-description ul,\n    .seo-product-description ol {\n        margin-bottom: 20px;\n    }\n    .seo-product-description ul {\n        list-style-position: inside;\n        padding-left: 10px;\n    }\n    .seo-product-description li {\n        margin-bottom: 10px;\n    }\n    \n    \/* Styling voor de Navigatie Box *\/\n    .page-nav-box {\n        background: rgba(217, 255, 54, 0.1);\n        border: 1px solid #d9ff36;\n        border-radius: 8px;\n        padding: 15px 25px;\n        margin: 30px 0;\n    }\n    .page-nav-box h4 {\n        margin-top: 0;\n        margin-bottom: 10px;\n        color: #333;\n    }\n    .page-nav-box ul {\n        list-style: none;\n        padding: 0;\n        margin: 0;\n        display: flex;\n        flex-wrap: wrap;\n        gap: 15px;\n    }\n    .page-nav-box ul li a {\n        text-decoration: none;\n        color: #0056b3;\n        font-weight: 500;\n    }\n    .page-nav-box ul li a:hover {\n        text-decoration: underline;\n    }\n\n    \/* Styling voor de 'Voordelen in het Kort' box *\/\n    .product-summary-box {\n        background-color: #f9f9f9;\n        border: 1px solid #e0e0e0;\n        border-radius: 8px;\n        padding: 20px;\n        margin: 40px 0;\n    }\n    .product-summary-box h3 { margin-top: 0; text-align: center; margin-bottom: 25px; }\n    .summary-columns { display: flex; justify-content: space-between; gap: 20px; }\n    .summary-column { width: 48%; }\n    .summary-column h4 { margin-top: 0; margin-bottom: 10px; border-bottom: 2px solid; padding-bottom: 5px; }\n    .summary-column.pros h4 { border-color: #28a745; }\n    .summary-column.cons h4 { border-color: #dbb8ff; }\n    .summary-column ul { list-style: none; padding: 0; margin: 0; }\n    .summary-column ul li { margin-bottom: 8px; }\n\n    \/* Styling voor de voedingstabel *\/\n    .nutrition-table-amacx{width:100%;border-collapse:collapse;margin:25px 0;font-size:15px;color:#333;background-color:#fff}.nutrition-table-amacx thead tr{background-color:#f2f2f2;color:#222;text-align:left;font-weight:700}.nutrition-table-amacx th,.nutrition-table-amacx td{padding:12px 15px;border-bottom:1px solid #e8e8e8}.nutrition-table-amacx tbody tr{transition:background-color .2s ease}.nutrition-table-amacx tbody tr:nth-child(even){background-color:#f9f9f9}.nutrition-table-amacx tbody tr:hover{background-color:#f1f1f1}.nutrition-table-amacx .sub-item{color:#555}.nutrition-table-amacx .sub-item td{padding-left:30px;}.nutrition-table-amacx strong{font-weight:600}\n\n    \/* FAQ Styling *\/\n    .faq-list { margin-top: 25px; }\n    .faq-list dt { font-weight: bold; margin-top: 20px; color: #111; }\n    .faq-list dd { margin-left: 0; margin-top: 5px; padding-bottom: 20px; border-bottom: 1px solid #e8e8e8; color: #555; }\n    .faq-list dd a { text-decoration: underline; color: #007bff; }\n    .faq-list dd a:hover { text-decoration: none; }\n\n    \/* Media Query voor mobiele apparaten *\/\n    @media (max-width: 768px) {\n        .summary-columns, .page-nav-box ul {\n            flex-direction: column;\n        }\n        .summary-column {\n            width: 100%;\n        }\n        .summary-column.cons {\n            margin-top: 20px;\n        }\n    }\n<\/style>","text_alignment":"left","add_vertical_spacing":true,"add_horizontal_spacing":true}},"related-products":{"type":"related-products","blocks":{"section-header":{"type":"_section-header","static":true,"settings":{"subheading":"","title":"Sporters kochten ook:","content":"","button_text":"","button_link":"","button_style":"outline","text_alignment":"left","heading_size":"h3","title_icon":"none","show_scrolling_title":false},"blocks":{}}},"settings":{"color_scheme":"scheme-2","stack_products":true,"recommendations_count":4,"products_per_row_mobile